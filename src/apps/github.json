{
  "slug": "github",
  "name": "GitHub",
  "description": "GitHub REST API - repos, issues, PRs, code, branches, commits, releases, actions, users, and search via OAuth2",
  "logo": "https://github.githubassets.com/favicons/favicon.svg",
  "categories": [
    "development",
    "git",
    "code",
    "collaboration",
    "github",
    "oauth2"
  ],
  "base_url": "https://api.github.com",
  "auth": {
    "types": [
      "bearer",
      "oauth2"
    ],
    "headers": {
      "Authorization": "Bearer {{token}}"
    },
    "credential_fields": [
      {
        "name": "token",
        "label": "access_token"
      },
      {
        "name": "token_type",
        "label": "token_type"
      },
      {
        "name": "scope",
        "label": "scope"
      }
    ],
    "oauth2": {
      "authorize_url": "https://github.com/login/oauth/authorize",
      "token_url": "https://github.com/login/oauth/access_token",
      "scopes": [
        "repo",
        "public_repo",
        "admin:repo_hook",
        "workflow",
        "read:user",
        "user:email"
      ],
      "client_id_required": true,
      "pkce": false
    }
  },
  "ui_components": [
    {
      "name": "issue-card",
      "entry": "/ui/IssueCard.mjs",
      "slots": ["chat.message_attachment"],
      "props_schema": {
        "type": "object",
        "required": ["repo", "issue_number"],
        "properties": {
          "repo": { "type": "string", "description": "owner/name (e.g. acme-corp/billing-service)" },
          "issue_number": { "type": "integer", "description": "Issue number (#NN)" },
          "title": { "type": "string", "description": "Issue title — pass from get_issue response" },
          "state": { "type": "string", "description": "open or closed" },
          "state_reason": { "type": "string", "description": "completed | not_planned | reopened" },
          "user_login": { "type": "string", "description": "Author login" },
          "user_avatar_url": { "type": "string", "description": "Author avatar URL" },
          "labels": { "type": "string", "description": "Comma-separated label names" },
          "assignees": { "type": "string", "description": "Comma-separated assignee logins" },
          "comments": { "type": "integer", "description": "Comments count" }
        }
      },
      "preview_props": { "preview": true }
    }
  ],
  "tools": [
    {
      "name": "get_authenticated_user",
      "description": "Get the authenticated user's profile including login, name, email, bio, public repos count, followers, and account details",
      "method": "GET",
      "path": "/user",
      "input_schema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "get_user",
      "description": "Get a user's public profile by their username",
      "method": "GET",
      "path": "/users/{username}",
      "input_schema": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "description": "GitHub username"
          }
        },
        "required": [
          "username"
        ]
      }
    },
    {
      "name": "list_repos",
      "description": "List repositories for the authenticated user. Returns repos you own, collaborate on, or are a member of.",
      "method": "GET",
      "path": "/user/repos",
      "input_schema": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Type of repos to list",
            "enum": [
              "all",
              "owner",
              "public",
              "private",
              "member"
            ],
            "default": "all"
          },
          "sort": {
            "type": "string",
            "description": "Sort field",
            "enum": [
              "created",
              "updated",
              "pushed",
              "full_name"
            ],
            "default": "updated"
          },
          "direction": {
            "type": "string",
            "description": "Sort direction",
            "enum": [
              "asc",
              "desc"
            ],
            "default": "desc"
          },
          "per_page": {
            "type": "integer",
            "description": "Results per page (max 100)",
            "default": 30
          },
          "page": {
            "type": "integer",
            "description": "Page number",
            "default": 1
          }
        }
      }
    },
    {
      "name": "get_repo",
      "description": "Get detailed information about a repository including description, stars, forks, language, default branch, and permissions",
      "method": "GET",
      "path": "/repos/{owner}/{repo}",
      "input_schema": {
        "type": "object",
        "properties": {
          "owner": {
            "type": "string",
            "description": "Repository owner (user or org)"
          },
          "repo": {
            "type": "string",
            "description": "Repository name"
          }
        },
        "required": [
          "owner",
          "repo"
        ]
      }
    },
    {
      "name": "get_archive",
      "description": "Download a repository as a gzipped tarball at a given ref (branch, tag, or SHA). Returns binary bytes. GitHub redirects to codeload.github.com; for private repos the redirect Location carries a short-lived signed token so the request succeeds even when the Authorization header is stripped on cross-subdomain redirect. Used by the Code app's import flow.",
      "method": "GET",
      "path": "/repos/{owner}/{repo}/tarball/{ref}",
      "timeout_ms": 120000,
      "input_schema": {
        "type": "object",
        "properties": {
          "owner": {
            "type": "string",
            "description": "Repository owner (user or org)"
          },
          "repo": {
            "type": "string",
            "description": "Repository name"
          },
          "ref": {
            "type": "string",
            "description": "Branch name, tag, or commit SHA. Defaults to the repo's default branch when omitted."
          }
        },
        "required": [
          "owner",
          "repo",
          "ref"
        ]
      }
    },
    {
      "name": "list_user_repos",
      "description": "List public repositories for a specific user",
      "method": "GET",
      "path": "/users/{username}/repos",
      "input_schema": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "description": "GitHub username"
          },
          "sort": {
            "type": "string",
            "description": "Sort field",
            "enum": [
              "created",
              "updated",
              "pushed",
              "full_name"
            ],
            "default": "updated"
          },
          "per_page": {
            "type": "integer",
            "description": "Results per page (max 100)",
            "default": 30
          },
          "page": {
            "type": "integer",
            "description": "Page number",
            "default": 1
          }
        },
        "required": [
          "username"
        ]
      }
    },
    {
      "name": "search_repos",
      "description": "Search for repositories using GitHub search syntax. Supports qualifiers like language:, stars:>, topic:, etc.",
      "method": "GET",
      "path": "/search/repositories",
      "input_schema": {
        "type": "object",
        "properties": {
          "q": {
            "type": "string",
            "description": "Search query (supports qualifiers like language:python, stars:>100, topic:machine-learning)"
          },
          "sort": {
            "type": "string",
            "description": "Sort field",
            "enum": [
              "stars",
              "forks",
              "help-wanted-issues",
              "updated"
            ],
            "default": "stars"
          },
          "order": {
            "type": "string",
            "description": "Sort order",
            "enum": [
              "asc",
              "desc"
            ],
            "default": "desc"
          },
          "per_page": {
            "type": "integer",
            "description": "Results per page (max 100)",
            "default": 30
          },
          "page": {
            "type": "integer",
            "description": "Page number",
            "default": 1
          }
        },
        "required": [
          "q"
        ]
      }
    },
    {
      "name": "search_code",
      "description": "Search for code across all repositories. Supports qualifiers like repo:, path:, language:, extension:",
      "method": "GET",
      "path": "/search/code",
      "input_schema": {
        "type": "object",
        "properties": {
          "q": {
            "type": "string",
            "description": "Search query (e.g., 'addClass repo:jquery/jquery', 'filename:config.yml language:yaml')"
          },
          "sort": {
            "type": "string",
            "description": "Sort field (only 'indexed' supported). Note: GitHub has flagged sort/order on code search as 'closing down' — prefer omitting both for forward compatibility.",
            "enum": [
              "indexed"
            ]
          },
          "order": {
            "type": "string",
            "description": "Sort order. Note: closing down per GitHub — prefer omitting.",
            "enum": [
              "asc",
              "desc"
            ],
            "default": "desc"
          },
          "per_page": {
            "type": "integer",
            "description": "Results per page (max 100)",
            "default": 30
          },
          "page": {
            "type": "integer",
            "description": "Page number",
            "default": 1
          }
        },
        "required": [
          "q"
        ]
      }
    },
    {
      "name": "get_contents",
      "description": "Get repository contents — a file (with content) or directory listing. For files up to 1MB, content is base64 encoded.",
      "method": "GET",
      "path": "/repos/{owner}/{repo}/contents/{path}",
      "input_schema": {
        "type": "object",
        "properties": {
          "owner": {
            "type": "string",
            "description": "Repository owner"
          },
          "repo": {
            "type": "string",
            "description": "Repository name"
          },
          "path": {
            "type": "string",
            "description": "Path to file or directory (empty string for repo root)",
            "default": ""
          },
          "ref": {
            "type": "string",
            "description": "Branch, tag, or commit SHA (defaults to default branch)"
          }
        },
        "required": [
          "owner",
          "repo"
        ]
      }
    },
    {
      "name": "create_or_update_file",
      "description": "Create or update a file in a repository. Content must be base64 encoded. To update, include the SHA of the file being replaced (from get-contents).",
      "method": "PUT",
      "path": "/repos/{owner}/{repo}/contents/{path}",
      "input_schema": {
        "type": "object",
        "properties": {
          "owner": {
            "type": "string",
            "description": "Repository owner"
          },
          "repo": {
            "type": "string",
            "description": "Repository name"
          },
          "path": {
            "type": "string",
            "description": "Path for the file"
          },
          "message": {
            "type": "string",
            "description": "Commit message"
          },
          "content": {
            "type": "string",
            "description": "File content (base64 encoded)"
          },
          "sha": {
            "type": "string",
            "description": "SHA of file being replaced (required for updates, get from get-contents)"
          },
          "branch": {
            "type": "string",
            "description": "Branch to commit to (defaults to default branch)"
          }
        },
        "required": [
          "owner",
          "repo",
          "path",
          "message",
          "content"
        ]
      }
    },
    {
      "name": "delete_file",
      "description": "Delete a file from a repository. Requires the file's SHA (from get-contents).",
      "method": "DELETE",
      "path": "/repos/{owner}/{repo}/contents/{path}",
      "input_schema": {
        "type": "object",
        "properties": {
          "owner": {
            "type": "string",
            "description": "Repository owner"
          },
          "repo": {
            "type": "string",
            "description": "Repository name"
          },
          "path": {
            "type": "string",
            "description": "Path to the file to delete"
          },
          "message": {
            "type": "string",
            "description": "Commit message"
          },
          "sha": {
            "type": "string",
            "description": "SHA of file being deleted (from get-contents)"
          },
          "branch": {
            "type": "string",
            "description": "Branch to commit to"
          }
        },
        "required": [
          "owner",
          "repo",
          "path",
          "message",
          "sha"
        ]
      }
    },
    {
      "name": "list_branches",
      "description": "List branches in a repository",
      "method": "GET",
      "path": "/repos/{owner}/{repo}/branches",
      "input_schema": {
        "type": "object",
        "properties": {
          "owner": {
            "type": "string",
            "description": "Repository owner"
          },
          "repo": {
            "type": "string",
            "description": "Repository name"
          },
          "per_page": {
            "type": "integer",
            "description": "Results per page (max 100)",
            "default": 30
          },
          "page": {
            "type": "integer",
            "description": "Page number",
            "default": 1
          }
        },
        "required": [
          "owner",
          "repo"
        ]
      }
    },
    {
      "name": "create_branch",
      "description": "Create a new branch. First get the SHA of the source branch via list-branches or get-contents, then create a git ref.",
      "method": "POST",
      "path": "/repos/{owner}/{repo}/git/refs",
      "input_schema": {
        "type": "object",
        "properties": {
          "owner": {
            "type": "string",
            "description": "Repository owner"
          },
          "repo": {
            "type": "string",
            "description": "Repository name"
          },
          "ref": {
            "type": "string",
            "description": "Full git ref to create (e.g., refs/heads/my-new-branch)"
          },
          "sha": {
            "type": "string",
            "description": "SHA of the commit to branch from"
          }
        },
        "required": [
          "owner",
          "repo",
          "ref",
          "sha"
        ]
      }
    },
    {
      "name": "list_commits",
      "description": "List commits in a repository. Can filter by branch, path, author, and date range.",
      "method": "GET",
      "path": "/repos/{owner}/{repo}/commits",
      "input_schema": {
        "type": "object",
        "properties": {
          "owner": {
            "type": "string",
            "description": "Repository owner"
          },
          "repo": {
            "type": "string",
            "description": "Repository name"
          },
          "sha": {
            "type": "string",
            "description": "Branch name or commit SHA to start from"
          },
          "path": {
            "type": "string",
            "description": "Only commits containing this file path"
          },
          "author": {
            "type": "string",
            "description": "GitHub username or email to filter by"
          },
          "since": {
            "type": "string",
            "description": "ISO 8601 date — only commits after this date"
          },
          "until": {
            "type": "string",
            "description": "ISO 8601 date — only commits before this date"
          },
          "per_page": {
            "type": "integer",
            "description": "Results per page (max 100)",
            "default": 30
          },
          "page": {
            "type": "integer",
            "description": "Page number",
            "default": 1
          }
        },
        "required": [
          "owner",
          "repo"
        ]
      }
    },
    {
      "name": "list_issues",
      "description": "List issues in a repository. Filter by state, labels, assignee, milestone, and more.",
      "method": "GET",
      "path": "/repos/{owner}/{repo}/issues",
      "input_schema": {
        "type": "object",
        "properties": {
          "owner": {
            "type": "string",
            "description": "Repository owner"
          },
          "repo": {
            "type": "string",
            "description": "Repository name"
          },
          "state": {
            "type": "string",
            "description": "Issue state filter",
            "enum": [
              "open",
              "closed",
              "all"
            ],
            "default": "open"
          },
          "labels": {
            "type": "string",
            "description": "Comma-separated label names"
          },
          "assignee": {
            "type": "string",
            "description": "Filter by assignee username (use * for any, none for unassigned)"
          },
          "sort": {
            "type": "string",
            "description": "Sort field",
            "enum": [
              "created",
              "updated",
              "comments"
            ],
            "default": "created"
          },
          "direction": {
            "type": "string",
            "description": "Sort direction",
            "enum": [
              "asc",
              "desc"
            ],
            "default": "desc"
          },
          "per_page": {
            "type": "integer",
            "description": "Results per page (max 100)",
            "default": 30
          },
          "page": {
            "type": "integer",
            "description": "Page number",
            "default": 1
          }
        },
        "required": [
          "owner",
          "repo"
        ]
      }
    },
    {
      "name": "get_issue",
      "description": "Get a specific issue by number with full details including body, labels, assignees, and milestone",
      "method": "GET",
      "path": "/repos/{owner}/{repo}/issues/{issue_number}",
      "input_schema": {
        "type": "object",
        "properties": {
          "owner": {
            "type": "string",
            "description": "Repository owner"
          },
          "repo": {
            "type": "string",
            "description": "Repository name"
          },
          "issue_number": {
            "type": "integer",
            "description": "Issue number"
          }
        },
        "required": [
          "owner",
          "repo",
          "issue_number"
        ]
      }
    },
    {
      "name": "create_issue",
      "description": "Create a new issue in a repository with title, body, labels, and assignees",
      "method": "POST",
      "path": "/repos/{owner}/{repo}/issues",
      "input_schema": {
        "type": "object",
        "properties": {
          "owner": {
            "type": "string",
            "description": "Repository owner"
          },
          "repo": {
            "type": "string",
            "description": "Repository name"
          },
          "title": {
            "type": "string",
            "description": "Issue title"
          },
          "body": {
            "type": "string",
            "description": "Issue body (supports markdown)"
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Label names to apply"
          },
          "assignees": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Usernames to assign"
          }
        },
        "required": [
          "owner",
          "repo",
          "title"
        ]
      }
    },
    {
      "name": "update_issue",
      "description": "Update an issue — change title, body, state, labels, or assignees",
      "method": "PATCH",
      "path": "/repos/{owner}/{repo}/issues/{issue_number}",
      "input_schema": {
        "type": "object",
        "properties": {
          "owner": {
            "type": "string",
            "description": "Repository owner"
          },
          "repo": {
            "type": "string",
            "description": "Repository name"
          },
          "issue_number": {
            "type": "integer",
            "description": "Issue number"
          },
          "title": {
            "type": "string",
            "description": "New title"
          },
          "body": {
            "type": "string",
            "description": "New body (markdown)"
          },
          "state": {
            "type": "string",
            "description": "Issue state",
            "enum": [
              "open",
              "closed"
            ]
          },
          "state_reason": {
            "type": "string",
            "description": "Reason for the state change. Only valid when transitioning state.",
            "enum": [
              "completed",
              "not_planned",
              "duplicate",
              "reopened"
            ]
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Labels to set (replaces all existing labels)"
          },
          "assignees": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Assignees to set (replaces all existing)"
          }
        },
        "required": [
          "owner",
          "repo",
          "issue_number"
        ]
      }
    },
    {
      "name": "list_issue_comments",
      "description": "List comments on an issue or pull request",
      "method": "GET",
      "path": "/repos/{owner}/{repo}/issues/{issue_number}/comments",
      "input_schema": {
        "type": "object",
        "properties": {
          "owner": {
            "type": "string",
            "description": "Repository owner"
          },
          "repo": {
            "type": "string",
            "description": "Repository name"
          },
          "issue_number": {
            "type": "integer",
            "description": "Issue or PR number"
          },
          "per_page": {
            "type": "integer",
            "description": "Results per page (max 100)",
            "default": 30
          },
          "page": {
            "type": "integer",
            "description": "Page number",
            "default": 1
          }
        },
        "required": [
          "owner",
          "repo",
          "issue_number"
        ]
      }
    },
    {
      "name": "add_issue_comment",
      "description": "Add a comment to an issue or pull request",
      "method": "POST",
      "path": "/repos/{owner}/{repo}/issues/{issue_number}/comments",
      "input_schema": {
        "type": "object",
        "properties": {
          "owner": {
            "type": "string",
            "description": "Repository owner"
          },
          "repo": {
            "type": "string",
            "description": "Repository name"
          },
          "issue_number": {
            "type": "integer",
            "description": "Issue or PR number"
          },
          "body": {
            "type": "string",
            "description": "Comment text (supports markdown)"
          }
        },
        "required": [
          "owner",
          "repo",
          "issue_number",
          "body"
        ]
      }
    },
    {
      "name": "search_issues",
      "description": "Search issues and pull requests across all repos. Supports qualifiers like repo:, is:pr, is:issue, label:, author:, state:",
      "method": "GET",
      "path": "/search/issues",
      "input_schema": {
        "type": "object",
        "properties": {
          "q": {
            "type": "string",
            "description": "Search query (e.g., 'bug label:bug is:open repo:owner/repo', 'is:pr author:username')"
          },
          "sort": {
            "type": "string",
            "description": "Sort field",
            "enum": [
              "comments",
              "reactions",
              "reactions-+1",
              "reactions--1",
              "reactions-smile",
              "reactions-thinking_face",
              "reactions-heart",
              "reactions-tada",
              "interactions",
              "created",
              "updated"
            ],
            "default": "created"
          },
          "order": {
            "type": "string",
            "description": "Sort order",
            "enum": [
              "asc",
              "desc"
            ],
            "default": "desc"
          },
          "per_page": {
            "type": "integer",
            "description": "Results per page (max 100)",
            "default": 30
          },
          "page": {
            "type": "integer",
            "description": "Page number",
            "default": 1
          }
        },
        "required": [
          "q"
        ]
      }
    },
    {
      "name": "list_pulls",
      "description": "List pull requests in a repository with state, branch, and sort filters",
      "method": "GET",
      "path": "/repos/{owner}/{repo}/pulls",
      "input_schema": {
        "type": "object",
        "properties": {
          "owner": {
            "type": "string",
            "description": "Repository owner"
          },
          "repo": {
            "type": "string",
            "description": "Repository name"
          },
          "state": {
            "type": "string",
            "description": "PR state filter",
            "enum": [
              "open",
              "closed",
              "all"
            ],
            "default": "open"
          },
          "head": {
            "type": "string",
            "description": "Filter by head branch (format: user:branch)"
          },
          "base": {
            "type": "string",
            "description": "Filter by base branch"
          },
          "sort": {
            "type": "string",
            "description": "Sort field",
            "enum": [
              "created",
              "updated",
              "popularity",
              "long-running"
