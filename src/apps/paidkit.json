      "description": "Delete an audience from the platform and locally.",
      "method": "DELETE",
      "path": "/audiences/{id}",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Audience ID to delete"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    {
      "name": "performance_get",
      "description": "Get performance metrics (impressions, clicks, spend, conversions, ROAS, CTR, CPC, CPM) for campaigns, ad groups, or ads over a date range.",
      "method": "GET",
      "path": "/performance",
      "input_schema": {
        "type": "object",
        "properties": {
          "entity_type": {
            "type": "string",
            "enum": [
              "campaign",
              "adgroup",
              "ad"
            ],
            "description": "Type of entity to get performance for"
          },
          "entity_id": {
            "type": "string",
            "description": "Specific entity ID"
          },
          "ad_account_id": {
            "type": "string",
            "description": "Filter by ad account"
          },
          "platform": {
            "type": "string",
            "enum": [
              "facebook",
              "google",
              "linkedin",
              "pinterest"
            ]
          },
          "start_date": {
            "type": "string",
            "description": "Start date (YYYY-MM-DD)"
          },
          "end_date": {
            "type": "string",
            "description": "End date (YYYY-MM-DD)"
          },
          "limit": {
            "type": "integer",
            "default": 100
          }
        }
      }
    },
    {
      "name": "performance_sync",
      "description": "Pull latest performance metrics from the ad platform for a specific ad account and date range.",
      "method": "POST",
      "path": "/performance/sync",
      "input_schema": {
        "type": "object",
        "properties": {
          "ad_account_id": {
            "type": "string",
            "description": "Ad account ID to sync performance for"
          },
          "start_date": {
            "type": "string",
            "description": "Start date (YYYY-MM-DD)"
          },
          "end_date": {
            "type": "string",
            "description": "End date (YYYY-MM-DD)"
          }
        },
        "required": [
          "ad_account_id"
        ]
      }
    },
    {
      "name": "asset_list",
      "description": "List uploaded media assets (images, videos) for an ad account.",
      "method": "GET",
      "path": "/assets",
      "input_schema": {
        "type": "object",
        "properties": {
          "ad_account_id": {
            "type": "string",
            "description": "PaidKit ad account ID (from paidkit-account-list)"
          },
          "platform": {
            "type": "string",
            "enum": [
              "facebook",
              "google",
              "linkedin",
              "pinterest"
            ]
          },
          "asset_type": {
            "type": "string",
            "enum": [
              "IMAGE",
              "VIDEO"
            ],
            "description": "Filter by asset type"
          },
          "limit": {
            "type": "integer",
            "default": 50
          },
          "offset": {
            "type": "integer",
            "default": 0
          }
        }
      }
    },
    {
      "name": "asset_upload",
      "description": "Upload an image or video asset to an ad account for use in creatives.",
      "method": "POST",
      "path": "/assets/upload",
      "input_schema": {
        "type": "object",
        "properties": {
          "ad_account_id": {
            "type": "string",
            "description": "PaidKit ad account ID (from paidkit-account-list)"
          },
          "name": {
            "type": "string",
            "description": "Asset name"
          },
          "asset_type": {
            "type": "string",
            "enum": [
              "IMAGE",
              "VIDEO"
            ]
          },
          "source_url": {
            "type": "string",
            "description": "URL of the image/video to upload"
          },
          "file_id": {
            "type": "string",
            "description": "Storage file ID (alternative to source_url)"
          }
        },
        "required": [
