{
  "slug": "paidkit",
  "name": "PaidKit",
  "description": "PaidKit cross-platform ad management — create and manage campaigns, ad groups, ads, creatives, audiences, and track performance across Facebook, Google, LinkedIn, and Pinterest from a single unified API",
  "logo": "https://www.google.com/s2/favicons?domain=paidkit.com&sz=128",
  "categories": [
    "advertising",
    "ads",
    "campaigns",
    "facebook-ads",
    "google-ads",
    "linkedin-ads",
    "pinterest-ads",
    "marketing",
    "cross-platform",
    "performance"
  ],
  "base_url": "https://api.paidkit.com",
  "auth": {
    "types": [
      "api_key"
    ],
    "headers": {
      "X-API-Key": "{{api_key}}"
    },
    "credential_fields": [
      {
        "name": "api_key",
        "label": "Api_key",
        "description": "PaidKit API Key (from your PaidKit dashboard under API Keys)"
      }
    ]
  },
  "tools": [
    {
      "name": "account_list",
      "description": "List all connected ad accounts across platforms (Facebook, Google, LinkedIn, Pinterest). Returns account name, platform, status, currency, and sync info.",
      "method": "GET",
      "path": "/accounts",
      "input_schema": {
        "type": "object",
        "properties": {
          "platform": {
            "type": "string",
            "enum": [
              "facebook",
              "google",
              "linkedin",
              "pinterest"
            ],
            "description": "Filter by platform"
          },
          "limit": {
            "type": "integer",
            "default": 100,
            "description": "Max results to return"
          },
          "offset": {
            "type": "integer",
            "default": 0,
            "description": "Offset for pagination"
          }
        }
      }
    },
    {
      "name": "campaign_list",
      "description": "List ad campaigns across all connected platforms. Filter by platform, status, objective, or ad account. Returns campaign name, status, budget, dates, and platform data.",
      "method": "GET",
      "path": "/campaigns",
      "input_schema": {
        "type": "object",
        "properties": {
          "ad_account_id": {
            "type": "string",
            "description": "PaidKit ad account ID (from paidkit-account-list)"
          },
          "platform": {
            "type": "string",
            "enum": [
              "facebook",
              "google",
              "linkedin",
              "pinterest"
            ],
            "description": "Filter by platform"
          },
          "status": {
            "type": "string",
            "enum": [
              "ACTIVE",
              "PAUSED",
              "DELETED",
              "ARCHIVED"
            ],
            "description": "Filter by campaign status"
          },
          "objective": {
            "type": "string",
            "enum": [
              "AWARENESS",
              "TRAFFIC",
              "ENGAGEMENT",
              "LEADS",
              "SALES",
              "APP_PROMOTION",
              "VIDEO",
              "PERFORMANCE_MAX"
            ],
            "description": "Filter by campaign objective"
          },
          "limit": {
            "type": "integer",
            "default": 50,
            "description": "Max results"
          },
          "offset": {
            "type": "integer",
            "default": 0,
            "description": "Pagination offset"
          },
          "sort": {
            "type": "string",
            "default": "created_at:desc",
            "description": "Sort field and direction (e.g. created_at:desc)"
          }
        }
      }
    },
    {
      "name": "campaign_get",
      "description": "Get a single campaign by ID with full details including platform data, budget, dates, and sync status.",
      "method": "GET",
      "path": "/campaigns/{id}",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Campaign ID"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    {
      "name": "campaign_create",
      "description": "Create a new ad campaign. Specify the ad account, platform, name, objective, budget, and dates. PaidKit creates the campaign on the target platform and stores it locally.",
      "method": "POST",
      "path": "/campaigns",
      "input_schema": {
        "type": "object",
        "properties": {
          "ad_account_id": {
            "type": "string",
            "description": "PaidKit ad account ID (from paidkit-account-list, NOT the platform's native account ID)"
          },
          "name": {
            "type": "string",
            "description": "Campaign name"
          },
          "objective": {
            "type": "string",
            "enum": [
              "AWARENESS",
              "TRAFFIC",
              "ENGAGEMENT",
              "LEADS",
              "SALES",
              "APP_PROMOTION",
              "VIDEO",
              "PERFORMANCE_MAX"
            ],
            "description": "Campaign objective — automatically mapped to the platform-specific objective"
          },
          "status": {
            "type": "string",
            "enum": [
              "ACTIVE",
              "PAUSED"
            ],
            "default": "PAUSED",
            "description": "Initial campaign status"
          },
          "daily_budget_cents": {
            "type": "integer",
            "description": "Daily budget in cents (e.g. 5000 = $50.00)"
          },
          "lifetime_budget_cents": {
            "type": "integer",
            "description": "Lifetime budget in cents (alternative to daily budget)"
          },
          "start_date": {
            "type": "string",
            "description": "Start date (ISO 8601 format)"
          },
          "end_date": {
            "type": "string",
            "description": "End date (ISO 8601 format)"
          },
          "bid_strategy": {
            "type": "string",
            "description": "Bid strategy (e.g. LOWEST_COST, COST_CAP)"
          },
          "platform_data": {
            "type": "object",
            "description": "Platform-specific campaign settings (passed directly to the platform API)"
          }
        },
        "required": [
          "ad_account_id",
          "name",
          "objective"
        ]
      }
    },
    {
      "name": "campaign_update",
      "description": "Update an existing campaign's name, status, budget, dates, or bid strategy. Changes are synced to the platform.",
      "method": "PUT",
      "path": "/campaigns/{id}",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Campaign ID to update"
          },
          "name": {
            "type": "string",
            "description": "New campaign name"
          },
          "status": {
            "type": "string",
            "enum": [
              "ACTIVE",
              "PAUSED"
            ],
            "description": "New campaign status"
          },
          "daily_budget_cents": {
            "type": "integer",
            "description": "New daily budget in cents"
          },
          "lifetime_budget_cents": {
            "type": "integer",
            "description": "New lifetime budget in cents"
          },
          "end_date": {
            "type": "string",
            "description": "New end date"
          },
          "bid_strategy": {
            "type": "string",
            "description": "New bid strategy"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    {
      "name": "campaign_delete",
      "description": "Delete a campaign from the platform and remove it locally.",
      "method": "DELETE",
      "path": "/campaigns/{id}",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Campaign ID to delete"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    {
      "name": "campaign_sync",
      "description": "Sync a campaign's data from the ad platform to the local database. Pulls latest status, budget, and platform data.",
      "method": "POST",
      "path": "/campaigns/{id}/sync",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Campaign ID to sync"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    {
      "name": "adgroup_list",
      "description": "List ad groups (ad sets) with optional filtering by campaign, platform, or status.",
      "method": "GET",
      "path": "/adgroups",
      "input_schema": {
        "type": "object",
        "properties": {
          "campaign_id": {
            "type": "string",
            "description": "Filter by campaign ID"
          },
          "ad_account_id": {
            "type": "string",
            "description": "PaidKit ad account ID (from paidkit-account-list)"
          },
          "platform": {
            "type": "string",
            "enum": [
              "facebook",
              "google",
              "linkedin",
              "pinterest"
            ],
            "description": "Filter by platform"
          },
          "status": {
            "type": "string",
            "enum": [
              "ACTIVE",
              "PAUSED",
              "DELETED"
            ],
            "description": "Filter by status"
          },
          "limit": {
            "type": "integer",
            "default": 50
          },
          "offset": {
            "type": "integer",
            "default": 0
          }
        }
      }
    },
    {
      "name": "adgroup_create",
      "description": "Create an ad group (Facebook: ad set) under a campaign. REQUIRED for Facebook: optimization_goal matching the campaign objective. Objective→optimization_goal mapping: AWARENESS→REACH, TRAFFIC→LINK_CLICKS, ENGAGEMENT→PAGE_LIKES (page likes) or POST_ENGAGEMENT (post engagement), LEADS→LEAD_GENERATION, SALES→OFFSITE_CONVERSIONS, APP_PROMOTION→APP_INSTALLS, VIDEO→THRUPLAY. Default billing_event is IMPRESSIONS. IMPORTANT platform_data requirements for Facebook: (1) PAGE_LIKES or POST_ENGAGEMENT goals MUST include {promotedObject:{page_id:'FACEBOOK_PAGE_ID'}} — use paidkit-page-list to get available page IDs. (2) OFFSITE_CONVERSIONS or VALUE goals MUST include {promotedObject:{pixel_id:'PIXEL_ID',custom_event_type:'Purchase'}} — use paidkit-pixel-list to get pixel IDs. The destination_type is auto-set from optimization_goal (PAGE_LIKES→ON_PAGE, POST_ENGAGEMENT→ON_POST, LINK_CLICKS→WEBSITE, LANDING_PAGE_VIEWS→WEBSITE, OFFSITE_CONVERSIONS→WEBSITE, EVENT_RESPONSES→ON_EVENT, CONVERSATIONS→MESSENGER). Targeting defaults to US if omitted.",
      "method": "POST",
      "path": "/adgroups",
      "input_schema": {
        "type": "object",
        "properties": {
          "ad_account_id": {
            "type": "string",
            "description": "PaidKit ad account ID (from paidkit-account-list, NOT the platform's native account ID)"
          },
          "campaign_id": {
            "type": "string",
            "description": "PaidKit campaign ID (from paidkit-campaign-list or paidkit-campaign-create)"
          },
          "name": {
            "type": "string",
            "description": "Ad group name"
          },
          "status": {
            "type": "string",
            "enum": [
              "ACTIVE",
              "PAUSED"
            ],
            "default": "PAUSED"
          },
          "daily_budget_cents": {
            "type": "integer",
            "description": "Daily budget in cents (e.g. 5000 = $50.00). Not needed if campaign uses Campaign Budget Optimization (CBO)"
          },
          "lifetime_budget_cents": {
            "type": "integer",
            "description": "Lifetime budget in cents (alternative to daily budget)"
          },
          "bid_amount_cents": {
            "type": "integer",
            "description": "Manual bid amount in cents (optional, defaults to automatic bidding)"
          },
          "optimization_goal": {
            "type": "string",
            "enum": [
              "REACH",
              "LINK_CLICKS",
              "PAGE_LIKES",
              "POST_ENGAGEMENT",
              "EVENT_RESPONSES",
              "LEAD_GENERATION",
              "OFFSITE_CONVERSIONS",
              "APP_INSTALLS",
              "THRUPLAY",
              "VIDEO_VIEWS",
              "LANDING_PAGE_VIEWS",
              "CONVERSATIONS",
              "IMPRESSIONS",
              "VALUE",
              "VISIT_INSTAGRAM_PROFILE"
            ],
            "description": "REQUIRED for Facebook. Must match campaign objective: AWARENESS→REACH, TRAFFIC→LINK_CLICKS, ENGAGEMENT→POST_ENGAGEMENT or PAGE_LIKES (page likes) or VISIT_INSTAGRAM_PROFILE (Instagram follower/profile visit campaigns), LEADS→LEAD_GENERATION, SALES→OFFSITE_CONVERSIONS, APP_PROMOTION→APP_INSTALLS, VIDEO→THRUPLAY. NOTE: POST_ENGAGEMENT and PAGE_LIKES require platform_data.promotedObject.page_id (from paidkit-page-list). VISIT_INSTAGRAM_PROFILE requires platform_data.promotedObject.instagram_profile_id (from paidkit-instagram-account-list). OFFSITE_CONVERSIONS requires platform_data.promotedObject.pixel_id (from paidkit-pixel-list). Defaults to LINK_CLICKS if omitted"
          },
          "billing_event": {
            "type": "string",
            "enum": [
              "IMPRESSIONS",
              "LINK_CLICKS",
              "THRUPLAY",
              "PAGE_LIKES",
              "POST_ENGAGEMENT",
              "VIDEO_VIEWS"
            ],
            "description": "How you are charged. Use IMPRESSIONS for most goals (default). Use THRUPLAY only with THRUPLAY optimization_goal"
          },
          "targeting": {
            "type": "object",
            "description": "Targeting config. Defaults to {geoLocations:{countries:['US']}} if omitted. Full format: {geoLocations:{countries:['US','CA']}, ageMin:18, ageMax:65, genders:[1,2], interests:[{id:'6003139266461',name:'Music'}]}"
          },
          "platform_data": {
            "type": "object",
            "description": "Platform-specific settings passed directly to the ad platform. REQUIRED for Facebook engagement/conversion goals. For PAGE_LIKES or POST_ENGAGEMENT: {promotedObject:{page_id:'YOUR_FACEBOOK_PAGE_ID'}} — get page_id from paidkit-page-list. For VISIT_INSTAGRAM_PROFILE: {promotedObject:{instagram_profile_id:'YOUR_IG_PROFILE_ID'}} — get instagram_profile_id from paidkit-instagram-account-list. For OFFSITE_CONVERSIONS or VALUE: {promotedObject:{pixel_id:'YOUR_PIXEL_ID',custom_event_type:'Purchase'}} — get pixel_id from paidkit-pixel-list, custom_event_type can be Purchase, Lead, CompleteRegistration, AddToCart, ViewContent, Search, InitiateCheckout, AddPaymentInfo, Subscribe, StartTrial. destination_type is auto-set from optimization_goal"
          }
        },
        "required": [
          "ad_account_id",
          "campaign_id",
          "name"
        ]
      }
    },
    {
      "name": "adgroup_update",
