      "method": "GET",
      "path": "/get-identity-verification",
      "input_schema": {
        "type": "object",
        "properties": {
          "identities": {
            "type": "array"
          }
        },
        "required": [
          "identities"
        ]
      }
    },
    {
      "name": "set_identity_dkim",
      "description": "Enable/disable DKIM",
      "method": "GET",
      "path": "/set-identity-dkim",
      "input_schema": {
        "type": "object",
        "properties": {
          "identity": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          }
        },
        "required": [
          "identity",
          "enabled"
        ]
      }
    },
    {
      "name": "set_identity_feedback",
      "description": "Configure feedback forwarding",
      "method": "GET",
      "path": "/set-identity-feedback",
      "input_schema": {
        "type": "object",
        "properties": {
          "identity": {
            "type": "string"
          },
          "forwarding_enabled": {
            "type": "boolean"
          }
        },
        "required": [
          "identity",
          "forwarding_enabled"
        ]
      }
    },
    {
      "name": "set_identity_notifications",
      "description": "Configure notification topics",
      "method": "GET",
      "path": "/set-identity-notifications",
      "input_schema": {
        "type": "object",
        "properties": {
          "identity": {
            "type": "string"
          },
          "notification_type": {
            "type": "string"
          },
          "sns_topic": {
            "type": "string"
          }
        },
        "required": [
          "identity",
          "notification_type"
        ]
      }
    },
    {
      "name": "create_config_set",
      "description": "Create configuration set",
      "method": "POST",
      "path": "/create-config-set",
      "input_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      }
    },
    {
      "name": "delete_config_set",
      "description": "Delete configuration set",
      "method": "DELETE",
      "path": "/delete-config-set",
      "input_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      }
    },
    {
      "name": "list_config_sets",
      "description": "List configuration sets",
      "method": "GET",
      "path": "/list-config-sets",
      "input_schema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "add_event_destination",
      "description": "Add event destination to config set",
      "method": "GET",
      "path": "/add-event-destination",
      "input_schema": {
        "type": "object",
        "properties": {
          "config_set_name": {
            "type": "string"
          },
          "event_destination": {
            "type": "object"
          }
        },
        "required": [
          "config_set_name",
          "event_destination"
        ]
      }
    },
    {
      "name": "update_event_destination",
      "description": "Update event destination",
      "method": "PUT",
      "path": "/update-event-destination",
      "input_schema": {
        "type": "object",
        "properties": {
          "config_set_name": {
            "type": "string"
          },
          "event_destination": {
            "type": "object"
          }
        },
        "required": [
          "config_set_name",
          "event_destination"
        ]
      }
    },
    {
      "name": "set_reputation_tracking",
      "description": "Configure reputation tracking",
      "method": "GET",
      "path": "/set-reputation-tracking",
      "input_schema": {
        "type": "object",
        "properties": {
          "config_set_name": {
            "type": "string"
          },
          "reputation_metrics_enabled": {
            "type": "boolean"
          }
