      "input_schema": {
        "type": "object",
        "properties": {
          "persona_id": {
            "type": "string",
            "description": "Persona ID to delete"
          }
        },
        "required": [
          "persona_id"
        ]
      }
    },
    {
      "name": "omnistudio_media_production_set_persona_image",
      "description": "Convenience tool to set a profile or reference image for a persona",
      "method": "GET",
      "path": "/omnistudio-media-production-set-persona-image",
      "input_schema": {
        "type": "object",
        "properties": {
          "persona_id": {
            "type": "string",
            "description": "Persona ID to update"
          },
          "organization_id": {
            "type": "integer",
            "description": "Organization ID for access control"
          },
          "image_url": {
            "type": "string",
            "description": "URL of the image to set"
          },
          "image_type": {
            "type": "string",
            "enum": [
              "profile",
              "reference",
              "background",
              "thumbnail"
            ],
            "default": "profile",
            "description": "Type of image to set"
          },
          "is_primary": {
            "type": "boolean",
            "default": true,
            "description": "Set as primary image for this type"
          }
        },
        "required": [
          "persona_id",
          "organization_id",
          "image_url"
        ]
      }
    },
