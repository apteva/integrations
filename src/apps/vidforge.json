    {
      "name": "omnistudio_media_production_get_persona",
      "description": "Retrieve detailed persona information including avatars, voices, images, and usage stats",
      "method": "GET",
      "path": "/omnistudio-media-production-get-persona",
      "input_schema": {
        "type": "object",
        "properties": {
          "persona_id": {
            "type": "string",
            "description": "Persona ID to retrieve"
          },
          "slug": {
            "type": "string",
            "description": "Alternative: Persona slug to retrieve (if persona_id not provided)"
          },
          "organization_id": {
            "type": "integer",
            "description": "Organization ID for access control"
          }
        },
        "required": [
          "organization_id"
        ]
      }
    },
    {
      "name": "omnistudio_media_production_list_personas",
      "description": "List available personas with primary avatar, voice, image, and usage summary",
      "method": "GET",
      "path": "/omnistudio-media-production-list-personas",
      "input_schema": {
        "type": "object",
        "properties": {
          "organization_id": {
            "type": "integer",
            "description": "Organization ID for multi-tenant isolation"
          },
          "is_active": {
            "type": "boolean",
            "default": true,
            "description": "Filter by active status"
          },
          "role": {
            "type": "string",
            "enum": [
              "presenter",
              "narrator",
              "host",
              "spokesperson",
              "assistant",
              "expert"
            ],
            "description": "Filter by persona role"
          },
          "communication_style": {
            "type": "string",
            "enum": [
              "professional",
              "casual",
              "friendly",
              "authoritative",
              "educational",
              "conversational"
            ],
            "description": "Filter by communication style"
          },
          "search": {
            "type": "string",
            "description": "Search personas by name"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50,
            "description": "Maximum number of results"
          },
          "offset": {
            "type": "integer",
            "minimum": 0,
            "default": 0,
            "description": "Number of results to skip"
          },
          "sort": {
            "type": "string",
            "default": "created_at:desc",
            "description": "Sort field and direction"
          }
        },
        "required": [
          "organization_id"
        ]
      }
    },
