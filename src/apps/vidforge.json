          },
          "provider_avatar_id": {
            "type": "string",
            "description": "Provider's avatar ID"
          },
          "avatar_name": {
            "type": "string",
            "description": "Display name for the avatar"
          },
          "resolution": {
            "type": "string",
            "description": "Avatar resolution"
          },
          "metadata": {
            "type": "object",
            "description": "Additional avatar metadata"
          }
        },
        "required": [
          "persona_id",
          "organization_id",
          "provider_avatar_id"
        ]
      }
    }
  ]
}
