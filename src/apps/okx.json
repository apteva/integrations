{
  "slug": "okx",
  "name": "OKX",
  "description": "Major crypto exchange — spot, margin, futures, perpetuals, and options market data with comprehensive REST API.",
  "logo": "https://www.google.com/s2/favicons?domain=okx.com&sz=128",
  "categories": [
    "crypto",
    "exchange",
    "trading",
    "derivatives",
    "options",
    "futures"
  ],
  "base_url": "",
  "auth": {
    "types": [
      "bearer"
    ],
    "headers": {
      "Authorization": "Bearer {{token}}"
    },
    "credential_fields": [
      {
        "name": "api_key",
        "label": "Api_key",
        "description": "OKX API key"
      },
      {
        "name": "secret_key",
        "label": "Secret_key",
        "description": "OKX secret key"
      },
      {
        "name": "passphrase",
        "label": "Passphrase",
        "description": "OKX passphrase (set during API key creation)"
      },
      {
        "name": "simulated",
        "label": "Simulated",
        "description": "Set to true for demo trading mode"
      }
    ]
  },
  "tools": [
    {
      "name": "get_tickers",
      "description": "Get tickers for all instruments of a type. instType: SPOT, SWAP (perps), FUTURES, OPTION.",
      "method": "GET",
      "path": "/get-tickers",
      "input_schema": {
        "type": "object",
        "properties": {
          "instType": {
            "type": "string",
            "enum": [
              "SPOT",
              "SWAP",
              "FUTURES",
              "OPTION"
            ],
            "default": "SPOT"
          }
        }
      }
    },
    {
      "name": "get_ticker",
      "description": "Get ticker for a specific instrument.",
      "method": "GET",
      "path": "/get-ticker",
      "input_schema": {
        "type": "object",
        "properties": {
          "instId": {
            "type": "string",
            "description": "Instrument ID (e.g., BTC-USDT, ETH-USDT-SWAP)"
          }
        },
        "required": [
          "instId"
        ]
      }
    },
    {
      "name": "get_candles",
      "description": "Get OHLCV candlestick data.",
      "method": "GET",
      "path": "/get-candles",
      "input_schema": {
        "type": "object",
        "properties": {
          "instId": {
            "type": "string",
            "description": "Instrument ID (e.g., BTC-USDT)"
          },
          "bar": {
            "type": "string",
            "enum": [
              "1m",
              "5m",
              "15m",
              "30m",
              "1H",
              "4H",
              "1D",
              "1W",
              "1M"
            ],
            "default": "1H"
          },
          "limit": {
            "type": "integer",
            "default": 100
          }
        },
        "required": [
          "instId"
        ]
      }
    },
    {
      "name": "get_orderbook",
      "description": "Get order book depth for an instrument.",
      "method": "GET",
      "path": "/get-orderbook",
      "input_schema": {
        "type": "object",
        "properties": {
          "instId": {
            "type": "string"
          },
          "sz": {
            "type": "integer",
            "default": 25
          }
        },
        "required": [
          "instId"
        ]
      }
    },
    {
      "name": "get_funding_rate",
      "description": "Get current and next funding rate for a perpetual swap.",
      "method": "GET",
      "path": "/get-funding-rate",
      "input_schema": {
        "type": "object",
        "properties": {
          "instId": {
            "type": "string",
            "description": "Swap instrument ID (e.g., BTC-USDT-SWAP)"
          }
        },
        "required": [
          "instId"
        ]
      }
    },
    {
      "name": "get_instruments",
      "description": "Get all available instruments/trading pairs with specs.",
      "method": "GET",
      "path": "/get-instruments",
      "input_schema": {
        "type": "object",
        "properties": {
          "instType": {
            "type": "string",
            "enum": [
              "SPOT",
              "SWAP",
              "FUTURES",
              "OPTION"
            ],
            "default": "SPOT"
          }
        }
      }
    }
  ]
}
