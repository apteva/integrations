{
  "slug": "google-play-developer",
  "name": "Google Play Developer",
  "description": "Google Play Android Publisher API v3 for releases, tracks, store listings and images, testers, reviews, subscriptions, purchases, voided purchases, orders, and account users. Publishing mutations use Google's edit workflow: create an edit, make changes, validate, then commit.",
  "logo": "https://www.google.com/s2/favicons?domain=play.google.com&sz=128",
  "categories": ["mobile", "android", "app-store", "publishing", "subscriptions", "google"],
  "base_url": "https://androidpublisher.googleapis.com/androidpublisher/v3",
  "auth": {
    "types": ["bearer", "oauth2"],
    "headers": { "Authorization": "Bearer {{token}}", "Accept": "application/json" },
    "credential_fields": [
      { "name": "token", "label": "Access Token", "description": "Google OAuth access token with the androidpublisher scope." },
      { "name": "refresh_token", "label": "Refresh Token", "required": false },
      { "name": "expires_in", "label": "Expires In", "required": false, "type": "text" },
      { "name": "scope", "label": "Scope", "required": false, "type": "text" }
    ],
    "oauth2": {
      "authorize_url": "https://accounts.google.com/o/oauth2/v2/auth",
      "token_url": "https://oauth2.googleapis.com/token",
      "scopes": ["https://www.googleapis.com/auth/androidpublisher"],
      "client_id_required": true,
      "pkce": false,
      "extra_authorize_params": { "access_type": "offline", "prompt": "consent", "include_granted_scopes": "true" }
    }
  },
  "tools": [
    {
      "name": "create_edit", "description": "Create a new app edit. Use the returned id for release, listing, image, and tester changes, then validate and commit it.", "method": "POST", "path": "/applications/{packageName}/edits",
      "input_schema": { "type": "object", "properties": { "packageName": { "type": "string", "description": "Android package name, e.g. com.example.app." } }, "required": ["packageName"] }
    },
    { "name": "get_edit", "description": "Get an app edit and its expiry time.", "method": "GET", "path": "/applications/{packageName}/edits/{editId}", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "editId": { "type": "string" } }, "required": ["packageName", "editId"] } },
    { "name": "validate_edit", "description": "Validate all changes in an edit without publishing them.", "method": "POST", "path": "/applications/{packageName}/edits/{editId}:validate", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "editId": { "type": "string" } }, "required": ["packageName", "editId"] } },
    { "name": "commit_edit", "description": "Commit an edit and publish its changes. changesNotSentForReview=true leaves eligible changes pending review submission.", "method": "POST", "path": "/applications/{packageName}/edits/{editId}:commit", "query_params": ["changesNotSentForReview"], "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "editId": { "type": "string" }, "changesNotSentForReview": { "type": "boolean" } }, "required": ["packageName", "editId"] } },
    { "name": "delete_edit", "description": "Delete an uncommitted app edit.", "method": "DELETE", "path": "/applications/{packageName}/edits/{editId}", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "editId": { "type": "string" } }, "required": ["packageName", "editId"] } },

    { "name": "list_tracks", "description": "List all release tracks in an edit, including releases, version codes, rollout fractions, and status.", "method": "GET", "path": "/applications/{packageName}/edits/{editId}/tracks", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "editId": { "type": "string" } }, "required": ["packageName", "editId"] } },
    { "name": "get_track", "description": "Get one release track from an edit.", "method": "GET", "path": "/applications/{packageName}/edits/{editId}/tracks/{track}", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "editId": { "type": "string" }, "track": { "type": "string", "description": "Track name such as production, beta, alpha, internal, or a custom track." } }, "required": ["packageName", "editId", "track"] } },
    {
      "name": "update_track", "description": "Replace a release track in an edit. releases entries support name, versionCodes, status (draft, inProgress, halted, completed), userFraction, releaseNotes, and countryTargeting.", "method": "PUT", "path": "/applications/{packageName}/edits/{editId}/tracks/{track}",
      "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "editId": { "type": "string" }, "track": { "type": "string" }, "releases": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "versionCodes": { "type": "array", "items": { "type": "string" } }, "status": { "type": "string", "enum": ["statusUnspecified", "draft", "inProgress", "halted", "completed"] }, "userFraction": { "type": "number" }, "releaseNotes": { "type": "array", "items": { "type": "object" } }, "countryTargeting": { "type": "object" } } } } }, "required": ["packageName", "editId", "track", "releases"] }
    },
    { "name": "list_apks", "description": "List APKs attached to an edit.", "method": "GET", "path": "/applications/{packageName}/edits/{editId}/apks", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "editId": { "type": "string" } }, "required": ["packageName", "editId"] } },
    { "name": "list_bundles", "description": "List Android App Bundles attached to an edit.", "method": "GET", "path": "/applications/{packageName}/edits/{editId}/bundles", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "editId": { "type": "string" } }, "required": ["packageName", "editId"] } },
    { "name": "upload_bundle", "description": "Upload an Android App Bundle (.aab) into an edit. Pass the file as a binary value/blob reference.", "method": "POST", "base_url": "https://androidpublisher.googleapis.com/upload/androidpublisher/v3", "path": "/applications/{packageName}/edits/{editId}/bundles", "query_params": ["uploadType", "ackBundleInstallationWarning", "deviceTierConfigId"], "body_binary_param": "bundle", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "editId": { "type": "string" }, "uploadType": { "type": "string", "enum": ["media"], "default": "media" }, "ackBundleInstallationWarning": { "type": "boolean" }, "deviceTierConfigId": { "type": "string" }, "bundle": { "description": "Binary .aab file or blob reference." } }, "required": ["packageName", "editId", "bundle"] } },

    { "name": "get_app_details", "description": "Get app-level details in an edit, including default language and contact information.", "method": "GET", "path": "/applications/{packageName}/edits/{editId}/details", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "editId": { "type": "string" } }, "required": ["packageName", "editId"] } },
    { "name": "update_app_details", "description": "Replace app-level details in an edit.", "method": "PUT", "path": "/applications/{packageName}/edits/{editId}/details", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "editId": { "type": "string" }, "defaultLanguage": { "type": "string" }, "contactWebsite": { "type": "string" }, "contactEmail": { "type": "string" }, "contactPhone": { "type": "string" } }, "required": ["packageName", "editId"] } },
    { "name": "list_store_listings", "description": "List all localized Play Store listings in an edit.", "method": "GET", "path": "/applications/{packageName}/edits/{editId}/listings", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "editId": { "type": "string" } }, "required": ["packageName", "editId"] } },
    { "name": "get_store_listing", "description": "Get one localized Play Store listing.", "method": "GET", "path": "/applications/{packageName}/edits/{editId}/listings/{language}", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "editId": { "type": "string" }, "language": { "type": "string", "description": "BCP-47 language tag, e.g. en-US." } }, "required": ["packageName", "editId", "language"] } },
    { "name": "update_store_listing", "description": "Create or replace a localized Play Store listing.", "method": "PUT", "path": "/applications/{packageName}/edits/{editId}/listings/{language}", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "editId": { "type": "string" }, "language": { "type": "string" }, "title": { "type": "string" }, "shortDescription": { "type": "string" }, "fullDescription": { "type": "string" }, "video": { "type": "string", "description": "YouTube promo video URL." } }, "required": ["packageName", "editId", "language"] } },
    { "name": "delete_store_listing", "description": "Delete one localized store listing from an edit.", "method": "DELETE", "path": "/applications/{packageName}/edits/{editId}/listings/{language}", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "editId": { "type": "string" }, "language": { "type": "string" } }, "required": ["packageName", "editId", "language"] } },
    { "name": "list_listing_images", "description": "List store assets for one language and image type.", "method": "GET", "path": "/applications/{packageName}/edits/{editId}/listings/{language}/{imageType}", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "editId": { "type": "string" }, "language": { "type": "string" }, "imageType": { "type": "string", "description": "icon, featureGraphic, phoneScreenshots, sevenInchScreenshots, tenInchScreenshots, tvScreenshots, wearScreenshots, or automotiveScreenshots." } }, "required": ["packageName", "editId", "language", "imageType"] } },
    { "name": "upload_listing_image", "description": "Upload one store image into an edit. Pass PNG/JPEG bytes as a binary value/blob reference.", "method": "POST", "base_url": "https://androidpublisher.googleapis.com/upload/androidpublisher/v3", "path": "/applications/{packageName}/edits/{editId}/listings/{language}/{imageType}", "query_params": ["uploadType"], "body_binary_param": "image", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "editId": { "type": "string" }, "language": { "type": "string" }, "imageType": { "type": "string" }, "uploadType": { "type": "string", "enum": ["media"], "default": "media" }, "image": { "description": "Binary PNG/JPEG or blob reference." } }, "required": ["packageName", "editId", "language", "imageType", "image"] } },
    { "name": "delete_listing_image", "description": "Delete one store image from an edit.", "method": "DELETE", "path": "/applications/{packageName}/edits/{editId}/listings/{language}/{imageType}/{imageId}", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "editId": { "type": "string" }, "language": { "type": "string" }, "imageType": { "type": "string" }, "imageId": { "type": "string" } }, "required": ["packageName", "editId", "language", "imageType", "imageId"] } },
    { "name": "get_track_testers", "description": "Get tester email lists and Google Groups assigned to a testing track in an edit.", "method": "GET", "path": "/applications/{packageName}/edits/{editId}/testers/{track}", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "editId": { "type": "string" }, "track": { "type": "string" } }, "required": ["packageName", "editId", "track"] } },
    { "name": "update_track_testers", "description": "Replace tester email lists and Google Groups for a testing track in an edit.", "method": "PUT", "path": "/applications/{packageName}/edits/{editId}/testers/{track}", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "editId": { "type": "string" }, "track": { "type": "string" }, "googleGroups": { "type": "array", "items": { "type": "string" } } }, "required": ["packageName", "editId", "track", "googleGroups"] } },

    { "name": "list_reviews", "description": "List recent user reviews. Use translationLanguage to request translated review text.", "method": "GET", "path": "/applications/{packageName}/reviews", "query_params": ["token", "startIndex", "maxResults", "translationLanguage"], "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "token": { "type": "string", "description": "Pagination token." }, "startIndex": { "type": "integer" }, "maxResults": { "type": "integer", "maximum": 100 }, "translationLanguage": { "type": "string" } }, "required": ["packageName"] } },
    { "name": "get_review", "description": "Get a single Play Store review.", "method": "GET", "path": "/applications/{packageName}/reviews/{reviewId}", "query_params": ["translationLanguage"], "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "reviewId": { "type": "string" }, "translationLanguage": { "type": "string" } }, "required": ["packageName", "reviewId"] } },
    { "name": "reply_to_review", "description": "Create or update the developer reply to a Play Store review.", "method": "POST", "path": "/applications/{packageName}/reviews/{reviewId}:reply", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "reviewId": { "type": "string" }, "replyText": { "type": "string", "maxLength": 350 } }, "required": ["packageName", "reviewId", "replyText"] } },

    { "name": "list_subscriptions", "description": "List subscription products and their base plans for an app.", "method": "GET", "path": "/applications/{packageName}/subscriptions", "query_params": ["pageSize", "pageToken", "showArchived"], "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "pageSize": { "type": "integer" }, "pageToken": { "type": "string" }, "showArchived": { "type": "boolean" } }, "required": ["packageName"] } },
    { "name": "get_subscription", "description": "Get one subscription product, its listings, and base plans.", "method": "GET", "path": "/applications/{packageName}/subscriptions/{productId}", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "productId": { "type": "string" } }, "required": ["packageName", "productId"] } },
    { "name": "create_subscription", "description": "Create a subscription product. listings must contain the default-language entry; basePlans may be included or added later.", "method": "POST", "path": "/applications/{packageName}/subscriptions", "query_params": ["productId", "regionsVersion.version"], "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "productId": { "type": "string" }, "regionsVersion.version": { "type": "string" }, "listings": { "type": "array", "items": { "type": "object", "properties": { "languageCode": { "type": "string" }, "title": { "type": "string" }, "benefits": { "type": "array", "items": { "type": "string" } }, "description": { "type": "string" } }, "required": ["languageCode", "title"] } }, "basePlans": { "type": "array", "items": { "type": "object" } }, "taxAndComplianceSettings": { "type": "object" }, "restrictedPaymentCountries": { "type": "object" } }, "required": ["packageName", "productId", "listings"] } },
    { "name": "update_subscription", "description": "Patch a subscription product, listings, base plans, or compliance settings.", "method": "PATCH", "path": "/applications/{packageName}/subscriptions/{productId}", "query_params": ["updateMask", "regionsVersion.version", "allowMissing", "latencyTolerance"], "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "productId": { "type": "string" }, "updateMask": { "type": "string" }, "regionsVersion.version": { "type": "string" }, "allowMissing": { "type": "boolean" }, "latencyTolerance": { "type": "string" }, "listings": { "type": "array", "items": { "type": "object" } }, "basePlans": { "type": "array", "items": { "type": "object" } }, "taxAndComplianceSettings": { "type": "object" }, "restrictedPaymentCountries": { "type": "object" } }, "required": ["packageName", "productId", "updateMask"] } },
    { "name": "delete_subscription", "description": "Delete a draft subscription product.", "method": "DELETE", "path": "/applications/{packageName}/subscriptions/{productId}", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "productId": { "type": "string" } }, "required": ["packageName", "productId"] } },
    { "name": "list_subscription_offers", "description": "List offers under a subscription base plan.", "method": "GET", "path": "/applications/{packageName}/subscriptions/{productId}/basePlans/{basePlanId}/offers", "query_params": ["pageSize", "pageToken"], "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "productId": { "type": "string" }, "basePlanId": { "type": "string" }, "pageSize": { "type": "integer" }, "pageToken": { "type": "string" } }, "required": ["packageName", "productId", "basePlanId"] } },
    { "name": "get_subscription_offer", "description": "Get one subscription offer.", "method": "GET", "path": "/applications/{packageName}/subscriptions/{productId}/basePlans/{basePlanId}/offers/{offerId}", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "productId": { "type": "string" }, "basePlanId": { "type": "string" }, "offerId": { "type": "string" } }, "required": ["packageName", "productId", "basePlanId", "offerId"] } },
    { "name": "create_subscription_offer", "description": "Create an offer under a base plan. Configure targeting, phases, regional configs, and tags.", "method": "POST", "path": "/applications/{packageName}/subscriptions/{productId}/basePlans/{basePlanId}/offers", "query_params": ["offerId", "regionsVersion.version"], "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "productId": { "type": "string" }, "basePlanId": { "type": "string" }, "offerId": { "type": "string" }, "regionsVersion.version": { "type": "string" }, "offerTags": { "type": "array", "items": { "type": "object" } }, "regionalConfigs": { "type": "array", "items": { "type": "object" } }, "otherRegionsConfig": { "type": "object" }, "targeting": { "type": "object" }, "phases": { "type": "array", "items": { "type": "object" } } }, "required": ["packageName", "productId", "basePlanId", "offerId"] } },
    { "name": "activate_subscription_offer", "description": "Activate a draft or inactive subscription offer.", "method": "POST", "path": "/applications/{packageName}/subscriptions/{productId}/basePlans/{basePlanId}/offers/{offerId}:activate", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "productId": { "type": "string" }, "basePlanId": { "type": "string" }, "offerId": { "type": "string" } }, "required": ["packageName", "productId", "basePlanId", "offerId"] } },
    { "name": "deactivate_subscription_offer", "description": "Deactivate an active subscription offer.", "method": "POST", "path": "/applications/{packageName}/subscriptions/{productId}/basePlans/{basePlanId}/offers/{offerId}:deactivate", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "productId": { "type": "string" }, "basePlanId": { "type": "string" }, "offerId": { "type": "string" } }, "required": ["packageName", "productId", "basePlanId", "offerId"] } },

    { "name": "get_product_purchase", "description": "Verify and inspect a one-time in-app product purchase token.", "method": "GET", "path": "/applications/{packageName}/purchases/products/{productId}/tokens/{purchaseToken}", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "productId": { "type": "string" }, "purchaseToken": { "type": "string" } }, "required": ["packageName", "productId", "purchaseToken"] } },
    { "name": "acknowledge_product_purchase", "description": "Acknowledge a one-time product purchase.", "method": "POST", "path": "/applications/{packageName}/purchases/products/{productId}/tokens/{purchaseToken}:acknowledge", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "productId": { "type": "string" }, "purchaseToken": { "type": "string" }, "developerPayload": { "type": "string" } }, "required": ["packageName", "productId", "purchaseToken"] } },
    { "name": "consume_product_purchase", "description": "Consume a one-time product purchase so it can be purchased again.", "method": "POST", "path": "/applications/{packageName}/purchases/products/{productId}/tokens/{purchaseToken}:consume", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "productId": { "type": "string" }, "purchaseToken": { "type": "string" } }, "required": ["packageName", "productId", "purchaseToken"] } },
    { "name": "get_subscription_purchase", "description": "Verify and inspect a subscription purchase using the current subscriptionsv2 endpoint.", "method": "GET", "path": "/applications/{packageName}/purchases/subscriptionsv2/tokens/{purchaseToken}", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "purchaseToken": { "type": "string" } }, "required": ["packageName", "purchaseToken"] } },
    { "name": "cancel_subscription_purchase", "description": "Cancel a subscription purchase. cancellationContext can specify the developer-requested stop reason.", "method": "POST", "path": "/applications/{packageName}/purchases/subscriptionsv2/tokens/{purchaseToken}:cancel", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "purchaseToken": { "type": "string" }, "cancellationContext": { "type": "object" } }, "required": ["packageName", "purchaseToken"] } },
    { "name": "revoke_subscription_purchase", "description": "Revoke a subscription purchase and optionally select a refund type.", "method": "POST", "path": "/applications/{packageName}/purchases/subscriptionsv2/tokens/{purchaseToken}:revoke", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "purchaseToken": { "type": "string" }, "revocationContext": { "type": "object" } }, "required": ["packageName", "purchaseToken"] } },
    { "name": "list_voided_purchases", "description": "List purchases canceled, refunded, or charged back during a time range.", "method": "GET", "path": "/applications/{packageName}/purchases/voidedpurchases", "query_params": ["startTime", "endTime", "maxResults", "token", "type", "includeQuantityBasedPartialRefund"], "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "startTime": { "type": "string", "description": "Unix epoch milliseconds." }, "endTime": { "type": "string" }, "maxResults": { "type": "integer" }, "token": { "type": "string" }, "type": { "type": "integer", "enum": [0, 1] }, "includeQuantityBasedPartialRefund": { "type": "boolean" } }, "required": ["packageName"] } },
    { "name": "get_order", "description": "Get a Play order by order ID.", "method": "GET", "path": "/applications/{packageName}/orders/{orderId}", "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "orderId": { "type": "string" } }, "required": ["packageName", "orderId"] } },
    { "name": "refund_order", "description": "Refund a subscription or in-app purchase order. Set revoke=true to revoke entitlement as well.", "method": "POST", "path": "/applications/{packageName}/orders/{orderId}:refund", "query_params": ["revoke"], "input_schema": { "type": "object", "properties": { "packageName": { "type": "string" }, "orderId": { "type": "string" }, "revoke": { "type": "boolean" } }, "required": ["packageName", "orderId"] } },
    { "name": "list_account_users", "description": "List users with access to a Google Play developer account.", "method": "GET", "path": "/developers/{developerId}/users", "query_params": ["pageSize", "pageToken"], "input_schema": { "type": "object", "properties": { "developerId": { "type": "string", "description": "Google Play developer account ID." }, "pageSize": { "type": "integer" }, "pageToken": { "type": "string" } }, "required": ["developerId"] } }
  ]
}
