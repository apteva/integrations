    {
      "name": "create_webhook",
      "description": "Register an event webhook to receive notifications (JSON or XML format)",
      "method": "POST",
      "path": "/integr/v1.0/setting/createWebHook",
      "input_schema": {
        "type": "object",
        "properties": {
          "api_secret": {
            "type": "string",
            "description": "API secret"
          },
          "user_email": {
            "type": "string",
            "description": "Account email"
          },
          "source_name": {
            "type": "string",
            "default": "omnikit"
          },
          "url": {
            "type": "string",
            "description": "Webhook endpoint URL"
          },
          "format": {
            "type": "string",
            "enum": [
              "json",
              "xml"
            ],
            "default": "json",
            "description": "Payload format"
          },
          "events": {
            "type": "array",
            "description": "Events to subscribe to",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "api_secret",
          "user_email",
          "url"
        ]
      }
    },
