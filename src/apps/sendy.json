{
  "slug": "sendy",
  "name": "Sendy",
  "description": "Sendy self-hosted newsletter API for subscribers, brands, lists, counts, status, and campaign create/send/schedule. Uses simple form-encoded POST requests to the user's Sendy installation.",
  "logo": "https://www.google.com/s2/favicons?domain=sendy.co&sz=128",
  "categories": ["newsletter", "email", "self-hosted", "amazon-ses"],
  "base_url": "{{credential.install_url}}",
  "auth": { "types": ["api_key"], "headers": { "Accept": "application/json", "Content-Type": "application/x-www-form-urlencoded" }, "body_params": { "api_key": "{{api_key}}" }, "credential_fields": [{ "name": "install_url", "label": "Sendy Install URL", "description": "Base URL of your Sendy installation, without a trailing slash.", "type": "text" }, { "name": "api_key", "label": "API Key", "description": "Sendy API key from Settings." }] },
  "tools": [
    { "name": "subscribe", "description": "Subscribe or update a subscriber in a list.", "method": "POST", "path": "/subscribe", "input_schema": { "type": "object", "properties": { "email": { "type": "string" }, "name": { "type": "string" }, "list": { "type": "string" }, "country": { "type": "string" }, "ipaddress": { "type": "string" }, "referrer": { "type": "string" }, "gdpr": { "type": "boolean" }, "silent": { "type": "boolean" }, "boolean": { "type": "boolean", "description": "Set true to receive plain true/false style API output." } }, "required": ["email", "list"] } },
    { "name": "unsubscribe", "description": "Unsubscribe a subscriber from a list.", "method": "POST", "path": "/unsubscribe", "input_schema": { "type": "object", "properties": { "email": { "type": "string" }, "list": { "type": "string" }, "boolean": { "type": "boolean" } }, "required": ["email", "list"] } },
    { "name": "delete_subscriber", "description": "Delete a subscriber from a list.", "method": "POST", "path": "/api/subscribers/delete.php", "input_schema": { "type": "object", "properties": { "email": { "type": "string" }, "list_id": { "type": "string" } }, "required": ["email", "list_id"] } },
    { "name": "get_subscription_status", "description": "Get a subscriber's status in a list.", "method": "POST", "path": "/api/subscribers/subscription-status.php", "input_schema": { "type": "object", "properties": { "email": { "type": "string" }, "list_id": { "type": "string" } }, "required": ["email", "list_id"] } },
    { "name": "get_active_subscriber_count", "description": "Get active subscriber count for a list.", "method": "POST", "path": "/api/subscribers/active-subscriber-count.php", "input_schema": { "type": "object", "properties": { "list_id": { "type": "string" } }, "required": ["list_id"] } },
    { "name": "get_lists", "description": "Get lists for the Sendy installation.", "method": "POST", "path": "/api/lists/get-lists.php", "input_schema": { "type": "object", "properties": {} } },
    { "name": "get_brands", "description": "Get brands for the Sendy installation.", "method": "POST", "path": "/api/brands/get-brands.php", "input_schema": { "type": "object", "properties": {} } },
    { "name": "create_campaign", "description": "Create, send, or schedule a Sendy campaign. Sending/scheduling requires Sendy's cron job to be configured.", "method": "POST", "path": "/api/campaigns/create.php", "input_schema": { "type": "object", "properties": { "from_name": { "type": "string" }, "from_email": { "type": "string" }, "reply_to": { "type": "string" }, "title": { "type": "string" }, "subject": { "type": "string" }, "plain_text": { "type": "string" }, "html_text": { "type": "string" }, "list_ids": { "type": "string" }, "segment_ids": { "type": "string" }, "exclude_list_ids": { "type": "string" }, "exclude_segments_ids": { "type": "string" }, "brand_id": { "type": "string" }, "query_string": { "type": "string" }, "track_opens": { "type": "string" }, "track_clicks": { "type": "string" }, "send_campaign": { "type": "string" }, "schedule_date_time": { "type": "string" }, "schedule_timezone": { "type": "string" } }, "required": ["from_name", "from_email", "reply_to", "title", "subject", "html_text"] } }
  ]
}
