{
  "slug": "justcall",
  "name": "JustCall",
  "description": "JustCall v2.1 API for calls, recordings, SMS/MMS, WhatsApp, contacts, phone numbers, users, AI voice agents, and webhooks.",
  "logo": "https://www.google.com/s2/favicons?domain=justcall.io&sz=128",
  "categories": ["telephony", "voice", "sms", "whatsapp", "phone", "communications", "sales"],
  "base_url": "https://api.justcall.io",
  "auth": {
    "types": ["api_key"],
    "headers": {
      "Authorization": "{{api_key}}:{{api_secret}}",
      "Accept": "application/json",
      "Content-Type": "application/json"
    },
    "credential_fields": [
      { "name": "api_key", "label": "API Key", "description": "JustCall API key from APIs and Webhooks.", "type": "text" },
      { "name": "api_secret", "label": "API Secret", "description": "JustCall API secret from APIs and Webhooks." }
    ]
  },
  "health_check": { "tool": "list_calls", "input": { "limit": 1 } },
  "tools": [
    { "name": "list_calls", "description": "List JustCall calls with time, number, agent, direction, queue, and AI-data filters.", "method": "GET", "path": "/v2.1/calls", "query_params": ["page", "limit", "from_datetime", "to_datetime", "contact_number", "justcall_number", "agent_id", "direction", "fetch_queue_data", "fetch_ai_data"], "input_schema": { "type": "object", "properties": { "page": { "type": "integer" }, "limit": { "type": "integer" }, "from_datetime": { "type": "string" }, "to_datetime": { "type": "string" }, "contact_number": { "type": "string" }, "justcall_number": { "type": "string" }, "agent_id": { "type": "integer" }, "direction": { "type": "string" }, "fetch_queue_data": { "type": "boolean" }, "fetch_ai_data": { "type": "boolean" } } } },
    { "name": "get_call", "description": "Retrieve one JustCall call by ID.", "method": "GET", "path": "/v2.1/calls/{id}", "input_schema": { "type": "object", "properties": { "id": { "type": "string" } }, "required": ["id"] } },
    { "name": "update_call", "description": "Update a completed call's notes, disposition, or rating.", "method": "PATCH", "path": "/v2.1/calls/{id}", "input_schema": { "type": "object", "properties": { "id": { "type": "string" }, "notes": { "type": "string" }, "disposition": { "type": "string" }, "rating": { "type": "number" } }, "required": ["id"] } },
    { "name": "download_call_recording", "description": "Download the recording for a completed call.", "method": "GET", "path": "/v2.1/calls/{id}/recording/download", "input_schema": { "type": "object", "properties": { "id": { "type": "string" } }, "required": ["id"] } },
    { "name": "get_call_journey", "description": "Retrieve journey details for a completed call.", "method": "GET", "path": "/v2.1/calls/{id}/journey", "input_schema": { "type": "object", "properties": { "id": { "type": "string" } }, "required": ["id"] } },
    { "name": "list_contacts", "description": "List JustCall contacts.", "method": "GET", "path": "/v2.1/contacts", "query_params": ["page", "limit", "search", "phone", "email"], "input_schema": { "type": "object", "properties": { "page": { "type": "integer" }, "limit": { "type": "integer" }, "search": { "type": "string" }, "phone": { "type": "string" }, "email": { "type": "string" } } } },
    { "name": "get_contact", "description": "Retrieve one JustCall contact.", "method": "GET", "path": "/v2.1/contacts/{id}", "input_schema": { "type": "object", "properties": { "id": { "type": "string" } }, "required": ["id"] } },
    { "name": "create_contact", "description": "Create a JustCall contact.", "method": "POST", "path": "/v2.1/contacts", "input_schema": { "type": "object", "properties": { "first_name": { "type": "string" }, "last_name": { "type": "string" }, "phone": { "type": "string" }, "email": { "type": "string" }, "company": { "type": "string" }, "address": { "type": "string" }, "custom_fields": { "type": "object", "additionalProperties": true } } } },
    { "name": "update_contact", "description": "Update a JustCall contact.", "method": "PATCH", "path": "/v2.1/contacts/{id}", "input_schema": { "type": "object", "properties": { "id": { "type": "string" }, "first_name": { "type": "string" }, "last_name": { "type": "string" }, "phone": { "type": "string" }, "email": { "type": "string" }, "company": { "type": "string" }, "custom_fields": { "type": "object", "additionalProperties": true } }, "required": ["id"] } },
    { "name": "list_phone_numbers", "description": "List JustCall phone numbers.", "method": "GET", "path": "/v2.1/phone-numbers", "query_params": ["page", "limit", "country_iso", "number_type"], "input_schema": { "type": "object", "properties": { "page": { "type": "integer" }, "limit": { "type": "integer" }, "country_iso": { "type": "string" }, "number_type": { "type": "string" } } } },
    { "name": "get_phone_number", "description": "Retrieve one JustCall phone number.", "method": "GET", "path": "/v2.1/phone-numbers/{id}", "input_schema": { "type": "object", "properties": { "id": { "type": "string" } }, "required": ["id"] } },
    { "name": "list_texts", "description": "List SMS/MMS messages.", "method": "GET", "path": "/v2.1/texts", "query_params": ["page", "limit", "from_datetime", "to_datetime", "contact_number", "justcall_number", "direction"], "input_schema": { "type": "object", "properties": { "page": { "type": "integer" }, "limit": { "type": "integer" }, "from_datetime": { "type": "string" }, "to_datetime": { "type": "string" }, "contact_number": { "type": "string" }, "justcall_number": { "type": "string" }, "direction": { "type": "string" } } } },
    { "name": "get_text", "description": "Retrieve one SMS/MMS message.", "method": "GET", "path": "/v2.1/texts/{id}", "input_schema": { "type": "object", "properties": { "id": { "type": "string" } }, "required": ["id"] } },
    { "name": "send_text", "description": "Send an SMS or MMS through JustCall.", "method": "POST", "path": "/v2.1/texts/new", "input_schema": { "type": "object", "properties": { "justcall_number": { "type": "string" }, "contact_number": { "type": "string" }, "body": { "type": "string" }, "media_url": { "type": "string" }, "scheduled_datetime": { "type": "string" } }, "required": ["justcall_number", "contact_number", "body"] } },
    { "name": "check_text_reply", "description": "Check the latest inbound SMS reply from a contact, optionally scoped to a JustCall number.", "method": "GET", "path": "/v2.1/texts/checkreply", "query_params": ["contact_number", "justcall_number"], "input_schema": { "type": "object", "properties": { "contact_number": { "type": "string" }, "justcall_number": { "type": "string" } }, "required": ["contact_number"] } },
    { "name": "list_whatsapp_messages", "description": "List WhatsApp messages.", "method": "GET", "path": "/v2.1/whatsapp/messages", "query_params": ["page", "limit", "from_datetime", "to_datetime", "contact_number", "justcall_number", "direction"], "input_schema": { "type": "object", "properties": { "page": { "type": "integer" }, "limit": { "type": "integer" }, "from_datetime": { "type": "string" }, "to_datetime": { "type": "string" }, "contact_number": { "type": "string" }, "justcall_number": { "type": "string" }, "direction": { "type": "string" } } } },
    { "name": "send_whatsapp_message", "description": "Send a WhatsApp message from a JustCall WhatsApp integrated number.", "method": "POST", "path": "/v2.1/whatsapp/messages/send", "input_schema": { "type": "object", "properties": { "justcall_number": { "type": "string" }, "contact_number": { "type": "string" }, "body": { "type": "string" }, "template_id": { "type": "string" }, "template_variables": { "type": "object", "additionalProperties": true } }, "required": ["justcall_number", "contact_number"] } },
    { "name": "list_users", "description": "List JustCall users/agents.", "method": "GET", "path": "/v2.1/users", "query_params": ["page", "limit", "email", "availability"], "input_schema": { "type": "object", "properties": { "page": { "type": "integer" }, "limit": { "type": "integer" }, "email": { "type": "string" }, "availability": { "type": "string" } } } },
    { "name": "get_user", "description": "Retrieve one JustCall user/agent.", "method": "GET", "path": "/v2.1/users/{id}", "input_schema": { "type": "object", "properties": { "id": { "type": "string" } }, "required": ["id"] } },
    { "name": "initiate_voice_agent_call", "description": "Trigger an outbound call from a configured JustCall AI Voice Agent.", "method": "POST", "path": "/v2.1/voice-agents/calls", "input_schema": { "type": "object", "properties": { "voice_agent_id": { "type": "string" }, "contact_number": { "type": "string" }, "justcall_number": { "type": "string" }, "dynamic_variables": { "type": "object", "additionalProperties": true } }, "required": ["voice_agent_id", "contact_number"] } },
    { "name": "list_webhooks", "description": "List subscribed JustCall webhook events and URLs.", "method": "GET", "path": "/v2.1/webhooks", "query_params": ["event_type"], "input_schema": { "type": "object", "properties": { "event_type": { "type": "string" } } } },
    { "name": "create_webhook", "description": "Add a URL to a JustCall webhook event.", "method": "POST", "path": "/v2.1/webhooks", "input_schema": { "type": "object", "properties": { "event_type": { "type": "string" }, "url": { "type": "string" } }, "required": ["event_type", "url"] } },
    { "name": "delete_webhook_url", "description": "Remove a URL from a JustCall webhook event.", "method": "DELETE", "path": "/v2.1/webhooks/url/{url_id}", "input_schema": { "type": "object", "properties": { "url_id": { "type": "string" } }, "required": ["url_id"] } }
  ]
}
