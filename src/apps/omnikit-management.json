{
  "slug": "omnikit-management",
  "name": "OmniKit Management",
  "description": "Project management system for OmniKit platform - handles project creation, listing, updates, and organization management",
  "logo": "https://cdn.omnikit.co/cdn/project-10/public/10_1770556267491_eecb0n/603050903_10162713420734412_6016628635295692734_n.jpg",
  "categories": [
    "management",
    "projects",
    "organizations",
    "omnikit",
    "platform"
  ],
  "base_url": "https://api.omnikit.co",
  "auth": {
    "types": [
      "api_key"
    ],
    "headers": {
      "X-API-Key": "{{api_key}}"
    },
    "credential_fields": [
      {
        "name": "api_key",
        "label": "Api Key",
        "description": "Your OmniKit API key (starts with 'okt_'). The project is determined automatically from the key."
      }
    ]
  },
  "tools": [
    {
      "name": "list_projects",
      "description": "List projects accessible to the user with organization filtering and search",
      "method": "GET",
      "path": "/management/projects",
      "input_schema": {
        "type": "object",
        "properties": {
          "organization_id": {
            "type": "integer",
            "description": "Organization ID to filter projects (defaults to 1)"
          },
          "is_active": {
            "type": "boolean",
            "description": "Filter by active status",
            "default": true
          },
          "search": {
            "type": "string",
            "description": "Search projects by name (partial match)"
          },
          "limit": {
            "type": "integer",
            "description": "Number of projects to return",
            "default": 50,
            "minimum": 1,
            "maximum": 100
          },
          "offset": {
            "type": "integer",
            "description": "Pagination offset",
            "default": 0,
            "minimum": 0
          }
        }
      }
    },
    {
      "name": "create_project",
      "description": "Create a new project in an organization with auto-generated slug",
      "method": "POST",
      "path": "/management/projects",
      "input_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Project name",
            "minLength": 1,
            "maxLength": 255
          },
          "organization_id": {
            "type": "integer",
            "description": "Organization ID to create project in"
          },
          "description": {
            "type": "string",
            "description": "Optional project description",
            "maxLength": 1000
          },
          "slug": {
            "type": "string",
            "description": "Project URL slug (auto-generated from name if not provided)",
            "pattern": "^[a-z0-9-]+$"
          },
          "userId": {
            "type": "integer",
            "description": "User ID creating the project (defaults to 1)"
          }
        },
        "required": [
          "name",
          "organization_id"
        ]
      }
    },
    {
      "name": "update_project",
      "description": "Update project information including name, description, and status",
      "method": "PUT",
      "path": "/management/projects/{project_id}",
      "input_schema": {
        "type": "object",
        "properties": {
          "organization_id": {
            "type": "integer",
            "description": "Organization ID for verification"
          },
          "name": {
            "type": "string",
            "description": "Updated project name",
            "minLength": 1,
            "maxLength": 255
          },
          "description": {
            "type": "string",
            "description": "Updated project description",
            "maxLength": 1000
          },
          "slug": {
            "type": "string",
            "description": "Updated project URL slug",
            "pattern": "^[a-z0-9-]+$"
          },
          "is_active": {
            "type": "boolean",
            "description": "Project active status"
          }
        },
        "required": [
          "organization_id"
        ]
      }
    },
    {
      "name": "delete_project",
      "description": "Delete a project (soft delete to preserve historical data)",
      "method": "DELETE",
      "path": "/management/projects/{project_id}",
      "input_schema": {
        "type": "object",
        "properties": {
          "organization_id": {
            "type": "integer",
            "description": "Organization ID for verification"
          },
          "force": {
            "type": "boolean",
            "description": "Force delete (hard delete)",
            "default": false
          }
        },
        "required": [
          "organization_id"
        ]
      }
    },
    {
      "name": "get_current_project",
      "description": "Get the currently active project for the user session",
      "method": "GET",
      "path": "/management/projects/current",
      "input_schema": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "integer",
            "description": "User ID (optional, defaults to current user)"
          }
        }
      }
    },
    {
      "name": "switch_project",
      "description": "Switch the user's active project context",
      "method": "POST",
      "path": "/management/projects/{project_id}/switch",
      "input_schema": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "integer",
            "description": "User ID (optional, defaults to current user)"
          }
        }
      }
    }
  ],
  "credential_group": {
    "id": "omnikit",
    "name": "OmniKit",
    "logo": "https://cdn.omnikit.co/cdn/project-10/public/10_1770556267491_eecb0n/603050903_10162713420734412_6016628635295692734_n.jpg",
    "description": "One key unlocks the whole OmniKit suite. Account keys can manage many projects; project keys are scoped to one.",
    "discovery": {
      "list_projects": {
        "method": "GET",
        "path": "/projects",
        "response_path": "data",
        "id_field": "id",
        "label_field": "name"
      },
      "api_lookup": {
        "method": "GET",
        "path": "/apis",
        "response_path": "data",
        "match_field": "base_path",
        "match_value": "omnikit",
        "id_field": "id"
      },
      "provision_project_key": {
        "method": "POST",
        "path": "/api-keys",
        "body": {
          "name": "Apteva \u00b7 {{label}}",
          "api_id": "{{api_lookup_id}}",
          "target_project_id": "{{external_project_id}}",
          "scopes": [
            "read",
            "write"
          ]
        },
        "response_key_path": "data.key",
        "id_response_path": "data.id",
        "credential_field": "api_key"
      }
    }
  },
  "scopes": {
    "account": {
      "credential_fields": [
        {
          "name": "api_key",
          "label": "Account API Key",
          "description": "Starts with okt_acc_ \u2014 operates across every project in the account.",
          "type": "password"
        }
      ],
      "auth_headers": {
        "X-API-Key": "{{api_key}}"
      },
      "project_binding": {
        "type": "header",
        "name": "X-Project-Id",
        "value": "{{project_id}}"
      }
    },
    "project": {
      "credential_fields": [
        {
          "name": "api_key",
          "label": "Project API Key",
          "description": "Starts with okt_ \u2014 already scoped to a single project.",
          "type": "password"
        }
      ],
      "auth_headers": {
        "X-API-Key": "{{api_key}}"
      }
    }
  }
}
