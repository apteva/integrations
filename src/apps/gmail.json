                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Labels to add"
              },
              "removeLabelIds": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Labels to remove (e.g. ['INBOX'] to skip inbox)"
              },
              "forward": {
                "type": "string",
                "description": "Email address to forward to"
              }
            }
          }
