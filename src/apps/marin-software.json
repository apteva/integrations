        ]
      }
    },
    {
      "name": "marin_strategies_create",
      "description": "Create automated bidding strategies in Marin. Strategies control bid optimization across campaigns and ad groups based on rules, targets, and performance data.",
      "method": "POST",
      "path": "/open-api/0.1/bulk/strategies",
      "input_schema": {
        "type": "object",
        "properties": {
          "clientId": {
            "type": "string",
            "description": "Marin client ID"
          },
          "customerId": {
            "type": "string",
            "description": "Marin customer ID"
          },
          "userId": {
            "type": "string",
            "description": "Marin user ID"
          },
          "userCustomerId": {
            "type": "string",
            "description": "User customer ID"
          },
          "data": {
            "type": "array",
            "description": "Array of strategy objects to create",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Strategy name"
                },
                "type": {
                  "type": "string",
                  "description": "Strategy type (e.g., TargetCPA, TargetROAS, MaxClicks, MaxConversions)"
                },
                "targetValue": {
                  "type": "number",
                  "description": "Target value (CPA amount, ROAS percentage, etc.)"
                },
                "minBid": {
                  "type": "number",
                  "description": "Minimum bid floor"
                },
                "maxBid": {
                  "type": "number",
                  "description": "Maximum bid ceiling"
                },
                "campaignIds": {
                  "type": "array",
                  "description": "Campaign IDs to apply the strategy to",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "name",
                "type"
              ]
            }
          }
        },
        "required": [
          "clientId",
          "customerId",
          "userId",
          "data"
        ]
      }
    },
