    },
    {
      "name": "marin_ads_create",
      "description": "Create one or more ads across connected publishers. Supports text ads, responsive ads, and display ads across Google, Meta, Amazon, and more.",
      "method": "POST",
      "path": "/open-api/0.1/bulk/ads",
      "input_schema": {
        "type": "object",
        "properties": {
          "clientId": {
            "type": "string",
            "description": "Marin client ID"
          },
          "customerId": {
            "type": "string",
            "description": "Marin customer ID"
          },
          "userId": {
            "type": "string",
            "description": "Marin user ID"
          },
          "userCustomerId": {
            "type": "string",
            "description": "User customer ID"
          },
          "data": {
            "type": "array",
            "description": "Array of ad objects to create",
            "items": {
              "type": "object",
              "properties": {
                "groupId": {
                  "type": "string",
                  "description": "Ad group ID"
                },
                "headline": {
                  "type": "string",
                  "description": "Ad headline"
                },
                "headline2": {
                  "type": "string",
                  "description": "Second headline (for expanded text ads)"
                },
                "headline3": {
                  "type": "string",
                  "description": "Third headline (for responsive search ads)"
                },
                "description": {
                  "type": "string",
                  "description": "Ad description"
                },
                "description2": {
                  "type": "string",
                  "description": "Second description"
                },
                "finalUrl": {
                  "type": "string",
                  "description": "Landing page URL"
                },
                "path1": {
                  "type": "string",
                  "description": "Display path 1"
                },
                "path2": {
                  "type": "string",
                  "description": "Display path 2"
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "Active",
                    "Paused",
                    "Deleted"
                  ]
                },
                "adType": {
                  "type": "string",
                  "description": "Ad type (TextAd, ResponsiveSearchAd, etc.)"
                }
              },
              "required": [
                "groupId",
                "headline",
                "finalUrl"
              ]
            }
          }
        },
        "required": [
          "clientId",
          "customerId",
          "userId",
          "data"
        ]
      }
    },
