            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Marin ad group ID"
                },
                "name": {
                  "type": "string",
                  "description": "Updated name"
                },
                "status": {
                  "type": "string",
