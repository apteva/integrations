        ]
      }
    },
    {
      "name": "marin_keywords_create",
      "description": "Create one or more keywords across connected search publishers (Google Ads, Microsoft Ads). Set match types, bids, and destination URLs.",
      "method": "POST",
      "path": "/open-api/0.1/bulk/keywords",
      "input_schema": {
        "type": "object",
        "properties": {
          "clientId": {
            "type": "string",
            "description": "Marin client ID"
          },
          "customerId": {
            "type": "string",
            "description": "Marin customer ID"
          },
          "userId": {
            "type": "string",
            "description": "Marin user ID"
          },
          "userCustomerId": {
            "type": "string",
            "description": "User customer ID"
          },
          "data": {
            "type": "array",
            "description": "Array of keyword objects to create",
            "items": {
              "type": "object",
              "properties": {
                "groupId": {
                  "type": "string",
                  "description": "Ad group ID"
                },
                "keyword": {
                  "type": "string",
                  "description": "Keyword text"
                },
                "matchType": {
                  "type": "string",
                  "description": "Match type",
                  "enum": [
                    "Broad",
                    "Phrase",
                    "Exact"
                  ]
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "Active",
                    "Paused",
                    "Deleted"
                  ]
                },
                "maxCpc": {
                  "type": "number",
                  "description": "Max CPC bid"
                },
                "destinationUrl": {
                  "type": "string",
                  "description": "Destination URL"
                }
              },
              "required": [
                "groupId",
                "keyword",
                "matchType"
              ]
            }
          }
        },
        "required": [
          "clientId",
          "customerId",
          "userId",
          "data"
        ]
      }
    },
    {
