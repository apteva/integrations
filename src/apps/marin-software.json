                },
                "minBid": {
                  "type": "number"
                },
                "maxBid": {
                  "type": "number"
                }
              }
            }
          }
        },
        "required": [
          "clientId",
          "customerId",
          "userId",
          "data"
        ]
      }
    },
    {
      "name": "marin_job_status",
      "description": "Check the status of a bulk operation job. Bulk creates and updates are processed asynchronously and return a job_id.",
      "method": "GET",
      "path": "/open-api/0.1/jobs/{job_id}/status",
      "input_schema": {
        "type": "object",
        "properties": {
          "job_id": {
            "type": "string",
            "description": "Job ID returned from a bulk operation"
          },
          "clientId": {
            "type": "string",
            "description": "Marin client ID"
          },
          "customerId": {
            "type": "string",
            "description": "Marin customer ID"
          },
          "userId": {
            "type": "string",
            "description": "Marin user ID"
          }
        },
        "required": [
          "job_id",
          "clientId"
        ]
      }
    },
    {
      "name": "marin_social_stats",
      "description": "Retrieve Meta/Facebook advertising statistics via the Marin Social API. Get advertiser data, campaign metrics, and media plan information.",
      "method": "GET",
      "path": "/social-api/v1/advertisers/{advertiserId}/stats",
      "input_schema": {
        "type": "object",
        "properties": {
          "advertiserId": {
            "type": "string",
            "description": "Marin advertiser ID for Meta"
          },
          "startDate": {
            "type": "string",
            "description": "Start date (YYYY-MM-DD)"
          },
          "endDate": {
            "type": "string",
            "description": "End date (YYYY-MM-DD)"
          },
          "metrics": {
            "type": "array",
            "description": "Metrics to retrieve: impressions, clicks, spend, conversions, ctr, cpc, cpm",
            "items": {
              "type": "string"
            },
            "default": [
              "impressions",
              "clicks",
              "spend",
              "conversions"
            ]
          },
          "level": {
            "type": "string",
            "description": "Aggregation level",
            "enum": [
              "campaign",
              "adgroup",
              "ad"
            ],
            "default": "campaign"
          }
        },
        "required": [
          "advertiserId",
          "startDate",
          "endDate"
        ]
      }
    }
  ]
}
