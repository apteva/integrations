{
  "slug": "marin-software",
  "name": "Marin Software",
  "description": "MCP server for Marin Software - cross-channel ad management platform. Single API to manage campaigns, ad groups, keywords, ads, and bidding strategies across Google, Meta, Amazon, Microsoft, and 12+ other publishers. Eliminates the need to integrate with each publisher API separately.",
  "logo": "https://www.google.com/s2/favicons?domain=marinsoftware.com&sz=128",
  "categories": [
    "advertising",
    "marketing",
    "campaigns",
    "cross-channel",
    "marin",
    "ppc",
    "bid-management"
  ],
  "base_url": "https://api.marinsoftware.com",
  "auth": {
    "types": [
      "bearer"
    ],
    "headers": {
      "Authorization": "Basic {{token}}"
    },
    "credential_fields": [
      {
        "name": "username",
        "label": "Username",
        "description": "Your Marin Software API username"
      },
      {
        "name": "password",
        "label": "Password",
        "description": "Your Marin Software API password"
      }
    ]
  },
  "tools": [
    {
      "name": "marin_campaigns_create",
      "description": "Create one or more campaigns across any connected publisher via the Marin bulk API. A single request can create campaigns across multiple publisher accounts. Supports Google Ads, Meta, Amazon, Microsoft Ads, and more.",
      "method": "POST",
      "path": "/open-api/0.1/bulk/campaigns",
      "input_schema": {
        "type": "object",
        "properties": {
          "clientId": {
            "type": "string",
            "description": "Marin client ID (found in M1 > Accounts > Publishers grid)"
          },
          "customerId": {
            "type": "string",
            "description": "Marin customer ID"
          },
          "userId": {
            "type": "string",
            "description": "Marin user ID"
          },
          "userCustomerId": {
            "type": "string",
            "description": "User customer ID"
          },
          "data": {
            "type": "array",
            "description": "Array of campaign objects to create. Each object contains field-value pairs like name, publisher, status, dailyBudget, startDate, endDate.",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Campaign name"
                },
                "publisher": {
                  "type": "string",
                  "description": "Publisher name (e.g., Google, Facebook, Amazon, Microsoft)"
                },
                "publisherAccountId": {
                  "type": "string",
                  "description": "Publisher account ID"
                },
                "status": {
                  "type": "string",
                  "description": "Campaign status",
                  "enum": [
                    "Active",
                    "Paused",
                    "Deleted"
                  ]
                },
                "dailyBudget": {
                  "type": "number",
                  "description": "Daily budget amount"
                },
                "startDate": {
                  "type": "string",
                  "description": "Start date (YYYY-MM-DD)"
                },
                "endDate": {
                  "type": "string",
                  "description": "End date (YYYY-MM-DD)"
                },
                "campaignType": {
                  "type": "string",
                  "description": "Campaign type (Search, Display, Shopping, Video, etc.)"
                }
              },
              "required": [
                "name",
                "publisher"
              ]
            }
          }
        },
        "required": [
          "clientId",
          "customerId",
          "userId",
          "data"
        ]
      }
    },
    {
      "name": "marin_campaigns_update",
      "description": "Edit one or more existing campaigns. Update name, status, budget, dates, or any campaign-level setting. Changes are pushed to the connected publisher accounts.",
      "method": "POST",
      "path": "/open-api/0.1/bulk/campaigns",
      "input_schema": {
        "type": "object",
        "properties": {
          "clientId": {
            "type": "string",
            "description": "Marin client ID"
          },
          "customerId": {
            "type": "string",
            "description": "Marin customer ID"
          },
          "userId": {
            "type": "string",
            "description": "Marin user ID"
          },
          "userCustomerId": {
            "type": "string",
            "description": "User customer ID"
          },
          "data": {
            "type": "array",
            "description": "Array of campaign updates. Each object must include the campaign identifier and fields to update.",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Marin campaign ID"
                },
                "publisherCampaignId": {
                  "type": "string",
                  "description": "Publisher campaign ID (alternative to Marin ID)"
                },
                "name": {
                  "type": "string",
                  "description": "Updated campaign name"
                },
                "status": {
                  "type": "string",
                  "description": "Updated status",
                  "enum": [
                    "Active",
                    "Paused",
                    "Deleted"
                  ]
                },
                "dailyBudget": {
                  "type": "number",
                  "description": "Updated daily budget"
                },
                "endDate": {
                  "type": "string",
                  "description": "Updated end date"
                }
              }
            }
          }
        },
        "required": [
          "clientId",
          "customerId",
          "userId",
          "data"
        ]
      }
    },
    {
      "name": "marin_groups_create",
      "description": "Create one or more ad groups across connected publishers. Set targeting, bids, and ad group settings.",
      "method": "POST",
      "path": "/open-api/0.1/bulk/groups",
      "input_schema": {
        "type": "object",
        "properties": {
          "clientId": {
            "type": "string",
            "description": "Marin client ID"
          },
          "customerId": {
            "type": "string",
            "description": "Marin customer ID"
          },
          "userId": {
            "type": "string",
            "description": "Marin user ID"
          },
          "userCustomerId": {
            "type": "string",
            "description": "User customer ID"
          },
          "data": {
            "type": "array",
            "description": "Array of ad group objects to create",
            "items": {
              "type": "object",
              "properties": {
                "campaignId": {
                  "type": "string",
                  "description": "Marin campaign ID or publisher campaign ID"
                },
                "name": {
                  "type": "string",
                  "description": "Ad group name"
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "Active",
                    "Paused",
                    "Deleted"
                  ]
                },
                "defaultBid": {
                  "type": "number",
                  "description": "Default bid amount"
                },
                "maxCpc": {
                  "type": "number",
                  "description": "Maximum CPC bid"
                }
              },
              "required": [
                "campaignId",
                "name"
              ]
            }
          }
        },
        "required": [
          "clientId",
          "customerId",
          "userId",
          "data"
        ]
      }
    },
