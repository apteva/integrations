    {
      "name": "create_ai_avatar",
      "description": "Create a single-avatar lip-sync video from text or an audio URL.",
      "method": "POST",
      "path": "/api/lipsyncs/",
      "input_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "audio": {
            "type": "string"
          },
          "creator": {
            "type": "string",
            "description": "Avatar/persona ID from list_avatars."
          },
          "accent": {
            "type": "string",
            "description": "Voice/accent ID from list_voices."
          },
          "model_version": {
            "type": "string",
            "enum": [
              "standard",
              "aurora_v1",
              "aurora_v1_fast"
            ]
          },
          "aspect_ratio": {
            "type": "string",
            "enum": [
              "16x9",
              "1x1",
              "9x16"
            ]
          },
          "green_screen": {
            "type": "boolean"
          },
          "transparent_background": {
            "type": "boolean"
          },
          "webhook_url": {
            "type": "string"
          }
        },
        "required": [
          "creator"
        ]
      }
    },
    {
      "name": "list_ai_avatar_videos",
