          "page": {
            "type": "integer"
          },
          "page_size": {
            "type": "integer"
          }
        }
      }
    },
    {
      "name": "clone_voice",
      "description": "Create a voice clone from audio/video file URLs.",
      "method": "POST",
    "path": "/api/voices/",
      "input_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "urls": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "language": {
            "type": "string"
          },
          "gender": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "urls"
        ]
      }
    },
    {
      "name": "delete_cloned_voice",
      "description": "Delete a cloned voice by ID.",
      "method": "DELETE",
    "path": "/api/voices/accents/{accent_id}/",
    "path_params": [
      "accent_id"
    ],
      "input_schema": {
        "type": "object",
        "properties": {
        "accent_id": {
          "type": "string"
        }
      },
      "required": [
        "accent_id"
      ]
    }
  },
    {
