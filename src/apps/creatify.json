{
  "slug": "creatify",
  "name": "Creatify",
  "description": "Creatify.ai API for URL-to-video ads, AI avatar/lip-sync videos, Aurora avatar videos, custom templates, product videos, scripts, voices, TTS, image ads, assets, and credits.",
  "logo": "https://www.google.com/s2/favicons?domain=creatify.ai&sz=128",
  "categories": [
    "ai",
    "video",
    "avatars",
    "ads",
    "generation",
    "ugc"
  ],
  "base_url": "https://api.creatify.ai",
  "auth": {
    "types": [
      "api_key"
    ],
    "headers": {
      "X-API-ID": "{{api_id}}",
      "X-API-KEY": "{{api_key}}",
      "Content-Type": "application/json",
      "Accept": "application/json"
    },
    "credential_fields": [
      {
        "name": "api_id",
        "label": "API ID",
        "type": "password",
        "description": "Creatify X-API-ID from the API credentials page."
      },
      {
        "name": "api_key",
        "label": "API Key",
        "type": "password",
        "description": "Creatify X-API-KEY from the API credentials page."
      }
    ]
  },
  "health_check": {
    "tool": "get_remaining_credits"
  },
  "tools": [
    {
      "name": "get_remaining_credits",
      "description": "Get remaining Creatify API credits for the workspace.",
      "method": "GET",
      "path": "/api/remaining_credits/",
      "input_schema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "list_avatars",
      "description": "List stock and available avatar/persona records.",
      "method": "GET",
      "path": "/api/personas/",
      "query_params": [
        "ids",
        "name",
        "gender",
        "age",
        "ethnicity",
        "page",
        "page_size"
      ],
      "input_schema": {
        "type": "object",
        "properties": {
          "ids": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "gender": {
            "type": "string"
          },
          "age": {
            "type": "string"
          },
          "ethnicity": {
            "type": "string"
          },
          "page": {
            "type": "integer"
          },
          "page_size": {
            "type": "integer"
          }
        }
      }
    },
    {
      "name": "get_avatar",
      "description": "Get one avatar/persona by ID.",
      "method": "GET",
      "path": "/api/personas/{id}/",
      "path_params": [
        "id"
      ],
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    {
      "name": "list_voices",
      "description": "List Creatify voices and accents.",
      "method": "GET",
      "path": "/api/voices/",
      "query_params": [
        "ids",
        "name",
        "language",
        "gender",
        "page",
        "page_size"
      ],
      "input_schema": {
        "type": "object",
        "properties": {
          "ids": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "gender": {
            "type": "string"
          },
          "page": {
            "type": "integer"
          },
          "page_size": {
            "type": "integer"
          }
        }
      }
    },
    {
      "name": "list_cloned_voices",
      "description": "List cloned voices.",
      "method": "GET",
      "path": "/api/voices/cloned/",
      "query_params": [
        "page",
        "page_size"
      ],
      "input_schema": {
        "type": "object",
