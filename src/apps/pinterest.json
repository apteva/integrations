{
  "slug": "pinterest",
  "name": "Pinterest",
  "description": "MCP server for Pinterest - boards, pins, user account, analytics",
  "logo": "https://www.google.com/s2/favicons?domain=pinterest.com&sz=128",
  "categories": ["social", "content", "marketing", "visual"],
  "base_url": "https://api.pinterest.com/v5",
  "auth": {
    "types": ["oauth2", "bearer"],
    "headers": { "Authorization": "Bearer {{token}}" },
    "credential_fields": [
      { "name": "token", "label": "OAuth Access Token" },
      { "name": "appId", "label": "App ID" },
      { "name": "appSecret", "label": "App Secret" }
    ]
  },
  "tools": [
    {
      "name": "list_boards",
      "description": "List boards owned by the authenticated user",
      "method": "GET",
      "path": "/boards",
      "input_schema": {
        "type": "object",
        "properties": {
          "bookmark": { "type": "string" },
          "page_size": { "type": "number" },
          "privacy": { "type": "string" }
        }
      },
      "mock_response": {
        "items": [
          {
            "id": "800000000000000001",
            "name": "Inspiration",
            "description": "Design ideas",
            "privacy": "PUBLIC",
            "pin_count": 42,
            "follower_count": 18,
            "created_at": "2025-04-01T00:00:00"
          }
        ],
        "bookmark": null
      }
    },
    {
      "name": "create_board",
      "description": "Create a board",
      "method": "POST",
      "path": "/boards",
      "input_schema": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "privacy": { "type": "string", "enum": ["PUBLIC", "SECRET"] }
        },
        "required": ["name"]
      },
      "mock_response": {
        "id": "800000000000000099",
        "name": "(board name)",
        "description": "",
        "privacy": "PUBLIC",
        "pin_count": 0,
        "follower_count": 0,
        "created_at": "2026-05-22T12:00:00"
      }
    },
    {
      "name": "get_board",
      "description": "Get a board",
      "method": "GET",
      "path": "/boards/{board_id}",
      "input_schema": {
        "type": "object",
        "properties": { "board_id": { "type": "string" } },
        "required": ["board_id"]
      },
      "mock_response": {
        "id": "800000000000000001",
        "name": "Inspiration",
        "description": "Design ideas",
        "privacy": "PUBLIC",
        "pin_count": 42,
        "follower_count": 18,
        "created_at": "2025-04-01T00:00:00"
      }
    },
    {
      "name": "list_pins",
      "description": "List pins",
      "method": "GET",
      "path": "/pins",
      "input_schema": {
        "type": "object",
        "properties": {
          "bookmark": { "type": "string" },
          "page_size": { "type": "number" }
        }
      },
      "mock_response": {
        "items": [
          {
            "id": "900000000000000001",
            "created_at": "2026-05-22T10:00:00",
            "link": "https://example.com/article",
            "title": "A great idea",
            "description": "",
            "board_id": "800000000000000001",
            "media": {
              "media_type": "image"
            }
          }
        ],
        "bookmark": null
      }
    },
    {
      "name": "create_pin",
      "description": "Create a pin",
      "method": "POST",
      "path": "/pins",
      "input_schema": {
        "type": "object",
        "properties": {
          "board_id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "link": { "type": "string" },
          "media_source": { "type": "object" },
          "alt_text": { "type": "string" }
        },
        "required": ["board_id", "media_source"]
      },
      "mock_response": {
        "id": "900000000000000099",
        "created_at": "2026-05-22T12:00:00",
        "link": "https://example.com/article",
        "title": "(pin title)",
        "description": "",
        "board_id": "800000000000000001",
        "board_owner": {
          "username": "apteva"
        },
        "media": {
          "media_type": "image"
        }
      }
    },
    {
      "name": "delete_pin",
      "description": "Delete a pin",
      "method": "DELETE",
      "path": "/pins/{pin_id}",
      "input_schema": {
        "type": "object",
        "properties": { "pin_id": { "type": "string" } },
        "required": ["pin_id"]
      },
      "mock_response": {
        "success": true
      }
    },
    {
      "name": "get_user_account",
      "description": "Get the authenticated user's account info",
      "method": "GET",
      "path": "/user_account",
      "input_schema": { "type": "object", "properties": {} },
      "mock_response": {
        "username": "apteva",
        "account_type": "BUSINESS",
        "profile_image": "https://i.pinimg.com/mock-profile.jpg",
        "website_url": "https://apteva.example",
        "board_count": 8,
        "pin_count": 124,
        "follower_count": 340,
        "following_count": 56
      }
    },
    {
      "name": "get_user_analytics",
      "description": "Get user account analytics",
      "method": "GET",
      "path": "/user_account/analytics",
      "input_schema": {
        "type": "object",
        "properties": {
          "start_date": { "type": "string" },
          "end_date": { "type": "string" },
          "metric_types": { "type": "array" }
        },
        "required": ["start_date", "end_date"]
      },
      "mock_response": {
        "all": {
          "daily_metrics": [
            {
              "date": "2026-05-22",
              "metrics": {
                "IMPRESSION": 1820,
                "PIN_CLICK": 94,
                "SAVE": 31
              }
            }
          ],
          "summary_metrics": {
            "IMPRESSION": 1820,
            "PIN_CLICK": 94,
            "SAVE": 31
          }
        }
      }
    }
  ]
}
