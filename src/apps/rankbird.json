{
  "slug": "rankbird",
  "name": "Rankbird",
  "description": "Rankbird SEO platform — keyword tracking, SERP rankings, backlinks, competitors, AI visibility (GEO), site audits, and reports.",
  "logo": "https://www.google.com/s2/favicons?domain=rankbird.co&sz=128",
  "categories": [
    "seo",
    "marketing",
    "analytics",
    "keywords",
    "rankings",
    "backlinks",
    "ai-visibility",
    "geo"
  ],
  "base_url": "https://api.rankbird.co",
  "auth": {
    "types": [
      "api_key"
    ],
    "headers": {
      "X-API-Key": "{{api_key}}"
    },
    "credential_fields": [
      {
        "name": "api_key",
        "label": "Api Key",
        "description": "Rankbird API key (e.g. okt_prod_...)"
      }
    ]
  },
  "tools": [
    {
      "name": "list_sites",
      "description": "List all SEO sites being tracked. Filter by project_id or status.",
      "method": "GET",
      "path": "/sites",
      "input_schema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Filter by status (active, paused, archived)"
          },
          "limit": {
            "type": "integer",
            "description": "Max results to return (default 50)"
          },
          "offset": {
            "type": "integer",
            "description": "Pagination offset"
          }
        }
      }
    },
    {
      "name": "get_site",
      "description": "Get details for a specific SEO site by ID.",
      "method": "GET",
      "path": "/sites/{id}",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Site ID"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    {
      "name": "create_site",
      "description": "Create a new SEO site to track.",
      "method": "POST",
      "path": "/sites",
      "input_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Site name"
          },
          "url": {
            "type": "string",
            "description": "Site URL (e.g. https://example.com)"
          }
        },
        "required": [
          "name",
          "url"
        ]
      }
    },
    {
      "name": "update_site",
      "description": "Update an existing SEO site.",
