                "delivered",
                "request",
                "click",
                "invalid",
                "deferred",
                "opened",
                "uniqueOpened",
                "unsubscribed",
                "listAddition",
                "contactUpdated",
                "contactDeleted"
              ]
            },
            "description": "Events to subscribe to"
          },
          "type": {
            "type": "string",
            "enum": [
              "transactional",
              "marketing",
              "inbound"
            ],
            "default": "transactional",
            "description": "Type of emails to monitor"
          }
        },
        "required": [
