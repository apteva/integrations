    {
      "name": "import_contacts",
      "description": "Import contacts from a list of emails with optional attributes",
      "method": "POST",
      "path": "/contacts/import",
      "input_schema": {
        "type": "object",
        "properties": {
          "listIds": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "List IDs to add contacts to"
          },
          "jsonBody": {
            "type": "array",
            "description": "Array of contact objects with email and attributes",
            "items": {
              "type": "object",
              "properties": {
                "email": {
                  "type": "string"
                },
                "attributes": {
                  "type": "object"
                }
              },
              "required": [
                "email"
              ]
            }
          },
          "updateExistingContacts": {
            "type": "boolean",
            "default": true,
            "description": "Update contacts if they already exist"
          },
          "emptyContactsAttributes": {
            "type": "boolean",
            "default": false,
            "description": "Clear attributes not in import"
          }
        },
        "required": [
          "listIds",
          "jsonBody"
        ]
      }
    },
    {
      "name": "get_folders",
      "description": "Get all contact list folders",
      "method": "GET",
      "path": "/contacts/folders",
      "input_schema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer",
            "default": 10,
            "description": "Number of folders to return"
          },
          "offset": {
            "type": "integer",
            "default": 0,
            "description": "Index of first folder"
