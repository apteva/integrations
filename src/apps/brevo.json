    {
      "name": "list_attributes",
      "description": "Get all contact attributes (fields) defined in your Brevo account. Attributes must exist before they can be used on contacts.",
      "method": "GET",
      "path": "/contacts/attributes",
      "input_schema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "create_attribute",
      "description": "Create a new contact attribute (field) definition. You must create an attribute before you can use it on contacts. Categories: normal (standard fields), transactional, category (enumerated values), calculated, global.",
      "method": "POST",
      "path": "/contacts/attributes/{attributeCategory}/{attributeName}",
      "input_schema": {
        "type": "object",
        "properties": {
          "attributeCategory": {
            "type": "string",
            "enum": [
              "normal",
              "transactional",
              "category",
              "calculated",
              "global"
            ],
            "description": "Category of the attribute (required)"
          },
          "attributeName": {
            "type": "string",
            "description": "Name of the attribute in UPPERCASE (required, e.g., FIRSTNAME, COMPANY)"
          },
          "type": {
            "type": "string",
            "enum": [
              "text",
              "date",
              "float",
              "boolean",
              "id",
              "category"
            ],
            "description": "Type of the attribute (for normal/category/transactional)"
          },
          "value": {
            "type": "string",
            "description": "Value formula (for calculated/global attributes)"
          },
          "enumeration": {
            "type": "array",
            "description": "List of values for category attributes, e.g., [{\"value\":1,\"label\":\"Male\"},{\"value\":2,\"label\":\"Female\"}]",
            "items": {
              "type": "object",
              "properties": {
                "value": {
                  "type": "integer"
                },
                "label": {
                  "type": "string"
                }
              }
            }
          }
        },
        "required": [
          "attributeCategory",
          "attributeName"
        ]
      }
    },
    {
      "name": "update_attribute",
      "description": "Update an existing contact attribute definition. Used to modify enumeration values for category attributes or formulas for calculated attributes.",
      "method": "PUT",
      "path": "/contacts/attributes/{attributeCategory}/{attributeName}",
      "input_schema": {
        "type": "object",
        "properties": {
          "attributeCategory": {
            "type": "string",
            "enum": [
              "normal",
              "category",
              "calculated",
              "global"
            ],
            "description": "Category of the attribute (required)"
          },
          "attributeName": {
            "type": "string",
            "description": "Name of the existing attribute (required)"
          },
          "value": {
            "type": "string",
            "description": "New value formula (for calculated/global attributes)"
          },
          "enumeration": {
            "type": "array",
            "description": "Updated list of values for category attributes",
            "items": {
              "type": "object",
              "properties": {
                "value": {
                  "type": "integer"
                },
                "label": {
                  "type": "string"
                }
              }
            }
          }
        },
        "required": [
          "attributeCategory",
          "attributeName"
        ]
      }
    },
    {
      "name": "delete_attribute",
      "description": "Delete a contact attribute definition. Warning: This removes the attribute from all contacts.",
      "method": "DELETE",
      "path": "/contacts/attributes/{attributeCategory}/{attributeName}",
      "input_schema": {
        "type": "object",
        "properties": {
          "attributeCategory": {
            "type": "string",
            "enum": [
              "normal",
              "transactional",
              "category",
              "calculated",
              "global"
            ],
            "description": "Category of the attribute (required)"
          },
          "attributeName": {
            "type": "string",
            "description": "Name of the attribute to delete (required)"
          }
        },
        "required": [
          "attributeCategory",
          "attributeName"
        ]
      }
    },
    {
      "name": "get_list",
