{
  "slug": "mailerlite",
  "name": "MailerLite",
  "description": "MailerLite API for subscribers, groups, segments, fields, automations, campaigns, forms, webhooks, and campaign reports.",
  "logo": "https://www.google.com/s2/favicons?domain=mailerlite.com&sz=128",
  "categories": ["email", "newsletter", "marketing", "automation", "subscribers"],
  "base_url": "https://connect.mailerlite.com/api",
  "auth": { "types": ["bearer"], "headers": { "Authorization": "Bearer {{token}}", "Accept": "application/json", "Content-Type": "application/json" }, "credential_fields": [{ "name": "token", "label": "API Token", "description": "MailerLite API token." }] },
  "health_check": { "tool": "list_subscribers", "input": { "limit": 1 } },
  "tools": [
    { "name": "list_subscribers", "description": "List subscribers.", "method": "GET", "path": "/subscribers", "query_params": ["filter[status]", "filter[search]", "limit", "page"], "input_schema": { "type": "object", "properties": { "filter[status]": { "type": "string" }, "filter[search]": { "type": "string" }, "limit": { "type": "integer" }, "page": { "type": "integer" } } } },
    { "name": "create_subscriber", "description": "Create or update a subscriber.", "method": "POST", "path": "/subscribers", "input_schema": { "type": "object", "properties": { "email": { "type": "string" }, "fields": { "type": "object", "additionalProperties": true }, "groups": { "type": "array", "items": { "type": "string" } }, "status": { "type": "string" }, "subscribed_at": { "type": "string" }, "ip_address": { "type": "string" }, "opted_in_at": { "type": "string" }, "optin_ip": { "type": "string" } }, "required": ["email"] } },
    { "name": "get_subscriber", "description": "Get one subscriber.", "method": "GET", "path": "/subscribers/{subscriber_id}", "input_schema": { "type": "object", "properties": { "subscriber_id": { "type": "string" } }, "required": ["subscriber_id"] } },
    { "name": "update_subscriber", "description": "Update a subscriber.", "method": "PUT", "path": "/subscribers/{subscriber_id}", "input_schema": { "type": "object", "properties": { "subscriber_id": { "type": "string" }, "email": { "type": "string" }, "fields": { "type": "object", "additionalProperties": true }, "groups": { "type": "array", "items": { "type": "string" } }, "status": { "type": "string" } }, "required": ["subscriber_id"] } },
    { "name": "delete_subscriber", "description": "Delete a subscriber.", "method": "DELETE", "path": "/subscribers/{subscriber_id}", "input_schema": { "type": "object", "properties": { "subscriber_id": { "type": "string" } }, "required": ["subscriber_id"] } },
    { "name": "forget_subscriber", "description": "Forget a subscriber for GDPR deletion.", "method": "POST", "path": "/subscribers/{subscriber_id}/forget", "input_schema": { "type": "object", "properties": { "subscriber_id": { "type": "string" } }, "required": ["subscriber_id"] } },
    { "name": "list_groups", "description": "List groups.", "method": "GET", "path": "/groups", "query_params": ["limit", "page"], "input_schema": { "type": "object", "properties": { "limit": { "type": "integer" }, "page": { "type": "integer" } } } },
    { "name": "create_group", "description": "Create a group.", "method": "POST", "path": "/groups", "input_schema": { "type": "object", "properties": { "name": { "type": "string" } }, "required": ["name"] } },
    { "name": "assign_subscriber_to_group", "description": "Assign subscriber to group.", "method": "POST", "path": "/subscribers/{subscriber_id}/groups/{group_id}", "input_schema": { "type": "object", "properties": { "subscriber_id": { "type": "string" }, "group_id": { "type": "string" } }, "required": ["subscriber_id", "group_id"] } },
    { "name": "unassign_subscriber_from_group", "description": "Remove subscriber from group.", "method": "DELETE", "path": "/subscribers/{subscriber_id}/groups/{group_id}", "input_schema": { "type": "object", "properties": { "subscriber_id": { "type": "string" }, "group_id": { "type": "string" } }, "required": ["subscriber_id", "group_id"] } },
    { "name": "list_segments", "description": "List segments.", "method": "GET", "path": "/segments", "query_params": ["limit", "page"], "input_schema": { "type": "object", "properties": { "limit": { "type": "integer" }, "page": { "type": "integer" } } } },
    { "name": "list_fields", "description": "List subscriber fields.", "method": "GET", "path": "/fields", "input_schema": { "type": "object", "properties": {} } },
    { "name": "create_field", "description": "Create a subscriber field.", "method": "POST", "path": "/fields", "input_schema": { "type": "object", "properties": { "name": { "type": "string" }, "type": { "type": "string" } }, "required": ["name", "type"] } },
    { "name": "list_campaigns", "description": "List campaigns.", "method": "GET", "path": "/campaigns", "query_params": ["filter[status]", "filter[type]", "limit", "page"], "input_schema": { "type": "object", "properties": { "filter[status]": { "type": "string" }, "filter[type]": { "type": "string" }, "limit": { "type": "integer" }, "page": { "type": "integer" } } } },
    { "name": "create_campaign", "description": "Create a campaign.", "method": "POST", "path": "/campaigns", "input_schema": { "type": "object", "properties": { "name": { "type": "string" }, "type": { "type": "string" }, "emails": { "type": "array", "items": { "type": "object" } }, "groups": { "type": "array", "items": { "type": "string" } }, "segments": { "type": "array", "items": { "type": "string" } }, "settings": { "type": "object" } }, "required": ["name", "type"] } },
    { "name": "get_campaign", "description": "Get one campaign.", "method": "GET", "path": "/campaigns/{campaign_id}", "input_schema": { "type": "object", "properties": { "campaign_id": { "type": "string" } }, "required": ["campaign_id"] } },
    { "name": "update_campaign", "description": "Update a campaign.", "method": "PUT", "path": "/campaigns/{campaign_id}", "input_schema": { "type": "object", "properties": { "campaign_id": { "type": "string" }, "name": { "type": "string" }, "emails": { "type": "array", "items": { "type": "object" } }, "groups": { "type": "array", "items": { "type": "string" } }, "segments": { "type": "array", "items": { "type": "string" } }, "settings": { "type": "object" } }, "required": ["campaign_id"] } },
    { "name": "send_campaign", "description": "Send a campaign.", "method": "POST", "path": "/campaigns/{campaign_id}/actions/send", "input_schema": { "type": "object", "properties": { "campaign_id": { "type": "string" } }, "required": ["campaign_id"] } },
    { "name": "schedule_campaign", "description": "Schedule a campaign.", "method": "POST", "path": "/campaigns/{campaign_id}/actions/schedule", "input_schema": { "type": "object", "properties": { "campaign_id": { "type": "string" }, "delivery": { "type": "string" }, "schedule": { "type": "object" } }, "required": ["campaign_id"] } },
    { "name": "get_campaign_report", "description": "Get campaign report.", "method": "GET", "path": "/campaigns/{campaign_id}/reports", "input_schema": { "type": "object", "properties": { "campaign_id": { "type": "string" } }, "required": ["campaign_id"] } },
    { "name": "list_forms", "description": "List forms.", "method": "GET", "path": "/forms", "query_params": ["limit", "page"], "input_schema": { "type": "object", "properties": { "limit": { "type": "integer" }, "page": { "type": "integer" } } } },
    { "name": "list_automations", "description": "List automations.", "method": "GET", "path": "/automations", "query_params": ["limit", "page"], "input_schema": { "type": "object", "properties": { "limit": { "type": "integer" }, "page": { "type": "integer" } } } },
    { "name": "list_webhooks", "description": "List webhooks.", "method": "GET", "path": "/webhooks", "input_schema": { "type": "object", "properties": {} } },
    { "name": "create_webhook", "description": "Create a webhook.", "method": "POST", "path": "/webhooks", "input_schema": { "type": "object", "properties": { "name": { "type": "string" }, "events": { "type": "array", "items": { "type": "string" } }, "url": { "type": "string" } }, "required": ["name", "events", "url"] } },
    { "name": "delete_webhook", "description": "Delete a webhook.", "method": "DELETE", "path": "/webhooks/{webhook_id}", "input_schema": { "type": "object", "properties": { "webhook_id": { "type": "string" } }, "required": ["webhook_id"] } }
  ]
}
