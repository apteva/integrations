      "path": "/translations",
      "query_params": [
        "groupId",
        "limit",
        "token"
      ],
      "input_schema": {
        "type": "object",
        "properties": {
          "groupId": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          },
          "token": {
            "type": "string"
          }
        }
      }
    },
    {
      "name": "delete_video_translation",
      "description": "Delete a video translation by ID.",
      "method": "DELETE",
      "path": "/translations/{id}",
      "path_params": [
        "id"
      ],
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          }
        },
        "required": [
