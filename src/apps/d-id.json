        ]
      }
    },
    {
      "name": "list_voices",
      "description": "List D-ID TTS voices, optionally filtered by provider or voice id.",
      "method": "GET",
      "path": "/tts/voices",
      "query_params": [
        "provider",
        "id"
      ],
      "input_schema": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string"
          },
          "id": {
            "type": "string"
          }
        }
      }
    },
    {
      "name": "get_credits",
      "description": "Get remaining D-ID credits for the authenticated account.",
      "method": "GET",
      "path": "/credits",
      "input_schema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "create_express_avatar",
      "description": "Create an Express Avatar from a scene/avatar request.",
      "method": "POST",
      "path": "/scenes/avatars",
      "input_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "source_url": {
            "type": "string"
          },
          "image_url": {
            "type": "string"
          },
          "consent": {
            "type": "object"
          },
          "config": {
            "type": "object"
          },
          "webhook": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      }
    },
    {
      "name": "list_scene_avatars",
      "description": "List scene/Express avatars.",
      "method": "GET",
      "path": "/scenes/avatars",
      "query_params": [
        "limit",
