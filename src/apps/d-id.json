      ],
      "input_schema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          },
          "token": {
            "type": "string"
          }
        }
      }
    },
    {
      "name": "list_scenes",
      "description": "List D-ID scenes.",
      "method": "GET",
      "path": "/scenes",
      "query_params": [
        "limit",
        "token"
      ],
      "input_schema": {
        "type": "object",
