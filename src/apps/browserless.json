{
  "slug": "browserless",
  "name": "Browserless",
  "description": "Managed or self-hosted browser infrastructure with REST rendering, BrowserQL, persistent sessions, authenticated profiles, stealth, proxies, replay, and CDP handoff. Set the endpoint to a Browserless cloud region or your own Browserless deployment.",
  "logo": "https://www.google.com/s2/favicons?domain=browserless.io&sz=128",
  "categories": ["browser", "screenshots", "rendering", "automation", "pdf", "scraping"],
  "base_url": "{{credential.endpoint}}",
  "auth": {
    "types": ["api_key"],
    "headers": {
      "Content-Type": "application/json"
    },
    "query_params": {
      "token": "{{api_key}}"
    },
    "credential_fields": [
      { "name": "api_key", "label": "Browserless API token" },
      {
        "name": "endpoint",
        "label": "Browserless Endpoint",
        "description": "Full HTTPS endpoint without a trailing slash. Cloud examples: https://production-sfo.browserless.io, https://production-lon.browserless.io, or https://production-ams.browserless.io. Self-hosted deployments may use their own URL.",
        "type": "text"
      }
    ]
  },
  "tools": [
    {
      "name": "screenshot",
      "description": "Take a screenshot of a URL. POST body is a Puppeteer-shaped options object — { url, options: { fullPage, type, quality, omitBackground, clip }, gotoOptions: { waitUntil, timeout } }. Returns the binary image directly.",
      "method": "POST",
      "path": "/screenshot",
      "input_schema": {
        "type": "object",
        "properties": {
          "url": { "type": "string", "description": "The URL to screenshot" },
          "html": { "type": "string", "description": "Render raw HTML instead (mutually exclusive with url)" },
          "options": {
            "type": "object",
            "description": "Puppeteer screenshot options",
            "properties": {
              "fullPage": { "type": "boolean", "default": false },
              "type": { "type": "string", "enum": ["png", "jpeg", "webp"], "default": "png" },
              "quality": { "type": "integer", "minimum": 0, "maximum": 100 },
              "omitBackground": { "type": "boolean", "default": false },
              "clip": {
                "type": "object",
                "properties": {
                  "x": { "type": "integer" },
                  "y": { "type": "integer" },
                  "width": { "type": "integer" },
                  "height": { "type": "integer" }
                }
              }
            }
          },
          "viewport": {
            "type": "object",
            "properties": {
              "width": { "type": "integer", "default": 1280 },
              "height": { "type": "integer", "default": 720 },
              "deviceScaleFactor": { "type": "number", "default": 1 },
              "isMobile": { "type": "boolean", "default": false }
            }
          },
          "gotoOptions": {
            "type": "object",
            "properties": {
              "waitUntil": {
                "type": "string",
                "enum": ["load", "domcontentloaded", "networkidle0", "networkidle2"],
                "default": "networkidle2"
              },
              "timeout": { "type": "integer", "default": 30000 }
            }
          },
          "waitFor": { "type": ["string", "integer"], "description": "CSS selector to wait for, or ms to wait" },
          "addStyleTag": { "type": "array", "items": { "type": "object" }, "description": "CSS to inject before capture" },
          "addScriptTag": { "type": "array", "items": { "type": "object" }, "description": "JS to inject before capture" },
          "rejectResourceTypes": { "type": "array", "items": { "type": "string" }, "description": "Block resource types: image, stylesheet, font, media, etc." },
          "userAgent": { "type": "string" },
          "cookies": { "type": "array", "items": { "type": "object" } },
          "authenticate": { "type": "object", "description": "{ username, password } for HTTP Basic auth on the target site" }
        },
        "required": ["url"]
      }
    },
    {
      "name": "pdf",
      "description": "Generate a PDF from a URL or HTML. Same options shape as screenshot, plus PDF-specific options.",
      "method": "POST",
      "path": "/pdf",
      "input_schema": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "html": { "type": "string" },
          "options": {
            "type": "object",
            "properties": {
              "format": { "type": "string", "enum": ["Letter", "Legal", "Tabloid", "Ledger", "A0", "A1", "A2", "A3", "A4", "A5", "A6"], "default": "A4" },
              "landscape": { "type": "boolean", "default": false },
              "printBackground": { "type": "boolean", "default": false },
              "displayHeaderFooter": { "type": "boolean", "default": false },
              "headerTemplate": { "type": "string" },
              "footerTemplate": { "type": "string" },
              "scale": { "type": "number", "default": 1 },
              "margin": { "type": "object" }
            }
          },
          "gotoOptions": { "type": "object" }
        },
        "required": ["url"]
      }
    },
    {
      "name": "content",
      "description": "Get the rendered HTML of a URL after JavaScript execution. Like a curl that runs JS first.",
      "method": "POST",
      "path": "/content",
      "input_schema": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "gotoOptions": { "type": "object" },
          "waitFor": { "type": ["string", "integer"] }
        },
        "required": ["url"]
      }
    },
    {
      "name": "function",
      "description": "Execute arbitrary Puppeteer code against a fresh browser instance. Send `{ code: 'module.exports = async ({ page, context }) => { ... return data; }' }` and the return value comes back as the response body. Powerful but slow.",
      "method": "POST",
      "path": "/function",
      "input_schema": {
        "type": "object",
        "properties": {
          "code": { "type": "string", "description": "Puppeteer function source — must export an async ({page, context}) => any" },
          "context": { "type": "object", "description": "Variables passed into the function" }
        },
        "required": ["code"]
      }
    },
    {
      "name": "scrape",
      "description": "Extract structured data from a page using a list of element selectors. Returns one entry per selector with text, attributes, and HTML.",
      "method": "POST",
      "path": "/scrape",
      "input_schema": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "elements": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "selector": { "type": "string" },
                "timeout": { "type": "integer" }
              }
            }
          },
          "gotoOptions": { "type": "object" }
        },
        "required": ["url", "elements"]
      }
    },
    {
      "name": "smart_scrape",
      "description": "Intelligently scrape a URL using Browserless cascading strategies: fast HTTP fetch, proxy, headless browser, and CAPTCHA solving as needed. Returns JSON with requested outputs such as HTML, markdown, links, screenshots, or PDFs.",
      "method": "POST",
      "path": "/smart-scrape",
      "input_schema": {
        "type": "object",
        "properties": {
          "url": { "type": "string", "description": "Target URL" },
          "formats": { "type": "array", "items": { "type": "string" }, "description": "Outputs to return, e.g. html, markdown, links, screenshot, pdf" },
          "waitFor": { "type": ["string", "integer"], "description": "Selector or milliseconds to wait" },
          "proxy": { "type": "object", "description": "Optional proxy configuration" },
          "timeout": { "type": "integer", "description": "Request timeout in milliseconds" }
        },
        "required": ["url"]
      }
    },
    {
      "name": "unblock",
      "description": "Bypass bot detection for a URL and return content, cookies, screenshots, or a browserWSEndpoint for custom automation. Best with Browserless residential proxies.",
      "method": "POST",
      "path": "/unblock",
      "timeout_ms": 305000,
      "input_schema": {
        "type": "object",
        "properties": {
          "url": { "type": "string", "description": "Target URL" },
          "browserWSEndpoint": { "type": "boolean", "description": "Return a WebSocket endpoint for handoff to Puppeteer/Playwright" },
          "cookies": { "type": "boolean", "description": "Return cookies" },
          "content": { "type": "boolean", "description": "Return page content" },
          "screenshot": { "type": "boolean", "description": "Return a screenshot" },
          "ttl": { "type": "integer", "description": "Browser lifetime in milliseconds" }
        },
        "required": ["url"]
      }
    },
    {
      "name": "search",
      "description": "Search the web through Browserless and return structured results for discovery before scraping.",
      "method": "POST",
      "path": "/search",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": { "type": "string" },
          "limit": { "type": "integer" },
          "country": { "type": "string" },
          "language": { "type": "string" }
        },
        "required": ["query"]
      }
    },
    {
      "name": "map",
      "description": "Discover URLs on a website through Browserless without scraping every page.",
      "method": "POST",
      "path": "/map",
      "input_schema": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "limit": { "type": "integer" },
          "includeSubdomains": { "type": "boolean" },
          "sitemap": { "type": "string" }
        },
        "required": ["url"]
      }
    },
    {
      "name": "crawl",
      "description": "Start an asynchronous Browserless crawl that maps and scrapes a site into structured output.",
      "method": "POST",
      "path": "/crawl",
      "timeout_ms": 65000,
      "input_schema": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "limit": { "type": "integer" },
          "formats": { "type": "array", "items": { "type": "string" } },
          "maxDepth": { "type": "integer" },
          "includePaths": { "type": "array", "items": { "type": "string" } },
          "excludePaths": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["url"]
      }
    },
    {
      "name": "bql",
      "description": "Run a BrowserQL GraphQL query against Browserless Chromium. Use for stealth browser automation, CAPTCHA solving, navigation, interaction, and extraction workflows that are too complex for REST scrape endpoints.",
      "method": "POST",
      "path": "/chromium/bql",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": { "type": "string", "description": "GraphQL BrowserQL query or mutation" },
          "variables": { "type": "object", "description": "GraphQL variables" }
        },
        "required": ["query"]
      }
    },
    {
      "name": "stats",
      "description": "Get account / session stats — credits used, concurrency, queue depth.",
      "method": "GET",
      "path": "/stats",
      "input_schema": { "type": "object", "properties": {} }
    },
    {
      "name": "service_status",
      "description": "Check whether the configured Browserless deployment is active. Returns HTTP 204 when healthy.",
      "method": "GET",
      "path": "/active",
      "input_schema": { "type": "object", "properties": {} }
    },
    {
      "name": "get_service_metadata",
      "description": "Get Browserless deployment metadata, including the current core API and browser versions.",
      "method": "GET",
      "path": "/meta",
      "input_schema": { "type": "object", "properties": {} }
    },
    {
      "name": "create_session",
      "description": "Create a persistent browser session. Returns id, connect (CDP WebSocket URL), stop URL, and BrowserQL URL. Use connect with a CDP client. Session replay is opt-in and defaults to false.",
      "method": "POST",
      "path": "/session",
      "input_schema": {
        "type": "object",
        "properties": {
          "ttl": { "type": "integer", "minimum": 1, "description": "Required session lifetime in milliseconds." },
          "processKeepAlive": { "type": "integer", "minimum": 0, "default": 0, "description": "Milliseconds to keep the browser process alive after disconnect for fast reconnection." },
          "browser": { "type": "string", "enum": ["chrome", "chromium", "stealth"], "default": "chromium" },
          "stealth": { "type": "boolean", "default": false },
          "headless": { "type": "boolean", "default": true },
          "blockAds": { "type": "boolean", "default": false },
          "blockAdsInclude": { "type": "string", "description": "Optional comma-separated uBlock ruleset IDs." },
          "args": { "type": "array", "items": { "type": "string" }, "description": "Browser command-line arguments." },
          "url": { "type": "string", "format": "uri", "description": "Optional initial target URL." },
          "proxy": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["datacenter", "residential"] },
              "sticky": { "type": "boolean", "default": true },
              "country": { "type": "string" },
              "state": { "type": "string" },
              "city": { "type": "string" },
              "preset": { "type": "string" }
            }
          },
          "replay": { "type": "boolean", "default": false, "description": "Enable rrweb session replay. Disabled unless explicitly true." },
          "extensions": { "type": "array", "items": { "type": "string" }, "description": "Previously uploaded extension IDs." },
          "profile": { "type": "string", "description": "Authenticated profile name to restore." },
          "integrationId": { "type": "string", "description": "Optional Browserless 1Password integration ID." },
          "credentials": { "type": "object", "description": "Alias to op:// reference map for the selected 1Password integration." },
          "allowedDomains": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["ttl"]
      }
    },
    {
      "name": "run_session_bql",
      "description": "Execute a BrowserQL query against an existing persistent session. BrowserQL session execution is available for stealth sessions.",
      "method": "POST",
      "path": "/session/bql/{session_id}",
      "input_schema": {
        "type": "object",
        "properties": {
          "session_id": { "type": "string" },
          "query": { "type": "string", "description": "BrowserQL GraphQL query or mutation." },
          "variables": { "type": "object" }
        },
        "required": ["session_id", "query"]
      }
    },
    {
      "name": "delete_session",
      "description": "Stop and permanently delete a persistent Browserless session and its stored data.",
      "method": "DELETE",
      "path": "/session/{session_id}",
      "query_params": ["force"],
      "input_schema": {
        "type": "object",
        "properties": {
          "session_id": { "type": "string" },
          "force": { "type": "boolean", "description": "Force termination when a client remains connected." }
        },
        "required": ["session_id"]
      }
    },
    {
      "name": "create_profile_session",
      "description": "Launch a temporary browser used to author an authenticated profile. Connect using the returned WebSocket, log in, call Browserless.saveProfile over CDP, then disconnect. The profile is not saved automatically.",
      "method": "POST",
      "path": "/profile",
      "input_schema": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Unique profile name." },
          "browser": { "type": "string", "enum": ["chrome", "chromium", "stealth"], "default": "stealth" },
          "stealth": { "type": "boolean", "default": false },
          "args": { "type": "array", "items": { "type": "string" } },
          "proxy": { "type": "object", "description": "Browserless proxy configuration with type, sticky, country, state, city, or preset." },
          "integrationId": { "type": "string" },
          "credentials": { "type": "object" },
          "allowedDomains": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["name"]
      }
    },
    {
      "name": "list_profiles",
      "description": "List authenticated profiles owned by the current Browserless token.",
      "method": "GET",
      "path": "/profiles",
      "query_params": ["limit", "offset"],
      "input_schema": {
        "type": "object",
        "properties": {
          "limit": { "type": "integer", "minimum": 1, "maximum": 1000, "default": 100 },
          "offset": { "type": "integer", "minimum": 0, "default": 0 }
        }
      }
    },
    {
      "name": "get_profile",
      "description": "Get metadata for one authenticated profile, including cookie/origin counts and timestamps. Does not return secret browser state.",
      "method": "GET",
      "path": "/profile/{name}",
      "input_schema": { "type": "object", "properties": { "name": { "type": "string" } }, "required": ["name"] }
    },
    {
      "name": "rename_profile",
      "description": "Rename an authenticated profile.",
      "method": "PUT",
      "path": "/profile/{current_name}",
      "input_schema": {
        "type": "object",
        "properties": {
          "current_name": { "type": "string" },
          "name": { "type": "string", "description": "New unique profile name." }
        },
        "required": ["current_name", "name"]
      }
    },
    {
      "name": "delete_profile",
      "description": "Delete an authenticated profile and its captured browser state.",
      "method": "DELETE",
      "path": "/profile/{name}",
      "input_schema": { "type": "object", "properties": { "name": { "type": "string" } }, "required": ["name"] }
    },
    {
      "name": "upload_profile",
      "description": "Create an authenticated profile from a previously captured Browserless state object containing cookies and per-origin storage.",
      "method": "POST",
      "path": "/profile/upload",
      "input_schema": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "state": { "type": "object", "description": "Captured state with cookies and origins arrays." }
        },
        "required": ["name", "state"]
      }
    }
  ],
  "health_check": { "tool": "service_status", "expect_status": [204] }
}
