{
  "slug": "duffel",
  "name": "Duffel",
  "description": "MCP server for Duffel travel API - flights, booking, ancillaries",
  "logo": "https://www.google.com/s2/favicons?domain=duffel.com&sz=128",
  "categories": [
    "travel",
    "flights",
    "booking",
    "airlines"
  ],
  "base_url": "https://api.duffel.com",
  "auth": {
    "types": [
      "bearer"
    ],
    "headers": {
      "Authorization": "Bearer {{token}}",
      "Duffel-Version": "v2"
    },
    "credential_fields": [
      {
        "name": "token",
        "label": "Api Key",
        "description": "Your Duffel API Key (test_ or live_)"
      }
    ]
  },
  "tools": [
    {
      "name": "search_flights",
      "description": "Create a Duffel offer request and return matching flight offers. Send body as { data: { slices, passengers, cabin_class?, max_connections? } }. Query options: return_offers, supplier_timeout, view.",
      "method": "POST",
      "path": "/air/offer_requests",
      "query_params": [
        "return_offers",
        "supplier_timeout",
        "view"
      ],
      "input_schema": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "description": "Duffel offer request body, containing slices, passengers, optional cabin_class, and optional max_connections. Use max_connections=0 for direct flights only.",
            "properties": {
              "slices": {
                "type": "array",
                "description": "Flight slices with origin, destination, departure_date"
              },
              "passengers": {
                "type": "array",
                "description": "Passenger types"
              },
              "cabin_class": {
                "type": "string",
                "enum": [
                  "economy",
                  "premium_economy",
                  "business",
                  "first"
                ]
              },
              "max_connections": {
                "type": "integer",
                "description": "Maximum connections per slice. 0 means direct flights only; 1 allows one connection."
              }
            },
            "required": [
              "slices",
              "passengers"
            ]
          },
          "return_offers": {
            "type": "boolean",
            "description": "Return offers in the offer request response. Defaults to true."
          },
          "supplier_timeout": {
            "type": "integer",
            "description": "Maximum supplier search wait in milliseconds. Duffel accepts 2000-60000."
          },
          "view": {
            "type": "string",
            "enum": [
              "offers",
              "itineraries"
            ]
          }
        },
        "required": [
          "data"
        ]
      }
    },
    {
      "name": "get_offer",
      "description": "Get a single offer, optionally including available services.",
      "method": "GET",
      "path": "/air/offers/{offer_id}",
      "query_params": [
        "return_available_services"
      ],
      "input_schema": {
        "type": "object",
        "properties": {
          "offer_id": {
            "type": "string"
          },
          "return_available_services": {
            "type": "boolean"
          }
        },
        "required": [
          "offer_id"
        ]
      }
    },
    {
      "name": "create_order",
      "description": "Create a Duffel order. Send body as { data: { selected_offers, passengers, payments?, type? } }.",
      "method": "POST",
      "path": "/air/orders",
      "input_schema": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "selected_offers": {
                "type": "array",
                "description": "Offer IDs to book."
              },
              "passengers": {
                "type": "array"
              },
              "payments": {
                "type": "array"
              },
              "type": {
                "type": "string",
                "enum": [
                  "instant",
                  "hold"
                ]
              },
              "services": {
                "type": "array"
              }
            },
            "required": [
              "selected_offers",
              "passengers"
            ]
          }
        },
        "required": [
          "data"
        ]
      }
    },
    {
      "name": "get_order",
      "description": "Get order details",
      "method": "GET",
      "path": "/air/orders/{order_id}",
      "input_schema": {
        "type": "object",
        "properties": {
          "order_id": {
            "type": "string"
          }
        },
        "required": [
          "order_id"
        ]
      }
    },
    {
      "name": "list_orders",
      "description": "List all orders",
      "method": "GET",
      "path": "/air/orders",
      "query_params": [
        "limit",
        "after",
        "before",
        "booking_reference",
        "offer_id",
        "awaiting_payment",
        "sort"
      ],
      "input_schema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "number"
          },
          "after": {
            "type": "string"
          },
          "before": {
            "type": "string"
          },
          "booking_reference": {
            "type": "string"
          },
          "offer_id": {
            "type": "string"
          },
          "awaiting_payment": {
            "type": "boolean"
          },
          "sort": {
            "type": "string"
          }
        }
      }
    },
    {
      "name": "cancel_order",
      "description": "Cancel an order",
      "method": "POST",
      "path": "/air/orders/{order_id}/actions/cancel",
      "input_schema": {
        "type": "object",
        "properties": {
          "order_id": {
            "type": "string"
          }
        },
        "required": [
          "order_id"
        ]
      }
    },
    {
      "name": "get_seat_maps",
      "description": "Get available seat maps",
      "method": "GET",
      "path": "/air/seat_maps",
      "query_params": [
        "offer_id"
      ],
      "input_schema": {
        "type": "object",
        "properties": {
          "offer_id": {
            "type": "string"
          }
        },
        "required": [
          "offer_id"
        ]
      }
    },
    {
      "name": "add_services",
      "description": "Add selected services such as seats or bags to an existing order.",
      "method": "POST",
      "path": "/air/orders/{order_id}/services",
      "input_schema": {
        "type": "object",
        "properties": {
          "order_id": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "add_services": {
                "type": "array"
              },
              "payment": {
                "type": "object"
              }
            },
            "required": [
              "add_services"
            ]
          }
        },
        "required": [
          "order_id",
          "data"
        ]
      }
    },
    {
      "name": "search_airports",
      "description": "List Duffel airports. Filter with iata_code or iata_country_code when available.",
      "method": "GET",
      "path": "/air/airports",
      "query_params": [
        "limit",
        "after",
        "before",
        "iata_code",
        "iata_country_code"
      ],
      "input_schema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "number"
          },
          "after": {
            "type": "string"
          },
          "before": {
            "type": "string"
          },
          "iata_code": {
            "type": "string"
          },
          "iata_country_code": {
            "type": "string"
          }
        }
      }
    },
    {
      "name": "search_airlines",
      "description": "List Duffel airlines.",
      "method": "GET",
      "path": "/air/airlines",
      "query_params": [
        "limit",
        "after",
        "before"
      ],
      "input_schema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "number"
          },
          "after": {
            "type": "string"
          },
          "before": {
            "type": "string"
          }
        }
      }
    }
  ]
}
