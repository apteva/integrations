{
  "slug": "coinbase",
  "name": "Coinbase Advanced Trade",
  "description": "Coinbase Advanced Trade REST API for spot/futures-ready accounts, products, order management, fills, portfolios, payment methods, fees, and public market data. Private tools use CDP JWT authentication from an Ed25519 or ECDSA API key.",
  "logo": "https://www.google.com/s2/favicons?domain=coinbase.com&sz=128",
  "categories": ["crypto", "trading", "exchange", "finance"],
  "base_url": "https://api.coinbase.com/api/v3/brokerage",
  "auth": {
    "types": ["custom"],
    "headers": {
      "Content-Type": "application/json"
    },
    "signers": [{ "name": "coinbase_jwt" }],
    "credential_fields": [
      {
        "name": "key_name",
        "label": "CDP API Key Name",
        "type": "password",
        "description": "Coinbase CDP key name / key ID, e.g. organizations/{org_id}/apiKeys/{key_id}."
      },
      {
        "name": "key_secret",
        "label": "CDP Private Key",
        "type": "password",
        "description": "Coinbase CDP private key. Ed25519 base64 secrets and PEM Ed25519/ECDSA keys are supported."
      }
    ]
  },
  "health_check": {
    "tool": "get_time",
    "input": {}
  },
  "tools": [
    {
      "name": "get_time",
      "description": "Public: get Coinbase server time.",
      "method": "GET",
      "path": "/time",
      "signing": { "signers": [] },
      "input_schema": { "type": "object", "properties": {} }
    },
    {
      "name": "list_public_products",
      "description": "Public: list tradable products and product metadata.",
      "method": "GET",
      "path": "/market/products",
      "signing": { "signers": [] },
      "query_params": ["limit", "offset", "product_type", "product_ids", "contract_expiry_type", "expiring_contract_status", "get_tradability_status"],
      "input_schema": {
        "type": "object",
        "properties": {
          "limit": { "type": "integer" },
          "offset": { "type": "integer" },
          "product_type": { "type": "string", "description": "SPOT, FUTURE, or UNKNOWN_PRODUCT_TYPE." },
          "product_ids": { "type": "array", "items": { "type": "string" }, "description": "Product IDs such as BTC-USD." },
          "contract_expiry_type": { "type": "string" },
          "expiring_contract_status": { "type": "string" },
          "get_tradability_status": { "type": "boolean" }
        }
      }
    },
    {
      "name": "get_public_product",
      "description": "Public: get one product by product ID.",
      "method": "GET",
      "path": "/market/products/{product_id}",
      "signing": { "signers": [] },
      "input_schema": { "type": "object", "properties": { "product_id": { "type": "string" } }, "required": ["product_id"] }
    },
    {
      "name": "get_public_product_book",
      "description": "Public: get level 2 product book.",
      "method": "GET",
      "path": "/market/product_book",
      "signing": { "signers": [] },
      "query_params": ["product_id", "limit"],
      "input_schema": {
        "type": "object",
        "properties": {
          "product_id": { "type": "string", "description": "Product ID such as BTC-USD." },
          "limit": { "type": "integer" }
        },
        "required": ["product_id"]
      }
    },
    {
      "name": "get_public_product_candles",
      "description": "Public: get OHLC candles for a product.",
      "method": "GET",
      "path": "/market/products/{product_id}/candles",
      "signing": { "signers": [] },
      "query_params": ["start", "end", "granularity"],
      "input_schema": {
        "type": "object",
        "properties": {
          "product_id": { "type": "string" },
          "start": { "type": "string", "description": "Unix timestamp seconds." },
          "end": { "type": "string", "description": "Unix timestamp seconds." },
          "granularity": { "type": "string", "enum": ["UNKNOWN_GRANULARITY", "ONE_MINUTE", "FIVE_MINUTE", "FIFTEEN_MINUTE", "THIRTY_MINUTE", "ONE_HOUR", "TWO_HOUR", "SIX_HOUR", "ONE_DAY"] }
        },
        "required": ["product_id", "start", "end", "granularity"]
      }
    },
    {
      "name": "get_public_market_trades",
      "description": "Public: get recent market trades for a product.",
      "method": "GET",
      "path": "/market/products/{product_id}/ticker",
      "signing": { "signers": [] },
      "query_params": ["limit", "start", "end"],
      "input_schema": {
        "type": "object",
        "properties": {
          "product_id": { "type": "string" },
          "limit": { "type": "integer" },
          "start": { "type": "string" },
          "end": { "type": "string" }
        },
        "required": ["product_id"]
      }
    },
    {
      "name": "list_accounts",
      "description": "Private: list Coinbase trading accounts.",
      "method": "GET",
      "path": "/accounts",
      "query_params": ["limit", "cursor", "retail_portfolio_id"],
      "input_schema": {
        "type": "object",
        "properties": {
          "limit": { "type": "integer" },
          "cursor": { "type": "string" },
          "retail_portfolio_id": { "type": "string" }
        }
      }
    },
    {
      "name": "get_account",
      "description": "Private: get one account by account UUID.",
      "method": "GET",
      "path": "/accounts/{account_id}",
      "input_schema": { "type": "object", "properties": { "account_id": { "type": "string" } }, "required": ["account_id"] }
    },
    {
      "name": "create_order",
      "description": "Private: create an order. Pass Coinbase's order_configuration object directly for market, limit, stop-limit, TWAP, bracket, scaled, or attached orders.",
      "method": "POST",
      "path": "/orders",
      "input_schema": {
        "type": "object",
        "properties": {
          "client_order_id": { "type": "string" },
          "product_id": { "type": "string" },
          "side": { "type": "string", "enum": ["BUY", "SELL"] },
          "order_configuration": { "type": "object", "description": "Coinbase order_configuration object." },
          "leverage": { "type": "string" },
          "margin_type": { "type": "string" },
          "retail_portfolio_id": { "type": "string" }
        },
        "required": ["client_order_id", "product_id", "side", "order_configuration"]
      }
    },
    {
      "name": "preview_order",
      "description": "Private: preview an order before creating it.",
      "method": "POST",
      "path": "/orders/preview",
      "input_schema": {
        "type": "object",
        "properties": {
          "product_id": { "type": "string" },
          "side": { "type": "string", "enum": ["BUY", "SELL"] },
          "order_configuration": { "type": "object" },
          "leverage": { "type": "string" },
          "margin_type": { "type": "string" },
          "retail_portfolio_id": { "type": "string" }
        },
        "required": ["product_id", "side", "order_configuration"]
      }
    },
    {
      "name": "cancel_orders",
      "description": "Private: batch cancel open orders.",
      "method": "POST",
      "path": "/orders/batch_cancel",
      "input_schema": {
        "type": "object",
        "properties": { "order_ids": { "type": "array", "items": { "type": "string" } } },
        "required": ["order_ids"]
      }
    },
    {
      "name": "list_orders",
      "description": "Private: list historical orders.",
      "method": "GET",
      "path": "/orders/historical/batch",
      "query_params": ["product_id", "order_status", "limit", "start_date", "end_date", "order_type", "order_side", "cursor", "product_type", "order_placement_source", "contract_expiry_type", "asset_filters", "retail_portfolio_id"],
      "input_schema": {
        "type": "object",
        "properties": {
          "product_id": { "type": "string" },
          "order_status": { "type": "array", "items": { "type": "string" } },
          "limit": { "type": "integer" },
          "start_date": { "type": "string" },
          "end_date": { "type": "string" },
          "order_type": { "type": "string" },
          "order_side": { "type": "string" },
          "cursor": { "type": "string" },
          "product_type": { "type": "string" },
          "order_placement_source": { "type": "string" },
          "contract_expiry_type": { "type": "string" },
          "asset_filters": { "type": "array", "items": { "type": "string" } },
          "retail_portfolio_id": { "type": "string" }
        }
      }
    },
    {
      "name": "get_order",
      "description": "Private: get one historical order by ID.",
      "method": "GET",
      "path": "/orders/historical/{order_id}",
      "input_schema": { "type": "object", "properties": { "order_id": { "type": "string" } }, "required": ["order_id"] }
    },
    {
      "name": "list_fills",
      "description": "Private: list order fills.",
      "method": "GET",
      "path": "/orders/historical/fills",
      "query_params": ["order_id", "product_id", "start_sequence_timestamp", "end_sequence_timestamp", "limit", "cursor", "retail_portfolio_id"],
      "input_schema": {
        "type": "object",
        "properties": {
          "order_id": { "type": "string" },
          "product_id": { "type": "string" },
          "start_sequence_timestamp": { "type": "string" },
          "end_sequence_timestamp": { "type": "string" },
          "limit": { "type": "integer" },
          "cursor": { "type": "string" },
          "retail_portfolio_id": { "type": "string" }
        }
      }
    },
    {
      "name": "get_best_bid_ask",
      "description": "Private: get best bid/ask for one or more products.",
      "method": "GET",
      "path": "/best_bid_ask",
      "query_params": ["product_ids"],
      "input_schema": { "type": "object", "properties": { "product_ids": { "type": "array", "items": { "type": "string" } } } }
    },
    {
      "name": "get_product_book",
      "description": "Private: get authenticated product book.",
      "method": "GET",
      "path": "/product_book",
      "query_params": ["product_id", "limit"],
      "input_schema": {
        "type": "object",
        "properties": { "product_id": { "type": "string" }, "limit": { "type": "integer" } },
        "required": ["product_id"]
      }
    },
    {
      "name": "get_transaction_summary",
      "description": "Private: get transaction summary / fee tier information.",
      "method": "GET",
      "path": "/transaction_summary",
      "query_params": ["product_type", "contract_expiry_type", "retail_portfolio_id"],
      "input_schema": {
        "type": "object",
        "properties": {
          "product_type": { "type": "string" },
          "contract_expiry_type": { "type": "string" },
          "retail_portfolio_id": { "type": "string" }
        }
      }
    },
    {
      "name": "list_portfolios",
      "description": "Private: list Coinbase portfolios.",
      "method": "GET",
      "path": "/portfolios",
      "query_params": ["portfolio_type"],
      "input_schema": { "type": "object", "properties": { "portfolio_type": { "type": "string" } } }
    },
    {
      "name": "get_portfolio_breakdown",
      "description": "Private: get portfolio breakdown.",
      "method": "GET",
      "path": "/portfolios/{portfolio_uuid}",
      "input_schema": { "type": "object", "properties": { "portfolio_uuid": { "type": "string" } }, "required": ["portfolio_uuid"] }
    },
    {
      "name": "list_payment_methods",
      "description": "Private: list payment methods.",
      "method": "GET",
      "path": "/payment_methods",
      "input_schema": { "type": "object", "properties": {} }
    },
    {
      "name": "get_payment_method",
      "description": "Private: get one payment method.",
      "method": "GET",
      "path": "/payment_methods/{payment_method_id}",
      "input_schema": { "type": "object", "properties": { "payment_method_id": { "type": "string" } }, "required": ["payment_method_id"] }
    },
    {
      "name": "get_key_permissions",
      "description": "Private: inspect API key permissions.",
      "method": "GET",
      "path": "/key_permissions",
      "input_schema": { "type": "object", "properties": {} }
    }
  ]
}
