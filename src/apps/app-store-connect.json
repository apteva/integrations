{
  "slug": "app-store-connect",
  "name": "App Store Connect",
  "description": "App Store Connect API for apps, versions and localized metadata, builds, TestFlight groups and testers, customer reviews, provisioning, team access, sales/finance reports, and analytics reports. Requests are signed automatically with the Issuer ID, Key ID, and .p8 API private key from App Store Connect.",
  "logo": "https://www.google.com/s2/favicons?domain=appstoreconnect.apple.com&sz=128",
  "categories": ["mobile", "ios", "app-store", "publishing", "testflight", "apple"],
  "base_url": "https://api.appstoreconnect.apple.com/v1",
  "auth": {
    "types": ["custom"],
    "headers": { "Accept": "application/json", "Content-Type": "application/json" },
    "signers": [{ "name": "app_store_connect_jwt" }],
    "credential_fields": [
      { "name": "issuer_id", "label": "Issuer ID", "type": "text", "description": "Issuer ID shown on App Store Connect > Users and Access > Integrations." },
      { "name": "key_id", "label": "Key ID", "type": "text", "description": "ID of the App Store Connect API key." },
      { "name": "private_key", "label": "API Private Key (.p8)", "type": "password", "description": "Full contents of the AuthKey_<KEY_ID>.p8 file, including BEGIN/END PRIVATE KEY lines." }
    ]
  },
  "health_check": { "tool": "list_apps", "input": { "limit": 1 } },
  "tools": [
    {
      "name": "list_apps", "description": "List apps visible to the API key. Filter by bundle ID, name, SKU, or platform and include related resources.", "method": "GET", "path": "/apps",
      "query_param_aliases": { "bundle_id": "filter[bundleId]", "name": "filter[name]", "sku": "filter[sku]", "platform": "filter[appStoreVersions.platform]" }, "query_params": ["include", "limit", "sort", "cursor"],
      "input_schema": { "type": "object", "properties": { "bundle_id": { "type": "string" }, "name": { "type": "string" }, "sku": { "type": "string" }, "platform": { "type": "string", "enum": ["IOS", "MAC_OS", "TV_OS", "VISION_OS"] }, "include": { "type": "string", "description": "Comma-separated relationships, e.g. builds,appStoreVersions,betaGroups." }, "limit": { "type": "integer", "maximum": 200 }, "sort": { "type": "string" }, "cursor": { "type": "string", "description": "Apple pagination cursor from links.next." } } }
    },
    { "name": "get_app", "description": "Get one app by App Store Connect resource ID.", "method": "GET", "path": "/apps/{app_id}", "query_params": ["include"], "input_schema": { "type": "object", "properties": { "app_id": { "type": "string" }, "include": { "type": "string" } }, "required": ["app_id"] } },

    { "name": "list_app_versions", "description": "List App Store versions for one app, optionally filtered by platform or App Store state.", "method": "GET", "path": "/apps/{app_id}/appStoreVersions", "query_param_aliases": { "platform": "filter[platform]", "state": "filter[appStoreState]", "version_string": "filter[versionString]" }, "query_params": ["include", "limit", "cursor"], "input_schema": { "type": "object", "properties": { "app_id": { "type": "string" }, "platform": { "type": "string" }, "state": { "type": "string" }, "version_string": { "type": "string" }, "include": { "type": "string" }, "limit": { "type": "integer" }, "cursor": { "type": "string" } }, "required": ["app_id"] } },
    { "name": "get_app_version", "description": "Get one App Store version and optionally include its build, localizations, review detail, or submission.", "method": "GET", "path": "/appStoreVersions/{version_id}", "query_params": ["include"], "input_schema": { "type": "object", "properties": { "version_id": { "type": "string" }, "include": { "type": "string" } }, "required": ["version_id"] } },
    {
      "name": "create_app_version", "description": "Create a new App Store version for an app. The runner builds Apple's JSON:API envelope from these arguments.", "method": "POST", "path": "/appStoreVersions",
      "request_transform": { "type": "json_api", "resource_type": "appStoreVersions", "attributes": ["platform", "versionString", "copyright", "releaseType", "earliestReleaseDate", "usesIdfa"], "relationships": { "app": { "source": "app_id", "resource_type": "apps" } } },
      "input_schema": { "type": "object", "properties": { "app_id": { "type": "string" }, "platform": { "type": "string", "enum": ["IOS", "MAC_OS", "TV_OS", "VISION_OS"] }, "versionString": { "type": "string" }, "copyright": { "type": "string" }, "releaseType": { "type": "string", "enum": ["MANUAL", "AFTER_APPROVAL", "SCHEDULED"] }, "earliestReleaseDate": { "type": "string", "description": "ISO 8601 datetime for scheduled release." }, "usesIdfa": { "type": "boolean" } }, "required": ["app_id", "platform", "versionString"] }
    },
    { "name": "update_app_version", "description": "Update an App Store version's release settings or metadata.", "method": "PATCH", "path": "/appStoreVersions/{version_id}", "request_transform": { "type": "json_api", "resource_type": "appStoreVersions", "id_field": "version_id", "attributes": ["copyright", "releaseType", "earliestReleaseDate", "usesIdfa", "downloadable"] }, "input_schema": { "type": "object", "properties": { "version_id": { "type": "string" }, "copyright": { "type": "string" }, "releaseType": { "type": "string" }, "earliestReleaseDate": { "type": "string" }, "usesIdfa": { "type": "boolean" }, "downloadable": { "type": "boolean" } }, "required": ["version_id"] } },
    { "name": "delete_app_version", "description": "Delete an editable App Store version.", "method": "DELETE", "path": "/appStoreVersions/{version_id}", "input_schema": { "type": "object", "properties": { "version_id": { "type": "string" } }, "required": ["version_id"] } },
    { "name": "request_version_release", "description": "Request manual release of a version currently in Pending Developer Release.", "method": "POST", "path": "/appStoreVersionReleaseRequests", "request_transform": { "type": "json_api", "resource_type": "appStoreVersionReleaseRequests", "relationships": { "appStoreVersion": { "source": "version_id", "resource_type": "appStoreVersions" } } }, "input_schema": { "type": "object", "properties": { "version_id": { "type": "string" } }, "required": ["version_id"] } },

    { "name": "list_version_localizations", "description": "List localized metadata for an App Store version.", "method": "GET", "path": "/appStoreVersions/{version_id}/appStoreVersionLocalizations", "query_param_aliases": { "locale": "filter[locale]" }, "query_params": ["limit", "cursor"], "input_schema": { "type": "object", "properties": { "version_id": { "type": "string" }, "locale": { "type": "string" }, "limit": { "type": "integer" }, "cursor": { "type": "string" } }, "required": ["version_id"] } },
    { "name": "get_version_localization", "description": "Get one App Store version localization.", "method": "GET", "path": "/appStoreVersionLocalizations/{localization_id}", "input_schema": { "type": "object", "properties": { "localization_id": { "type": "string" } }, "required": ["localization_id"] } },
    { "name": "create_version_localization", "description": "Create localized App Store metadata for a version.", "method": "POST", "path": "/appStoreVersionLocalizations", "request_transform": { "type": "json_api", "resource_type": "appStoreVersionLocalizations", "attributes": ["locale", "description", "keywords", "marketingUrl", "promotionalText", "supportUrl", "whatsNew"], "relationships": { "appStoreVersion": { "source": "version_id", "resource_type": "appStoreVersions" } } }, "input_schema": { "type": "object", "properties": { "version_id": { "type": "string" }, "locale": { "type": "string" }, "description": { "type": "string" }, "keywords": { "type": "string" }, "marketingUrl": { "type": "string" }, "promotionalText": { "type": "string" }, "supportUrl": { "type": "string" }, "whatsNew": { "type": "string" } }, "required": ["version_id", "locale"] } },
    { "name": "update_version_localization", "description": "Update localized App Store metadata.", "method": "PATCH", "path": "/appStoreVersionLocalizations/{localization_id}", "request_transform": { "type": "json_api", "resource_type": "appStoreVersionLocalizations", "id_field": "localization_id", "attributes": ["description", "keywords", "marketingUrl", "promotionalText", "supportUrl", "whatsNew"] }, "input_schema": { "type": "object", "properties": { "localization_id": { "type": "string" }, "description": { "type": "string" }, "keywords": { "type": "string" }, "marketingUrl": { "type": "string" }, "promotionalText": { "type": "string" }, "supportUrl": { "type": "string" }, "whatsNew": { "type": "string" } }, "required": ["localization_id"] } },
    { "name": "delete_version_localization", "description": "Delete one version localization.", "method": "DELETE", "path": "/appStoreVersionLocalizations/{localization_id}", "input_schema": { "type": "object", "properties": { "localization_id": { "type": "string" } }, "required": ["localization_id"] } },

    { "name": "list_builds", "description": "List processed builds. Filter by app, version, processing state, platform, or expired status.", "method": "GET", "path": "/builds", "query_param_aliases": { "app_id": "filter[app]", "version": "filter[version]", "processing_state": "filter[processingState]", "platform": "filter[preReleaseVersion.platform]", "expired": "filter[expired]" }, "query_params": ["include", "limit", "sort", "cursor"], "input_schema": { "type": "object", "properties": { "app_id": { "type": "string" }, "version": { "type": "string" }, "processing_state": { "type": "string" }, "platform": { "type": "string" }, "expired": { "type": "boolean" }, "include": { "type": "string" }, "limit": { "type": "integer" }, "sort": { "type": "string" }, "cursor": { "type": "string" } } } },
    { "name": "get_build", "description": "Get one build and optionally include its app, prerelease version, beta groups, or beta review submission.", "method": "GET", "path": "/builds/{build_id}", "query_params": ["include"], "input_schema": { "type": "object", "properties": { "build_id": { "type": "string" }, "include": { "type": "string" } }, "required": ["build_id"] } },
    { "name": "expire_build", "description": "Expire a TestFlight build so testers can no longer install it.", "method": "PATCH", "path": "/builds/{build_id}", "request_transform": { "type": "json_api", "resource_type": "builds", "id_field": "build_id", "attributes": ["expired"] }, "input_schema": { "type": "object", "properties": { "build_id": { "type": "string" }, "expired": { "type": "boolean", "const": true } }, "required": ["build_id", "expired"] } },
    { "name": "set_app_version_build", "description": "Attach a processed build to an App Store version.", "method": "PATCH", "path": "/appStoreVersions/{version_id}/relationships/build", "body_root_param": "body", "input_schema": { "type": "object", "properties": { "version_id": { "type": "string" }, "body": { "type": "object", "description": "JSON:API build linkage body." } }, "required": ["version_id", "body"] } },
    { "name": "add_builds_to_beta_group", "description": "Add one or more processed builds to a TestFlight beta group.", "method": "POST", "path": "/betaGroups/{group_id}/relationships/builds", "body_root_param": "body", "input_schema": { "type": "object", "properties": { "group_id": { "type": "string" }, "body": { "type": "object", "description": "JSON:API build linkage array body." } }, "required": ["group_id", "body"] } },
    { "name": "create_review_submission", "description": "Create a review submission for an app.", "method": "POST", "path": "/reviewSubmissions", "request_transform": { "type": "json_api", "resource_type": "reviewSubmissions", "attributes": ["platform"], "relationships": { "app": { "source": "app_id", "resource_type": "apps" } } }, "input_schema": { "type": "object", "properties": { "app_id": { "type": "string" }, "platform": { "type": "string", "enum": ["IOS", "MAC_OS", "TV_OS", "VISION_OS"] } }, "required": ["app_id"] } },
    { "name": "create_review_submission_item", "description": "Add an App Store version to a review submission.", "method": "POST", "path": "/reviewSubmissionItems", "request_transform": { "type": "json_api", "resource_type": "reviewSubmissionItems", "relationships": { "reviewSubmission": { "source": "submission_id", "resource_type": "reviewSubmissions" }, "appStoreVersion": { "source": "version_id", "resource_type": "appStoreVersions" } } }, "input_schema": { "type": "object", "properties": { "submission_id": { "type": "string" }, "version_id": { "type": "string" } }, "required": ["submission_id", "version_id"] } },
    { "name": "submit_review_submission", "description": "Submit a prepared review submission to App Review.", "method": "PATCH", "path": "/reviewSubmissions/{submission_id}", "request_transform": { "type": "json_api", "resource_type": "reviewSubmissions", "id_field": "submission_id", "attributes": ["submitted"] }, "input_schema": { "type": "object", "properties": { "submission_id": { "type": "string" }, "submitted": { "type": "boolean", "const": true } }, "required": ["submission_id", "submitted"] } },

    { "name": "list_beta_groups", "description": "List TestFlight beta groups, optionally filtered by app, name, internal status, or public-link status.", "method": "GET", "path": "/betaGroups", "query_param_aliases": { "app_id": "filter[app]", "name": "filter[name]", "internal": "filter[isInternalGroup]", "public_link_enabled": "filter[publicLinkEnabled]" }, "query_params": ["include", "limit", "sort", "cursor"], "input_schema": { "type": "object", "properties": { "app_id": { "type": "string" }, "name": { "type": "string" }, "internal": { "type": "boolean" }, "public_link_enabled": { "type": "boolean" }, "include": { "type": "string" }, "limit": { "type": "integer" }, "sort": { "type": "string" }, "cursor": { "type": "string" } } } },
    { "name": "get_beta_group", "description": "Get one TestFlight beta group.", "method": "GET", "path": "/betaGroups/{group_id}", "query_params": ["include"], "input_schema": { "type": "object", "properties": { "group_id": { "type": "string" }, "include": { "type": "string" } }, "required": ["group_id"] } },
    { "name": "create_beta_group", "description": "Create a TestFlight beta group for an app.", "method": "POST", "path": "/betaGroups", "request_transform": { "type": "json_api", "resource_type": "betaGroups", "attributes": ["name", "isInternalGroup", "publicLinkEnabled", "publicLinkLimit", "feedbackEnabled"], "relationships": { "app": { "source": "app_id", "resource_type": "apps" } } }, "input_schema": { "type": "object", "properties": { "app_id": { "type": "string" }, "name": { "type": "string" }, "isInternalGroup": { "type": "boolean" }, "publicLinkEnabled": { "type": "boolean" }, "publicLinkLimit": { "type": "integer" }, "feedbackEnabled": { "type": "boolean" } }, "required": ["app_id", "name"] } },
    { "name": "update_beta_group", "description": "Update a TestFlight beta group's name, public link, limits, or feedback setting.", "method": "PATCH", "path": "/betaGroups/{group_id}", "request_transform": { "type": "json_api", "resource_type": "betaGroups", "id_field": "group_id", "attributes": ["name", "publicLinkEnabled", "publicLinkLimit", "feedbackEnabled"] }, "input_schema": { "type": "object", "properties": { "group_id": { "type": "string" }, "name": { "type": "string" }, "publicLinkEnabled": { "type": "boolean" }, "publicLinkLimit": { "type": "integer" }, "feedbackEnabled": { "type": "boolean" } }, "required": ["group_id"] } },
    { "name": "delete_beta_group", "description": "Delete a TestFlight beta group.", "method": "DELETE", "path": "/betaGroups/{group_id}", "input_schema": { "type": "object", "properties": { "group_id": { "type": "string" } }, "required": ["group_id"] } },
    { "name": "list_beta_testers", "description": "List TestFlight beta testers, optionally filtered by email, app, group, or build.", "method": "GET", "path": "/betaTesters", "query_param_aliases": { "email": "filter[email]", "app_id": "filter[apps]", "group_id": "filter[betaGroups]", "build_id": "filter[builds]" }, "query_params": ["include", "limit", "sort", "cursor"], "input_schema": { "type": "object", "properties": { "email": { "type": "string" }, "app_id": { "type": "string" }, "group_id": { "type": "string" }, "build_id": { "type": "string" }, "include": { "type": "string" }, "limit": { "type": "integer" }, "sort": { "type": "string" }, "cursor": { "type": "string" } } } },
    { "name": "get_beta_tester", "description": "Get one TestFlight beta tester.", "method": "GET", "path": "/betaTesters/{tester_id}", "query_params": ["include"], "input_schema": { "type": "object", "properties": { "tester_id": { "type": "string" }, "include": { "type": "string" } }, "required": ["tester_id"] } },
    { "name": "create_beta_tester", "description": "Invite a TestFlight beta tester and optionally assign beta groups or builds in the same request.", "method": "POST", "path": "/betaTesters", "request_transform": { "type": "json_api", "resource_type": "betaTesters", "attributes": ["email", "firstName", "lastName"], "relationships": { "betaGroups": { "source": "group_ids", "resource_type": "betaGroups", "many": true }, "builds": { "source": "build_ids", "resource_type": "builds", "many": true } } }, "input_schema": { "type": "object", "properties": { "email": { "type": "string" }, "firstName": { "type": "string" }, "lastName": { "type": "string" }, "group_ids": { "type": "array", "items": { "type": "string" } }, "build_ids": { "type": "array", "items": { "type": "string" } } }, "required": ["email"] } },
    { "name": "delete_beta_tester", "description": "Delete a TestFlight beta tester and remove access to all apps.", "method": "DELETE", "path": "/betaTesters/{tester_id}", "input_schema": { "type": "object", "properties": { "tester_id": { "type": "string" } }, "required": ["tester_id"] } },

    { "name": "list_customer_reviews", "description": "List App Store customer reviews for an app, filterable by territory, rating, and whether a published developer response exists.", "method": "GET", "path": "/apps/{app_id}/customerReviews", "query_param_aliases": { "territory": "filter[territory]", "rating": "filter[rating]", "has_published_response": "exists[publishedResponse]" }, "query_params": ["include", "limit", "sort", "cursor"], "input_schema": { "type": "object", "properties": { "app_id": { "type": "string" }, "territory": { "type": "string" }, "rating": { "type": "integer", "minimum": 1, "maximum": 5 }, "has_published_response": { "type": "boolean" }, "include": { "type": "string", "description": "Use publishedResponse or territory to include related resources." }, "limit": { "type": "integer" }, "sort": { "type": "string" }, "cursor": { "type": "string" } }, "required": ["app_id"] } },
    { "name": "get_customer_review", "description": "Get one App Store customer review.", "method": "GET", "path": "/customerReviews/{review_id}", "query_params": ["include"], "input_schema": { "type": "object", "properties": { "review_id": { "type": "string" }, "include": { "type": "string" } }, "required": ["review_id"] } },
    { "name": "create_review_response", "description": "Respond to an App Store customer review.", "method": "POST", "path": "/customerReviewResponses", "request_transform": { "type": "json_api", "resource_type": "customerReviewResponses", "attributes": ["responseBody"], "relationships": { "review": { "source": "review_id", "resource_type": "customerReviews" } } }, "input_schema": { "type": "object", "properties": { "review_id": { "type": "string" }, "responseBody": { "type": "string" } }, "required": ["review_id", "responseBody"] } },
    { "name": "delete_review_response", "description": "Delete a response to a customer review.", "method": "DELETE", "path": "/customerReviewResponses/{response_id}", "input_schema": { "type": "object", "properties": { "response_id": { "type": "string" } }, "required": ["response_id"] } },

    { "name": "list_bundle_ids", "description": "List registered bundle IDs for provisioning.", "method": "GET", "path": "/bundleIds", "query_param_aliases": { "identifier": "filter[identifier]", "name": "filter[name]", "platform": "filter[platform]" }, "query_params": ["include", "limit", "sort", "cursor"], "input_schema": { "type": "object", "properties": { "identifier": { "type": "string" }, "name": { "type": "string" }, "platform": { "type": "string" }, "include": { "type": "string" }, "limit": { "type": "integer" }, "sort": { "type": "string" }, "cursor": { "type": "string" } } } },
    { "name": "get_bundle_id", "description": "Get one registered bundle ID.", "method": "GET", "path": "/bundleIds/{bundle_id}", "query_params": ["include"], "input_schema": { "type": "object", "properties": { "bundle_id": { "type": "string" }, "include": { "type": "string" } }, "required": ["bundle_id"] } },
    { "name": "register_bundle_id", "description": "Register a new explicit or wildcard bundle ID.", "method": "POST", "path": "/bundleIds", "request_transform": { "type": "json_api", "resource_type": "bundleIds", "attributes": ["identifier", "name", "platform", "seedId"] }, "input_schema": { "type": "object", "properties": { "identifier": { "type": "string" }, "name": { "type": "string" }, "platform": { "type": "string", "enum": ["IOS", "MAC_OS"] }, "seedId": { "type": "string" } }, "required": ["identifier", "name", "platform"] } },
    { "name": "update_bundle_id", "description": "Rename a registered bundle ID.", "method": "PATCH", "path": "/bundleIds/{bundle_id}", "request_transform": { "type": "json_api", "resource_type": "bundleIds", "id_field": "bundle_id", "attributes": ["name"] }, "input_schema": { "type": "object", "properties": { "bundle_id": { "type": "string" }, "name": { "type": "string" } }, "required": ["bundle_id", "name"] } },
    { "name": "delete_bundle_id", "description": "Delete a registered bundle ID when Apple permits it.", "method": "DELETE", "path": "/bundleIds/{bundle_id}", "input_schema": { "type": "object", "properties": { "bundle_id": { "type": "string" } }, "required": ["bundle_id"] } },
    { "name": "list_certificates", "description": "List development and distribution certificates.", "method": "GET", "path": "/certificates", "query_param_aliases": { "certificate_type": "filter[certificateType]", "display_name": "filter[displayName]" }, "query_params": ["limit", "sort", "cursor"], "input_schema": { "type": "object", "properties": { "certificate_type": { "type": "string" }, "display_name": { "type": "string" }, "limit": { "type": "integer" }, "sort": { "type": "string" }, "cursor": { "type": "string" } } } },
    { "name": "create_certificate", "description": "Create a signing certificate from a PEM-encoded certificate signing request.", "method": "POST", "path": "/certificates", "request_transform": { "type": "json_api", "resource_type": "certificates", "attributes": ["certificateType", "csrContent"] }, "input_schema": { "type": "object", "properties": { "certificateType": { "type": "string", "description": "For example IOS_DISTRIBUTION, DEVELOPMENT, or MAC_APP_DISTRIBUTION." }, "csrContent": { "type": "string", "description": "PEM CSR content." } }, "required": ["certificateType", "csrContent"] } },
    { "name": "revoke_certificate", "description": "Revoke a signing certificate.", "method": "DELETE", "path": "/certificates/{certificate_id}", "input_schema": { "type": "object", "properties": { "certificate_id": { "type": "string" } }, "required": ["certificate_id"] } },
    { "name": "list_devices", "description": "List registered test devices.", "method": "GET", "path": "/devices", "query_param_aliases": { "udid": "filter[udid]", "name": "filter[name]", "platform": "filter[platform]", "status": "filter[status]" }, "query_params": ["limit", "sort", "cursor"], "input_schema": { "type": "object", "properties": { "udid": { "type": "string" }, "name": { "type": "string" }, "platform": { "type": "string" }, "status": { "type": "string" }, "limit": { "type": "integer" }, "sort": { "type": "string" }, "cursor": { "type": "string" } } } },
    { "name": "register_device", "description": "Register a device for development or testing.", "method": "POST", "path": "/devices", "request_transform": { "type": "json_api", "resource_type": "devices", "attributes": ["name", "platform", "udid"] }, "input_schema": { "type": "object", "properties": { "name": { "type": "string" }, "platform": { "type": "string", "enum": ["IOS", "MAC_OS"] }, "udid": { "type": "string" } }, "required": ["name", "platform", "udid"] } },
    { "name": "update_device", "description": "Rename or enable/disable a registered device.", "method": "PATCH", "path": "/devices/{device_id}", "request_transform": { "type": "json_api", "resource_type": "devices", "id_field": "device_id", "attributes": ["name", "status"] }, "input_schema": { "type": "object", "properties": { "device_id": { "type": "string" }, "name": { "type": "string" }, "status": { "type": "string", "enum": ["ENABLED", "DISABLED"] } }, "required": ["device_id"] } },
    { "name": "list_profiles", "description": "List provisioning profiles and optionally include bundle ID, certificates, and devices.", "method": "GET", "path": "/profiles", "query_param_aliases": { "profile_type": "filter[profileType]", "name": "filter[name]" }, "query_params": ["include", "limit", "sort", "cursor"], "input_schema": { "type": "object", "properties": { "profile_type": { "type": "string" }, "name": { "type": "string" }, "include": { "type": "string" }, "limit": { "type": "integer" }, "sort": { "type": "string" }, "cursor": { "type": "string" } } } },
    { "name": "get_profile", "description": "Get a provisioning profile. profileContent in the response is base64-encoded profile data.", "method": "GET", "path": "/profiles/{profile_id}", "query_params": ["include"], "input_schema": { "type": "object", "properties": { "profile_id": { "type": "string" }, "include": { "type": "string" } }, "required": ["profile_id"] } },
