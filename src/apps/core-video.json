    {
      "name": "probe",
      "description": "Extract detailed metadata from a media file (duration, resolution, codec, bitrate, frame rate, audio channels, etc.)",
      "method": "POST",
      "path": "/media/probe-media",
      "input_schema": {
        "type": "object",
        "properties": {
          "file_id": {
            "type": "integer",
            "description": "ID of the file to probe"
          }
        },
        "required": [
          "file_id"
        ]
      }
    },
    {
      "name": "download_media",
      "description": "Download video or audio from any platform (YouTube, Vimeo, TikTok, Twitter, Instagram, Soundgasm, etc.) and save directly to storage",
      "method": "POST",
      "path": "/media/download-media",
      "input_schema": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "URL of the video or audio to download"
          },
          "folder_id": {
            "type": "integer",
            "description": "Optional folder ID to organize the downloaded file"
          },
          "bucket_id": {
            "type": "integer",
            "description": "Optional storage bucket ID (uses default if not provided)"
          },
          "format_type": {
            "type": "string",
            "enum": [
              "audio",
              "video",
              "best"
            ],
            "default": "best",
            "description": "Type of media to download: 'audio' extracts audio only, 'video' downloads video with audio, 'best' selects highest quality"
          },
          "quality": {
            "type": "string",
            "description": "Quality: '1080p', '720p', '480p' for video OR '320', '192', '128' (kbps) for audio"
          },
          "format_id": {
            "type": "string",
            "description": "Specific format ID from extract-media-info (overrides quality)"
          },
          "file_name": {
            "type": "string",
            "description": "Custom filename (uses video title if not provided)"
          },
          "access_level": {
            "type": "string",
            "enum": [
              "public",
              "private"
            ],
            "default": "public",
            "description": "File access level"
          },
          "skip_thumbnails": {
            "type": "boolean",
            "default": false,
            "description": "Skip automatic thumbnail generation"
          },
          "auto_transcribe": {
            "type": "boolean",
            "default": true,
            "description": "Auto-generate transcripts for audio content"
          },
          "description": {
            "type": "string",
            "description": "File description"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Tags for file organization"
          }
        },
        "required": [
          "url"
        ]
      }
    },
    {
      "name": "extract_media_info",
      "description": "Extract metadata and available formats from any video/audio URL without downloading. Returns title, duration, available qualities, and format details.",
      "method": "POST",
      "path": "/media/extract-media-info",
      "input_schema": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "URL of the video or audio to extract info from"
          },
          "format_type": {
            "type": "string",
            "enum": [
              "audio",
              "video",
              "all"
            ],
            "default": "all",
            "description": "Type of formats to return"
          },
          "include_formats": {
            "type": "boolean",
            "default": true,
            "description": "Include detailed format information (codecs, bitrates, resolutions)"
          }
        },
        "required": [
          "url"
        ]
      }
    },
    {
      "name": "extract_media_metadata",
      "description": "Extract and persist media metadata (duration, resolution, codec, bitrate) for a file already in storage. Updates the file record with extracted info.",
      "method": "POST",
      "path": "/media/extract-media-metadata",
      "input_schema": {
        "type": "object",
        "properties": {
          "file_id": {
            "type": "integer",
            "description": "ID of the file to extract metadata from"
          },
          "file_type": {
            "type": "string",
            "enum": [
              "video",
              "audio"
            ],
            "description": "Type of file (video or audio)"
          }
        },
        "required": [
          "file_id"
        ]
      }
    }
  ]
