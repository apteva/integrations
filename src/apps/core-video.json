            "type": "string",
            "enum": [
              "top-left",
              "top-right",
              "bottom-left",
              "bottom-right"
            ],
            "default": "bottom-right",
            "description": "Position of PiP overlay (only for pip layout)"
          },
          "pip_size": {
            "type": "number",
            "default": 0.25,
            "description": "Size of PiP as fraction of main video (0.1-0.5)"
          },
          "output_format": {
            "type": "string",
            "enum": [
              "mp4",
              "webm"
            ],
            "default": "mp4",
            "description": "Output format"
          },
          "access_level": {
            "type": "string",
            "enum": [
              "public",
              "private"
            ],
            "default": "public",
            "description": "Access level for created file"
          }
        },
        "required": [
          "file_ids"
        ]
      }
