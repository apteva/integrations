          },
          "page": {
            "type": "integer",
            "description": "Page number"
          },
          "per_page": {
            "type": "integer",
            "description": "Results per page"
          },
          "name": {
            "type": "string",
            "description": "Filter by name"
          },
          "project": {
            "type": "string",
            "description": "Filter by project ID"
          }
        }
      }
    },
    {
      "name": "security_group_get",
      "description": "Get details of a specific Scaleway security group",
      "method": "GET",
      "path": "/security-group-get",
      "input_schema": {
        "type": "object",
        "properties": {
          "zone": {
            "type": "string",
            "description": "Scaleway zone",
            "default": "fr-par-1"
          },
          "security_group_id": {
            "type": "string",
            "description": "Security group UUID"
          }
        },
        "required": [
          "security_group_id"
        ]
      }
    },
    {
      "name": "security_group_create",
      "description": "Create a new security group in Scaleway",
      "method": "GET",
      "path": "/security-group-create",
      "input_schema": {
        "type": "object",
        "properties": {
          "zone": {
            "type": "string",
            "description": "Scaleway zone",
            "default": "fr-par-1"
          },
          "name": {
            "type": "string",
            "description": "Security group name"
          },
          "description": {
            "type": "string",
            "description": "Description"
          },
          "stateful": {
            "type": "boolean",
            "description": "Whether the security group is stateful",
            "default": true
          },
          "inbound_default_policy": {
            "type": "string",
            "enum": [
              "accept",
              "drop"
            ],
            "description": "Default policy for inbound traffic",
            "default": "accept"
          },
          "outbound_default_policy": {
            "type": "string",
            "enum": [
              "accept",
              "drop"
            ],
            "description": "Default policy for outbound traffic",
            "default": "accept"
          }
        },
        "required": [
          "name"
        ]
      }
    },
    {
      "name": "security_group_delete",
      "description": "Delete a Scaleway security group",
      "method": "GET",
      "path": "/security-group-delete",
      "input_schema": {
        "type": "object",
        "properties": {
          "zone": {
            "type": "string",
            "description": "Scaleway zone",
            "default": "fr-par-1"
          },
          "security_group_id": {
            "type": "string",
            "description": "Security group UUID to delete"
          }
        },
        "required": [
          "security_group_id"
        ]
      }
    },
    {
      "name": "security_group_rules_list",
      "description": "List all rules in a Scaleway security group",
      "method": "GET",
      "path": "/security-group-rules-list",
      "input_schema": {
        "type": "object",
        "properties": {
          "zone": {
            "type": "string",
            "description": "Scaleway zone",
            "default": "fr-par-1"
          },
          "security_group_id": {
            "type": "string",
            "description": "Security group UUID"
          },
          "page": {
            "type": "integer",
            "description": "Page number"
          },
          "per_page": {
            "type": "integer",
            "description": "Results per page"
          }
        },
        "required": [
          "security_group_id"
        ]
      }
    },
    {
      "name": "security_group_rule_create",
      "description": "Create a new rule in a Scaleway security group",
      "method": "GET",
      "path": "/security-group-rule-create",
      "input_schema": {
        "type": "object",
        "properties": {
          "zone": {
            "type": "string",
            "description": "Scaleway zone",
            "default": "fr-par-1"
          },
          "security_group_id": {
            "type": "string",
            "description": "Security group UUID"
          },
          "protocol": {
            "type": "string",
            "enum": [
              "TCP",
              "UDP",
              "ICMP",
              "ANY"
            ],
            "description": "Protocol for the rule"
          },
          "direction": {
            "type": "string",
            "enum": [
              "inbound",
              "outbound"
            ],
            "description": "Direction of traffic"
          },
          "action": {
            "type": "string",
            "enum": [
              "accept",
              "drop"
            ],
            "description": "Action to take"
          },
          "ip_range": {
            "type": "string",
            "description": "IP range in CIDR notation (e.g., 0.0.0.0/0)"
          },
          "dest_port_from": {
            "type": "integer",
            "description": "Start of port range"
          },
          "dest_port_to": {
            "type": "integer",
            "description": "End of port range"
          },
          "position": {
            "type": "integer",
            "description": "Position of the rule (lower = higher priority)",
            "default": 0
          }
        },
        "required": [
          "security_group_id",
          "protocol",
          "direction",
          "action"
        ]
      }
    },
    {
      "name": "security_group_rule_delete",
      "description": "Delete a rule from a Scaleway security group",
      "method": "GET",
      "path": "/security-group-rule-delete",
      "input_schema": {
        "type": "object",
        "properties": {
          "zone": {
            "type": "string",
            "description": "Scaleway zone",
            "default": "fr-par-1"
          },
          "security_group_id": {
            "type": "string",
            "description": "Security group UUID"
          },
          "rule_id": {
            "type": "string",
            "description": "Rule UUID to delete"
          }
        },
        "required": [
          "security_group_id",
          "rule_id"
        ]
      }
    },
