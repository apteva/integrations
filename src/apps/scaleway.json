{
  "slug": "scaleway",
  "name": "Scaleway Cloud",
  "description": "Manage Scaleway cloud infrastructure - servers, volumes, IPs, security groups, images, and snapshots",
  "logo": "https://www.google.com/s2/favicons?domain=scaleway.com&sz=128",
  "categories": [
    "cloud",
    "vps",
    "hosting",
    "infrastructure",
    "storage"
  ],
  "base_url": "https://api.scaleway.com",
  "auth": {
    "types": [
      "bearer"
    ],
    "headers": {
      "Authorization": "Bearer {{token}}"
    },
    "credential_fields": [
      {
        "name": "token",
        "label": "API Key"
      }
    ]
  },
  "tools": [
    {
      "name": "server_list",
      "description": "List all Scaleway servers/instances in a zone. Returns server details including ID, name, state, IP addresses, and type.",
      "method": "GET",
      "path": "/server-list",
      "input_schema": {
        "type": "object",
        "properties": {
          "zone": {
            "type": "string",
            "description": "Scaleway zone (fr-par-1, fr-par-2, nl-ams-1, pl-waw-1, etc.)",
            "default": "fr-par-1"
          },
          "page": {
            "type": "integer",
            "description": "Page number for pagination"
          },
          "per_page": {
            "type": "integer",
            "description": "Number of results per page (max 100)"
          },
          "name": {
            "type": "string",
            "description": "Filter by server name"
          },
          "project": {
            "type": "string",
            "description": "Filter by project ID"
          }
        }
      }
    },
    {
      "name": "server_get",
      "description": "Get detailed information about a specific Scaleway server/instance by ID",
      "method": "GET",
      "path": "/server-get",
      "input_schema": {
        "type": "object",
        "properties": {
          "zone": {
            "type": "string",
            "description": "Scaleway zone",
            "default": "fr-par-1"
          },
          "server_id": {
            "type": "string",
            "description": "Server UUID"
          }
        },
        "required": [
          "server_id"
        ]
      }
    },
    {
      "name": "server_create",
      "description": "Create a new Scaleway server/instance. Requires commercial_type (e.g., DEV1-S, GP1-S) and image ID.",
      "method": "GET",
      "path": "/server-create",
      "input_schema": {
        "type": "object",
        "properties": {
          "zone": {
            "type": "string",
            "description": "Scaleway zone",
            "default": "fr-par-1"
          },
          "name": {
            "type": "string",
            "description": "Server name"
          },
          "commercial_type": {
            "type": "string",
            "description": "Instance type (DEV1-S, DEV1-M, DEV1-L, GP1-S, GP1-M, etc.)"
          },
          "image": {
            "type": "string",
            "description": "Image UUID to use for the server"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Tags for the server"
          },
          "enable_ipv6": {
            "type": "boolean",
            "description": "Enable IPv6",
            "default": false
          },
          "boot_type": {
            "type": "string",
            "description": "Boot type (local, bootscript, rescue)",
            "default": "local"
          }
        },
        "required": [
          "name",
          "commercial_type",
          "image"
        ]
      }
    },
    {
      "name": "server_delete",
      "description": "Delete/terminate a Scaleway server/instance",
      "method": "GET",
      "path": "/server-delete",
      "input_schema": {
        "type": "object",
        "properties": {
          "zone": {
            "type": "string",
            "description": "Scaleway zone",
            "default": "fr-par-1"
          },
          "server_id": {
            "type": "string",
            "description": "Server UUID to delete"
          }
        },
        "required": [
          "server_id"
        ]
      }
    },
    {
      "name": "server_action",
      "description": "Perform an action on a Scaleway server (poweron, poweroff, reboot, terminate, stop_in_place, backup)",
      "method": "GET",
      "path": "/server-action",
      "input_schema": {
        "type": "object",
        "properties": {
          "zone": {
            "type": "string",
            "description": "Scaleway zone",
            "default": "fr-par-1"
          },
          "server_id": {
            "type": "string",
            "description": "Server UUID"
          },
          "action": {
            "type": "string",
            "enum": [
              "poweron",
              "poweroff",
              "reboot",
              "terminate",
              "stop_in_place",
              "backup"
            ],
            "description": "Action to perform"
          }
        },
        "required": [
          "server_id",
          "action"
        ]
      }
    },
    {
      "name": "volume_list",
      "description": "List all block storage volumes in a Scaleway zone",
      "method": "GET",
      "path": "/volume-list",
      "input_schema": {
        "type": "object",
        "properties": {
          "zone": {
            "type": "string",
            "description": "Scaleway zone",
            "default": "fr-par-1"
          },
          "page": {
            "type": "integer",
            "description": "Page number"
          },
          "per_page": {
            "type": "integer",
            "description": "Results per page"
          },
          "volume_type": {
            "type": "string",
            "description": "Filter by volume type (l_ssd, b_ssd)"
          },
          "name": {
            "type": "string",
            "description": "Filter by name"
          }
        }
      }
    },
    {
      "name": "volume_get",
      "description": "Get details of a specific Scaleway volume by ID",
      "method": "GET",
      "path": "/volume-get",
      "input_schema": {
        "type": "object",
        "properties": {
          "zone": {
            "type": "string",
            "description": "Scaleway zone",
            "default": "fr-par-1"
          },
          "volume_id": {
            "type": "string",
            "description": "Volume UUID"
          }
        },
        "required": [
          "volume_id"
        ]
      }
    },
    {
      "name": "volume_create",
      "description": "Create a new Scaleway block storage volume",
      "method": "GET",
      "path": "/volume-create",
      "input_schema": {
        "type": "object",
        "properties": {
          "zone": {
            "type": "string",
            "description": "Scaleway zone",
            "default": "fr-par-1"
          },
          "name": {
            "type": "string",
            "description": "Volume name"
          },
          "volume_type": {
            "type": "string",
            "description": "Volume type (b_ssd, l_ssd)",
            "default": "b_ssd"
          },
          "size": {
            "type": "integer",
            "description": "Volume size in bytes (e.g., 10000000000 for 10GB)"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Tags for the volume"
          }
        },
        "required": [
          "name",
          "size"
        ]
      }
    },
    {
      "name": "volume_delete",
      "description": "Delete a Scaleway block storage volume",
      "method": "GET",
      "path": "/volume-delete",
      "input_schema": {
        "type": "object",
        "properties": {
          "zone": {
            "type": "string",
            "description": "Scaleway zone",
            "default": "fr-par-1"
          },
          "volume_id": {
            "type": "string",
            "description": "Volume UUID to delete"
          }
        },
        "required": [
          "volume_id"
        ]
      }
    },
    {
