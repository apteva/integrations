        ]
      }
    },
    {
      "name": "ip_create",
      "description": "Reserve a new flexible IP address in Scaleway",
      "method": "GET",
      "path": "/ip-create",
      "input_schema": {
        "type": "object",
        "properties": {
          "zone": {
            "type": "string",
            "description": "Scaleway zone",
            "default": "fr-par-1"
          },
          "server_id": {
            "type": "string",
            "description": "Optionally attach to a server immediately"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Tags for the IP"
          }
        }
      }
    },
    {
      "name": "ip_attach",
      "description": "Attach a flexible IP to a Scaleway server",
      "method": "GET",
      "path": "/ip-attach",
      "input_schema": {
        "type": "object",
        "properties": {
          "zone": {
            "type": "string",
            "description": "Scaleway zone",
            "default": "fr-par-1"
          },
          "ip_id": {
            "type": "string",
            "description": "IP UUID to attach"
          },
          "server_id": {
            "type": "string",
            "description": "Server UUID to attach the IP to"
          }
        },
        "required": [
          "ip_id",
          "server_id"
        ]
      }
    },
    {
      "name": "ip_detach",
      "description": "Detach a flexible IP from its current server",
      "method": "GET",
      "path": "/ip-detach",
      "input_schema": {
        "type": "object",
        "properties": {
          "zone": {
            "type": "string",
            "description": "Scaleway zone",
            "default": "fr-par-1"
          },
          "ip_id": {
            "type": "string",
            "description": "IP UUID to detach"
          }
        },
        "required": [
          "ip_id"
        ]
      }
    },
    {
      "name": "ip_delete",
      "description": "Release/delete a flexible IP address",
      "method": "GET",
      "path": "/ip-delete",
      "input_schema": {
        "type": "object",
        "properties": {
          "zone": {
            "type": "string",
            "description": "Scaleway zone",
            "default": "fr-par-1"
          },
          "ip_id": {
            "type": "string",
            "description": "IP UUID to delete"
          }
        },
        "required": [
          "ip_id"
        ]
      }
    },
    {
      "name": "security_group_list",
      "description": "List all security groups in a Scaleway zone",
      "method": "GET",
      "path": "/security-group-list",
      "input_schema": {
        "type": "object",
        "properties": {
          "zone": {
            "type": "string",
