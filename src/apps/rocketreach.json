{
  "slug": "rocketreach",
  "name": "RocketReach",
  "description": "Contact finder \u2014 emails (personal + work) and phone numbers for 700M+ professionals. Strong at people-level lookups when you have a name + company.",
  "logo": "https://www.google.com/s2/favicons?domain=rocketreach.co&sz=128",
  "categories": [
    "sales",
    "leads",
    "enrichment",
    "contacts",
    "prospecting",
    "b2b"
  ],
  "base_url": "https://api.rocketreach.co/v2/api",
  "auth": {
    "types": [
      "api_key"
    ],
    "headers": {
      "Api-Key": "{{api_key}}"
    },
    "credential_fields": [
      {
        "name": "api_key",
        "label": "API key",
        "description": "RocketReach API key from rocketreach.co \u2192 Settings \u2192 API"
      }
    ]
  },
  "tools": [
    {
      "name": "person_lookup",
      "description": "Look up a person and unlock their contact info (email + phone). Provide LinkedIn URL OR (name + current_employer) OR id.",
      "method": "GET",
      "path": "/lookupProfile",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "RocketReach profile id (from a search result)"
          },
          "linkedin_url": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "current_employer": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "lookup_type": {
            "type": "string",
            "enum": [
              "standard",
              "premium",
              "premium_(feeds_unlimited)",
              "phone",
              "enrich"
            ],
            "default": "standard"
          }
        }
      }
    },
    {
      "name": "person_search",
      "description": "Search for people. Returns id + basic profile, no contact details (call person_lookup with id to unlock).",
      "method": "POST",
      "path": "/search",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "object",
            "description": "Filter object \u2014 supports name, current_title, current_employer, location, keyword, company_industry, company_size_range, etc. (each as a string array of include terms; suffix '_excluded' to exclude)"
          },
          "start": {
            "type": "integer",
            "default": 1
          },
          "page_size": {
            "type": "integer",
            "default": 10,
            "maximum": 100
          }
        },
        "required": [
          "query"
        ]
      }
    },
    {
      "name": "company_lookup",
      "description": "Look up a company by domain or name.",
      "method": "GET",
      "path": "/company/lookup",
      "input_schema": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "ticker": {
            "type": "string"
          }
        }
      }
    },
    {
      "name": "company_search",
      "description": "Search companies by name, industry, size, location.",
      "method": "POST",
      "path": "/searchCompany",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "object"
          },
          "start": {
            "type": "integer",
            "default": 1
          },
          "page_size": {
            "type": "integer",
            "default": 10
          }
        },
        "required": [
          "query"
        ]
      }
    },
    {
      "name": "account",
      "description": "Get current account details \u2014 credits, plan, daily limits.",
      "method": "GET",
      "path": "/account",
      "input_schema": {
        "type": "object",
        "properties": {}
      }
    }
  ],
  "health_check": {
    "tool": "account"
  }
}