{
  "slug": "wordpress",
  "name": "WordPress",
  "description": "Complete WordPress integration for content management - posts, pages, media, comments, users, categories, and tags",
  "logo": "https://www.google.com/s2/favicons?domain=wordpress.org&sz=128",
  "categories": [
    "cms",
    "blog",
    "wordpress",
    "posts",
    "pages",
    "media",
    "content"
  ],
  "base_url": "",
  "auth": {
    "types": [
      "bearer"
    ],
    "headers": {
      "Authorization": "Bearer {{token}}"
    },
    "credential_fields": [
      {
        "name": "site_url",
        "label": "Site_url",
        "description": "Your WordPress site URL (e.g., https://example.com)"
      },
      {
        "name": "username",
        "label": "Username",
        "description": "WordPress username with API access"
      },
      {
        "name": "application_password",
        "label": "Application_password",
        "description": "Application password generated in WordPress admin under Users > Profile > Application Passwords"
      }
    ]
  },
  "tools": [
    {
      "name": "list_posts",
      "description": "List posts from a WordPress site",
      "method": "GET",
      "path": "/list-posts",
      "input_schema": {
        "type": "object",
        "properties": {
          "site_url": {
            "type": "string",
            "description": "WordPress site URL (e.g., https://example.com)"
          },
          "username": {
            "type": "string",
            "description": "WordPress username"
          },
          "application_password": {
            "type": "string",
            "description": "WordPress application password"
          },
          "per_page": {
            "type": "number",
            "description": "Posts per page (default: 10)"
          },
          "page": {
            "type": "number",
            "description": "Page number (default: 1)"
          },
          "status": {
            "type": "string",
            "description": "Post status: publish, draft, pending, private"
          },
          "search": {
            "type": "string",
            "description": "Search term"
          },
          "categories": {
            "type": "string",
            "description": "Filter by category IDs (comma-separated)"
          },
          "tags": {
            "type": "string",
            "description": "Filter by tag IDs (comma-separated)"
          }
        },
        "required": [
          "site_url"
        ]
      }
    },
    {
      "name": "get_post",
      "description": "Get a single post by ID",
      "method": "GET",
      "path": "/get-post",
      "input_schema": {
        "type": "object",
        "properties": {
          "site_url": {
            "type": "string",
            "description": "WordPress site URL"
          },
          "username": {
            "type": "string",
            "description": "WordPress username"
          },
          "application_password": {
            "type": "string",
            "description": "WordPress application password"
          },
          "post_id": {
            "type": "number",
            "description": "Post ID"
          }
        },
        "required": [
          "site_url",
          "post_id"
        ]
      }
    },
    {
      "name": "create_post",
      "description": "Create a new post",
      "method": "POST",
      "path": "/create-post",
      "input_schema": {
        "type": "object",
        "properties": {
          "site_url": {
            "type": "string",
            "description": "WordPress site URL"
          },
          "username": {
            "type": "string",
            "description": "WordPress username"
          },
          "application_password": {
            "type": "string",
            "description": "WordPress application password"
          },
          "title": {
            "type": "string",
            "description": "Post title"
          },
          "content": {
            "type": "string",
            "description": "Post content (HTML)"
          },
          "status": {
            "type": "string",
            "description": "Post status: publish, draft, pending, private (default: draft)"
          },
          "excerpt": {
            "type": "string",
            "description": "Post excerpt"
          },
          "categories": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "description": "Category IDs"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "description": "Tag IDs"
          },
          "featured_media": {
            "type": "number",
            "description": "Featured image media ID"
          },
          "slug": {
            "type": "string",
            "description": "Post slug/permalink"
          }
        },
        "required": [
          "site_url",
          "username",
          "application_password",
          "title",
          "content"
        ]
      }
    },
