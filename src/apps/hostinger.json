{
  "slug": "hostinger",
  "name": "Hostinger",
  "description": "MCP server for Hostinger - domains, DNS, VPS, and billing management",
  "logo": "https://www.google.com/s2/favicons?domain=hostinger.com&sz=128",
  "categories": [
    "cloud",
    "domains",
    "dns",
    "vps",
    "hosting",
    "infrastructure"
  ],
  "base_url": "https://developers.hostinger.com",
  "auth": {
    "types": [
      "bearer"
    ],
    "headers": {
      "Authorization": "Bearer {{token}}"
    },
    "credential_fields": [
      {
        "name": "api_key",
        "label": "Api_key",
        "description": "Your Hostinger API Bearer Token (generate at developers.hostinger.com)"
      }
    ]
  },
  "tools": [
    {
      "name": "dns_get",
      "description": "Get DNS records for a domain",
      "method": "GET",
      "path": "/dns-get",
      "input_schema": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string",
            "description": "The domain name to get DNS records for"
          }
        },
        "required": [
          "domain"
        ]
      }
    },
    {
      "name": "dns_update",
      "description": "Update DNS records for a domain",
      "method": "GET",
      "path": "/dns-update",
      "input_schema": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string",
            "description": "The domain name"
          },
          "records": {
            "type": "array",
            "description": "Array of DNS records to add/update",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "description": "Record type (A, AAAA, CNAME, MX, TXT, etc.)"
                },
                "name": {
                  "type": "string",
                  "description": "Record name (@ for root)"
                },
                "content": {
                  "type": "string",
                  "description": "Record value"
                },
                "ttl": {
                  "type": "number",
                  "description": "TTL in seconds"
                }
              }
            }
          },
          "overwrite": {
            "type": "boolean",
            "description": "If true, overwrite all existing records"
          }
        },
        "required": [
          "domain",
          "records"
        ]
      }
    },
    {
      "name": "dns_delete",
      "description": "Delete specific DNS records for a domain",
      "method": "GET",
      "path": "/dns-delete",
      "input_schema": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string",
            "description": "The domain name"
          },
          "records": {
            "type": "array",
            "description": "Array of DNS records to delete",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "content": {
                  "type": "string"
                }
              }
            }
          }
        },
        "required": [
          "domain",
          "records"
        ]
      }
    },
    {
      "name": "dns_reset",
      "description": "Reset DNS records to defaults for a domain",
      "method": "GET",
      "path": "/dns-reset",
      "input_schema": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string",
            "description": "The domain name to reset DNS for"
          }
        },
        "required": [
          "domain"
        ]
      }
    },
    {
      "name": "domain_list",
      "description": "List all domains in portfolio",
      "method": "GET",
      "path": "/domain-list",
      "input_schema": {
        "type": "object",
        "properties": {
          "page": {
            "type": "number",
            "description": "Page number for pagination"
          },
          "limit": {
            "type": "number",
            "description": "Number of results per page"
          }
        }
      }
    },
    {
      "name": "domain_get",
      "description": "Get details for a specific domain",
      "method": "GET",
      "path": "/domain-get",
      "input_schema": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string",
            "description": "The domain name"
          }
        },
        "required": [
          "domain"
        ]
      }
    },
    {
      "name": "domain_check",
      "description": "Check if domains are available for registration",
      "method": "GET",
      "path": "/domain-check",
      "input_schema": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string",
            "description": "Single domain to check"
          },
          "domains": {
            "type": "array",
            "description": "Array of domains to check",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "name": "domain_nameservers",
      "description": "Update nameservers for a domain",
      "method": "GET",
      "path": "/domain-nameservers",
      "input_schema": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string",
            "description": "The domain name"
          },
          "nameservers": {
            "type": "array",
            "description": "Array of nameserver hostnames (minimum 2)",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "domain",
          "nameservers"
        ]
      }
    },
    {
      "name": "vps_list",
      "description": "List all VPS instances",
      "method": "GET",
      "path": "/vps-list",
      "input_schema": {
        "type": "object",
        "properties": {
          "page": {
            "type": "number",
            "description": "Page number for pagination"
          },
          "limit": {
            "type": "number",
            "description": "Number of results per page"
          }
        }
      }
    },
    {
      "name": "vps_get",
      "description": "Get details for a specific VPS instance",
      "method": "GET",
      "path": "/vps-get",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "description": "VPS instance ID"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    {
      "name": "vps_start",
      "description": "Power on a VPS instance",
      "method": "GET",
      "path": "/vps-start",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "description": "VPS instance ID"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    {
      "name": "vps_stop",
      "description": "Power off a VPS instance",
      "method": "GET",
      "path": "/vps-stop",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "description": "VPS instance ID"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    {
      "name": "vps_restart",
      "description": "Reboot a VPS instance",
      "method": "GET",
      "path": "/vps-restart",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "description": "VPS instance ID"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    {
      "name": "vps_metrics",
      "description": "Get performance metrics for a VPS instance",
      "method": "GET",
      "path": "/vps-metrics",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "description": "VPS instance ID"
          },
          "date_from": {
            "type": "string",
            "description": "Start date for metrics (ISO 8601 format)"
          },
          "date_to": {
            "type": "string",
            "description": "End date for metrics (ISO 8601 format)"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    {
      "name": "billing_subscriptions",
      "description": "List billing subscriptions",
      "method": "GET",
      "path": "/billing-subscriptions",
      "input_schema": {
        "type": "object",
        "properties": {
          "page": {
            "type": "number",
            "description": "Page number for pagination"
          },
          "limit": {
            "type": "number",
            "description": "Number of results per page"
          }
        }
      }
    }
  ]
}
