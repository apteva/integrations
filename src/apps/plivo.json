{
  "slug": "plivo",
  "name": "Plivo",
  "description": "Plivo Voice API for inbound and outbound AI calls, phone-number inventory, Voice Applications, signed call control, bidirectional audio streaming, and cloud recordings.",
  "logo": "https://www.google.com/s2/favicons?domain=plivo.com&sz=128",
  "categories": [
    "voice",
    "calls",
    "telephony",
    "phone",
    "communications",
    "numbers",
    "ai"
  ],
  "base_url": "https://api.plivo.com/v1/Account/{{auth_id}}",
  "auth": {
    "types": [
      "basic"
    ],
    "headers": {
      "Authorization": "Basic {{basic_auth}}",
      "Content-Type": "application/json",
      "Accept": "application/json"
    },
    "credential_fields": [
      {
        "name": "username",
        "label": "Auth ID",
        "description": "Plivo Auth ID. Also used as the HTTP Basic username.",
        "required": true
      },
      {
        "name": "password",
        "label": "Auth Token",
        "description": "Plivo Auth Token. Also used as the HTTP Basic password.",
        "type": "password",
        "required": true
      },
      {
        "name": "auth_id",
        "label": "Auth ID",
        "description": "Same Plivo Auth ID, used in REST paths.",
        "required": true
      },
      {
        "name": "phone_number",
        "label": "Default From Number",
        "description": "Default Plivo phone number to call from, in E.164 format."
      }
    ]
  },
  "health_check": {
    "tool": "list_calls",
    "input": {
      "limit": 1
    }
  },
  "tools": [
    {
      "name": "search_phone_numbers",
      "description": "Search Plivo phone-number inventory by country, type, capability, region, city, or number pattern.",
      "method": "GET",
      "path": "/PhoneNumber/",
      "input_schema": {
        "type": "object",
        "properties": {
          "country_iso": { "type": "string", "description": "ISO alpha-2 country code." },
          "type": { "type": "string", "enum": ["local", "mobile", "national", "tollfree"] },
          "services": { "type": "string", "description": "Required capabilities, e.g. voice or voice,sms." },
          "pattern": { "type": "string", "description": "Optional number pattern." },
          "region": { "type": "string" },
          "city": { "type": "string" },
          "limit": { "type": "integer", "default": 20 },
          "offset": { "type": "integer", "default": 0 }
        },
        "required": ["country_iso"]
      }
    },
    {
      "name": "get_number_pricing",
      "description": "Retrieve Plivo account pricing for number rental, setup, and inbound voice in one country.",
      "method": "GET",
      "path": "/Pricing/",
      "input_schema": {
        "type": "object",
        "properties": {
          "country_iso": { "type": "string", "description": "ISO alpha-2 country code." }
        },
        "required": ["country_iso"]
      }
    },
    {
      "name": "buy_phone_number",
      "description": "Rent an available Plivo phone number. This creates a recurring charge.",
      "method": "POST",
      "path": "/PhoneNumber/{number}/",
      "input_schema": {
        "type": "object",
        "properties": {
          "number": { "type": "string", "description": "Available phone number from search results." },
          "app_id": { "type": "string", "description": "Optional Plivo application id to assign." }
        },
        "required": ["number"]
      }
    },
    {
      "name": "list_owned_phone_numbers",
      "description": "List phone numbers rented by this Plivo account, including their assigned Voice applications.",
      "method": "GET",
      "path": "/Number/",
      "input_schema": {
        "type": "object",
        "properties": {
          "number_startswith": { "type": "string" },
          "subaccount": { "type": "string" },
          "services": { "type": "string" },
          "type": { "type": "string" },
          "limit": { "type": "integer" },
          "offset": { "type": "integer" }
        }
      }
    },
    {
      "name": "get_owned_phone_number",
      "description": "Retrieve one phone number rented by this Plivo account.",
      "method": "GET",
      "path": "/Number/{number}/",
      "input_schema": {
        "type": "object",
        "properties": { "number": { "type": "string" } },
        "required": ["number"]
      }
    },
    {
      "name": "update_owned_phone_number",
      "description": "Assign a Plivo Application or alias to a rented phone number.",
      "method": "POST",
      "path": "/Number/{number}/",
      "input_schema": {
        "type": "object",
        "properties": {
          "number": { "type": "string" },
          "app_id": { "type": "string" },
          "alias": { "type": "string" },
          "subaccount": { "type": "string" }
        },
        "required": ["number"]
      }
    },
    {
      "name": "create_application",
      "description": "Create a Plivo Voice Application for inbound call control.",
      "method": "POST",
      "path": "/Application/",
      "input_schema": {
        "type": "object",
        "properties": {
          "app_name": { "type": "string" },
          "answer_url": { "type": "string" },
          "answer_method": { "type": "string", "enum": ["GET", "POST"] },
          "hangup_url": { "type": "string" },
          "hangup_method": { "type": "string", "enum": ["GET", "POST"] },
          "fallback_answer_url": { "type": "string" },
          "fallback_method": { "type": "string", "enum": ["GET", "POST"] }
        },
        "required": ["app_name", "answer_url"]
      }
    },
    {
      "name": "get_application",
      "description": "Retrieve a Plivo Voice Application.",
      "method": "GET",
      "path": "/Application/{app_id}/",
      "input_schema": {
        "type": "object",
        "properties": { "app_id": { "type": "string" } },
        "required": ["app_id"]
      }
    },
    {
      "name": "delete_application",
      "description": "Delete a Plivo Voice Application.",
      "method": "DELETE",
      "path": "/Application/{app_id}/",
      "input_schema": {
        "type": "object",
        "properties": { "app_id": { "type": "string" } },
        "required": ["app_id"]
      }
    },
    {
      "name": "make_call",
      "description": "Place an outbound Plivo call. For AI voice agents, answer_url should return Plivo XML with a bidirectional <Stream> element pointing to the Telephony WebSocket.",
      "method": "POST",
      "path": "/Call/",
      "input_schema": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "description": "Plivo number to call from, in E.164 format."
          },
          "to": {
            "type": "string",
            "description": "Destination phone number in E.164 format."
          },
          "answer_url": {
            "type": "string",
            "description": "HTTPS URL returning Plivo XML call-control instructions."
          },
          "answer_method": {
            "type": "string",
            "enum": [
              "GET",
              "POST"
            ],
            "default": "POST"
          },
          "hangup_url": {
            "type": "string"
          },
          "hangup_method": {
            "type": "string",
            "enum": [
              "GET",
              "POST"
            ],
            "default": "POST"
          },
          "ring_url": {
            "type": "string",
            "description": "HTTPS callback invoked when the destination starts ringing; includes the live CallUUID."
          },
          "ring_method": {
            "type": "string",
            "enum": [
              "GET",
              "POST"
            ],
            "default": "POST"
          },
          "time_limit": {
            "type": "integer"
          },
          "ring_timeout": {
            "type": "integer"
          }
        },
        "required": [
          "from",
          "to",
          "answer_url"
        ]
      },
      "mock_response": {
        "api_id": "mock-api-id",
        "message": "call fired",
        "request_uuid": "mock-request-uuid"
      }
    },
    {
      "name": "update_call",
      "description": "Redirect or transfer an active Plivo call by making it fetch new XML.",
      "method": "POST",
      "path": "/Call/{call_uuid}/",
      "input_schema": {
        "type": "object",
        "properties": {
          "call_uuid": {
            "type": "string"
          },
          "legs": {
            "type": "string",
            "enum": [
              "aleg",
              "bleg",
              "both"
            ],
            "default": "aleg"
          },
          "aleg_url": {
            "type": "string"
          },
          "aleg_method": {
            "type": "string",
            "enum": [
              "GET",
              "POST"
            ]
          },
          "bleg_url": {
            "type": "string"
          },
          "bleg_method": {
            "type": "string",
            "enum": [
              "GET",
              "POST"
            ]
          }
        },
        "required": [
          "call_uuid"
        ]
      }
    },
    {
      "name": "hangup_call",
      "description": "Hang up an active Plivo call.",
      "method": "DELETE",
      "path": "/Call/{call_uuid}/",
      "input_schema": {
        "type": "object",
        "properties": {
          "call_uuid": {
            "type": "string"
          }
        },
        "required": [
          "call_uuid"
        ]
      }
    },
    {
      "name": "start_stream",
      "description": "Start an audio stream on an active Plivo call using the Audio Streams API.",
      "method": "POST",
      "path": "/Call/{call_uuid}/Stream/",
      "input_schema": {
        "type": "object",
        "properties": {
          "call_uuid": {
            "type": "string"
          },
          "service_url": {
            "type": "string",
            "description": "WebSocket URL that receives call audio."
          },
          "bidirectional": {
            "type": "boolean",
            "default": true
          },
          "audio_track": {
            "type": "string",
            "enum": [
              "inbound",
              "outbound",
              "both"
            ],
            "default": "inbound"
          },
          "content_type": {
            "type": "string",
            "description": "Audio content type, for example audio/x-mulaw;rate=8000."
          },
          "status_callback_url": {
            "type": "string"
          }
        },
        "required": [
          "call_uuid",
          "service_url"
        ]
      }
    },
    {
      "name": "stop_stream",
      "description": "Stop one Plivo audio stream.",
      "method": "DELETE",
      "path": "/Call/{call_uuid}/Stream/{stream_id}/",
      "input_schema": {
        "type": "object",
        "properties": {
          "call_uuid": {
            "type": "string"
          },
          "stream_id": {
            "type": "string"
          }
        },
        "required": [
          "call_uuid",
          "stream_id"
        ]
      }
    },
    {
      "name": "list_calls",
      "description": "List Plivo calls.",
      "method": "GET",
      "path": "/Call/",
      "input_schema": {
        "type": "object",
        "properties": {
          "from_number": {
            "type": "string"
          },
          "to_number": {
            "type": "string"
          },
          "call_direction": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          },
          "offset": {
            "type": "integer"
          }
        }
      }
    },
    {
      "name": "list_recordings",
      "description": "List Plivo call recordings, optionally filtered by call UUID.",
      "method": "GET",
      "path": "/Recording/",
      "input_schema": {
        "type": "object",
        "properties": {
          "call_uuid": { "type": "string" },
          "limit": { "type": "integer" },
          "offset": { "type": "integer" }
        }
      }
    },
    {
      "name": "get_recording",
      "description": "Retrieve a Plivo call recording and its media URL.",
      "method": "GET",
      "path": "/Recording/{recording_id}/",
      "input_schema": {
        "type": "object",
        "properties": { "recording_id": { "type": "string" } },
        "required": ["recording_id"]
      }
    },
    {
      "name": "delete_recording",
      "description": "Delete a Plivo call recording.",
      "method": "DELETE",
      "path": "/Recording/{recording_id}/",
      "input_schema": {
        "type": "object",
        "properties": { "recording_id": { "type": "string" } },
        "required": ["recording_id"]
      }
    }
  ]
}
