{
  "slug": "sendgrid-email",
  "name": "SendGrid",
  "description": "MCP server for SendGrid email delivery, template management, and email analytics",
  "logo": "https://www.google.com/s2/favicons?domain=sendgrid.com&sz=128",
  "categories": [
    "sendgrid",
    "email",
    "delivery",
    "templates",
    "marketing"
  ],
  "base_url": "",
  "auth": {
    "types": [
      "bearer"
    ],
    "headers": {
      "Authorization": "Bearer {{token}}"
    },
    "credential_fields": [
      {
        "name": "token",
        "label": "API Key"
      }
    ]
  },
  "tools": [
    {
      "name": "send_email",
      "description": "Send an email via SendGrid",
      "method": "POST",
      "path": "/send-email",
      "input_schema": {
        "type": "object",
        "properties": {
          "to": {
            "type": "array",
            "description": "Recipient email addresses",
            "items": {
              "type": "object",
              "properties": {
                "email": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                }
              }
            }
          },
          "from": {
            "type": "object",
            "description": "Sender information",
            "properties": {
              "email": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            }
          },
          "subject": {
            "type": "string",
            "description": "Email subject"
          },
          "content": {
            "type": "array",
            "description": "Email content",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string"
                },
                "value": {
                  "type": "string"
                }
              }
            }
          },
          "html": {
            "type": "string",
            "description": "HTML content"
          },
          "text": {
            "type": "string",
            "description": "Plain text content"
          },
          "template_id": {
            "type": "string",
            "description": "SendGrid template ID"
          },
          "dynamic_template_data": {
            "type": "object",
            "description": "Template variables"
          }
        },
        "required": [
          "to",
          "from",
          "subject"
        ]
      }
    },
    {
      "name": "create_template",
      "description": "Create a new email template in SendGrid",
      "method": "POST",
      "path": "/create-template",
      "input_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Template name"
          },
          "generation": {
            "type": "string",
            "description": "Template generation",
            "enum": [
              "legacy",
              "dynamic"
            ],
            "default": "dynamic"
          }
        },
        "required": [
          "name"
        ]
      }
    },
    {
      "name": "get_templates",
      "description": "Retrieve email templates from SendGrid",
      "method": "GET",
      "path": "/get-templates",
      "input_schema": {
        "type": "object",
        "properties": {
          "generations": {
            "type": "string",
            "description": "Template generation filter",
            "enum": [
              "legacy",
              "dynamic"
            ]
          },
          "page_size": {
            "type": "integer",
            "description": "Number of templates per page",
            "default": 200,
            "maximum": 200
          }
        }
      }
    },
    {
      "name": "add_contact",
      "description": "Add a contact to SendGrid",
      "method": "GET",
      "path": "/add-contact",
      "input_schema": {
        "type": "object",
        "properties": {
          "contacts": {
            "type": "array",
            "description": "Contact information",
            "items": {
              "type": "object",
              "properties": {
                "email": {
                  "type": "string"
                },
                "first_name": {
                  "type": "string"
                },
                "last_name": {
                  "type": "string"
                },
                "custom_fields": {
                  "type": "object"
                }
              }
            }
          },
          "list_ids": {
            "type": "array",
            "description": "List IDs to add contacts to",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "contacts"
        ]
      }
    },
    {
      "name": "get_stats",
      "description": "Retrieve email delivery statistics from SendGrid",
      "method": "GET",
      "path": "/get-stats",
      "input_schema": {
        "type": "object",
        "properties": {
          "start_date": {
            "type": "string",
            "description": "Start date (YYYY-MM-DD)"
          },
          "end_date": {
            "type": "string",
            "description": "End date (YYYY-MM-DD)"
          },
          "aggregated_by": {
            "type": "string",
            "description": "Aggregation method",
            "enum": [
              "day",
              "week",
              "month"
            ]
          }
        },
        "required": [
          "start_date"
        ]
      }
    }
  ]
}
