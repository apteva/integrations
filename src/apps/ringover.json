      "path": "/calls/{call_id}",
      "input_schema": {
        "type": "object",
        "properties": {
          "call_id": {
            "type": "string",
            "description": "Ringover call ID."
          }
        },
        "required": [
          "call_id"
        ]
      }
    },
    {
      "name": "list_current_calls",
      "display_name": "List Current Calls",
      "description": "List live calls currently active in the team.",
      "method": "POST",
      "path": "/calls/current",
      "input_schema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "array",
            "description": "Live call statuses.",
            "items": {
              "type": "string",
              "enum": [
                "ANSWERED",
                "RINGING"
              ]
            }
          },
          "interface": {
            "type": "array",
            "description": "Call interfaces.",
            "items": {
              "type": "string",
              "enum": [
                "WEBRTC",
                "SIP",
                "MOBILE",
                "APP"
              ]
            }
          },
          "direction": {
            "type": "string",
            "description": "Call direction.",
            "enum": [
              "IN",
              "OUT"
            ]
          },
          "limit_count": {
            "type": "integer",
            "description": "Maximum number of calls to return."
          },
          "limit_offset": {
            "type": "integer",
            "description": "Offset for paginated results."
          }
        }
      }
    },
    {
