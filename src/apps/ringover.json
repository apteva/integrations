      "name": "create_contacts",
      "display_name": "Create Contacts",
      "description": "Create up to 50 Ringover contacts.",
      "method": "POST",
      "path": "/contacts",
      "input_schema": {
        "type": "object",
        "properties": {
          "contacts": {
            "type": "array",
            "description": "Contacts to create.",
            "items": {
              "type": "object",
              "properties": {
                "firstname": {
                  "type": "string"
