        "type": "object",
        "properties": {
          "channel_id": {
            "type": "string",
            "description": "Live call channel ID."
          },
          "dtmf": {
            "type": "string",
            "description": "DTMF sequence using digits, #, or *."
          }
        },
        "required": [
          "channel_id",
          "dtmf"
        ]
      }
    },
    {
      "name": "list_contacts",
      "display_name": "List Contacts",
