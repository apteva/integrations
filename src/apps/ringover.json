      "input_schema": {
        "type": "object",
        "properties": {
          "ivr_id": {
            "type": "integer",
            "description": "Ringover IVR ID."
          }
        },
        "required": [
          "ivr_id"
        ]
      }
    },
    {
      "name": "list_ivr_scenarios",
      "display_name": "List IVR Scenarios",
      "description": "List scenarios configured for an IVR.",
      "method": "GET",
      "path": "/ivrs/{ivr_id}/scenarios",
      "input_schema": {
        "type": "object",
        "properties": {
          "ivr_id": {
            "type": "integer",
            "description": "Ringover IVR ID."
          }
        },
        "required": [
          "ivr_id"
        ]
      }
    },
    {
      "name": "list_tags",
      "display_name": "List Tags",
      "description": "List call/contact tags.",
      "method": "GET",
      "path": "/tags"
    },
    {
      "name": "create_tag",
      "display_name": "Create Tag",
      "description": "Create a Ringover tag.",
      "method": "POST",
      "path": "/tags",
      "input_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Tag name."
          },
          "color": {
            "type": "string",
            "description": "Tag color."
          },
          "description": {
            "type": "string",
            "description": "Optional tag description."
          }
        },
        "required": [
          "name"
        ]
      }
    },
    {
      "name": "list_calls",
      "display_name": "List Calls",
      "description": "List call history with common filters.",
      "method": "GET",
      "path": "/calls",
      "input_schema": {
        "type": "object",
        "properties": {
          "start_date": {
            "type": "string",
            "description": "Start date/time filter."
          },
          "end_date": {
            "type": "string",
            "description": "End date/time filter."
          },
          "call_type": {
            "type": "string",
            "description": "Call type filter.",
            "enum": [
              "ANSWERED",
              "MISSED",
              "OUT",
              "VOICEMAIL"
            ]
          },
          "limit_count": {
            "type": "integer",
            "description": "Maximum number of calls to return."
          },
          "limit_offset": {
            "type": "integer",
            "description": "Offset for paginated results."
          },
          "last_id_returned": {
            "type": "integer",
            "description": "Last call ID returned by a previous request."
          }
        }
      }
    },
    {
      "name": "search_calls",
      "display_name": "Search Calls",
      "description": "Search call history with richer filters.",
      "method": "POST",
      "path": "/calls",
      "input_schema": {
        "type": "object",
        "properties": {
          "filter": {
            "type": "string",
            "description": "Text filter for calls."
          },
          "call_type": {
            "type": "array",
            "description": "Call type filters.",
            "items": {
              "type": "string",
              "enum": [
                "ANSWERED",
                "MISSED",
                "OUT",
                "VOICEMAIL"
              ]
            }
          },
          "start_date": {
            "type": "string",
            "description": "Start date/time filter."
          },
          "end_date": {
            "type": "string",
            "description": "End date/time filter."
          },
          "users": {
            "type": "array",
            "description": "User IDs to include.",
            "items": {
              "type": "integer"
            }
          },
          "groups": {
            "type": "array",
            "description": "Group IDs to include.",
            "items": {
              "type": "integer"
            }
          },
          "contacts": {
            "type": "array",
            "description": "Contact IDs to include.",
            "items": {
              "type": "integer"
            }
          },
          "tags": {
            "type": "array",
            "description": "Tag IDs to include.",
            "items": {
              "type": "integer"
            }
          },
          "stars": {
            "type": "array",
            "description": "Star ratings to include.",
            "items": {
              "type": "integer"
            }
          },
          "limit_count": {
            "type": "integer",
            "description": "Maximum number of calls to return."
          },
          "limit_offset": {
            "type": "integer",
            "description": "Offset for paginated results."
          },
          "last_id_returned": {
            "type": "integer",
            "description": "Last call ID returned by a previous request."
          }
        }
      }
    },
    {
      "name": "get_call",
      "display_name": "Get Call",
      "description": "Get details for one call.",
      "method": "GET",
      "path": "/calls/{call_id}",
      "input_schema": {
        "type": "object",
        "properties": {
          "call_id": {
            "type": "string",
