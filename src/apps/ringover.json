          }
        },
        "required": [
          "group_id"
        ]
      }
    },
    {
      "name": "list_ivrs",
      "display_name": "List IVRs",
      "description": "List Ringover IVRs.",
      "method": "GET",
      "path": "/ivrs"
    },
    {
      "name": "get_ivr",
