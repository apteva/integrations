      "path": "/course_lessons/{id}",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "lesson_type": { "type": "string", "enum": ["text", "video", "pdf", "multi", "quiz", "knowledge_check"] },
