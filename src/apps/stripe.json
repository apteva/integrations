{
  "slug": "stripe",
  "name": "Stripe",
  "description": "MCP server for Stripe payments - customers, payments, subscriptions, invoices",
  "logo": "https://www.google.com/s2/favicons?domain=stripe.com&sz=128",
  "categories": [
    "payments",
    "finance",
    "subscriptions",
    "billing"
  ],
  "base_url": "https://api.stripe.com/v1",
  "auth": {
    "types": [
      "bearer"
    ],
    "headers": {
      "Authorization": "Bearer {{token}}"
    },
    "credential_fields": [
      {
        "name": "token",
        "label": "Secret Key",
        "description": "Your Stripe Secret Key (sk_live_ or sk_test_)"
      }
    ]
  },
  "tools": [
    {
      "name": "create_customer",
      "description": "Create a new customer",
      "method": "POST",
      "path": "/create-customer",
      "input_schema": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "metadata": {
            "type": "object"
          }
        },
        "required": [
          "email"
        ]
      }
    },
    {
      "name": "get_customer",
      "description": "Get customer details",
      "method": "GET",
      "path": "/get-customer",
      "input_schema": {
        "type": "object",
        "properties": {
          "customer_id": {
            "type": "string"
          }
        },
        "required": [
          "customer_id"
        ]
      }
    },
    {
      "name": "update_customer",
      "description": "Update customer details",
      "method": "PUT",
      "path": "/update-customer",
      "input_schema": {
        "type": "object",
        "properties": {
          "customer_id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "customer_id"
        ]
      }
    },
    {
      "name": "delete_customer",
      "description": "Delete a customer",
      "method": "DELETE",
      "path": "/delete-customer",
      "input_schema": {
        "type": "object",
        "properties": {
          "customer_id": {
            "type": "string"
          }
        },
        "required": [
          "customer_id"
        ]
      }
    },
    {
      "name": "search_customers",
      "description": "Search for customers",
      "method": "GET",
      "path": "/search-customers",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "limit": {
            "type": "number"
          }
        },
        "required": [
          "query"
        ]
      }
    },
    {
      "name": "create_payment_intent",
      "description": "Create a payment intent",
      "method": "POST",
      "path": "/create-payment-intent",
      "input_schema": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number"
          },
          "currency": {
            "type": "string"
          },
          "customer": {
            "type": "string"
          }
        },
        "required": [
          "amount",
          "currency"
        ]
      }
    },
    {
      "name": "get_payment_intent",
      "description": "Get payment intent details",
      "method": "GET",
      "path": "/get-payment-intent",
      "input_schema": {
        "type": "object",
        "properties": {
          "payment_intent_id": {
            "type": "string"
          }
        },
        "required": [
          "payment_intent_id"
        ]
      }
    },
    {
      "name": "cancel_payment_intent",
      "description": "Cancel a payment intent",
      "method": "GET",
      "path": "/cancel-payment-intent",
      "input_schema": {
        "type": "object",
        "properties": {
          "payment_intent_id": {
            "type": "string"
          }
        },
        "required": [
          "payment_intent_id"
        ]
      }
    },
    {
      "name": "list_payment_intents",
      "description": "List payment intents",
      "method": "GET",
      "path": "/list-payment-intents",
      "input_schema": {
        "type": "object",
        "properties": {
          "customer": {
            "type": "string"
          },
          "limit": {
            "type": "number"
          }
        }
      }
    },
    {
      "name": "create_subscription",
      "description": "Create a subscription",
      "method": "POST",
      "path": "/create-subscription",
      "input_schema": {
        "type": "object",
        "properties": {
          "customer": {
            "type": "string"
          },
          "items": {
            "type": "array"
