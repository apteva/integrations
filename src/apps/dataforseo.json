{
  "slug": "dataforseo",
  "name": "DataForSEO",
  "description": "Complete SEO data platform — SERP tracking, keyword research, backlink analysis, on-page audits, competitor intelligence, content analysis, domain insights, and AI optimization",
  "logo": "https://cdn-icons-png.flaticon.com/512/2103/2103633.png",
  "categories": [
    "seo",
    "serp",
    "keywords",
    "backlinks",
    "competitors",
    "analytics",
    "domain-analysis",
    "rank-tracking",
    "content-analysis",
    "ai-optimization"
  ],
  "base_url": "https://api.dataforseo.com/v3",
  "auth": {
    "types": [
      "bearer"
    ],
    "headers": {
      "Authorization": "Bearer {{token}}"
    },
    "credential_fields": [
      {
        "name": "login",
        "label": "Login",
        "description": "Your DataForSEO API login email"
      },
      {
        "name": "password",
        "label": "Password",
        "description": "Your DataForSEO API password"
      }
    ]
  },
  "tools": [
    {
      "name": "keyword_search_volume",
      "description": "Get search volume, competition, CPC data, and monthly trends for keywords via Google Ads API. Max 1000 keywords per request.",
      "method": "POST",
      "path": "/keywords_data/google_ads/search_volume/live",
      "input_schema": {
        "type": "object",
        "properties": {
          "keywords": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of keywords to analyze (max 1000)"
          },
          "location_name": {
            "type": "string",
            "description": "Target location name (e.g., 'United States')"
          },
          "location_code": {
            "type": "integer",
            "description": "Target location code (e.g., 2840 for US)"
          },
          "language_code": {
            "type": "string",
            "description": "Language code (e.g., 'en')"
          },
          "sort_by": {
            "type": "string",
            "enum": [
              "relevance",
              "search_volume",
              "competition_index"
            ],
            "description": "Sort results by field"
          }
        },
        "required": [
          "keywords"
        ]
      }
    },
    {
      "name": "keyword_suggestions",
      "description": "Get keyword suggestions and ideas based on seed keywords from Google Ads data, with search volume and competition metrics",
      "method": "POST",
      "path": "/keywords_data/google_ads/keywords_for_keywords/live",
      "input_schema": {
        "type": "object",
        "properties": {
          "keywords": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of seed keywords (max 20)"
          },
          "location_code": {
            "type": "integer",
            "description": "Target location code (e.g., 2840 for US)"
          },
          "language_code": {
            "type": "string",
            "description": "Language code (e.g., 'en')"
          },
          "sort_by": {
            "type": "string",
            "enum": [
              "relevance",
              "search_volume",
              "competition_index"
            ],
            "description": "Sort results"
          }
        },
        "required": [
          "keywords"
        ]
      }
    },
    {
      "name": "keyword_ideas",
      "description": "Get keyword ideas from DataForSEO Labs database with keyword difficulty, search volume, and SERP features",
      "method": "POST",
      "path": "/dataforseo_labs/google/keyword_ideas/live",
      "input_schema": {
        "type": "object",
        "properties": {
          "keywords": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Seed keywords"
          },
          "location_code": {
            "type": "integer",
            "description": "Location code (e.g., 2840 for US)"
          },
          "language_code": {
            "type": "string",
            "description": "Language code (e.g., 'en')"
          },
          "include_seed_keyword": {
            "type": "boolean",
            "default": true,
            "description": "Include seed keyword in results"
          },
          "limit": {
            "type": "integer",
            "default": 100,
            "description": "Max results"
          },
          "offset": {
            "type": "integer",
            "default": 0,
            "description": "Pagination offset"
          }
        },
        "required": [
          "keywords"
        ]
      }
    },
