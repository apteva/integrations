            "type": "string",
            "description": "Pagination token for next page"
          }
        },
        "required": [
          "user_id"
        ]
      }
    },
    {
      "name": "block_user",
      "description": "Block a user. Blocked users cannot follow you or view your posts.",
      "method": "POST",
      "path": "/2/users/{user_id}/blocking",
      "input_schema": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "string",
            "description": "The authenticated user's ID"
          },
          "target_user_id": {
            "type": "string",
            "description": "The user ID to block"
          }
        },
        "required": [
          "user_id",
          "target_user_id"
        ]
      }
    },
    {
      "name": "unblock_user",
      "description": "Unblock a previously blocked user",
      "method": "DELETE",
      "path": "/2/users/{user_id}/blocking/{target_user_id}",
      "input_schema": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "string",
            "description": "The authenticated user's ID"
          },
          "target_user_id": {
            "type": "string",
            "description": "The user ID to unblock"
          }
        },
        "required": [
          "user_id",
          "target_user_id"
        ]
      }
    },
    {
      "name": "get_blocked_users",
      "description": "Get the list of users the authenticated user has blocked",
      "method": "GET",
      "path": "/2/users/{user_id}/blocking",
      "input_schema": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "string",
            "description": "The authenticated user's ID"
          },
          "max_results": {
            "type": "integer",
            "description": "Number of results (1-1000)",
            "default": 100,
            "minimum": 1,
            "maximum": 1000
          },
          "user.fields": {
            "type": "string",
            "description": "Comma-separated user fields",
            "default": "id,name,username,description,profile_image_url,public_metrics"
          },
          "pagination_token": {
            "type": "string",
            "description": "Pagination token for next page"
          }
        },
        "required": [
          "user_id"
        ]
      }
    },
    {
      "name": "send_dm",
      "description": "Send a direct message to a specific user. Creates a one-on-one DM conversation if one doesn't exist.",
      "method": "POST",
      "path": "/2/dm_conversations/with/{participant_id}/messages",
      "input_schema": {
        "type": "object",
        "properties": {
          "participant_id": {
            "type": "string",
            "description": "The user ID of the person to send the DM to"
          },
          "text": {
            "type": "string",
            "description": "The text content of the direct message"
          }
        },
        "required": [
          "participant_id",
          "text"
        ]
      }
    },
    {
      "name": "send_dm_to_conversation",
      "description": "Send a direct message to an existing DM conversation (one-on-one or group). Use the conversation ID from a previous DM lookup.",
      "method": "POST",
      "path": "/2/dm_conversations/{dm_conversation_id}/messages",
      "input_schema": {
        "type": "object",
        "properties": {
          "dm_conversation_id": {
            "type": "string",
            "description": "The DM conversation ID (numeric string or pair like '123-456')"
          },
          "text": {
            "type": "string",
            "description": "The text content of the direct message"
          }
        },
        "required": [
          "dm_conversation_id",
          "text"
        ]
      }
    },
    {
      "name": "get_dm_events",
      "description": "Get recent direct message events for the authenticated user, including messages from one-on-one and group conversations",
      "method": "GET",
      "path": "/2/dm_events",
      "input_schema": {
        "type": "object",
        "properties": {
          "max_results": {
            "type": "integer",
            "description": "Number of results (1-100)",
            "default": 100,
            "minimum": 1,
            "maximum": 100
          },
          "pagination_token": {
            "type": "string",
            "description": "Pagination token for next page"
          },
          "event_types": {
            "type": "string",
            "description": "Comma-separated event types: MessageCreate,ParticipantsJoin,ParticipantsLeave",
            "default": "MessageCreate"
          },
          "dm_event.fields": {
            "type": "string",
            "description": "Comma-separated DM event fields",
            "default": "id,text,event_type,created_at,dm_conversation_id,sender_id"
          },
          "expansions": {
            "type": "string",
            "description": "Comma-separated expansions",
            "default": "sender_id"
          },
          "user.fields": {
            "type": "string",
            "description": "Comma-separated user fields for expanded users",
            "default": "id,name,username,profile_image_url"
          }
        }
      }
    },
    {
      "name": "upload_media",
      "description": "Upload an image or subtitle file (up to 5MB) in a single request. Returns a media_id to use when posting a tweet with media. Supported: JPEG, PNG, WEBP, GIF (static), SRT, VTT.",
      "method": "POST",
      "path": "/2/media/upload",
      "input_schema": {
        "type": "object",
        "properties": {
          "media": {
            "type": "string",
            "description": "Base64-encoded media file data"
          },
          "media_category": {
            "type": "string",
            "enum": [
              "tweet_image",
              "dm_image",
              "subtitles"
            ],
            "description": "Media category determining upload constraints",
            "default": "tweet_image"
          },
          "media_type": {
            "type": "string",
            "enum": [
              "image/jpeg",
              "image/png",
              "image/webp",
              "image/gif",
              "text/srt",
              "text/vtt"
            ],
            "description": "MIME type of the media file"
          },
          "additional_owners": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "User IDs who can use this media"
          }
        },
        "required": [
          "media",
          "media_category"
        ]
      }
    },
    {
      "name": "upload_init",
      "description": "Initialize a chunked media upload for videos, animated GIFs, or large files. Returns a media_id to use with append and finalize. Limits: images up to 5MB, GIFs up to 15MB, videos up to 512MB.",
      "method": "POST",
      "path": "/2/media/upload/initialize",
      "input_schema": {
        "type": "object",
        "properties": {
          "total_bytes": {
            "type": "integer",
            "description": "Total file size in bytes"
          },
          "media_type": {
            "type": "string",
            "description": "MIME type (e.g., video/mp4, image/gif, video/quicktime)"
          },
          "media_category": {
            "type": "string",
            "enum": [
              "tweet_image",
              "tweet_gif",
              "tweet_video",
              "amplify_video",
              "dm_gif",
              "dm_image",
              "dm_video"
            ],
            "description": "Media category"
          },
          "additional_owners": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "User IDs who can use this media"
          },
          "shared": {
            "type": "boolean",
            "description": "Whether media is shared",
            "default": false
          }
        },
        "required": [
          "total_bytes",
          "media_type",
          "media_category"
        ]
      }
    },
    {
      "name": "upload_append",
      "description": "Append a chunk of data to an in-progress chunked upload. Call sequentially with incrementing segment_index (starting at 0) until all data is uploaded.",
      "method": "POST",
      "path": "/2/media/upload/{media_id}/append",
      "input_schema": {
        "type": "object",
        "properties": {
          "media_id": {
            "type": "string",
            "description": "Media ID returned from the initialize step"
          },
          "segment_index": {
            "type": "integer",
            "description": "Chunk index (0-based, sequential)"
          },
          "media": {
            "type": "string",
            "description": "Base64-encoded chunk data"
          }
        },
        "required": [
          "media_id",
          "segment_index",
          "media"
        ]
      }
    },
    {
      "name": "upload_finalize",
      "description": "Finalize a chunked media upload after all chunks have been appended. If response includes processing_info with state 'pending' or 'in_progress', wait check_after_secs then check status again. Once state is 'succeeded', use the media_id to post a tweet.",
      "method": "POST",
      "path": "/2/media/upload/{media_id}/finalize",
      "input_schema": {
        "type": "object",
        "properties": {
          "media_id": {
            "type": "string",
            "description": "Media ID from the initialize step"
          }
        },
        "required": [
          "media_id"
        ]
      }
    },
    {
      "name": "get_tweet_analytics",
      "description": "Get engagement metrics for one or more tweets. Returns public_metrics (impressions, likes, retweets, replies, quotes, bookmarks) and optionally non_public_metrics and organic_metrics (requires tweet owner auth). Up to 100 tweet IDs per request.\n\nExample:\n{\n  \"tweetIds\": [\"1234567890\", \"0987654321\"],\n  \"include_non_public\": true\n}",
      "method": "GET",
      "path": "/get-tweet-analytics",
      "input_schema": {
        "type": "object",
        "properties": {
          "tweetIds": {
            "type": "array",
            "description": "Array of tweet IDs to get analytics for (max 100)",
            "items": {
              "type": "string"
            },
            "maxItems": 100
          },
          "tweetId": {
            "type": "string",
            "description": "Single tweet ID (alternative to tweetIds array)"
          },
          "include_non_public": {
            "type": "boolean",
            "description": "Include non_public_metrics and organic_metrics (requires tweet owner authentication)",
            "default": false
          }
        }
      }
    },
    {
      "name": "get_account_analytics",
      "description": "Get account-level analytics for an X/Twitter user. Returns profile public_metrics (followers, following, tweet count, listed count) and optionally aggregated engagement metrics from recent original tweets (total impressions, likes, retweets, replies, quotes, bookmarks, and average engagement rate).\n\nExample:\n{\n  \"userId\": \"1234567890\",\n  \"include_recent_tweets\": true,\n  \"recent_tweet_count\": 20\n}",
      "method": "GET",
      "path": "/get-account-analytics",
      "input_schema": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "description": "X/Twitter user ID"
          },
          "include_recent_tweets": {
            "type": "boolean",
            "description": "Include recent tweets and engagement summary",
            "default": true
          },
          "recent_tweet_count": {
            "type": "integer",
            "description": "Number of recent tweets to analyze (max 100)",
            "default": 10
          }
        },
        "required": [
          "userId"
        ]
      }
    }
  ]
}
