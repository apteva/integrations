{
  "slug": "twitter-api",
  "name": "X / Twitter API",
  "description": "X API v2 - post tweets, manage followers, search, timelines, likes, retweets, bookmarks, DMs, mutes, and blocks via OAuth2",
  "logo": "https://www.google.com/s2/favicons?domain=x.com&sz=128",
  "categories": [
    "twitter",
    "x",
    "social-media",
    "tweets",
    "oauth2"
  ],
  "base_url": "https://api.x.com",
  "auth": {
    "types": [
      "bearer",
      "oauth2"
    ],
    "headers": {
      "Authorization": "Bearer {{token}}"
    },
    "credential_fields": [
      {
        "name": "token",
        "label": "access_token"
      },
      {
        "name": "refresh_token",
        "label": "refresh_token"
      },
      {
        "name": "expires_in",
        "label": "expires_in"
      },
      {
        "name": "scope",
        "label": "scope"
      }
    ],
    "oauth2": {
      "authorize_url": "https://twitter.com/i/oauth2/authorize",
      "token_url": "https://api.twitter.com/2/oauth2/token",
      "scopes": [
        "tweet.read",
        "tweet.write",
        "tweet.moderate.write",
        "users.read",
        "follows.read",
        "follows.write",
        "offline.access",
        "space.read",
        "mute.read",
        "mute.write",
        "like.read",
        "like.write",
        "list.read",
        "list.write",
        "block.read",
        "block.write",
        "bookmark.read",
        "bookmark.write",
        "media.write",
        "dm.read",
        "dm.write"
      ],
      "client_id_required": true,
      "pkce": false
    }
  },
  "tools": [
    {
      "name": "get_me",
      "description": "Get the authenticated user's profile information including name, username, bio, follower counts, and verification status",
      "method": "GET",
      "path": "/2/users/me",
      "input_schema": {
        "type": "object",
        "properties": {
          "user.fields": {
            "type": "string",
            "description": "Comma-separated user fields to return",
            "default": "id,name,username,description,profile_image_url,public_metrics,verified,created_at"
          }
        }
      }
    },
    {
      "name": "get_user_by_username",
      "description": "Look up an X user by their username (handle) to get their profile info and user ID",
      "method": "GET",
      "path": "/2/users/by/username/{username}",
      "input_schema": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "description": "X username without the @ symbol"
          },
          "user.fields": {
            "type": "string",
            "description": "Comma-separated user fields to return",
            "default": "id,name,username,description,profile_image_url,public_metrics,verified,created_at"
          }
        },
        "required": [
          "username"
        ]
      }
    },
    {
      "name": "get_tweet",
      "description": "Get a single post by its ID with full details including metrics, author info, and referenced posts",
      "method": "GET",
      "path": "/2/tweets/{tweet_id}",
      "input_schema": {
        "type": "object",
        "properties": {
          "tweet_id": {
            "type": "string",
            "description": "The post ID to look up"
          },
          "tweet.fields": {
            "type": "string",
            "description": "Comma-separated tweet fields",
            "default": "id,text,author_id,created_at,public_metrics,conversation_id,in_reply_to_user_id,referenced_tweets,entities"
          },
          "expansions": {
            "type": "string",
            "description": "Comma-separated expansions",
            "default": "author_id,referenced_tweets.id"
          },
          "user.fields": {
            "type": "string",
            "description": "Comma-separated user fields for expanded users",
            "default": "id,name,username,profile_image_url,verified"
          }
        },
        "required": [
          "tweet_id"
        ]
      }
    },
    {
      "name": "post_tweet",
      "description": "Post a new tweet. Can include text, reply to another tweet, or quote tweet. Max 280 characters.",
      "method": "POST",
      "path": "/2/tweets",
      "input_schema": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "The text content of the tweet (max 280 characters)",
            "maxLength": 280
          },
          "reply": {
            "type": "object",
            "description": "Reply settings - include to make this a reply",
            "properties": {
              "in_reply_to_tweet_id": {
                "type": "string",
                "description": "Tweet ID to reply to"
              }
            },
            "required": [
              "in_reply_to_tweet_id"
            ]
          },
          "quote_tweet_id": {
            "type": "string",
            "description": "Tweet ID to quote"
          },
          "media": {
            "type": "object",
            "description": "Media attachments",
            "properties": {
              "media_ids": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Array of media IDs to attach (1-4)"
              }
            }
          }
        },
        "required": [
          "text"
        ]
      }
    },
    {
      "name": "delete_tweet",
      "description": "Delete a tweet by its ID. Must be the authenticated user's own tweet.",
      "method": "DELETE",
      "path": "/2/tweets/{tweet_id}",
      "input_schema": {
        "type": "object",
        "properties": {
          "tweet_id": {
            "type": "string",
            "description": "The tweet ID to delete"
          }
        },
        "required": [
          "tweet_id"
        ]
      }
    },
    {
      "name": "search_recent",
      "description": "Search for tweets from the last 7 days using X search operators. Supports advanced query syntax.",
      "method": "GET",
      "path": "/2/tweets/search/recent",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Search query (supports operators like from:, to:, #hashtag, @mention, lang:, is:retweet, etc.)"
          },
          "max_results": {
            "type": "integer",
            "description": "Number of results (10-100)",
            "default": 10,
            "minimum": 10,
            "maximum": 100
          },
          "tweet.fields": {
            "type": "string",
            "description": "Comma-separated tweet fields",
            "default": "id,text,author_id,created_at,public_metrics,entities"
          },
          "expansions": {
            "type": "string",
            "description": "Comma-separated expansions",
            "default": "author_id"
          },
          "user.fields": {
            "type": "string",
            "description": "Comma-separated user fields for expanded users",
            "default": "id,name,username,verified"
          },
          "next_token": {
            "type": "string",
            "description": "Pagination token for next page of results"
          },
          "start_time": {
            "type": "string",
            "description": "ISO 8601 start time for search window (e.g., 2024-01-01T00:00:00Z)"
          },
          "end_time": {
            "type": "string",
            "description": "ISO 8601 end time for search window"
          },
          "sort_order": {
            "type": "string",
            "enum": [
              "recency",
              "relevancy"
            ],
            "description": "Sort order for results"
          }
        },
        "required": [
          "query"
        ]
      }
    },
    {
      "name": "get_user_tweets",
      "description": "Get tweets posted by a specific user. Returns their timeline of original tweets and retweets.",
      "method": "GET",
      "path": "/2/users/{user_id}/tweets",
      "input_schema": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "string",
            "description": "The user ID whose tweets to retrieve"
          },
          "max_results": {
            "type": "integer",
            "description": "Number of results (5-100)",
            "default": 10,
            "minimum": 5,
            "maximum": 100
          },
          "tweet.fields": {
            "type": "string",
            "description": "Comma-separated tweet fields",
            "default": "id,text,created_at,public_metrics,entities,referenced_tweets"
          },
          "pagination_token": {
            "type": "string",
            "description": "Pagination token for next page"
          },
          "exclude": {
            "type": "string",
            "description": "Comma-separated types to exclude: retweets,replies"
          },
          "start_time": {
            "type": "string",
            "description": "ISO 8601 start time filter"
          },
          "end_time": {
            "type": "string",
            "description": "ISO 8601 end time filter"
          }
        },
        "required": [
          "user_id"
        ]
      }
    },
