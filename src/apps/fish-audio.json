{
  "slug": "fish-audio",
  "name": "Fish Audio",
  "description": "Fish Audio text-to-speech and voice cloning API. Generate expressive multilingual speech, use saved voice models, and create, browse, update, or delete cloned voices.",
  "logo": "https://www.google.com/s2/favicons?domain=fish.audio&sz=128",
  "categories": ["ai", "voice", "text-to-speech", "tts", "audio", "voice-cloning", "speech-synthesis"],
  "base_url": "https://api.fish.audio",
  "auth": {
    "types": ["bearer"],
    "headers": {
      "Authorization": "Bearer {{api_key}}"
    },
    "credential_fields": [
      {
        "name": "api_key",
        "label": "API Key",
        "description": "Fish Audio API key from https://fish.audio/app/api-keys."
      }
    ]
  },
  "health_check": { "tool": "list_voice_models", "input": { "page_size": 1, "page_number": 1, "self": true } },
  "tools": [
    {
      "name": "text_to_speech",
      "description": "Generate speech with Fish Audio. Use reference_id for a saved voice model. S2.1 Pro also supports multiple reference IDs with <|speaker:N|> tags for dialogue. Returns binary audio.",
      "method": "POST",
      "path": "/v1/tts",
      "timeout_ms": 180000,
      "header_params": { "model": "model" },
      "input_schema": {
        "type": "object",
        "properties": {
          "model": {
            "type": "string",
            "enum": ["s2.1-pro-free", "s2.1-pro", "s2-pro", "s1"],
            "default": "s2.1-pro",
            "description": "Fish TTS engine, sent in the required model request header. The free model is subject to Fish's fair-use and licensing terms."
          },
          "text": { "type": "string", "description": "Text to synthesize. For multi-speaker S2.1 Pro dialogue, annotate turns with <|speaker:0|>, <|speaker:1|>, and so on." },
          "reference_id": {
            "description": "Saved Fish voice-model ID for one speaker, or an array of IDs for S2.1 Pro multi-speaker dialogue.",
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" }, "minItems": 1 }
            ]
          },
          "prosody": {
            "type": "object",
            "description": "Optional output prosody controls.",
            "properties": {
              "speed": { "type": "number", "minimum": 0.5, "maximum": 2, "default": 1 },
              "volume": { "type": "number", "minimum": -20, "maximum": 20, "default": 0 },
              "normalize_loudness": { "type": "boolean", "default": true }
            }
          },
          "temperature": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.7 },
          "top_p": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.7 },
          "chunk_length": { "type": "integer", "minimum": 100, "maximum": 300, "default": 300 },
          "normalize": { "type": "boolean", "default": true },
          "format": { "type": "string", "enum": ["wav", "pcm", "mp3", "opus"], "default": "mp3" },
          "sample_rate": { "type": "integer", "description": "Optional sample rate. Omit for the selected format's default." },
          "mp3_bitrate": { "type": "integer", "enum": [64, 128, 192], "default": 128 },
          "opus_bitrate": { "type": "integer", "enum": [-1000, 24000, 32000, 48000, 64000], "default": -1000 },
          "latency": { "type": "string", "enum": ["low", "normal", "balanced"], "default": "normal" },
          "max_new_tokens": { "type": "integer", "default": 1024 },
          "repetition_penalty": { "type": "number", "default": 1.2 },
          "min_chunk_length": { "type": "integer", "minimum": 0, "maximum": 100, "default": 50 },
          "condition_on_previous_chunks": { "type": "boolean", "default": true },
          "early_stop_threshold": { "type": "number", "minimum": 0, "maximum": 1, "default": 1 }
        },
        "required": ["model", "text"]
      }
    },
    {
      "name": "list_voice_models",
      "description": "List Fish Audio voice models. Set self=true to list only voices created by the authenticated account; otherwise this searches the public/discoverable catalog.",
      "method": "GET",
      "path": "/model",
      "query_params": ["page_size", "page_number", "title", "tag", "self", "author_id", "language", "title_language", "sort_by"],
      "input_schema": {
        "type": "object",
        "properties": {
          "page_size": { "type": "integer", "minimum": 1, "default": 10 },
          "page_number": { "type": "integer", "minimum": 1, "default": 1 },
          "title": { "type": "string" },
          "tag": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }] },
          "self": { "type": "boolean", "default": false },
          "author_id": { "type": "string" },
          "language": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }] },
          "title_language": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }] },
          "sort_by": { "type": "string", "enum": ["score", "task_count", "created_at"], "default": "score" }
        }
      }
    },
    {
      "name": "get_voice_model",
      "description": "Get one Fish Audio voice model, including its state, owner, language, samples, visibility, and quality metadata.",
      "method": "GET",
      "path": "/model/{model_id}",
      "input_schema": {
        "type": "object",
        "properties": { "model_id": { "type": "string", "description": "Fish voice-model ID." } },
        "required": ["model_id"]
      }
    },
    {
      "name": "create_voice_model",
      "description": "Create an instant Fish Audio voice model from one or more consented audio samples. Provide voices as base64, data URLs, blobrefs, binary envelopes, or arrays of those values. Use the returned _id as text_to_speech.reference_id.",
      "method": "POST",
      "path": "/model",
      "timeout_ms": 180000,
      "multipart_form": {
        "field_names": ["type", "title", "train_mode", "visibility", "description", "texts", "tags", "enhance_audio_quality", "generate_sample"],
        "repeat_fields": ["texts", "tags"],
        "file_fields": { "voices": "voices", "cover_image": "cover_image" }
      },
      "input_schema": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["tts"], "default": "tts" },
          "title": { "type": "string", "description": "Name for the cloned voice model." },
          "train_mode": { "type": "string", "enum": ["fast"], "default": "fast" },
          "voices": {
            "description": "One audio sample or an array of samples. Values may be base64, data URLs, blobrefs, or binary envelopes.",
            "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" }, "minItems": 1 }]
          },
          "voices_filename": { "type": "string", "description": "Optional filename when uploading one sample." },
          "texts": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }], "description": "Optional transcripts corresponding to the voice samples. Fish performs ASR when omitted." },
          "visibility": { "type": "string", "enum": ["public", "unlist", "private"], "default": "private" },
          "description": { "type": "string" },
          "cover_image": { "type": "string", "description": "Optional cover image upload. Required by Fish when visibility=public." },
          "cover_image_filename": { "type": "string" },
          "tags": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }] },
          "enhance_audio_quality": { "type": "boolean", "default": true },
          "generate_sample": { "type": "boolean", "default": false }
        },
        "required": ["type", "title", "train_mode", "voices"]
      }
    },
    {
      "name": "update_voice_model",
      "description": "Update metadata or visibility for a Fish Audio voice model owned by the authenticated account.",
      "method": "PATCH",
      "path": "/model/{model_id}",
      "input_schema": {
        "type": "object",
        "properties": {
          "model_id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "visibility": { "type": "string", "enum": ["public", "unlist", "private"] },
          "tags": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }] }
        },
        "required": ["model_id"]
      }
    },
    {
      "name": "delete_voice_model",
      "description": "Delete a Fish Audio voice model owned by the authenticated account. This is destructive and cannot be undone.",
      "method": "DELETE",
      "path": "/model/{model_id}",
      "input_schema": {
        "type": "object",
        "properties": { "model_id": { "type": "string" } },
        "required": ["model_id"]
      }
    }
  ]
}
