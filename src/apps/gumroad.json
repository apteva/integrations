      "description": "Send or publish an audience email/newsletter.",
      "method": "POST",
      "path": "/emails/{emailId}/send",
      "path_params": ["emailId"],
      "input_schema": {"type": "object", "properties": {"emailId": {"type": "string"}}, "required": ["emailId"]}
