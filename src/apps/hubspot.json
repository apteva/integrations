{
  "slug": "hubspot",
  "name": "HubSpot",
  "description": "MCP server for HubSpot CRM operations - deals, contacts, companies, and pipelines",
  "logo": "https://www.google.com/s2/favicons?domain=hubspot.com&sz=128",
  "categories": [
    "crm",
    "hubspot",
    "deals",
    "contacts",
    "sales"
  ],
  "base_url": "https://api.hubapi.com",
  "auth": {
    "types": [
      "bearer",
      "oauth2"
    ],
    "headers": {
      "Authorization": "Bearer {{token}}"
    },
    "credential_fields": [
      {
        "name": "token",
        "label": "access_token"
      }
    ],
    "oauth2": {
      "authorize_url": "https://app.hubspot.com/oauth/authorize",
      "token_url": "https://api.hubapi.com/oauth/v1/token",
      "scopes": [
        "contacts",
        "content",
        "reports",
        "social",
        "automation",
        "timeline",
        "forms",
        "files",
        "hubdb",
        "integration-sync",
        "tickets",
        "e-commerce",
        "accounting",
        "sales-email-read",
        "forms-uploaded-files",
        "media_bridge.read",
        "media_bridge.write",
        "oauth",
        "crm.objects.companies.read",
        "crm.objects.companies.write",
        "crm.objects.contacts.read",
        "crm.objects.contacts.write",
        "crm.objects.deals.read",
        "crm.objects.deals.write",
        "crm.schemas.companies.read",
        "crm.schemas.companies.write",
        "crm.schemas.contacts.read",
        "crm.schemas.contacts.write",
        "crm.schemas.deals.read",
        "crm.schemas.deals.write"
      ],
      "client_id_required": true,
      "pkce": false
    }
  },
  "tools": [
    {
      "name": "list_deals",
      "description": "List deals from HubSpot CRM",
      "method": "GET",
      "path": "/list-deals",
      "input_schema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "number",
            "description": "Maximum number of deals to return",
            "default": 100
          },
          "after": {
            "type": "string",
            "description": "Pagination cursor"
          },
          "properties": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Properties to include"
          },
          "associations": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Associations to include"
          }
        }
      }
    },
    {
      "name": "create_deal",
      "description": "Create a new deal in HubSpot",
      "method": "POST",
      "path": "/create-deal",
      "input_schema": {
        "type": "object",
        "properties": {
          "dealname": {
            "type": "string",
            "description": "Name of the deal"
          },
          "amount": {
            "type": "number",
            "description": "Deal amount"
          },
          "dealstage": {
            "type": "string",
            "description": "Deal stage ID"
          },
          "pipeline": {
            "type": "string",
            "description": "Pipeline ID"
          },
          "closedate": {
            "type": "string",
            "description": "Expected close date"
          },
          "hubspot_owner_id": {
            "type": "string",
            "description": "Owner ID"
          }
        },
        "required": [
          "dealname"
        ]
      }
    },
