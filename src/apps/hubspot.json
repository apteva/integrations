{
  "slug": "hubspot",
  "name": "HubSpot",
  "description": "MCP server for HubSpot CRM operations - deals, contacts, companies, and pipelines",
  "logo": "https://www.google.com/s2/favicons?domain=hubspot.com&sz=128",
  "categories": [
    "crm",
    "hubspot",
    "deals",
    "contacts",
    "sales"
  ],
  "base_url": "https://api.hubapi.com",
  "auth": {
    "types": [
      "bearer",
      "oauth2"
    ],
    "headers": {
      "Authorization": "Bearer {{token}}"
    },
    "credential_fields": [
      {
        "name": "token",
        "label": "access_token"
      },
      {
        "name": "refresh_token",
        "label": "refresh_token"
      },
      {
        "name": "expires_in",
        "label": "expires_in"
      },
      {
        "name": "token_type",
        "label": "token_type"
      }
    ],
    "oauth2": {
      "authorize_url": "https://app.hubspot.com/oauth/authorize",
      "token_url": "https://api.hubapi.com/oauth/v1/token",
      "scopes": [
        "contacts",
        "content",
        "reports",
        "social",
        "automation",
        "timeline",
        "forms",
        "files",
        "hubdb",
        "integration-sync",
        "tickets",
        "e-commerce",
