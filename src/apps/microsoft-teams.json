{
  "slug": "microsoft-teams",
  "name": "Microsoft Teams",
  "description": "Microsoft Teams integration for team collaboration, messaging, and channel management",
  "logo": "https://www.google.com/s2/favicons?domain=teams.microsoft.com&sz=128",
  "categories": [
    "collaboration",
    "messaging",
    "teams",
    "microsoft",
    "channels"
  ],
  "base_url": "",
  "auth": {
    "types": [
      "bearer",
      "oauth2"
    ],
    "headers": {
      "Authorization": "Bearer {{token}}"
    },
    "credential_fields": [
      {
        "name": "token",
        "label": "access_token"
      },
      {
        "name": "refresh_token",
        "label": "refresh_token"
      },
      {
        "name": "expires_in",
        "label": "expires_in"
      },
      {
        "name": "token_type",
        "label": "token_type"
      },
      {
        "name": "scope",
        "label": "scope"
      },
      {
        "name": "id_token",
        "label": "id_token"
      }
    ],
    "oauth2": {
      "authorize_url": "https://login.microsoftonline.com/common/oauth2/v2.0/authorize",
      "token_url": "https://login.microsoftonline.com/common/oauth2/v2.0/token",
      "scopes": [
        "openid",
        "profile",
        "email",
        "offline_access",
        "User.Read",
        "User.ReadWrite",
        "User.ReadBasic.All",
        "Mail.Read",
        "Mail.ReadWrite",
        "Mail.Send",
        "Calendars.Read",
        "Calendars.ReadWrite",
        "Contacts.Read",
        "Contacts.ReadWrite",
        "Files.Read",
        "Files.ReadWrite",
        "Files.Read.All",
        "Files.ReadWrite.All",
        "Sites.Read.All",
        "Sites.ReadWrite.All",
        "Directory.Read.All",
        "Group.Read.All",
        "Group.ReadWrite.All",
        "Team.ReadBasic.All",
        "TeamSettings.Read.All",
        "TeamSettings.ReadWrite.All",
        "Channel.ReadBasic.All",
        "ChannelSettings.Read.All",
        "ChannelSettings.ReadWrite.All",
        "ChatMessage.Read",
        "ChatMessage.Send"
      ],
      "client_id_required": true,
      "pkce": false
    }
  },
  "tools": [
    {
      "name": "send_message",
      "description": "Send a message to a Microsoft Teams channel",
      "method": "POST",
      "path": "/send-message",
      "input_schema": {
        "type": "object",
        "properties": {
          "team_id": {
            "type": "string",
            "description": "Team ID"
          },
          "channel_id": {
            "type": "string",
            "description": "Channel ID"
          },
          "message": {
            "type": "string",
            "description": "Message content (supports HTML)"
          }
        },
        "required": [
          "team_id",
          "channel_id",
          "message"
        ]
      }
    },
    {
      "name": "list_teams",
      "description": "List all teams the user is a member of",
      "method": "GET",
      "path": "/list-teams",
      "input_schema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "list_channels",
      "description": "List all channels in a team",
      "method": "GET",
      "path": "/list-channels",
      "input_schema": {
        "type": "object",
        "properties": {
          "team_id": {
            "type": "string",
            "description": "Team ID"
          }
        },
        "required": [
          "team_id"
        ]
      }
    },
    {
      "name": "create_channel",
      "description": "Create a new channel in a team",
      "method": "POST",
      "path": "/create-channel",
      "input_schema": {
        "type": "object",
        "properties": {
          "team_id": {
            "type": "string",
            "description": "Team ID"
          },
          "display_name": {
            "type": "string",
            "description": "Channel name"
          },
          "description": {
            "type": "string",
            "description": "Channel description"
          },
          "membership_type": {
            "type": "string",
            "description": "Channel type: standard, private, shared"
          }
        },
        "required": [
          "team_id",
          "display_name"
        ]
      }
    },
    {
      "name": "list_members",
      "description": "List members of a team",
      "method": "GET",
      "path": "/list-members",
      "input_schema": {
        "type": "object",
        "properties": {
          "team_id": {
            "type": "string",
            "description": "Team ID"
          }
        },
        "required": [
          "team_id"
        ]
      }
    },
    {
      "name": "get_messages",
      "description": "Get messages from a channel",
      "method": "GET",
      "path": "/get-messages",
      "input_schema": {
        "type": "object",
        "properties": {
          "team_id": {
            "type": "string",
            "description": "Team ID"
          },
          "channel_id": {
            "type": "string",
            "description": "Channel ID"
          },
          "top": {
            "type": "number",
            "description": "Number of messages to retrieve"
          }
        },
        "required": [
          "team_id",
          "channel_id"
        ]
      }
    }
  ]
}
