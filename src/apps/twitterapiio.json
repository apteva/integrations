          },
          "text": {
            "type": "string",
            "description": "Message text content"
          },
          "mediaId": {
            "type": "string",
            "description": "Media ID to attach (optional)"
          }
        },
        "required": [
          "recipientId",
          "text"
        ]
      }
    }
  ]
}
