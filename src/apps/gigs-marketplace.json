{
  "slug": "gigs-marketplace",
  "name": "Gigs Marketplace",
  "description": "MCP server for managing gigs, instructions, templates, and work submissions in a marketplace platform",
  "logo": "https://www.google.com/s2/favicons?domain=upwork.com&sz=128",
  "categories": [
    "gigs",
    "marketplace",
    "freelance",
    "workflow",
    "project-management"
  ],
  "base_url": "https://gigsapi.schwartzindustries.com",
  "auth": {
    "types": [
      "bearer"
    ],
    "headers": {
      "Authorization": "Bearer {{token}}"
    },
    "credential_fields": [
      {
        "name": "token",
        "label": "API Key"
      }
    ]
  },
  "tools": [
    {
      "name": "create_gig",
      "description": "Create a new gig with optional template application",
      "method": "POST",
      "path": "/gigs",
      "input_schema": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Gig title/name",
            "minLength": 1,
            "maxLength": 255
          },
          "description": {
            "type": "string",
            "description": "Detailed description of the gig"
          },
          "budget": {
            "type": "number",
            "description": "Budget amount in USD"
          },
          "deadline": {
            "type": "string",
            "description": "Deadline in ISO 8601 format (YYYY-MM-DD)",
            "format": "date"
          },
          "project_id": {
            "type": "integer",
            "description": "Associated project ID"
          },
          "template_id": {
            "type": "integer",
            "description": "Template ID to apply instructions from"
          },
          "status": {
            "type": "string",
            "description": "Initial gig status",
            "enum": [
              "open",
              "assigned",
              "in_progress",
              "submitted",
              "completed",
              "cancelled"
            ],
            "default": "open"
          },
          "userId": {
            "type": "integer",
            "description": "User ID creating the gig (client)"
          }
        },
        "required": [
          "title",
          "userId"
        ]
      }
    },
    {
      "name": "list_gigs",
      "description": "List gigs filtered by user role (client, worker, or available)",
      "method": "GET",
      "path": "/gigs",
      "input_schema": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "integer",
            "description": "User ID for filtering"
          },
          "role": {
            "type": "string",
            "description": "Filter by role perspective",
            "enum": [
              "all",
              "client",
              "worker",
              "available"
            ],
            "default": "all"
          },
          "status": {
            "type": "string",
            "description": "Filter by gig status",
            "enum": [
              "open",
              "assigned",
              "in_progress",
              "submitted",
              "completed",
              "cancelled"
            ]
          },
          "limit": {
            "type": "integer",
            "description": "Number of gigs to return",
            "default": 50,
            "minimum": 1,
            "maximum": 100
          },
          "offset": {
            "type": "integer",
            "description": "Pagination offset",
            "default": 0,
            "minimum": 0
          }
        }
      }
    },
    {
      "name": "get_gig_details",
      "description": "Get detailed information about a specific gig",
      "method": "GET",
      "path": "/gigs/%7B%7Bid%7D%7D",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Gig ID"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    {
      "name": "assign_gig",
      "description": "Assign a gig to a worker (client only)",
      "method": "POST",
      "path": "/gigs/%7B%7Bid%7D%7D/assign",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Gig ID to assign"
          },
          "worker_id": {
            "type": "integer",
            "description": "Worker user ID to assign to"
          },
          "userId": {
            "type": "integer",
            "description": "Client user ID (must be gig owner)"
          }
        },
        "required": [
          "id",
          "worker_id",
          "userId"
        ]
      }
    },
    {
      "name": "update_gig_status",
      "description": "Update the status of a gig",
      "method": "PUT",
      "path": "/gigs/%7B%7Bid%7D%7D/status",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Gig ID"
          },
          "status": {
            "type": "string",
            "description": "New status",
            "enum": [
              "open",
              "assigned",
              "in_progress",
              "submitted",
              "completed",
              "cancelled"
            ]
          },
          "userId": {
            "type": "integer",
            "description": "User ID performing the update"
          }
        },
        "required": [
          "id",
          "status",
          "userId"
        ]
      }
    },
    {
      "name": "update_gig",
      "description": "Update gig details such as title, description, budget, deadline, or priority",
      "method": "PUT",
      "path": "/gigs/%7B%7Bid%7D%7D",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Gig ID to update"
          },
          "title": {
            "type": "string",
            "description": "Updated gig title"
          },
          "description": {
            "type": "string",
            "description": "Updated gig description"
          },
          "budget": {
            "type": "number",
            "description": "Updated budget amount in USD"
          },
          "deadline": {
            "type": "string",
            "description": "Updated deadline in ISO 8601 format (YYYY-MM-DD)",
            "format": "date"
          },
          "priority": {
            "type": "string",
            "description": "Updated priority level",
            "enum": [
              "low",
              "medium",
              "high",
              "urgent"
            ]
          }
        },
        "required": [
          "id"
        ]
      }
    },
    {
      "name": "cancel_gig",
      "description": "Cancel a gig (client only)",
      "method": "DELETE",
      "path": "/gigs/%7B%7Bid%7D%7D",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Gig ID to cancel"
          },
          "reason": {
            "type": "string",
            "description": "Cancellation reason"
          },
          "userId": {
            "type": "integer",
            "description": "User ID (must be client)"
          }
        },
        "required": [
          "id",
          "userId"
        ]
      }
    },
    {
      "name": "create_instruction",
      "description": "Create a reusable instruction in the library",
      "method": "POST",
      "path": "/instructions",
      "input_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Instruction name",
            "minLength": 1,
            "maxLength": 255
          },
          "description": {
            "type": "string",
            "description": "Instruction description"
          },
          "content": {
            "type": "string",
            "description": "Instruction content/details"
          },
          "category": {
            "type": "string",
            "description": "Instruction category"
          },
          "tags": {
            "type": "array",
            "description": "Tags for categorization",
            "items": {
              "type": "string"
            }
          },
          "media_type": {
            "type": "string",
            "description": "Type of media",
            "enum": [
              "text",
              "video",
              "image",
              "audio",
              "document"
            ],
            "default": "text"
          },
          "media_url": {
            "type": "string",
            "description": "URL to media file"
          },
          "is_public": {
            "type": "boolean",
            "description": "Whether instruction is publicly visible",
            "default": false
          },
          "duration_minutes": {
            "type": "integer",
            "description": "Expected duration in minutes"
          },
          "userId": {
            "type": "integer",
            "description": "User ID creating the instruction"
          }
        },
        "required": [
          "name",
          "content",
          "userId"
        ]
      }
    },
    {
      "name": "list_instructions",
      "description": "List instructions from the library with filtering",
      "method": "GET",
      "path": "/instructions",
      "input_schema": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string",
            "description": "Filter by category"
          },
          "is_public": {
            "type": "boolean",
            "description": "Filter by public visibility"
          },
          "userId": {
            "type": "integer",
            "description": "Filter by creator user ID"
          },
          "limit": {
            "type": "integer",
            "description": "Number of instructions to return",
            "default": 50,
            "minimum": 1,
            "maximum": 100
          },
          "offset": {
            "type": "integer",
            "description": "Pagination offset",
            "default": 0,
            "minimum": 0
          }
        }
      }
    },
    {
      "name": "search_instructions",
      "description": "Search instructions by keyword in name, description, or content. Results are ranked by relevance (name matches first, then description, then content).",
      "method": "GET",
      "path": "/instructions/search",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Search query to find in name, description, or content",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "description": "Filter by instruction category"
          },
          "userId": {
            "type": "integer",
            "description": "User ID to include their private instructions in results"
          },
          "limit": {
            "type": "integer",
            "description": "Number of results to return",
            "default": 20,
            "minimum": 1,
            "maximum": 50
          },
          "offset": {
            "type": "integer",
            "description": "Pagination offset",
            "default": 0,
            "minimum": 0
          }
        },
        "required": [
          "query"
        ]
      }
    },
    {
      "name": "create_template",
      "description": "Create a reusable gig template with instructions",
      "method": "POST",
      "path": "/templates",
      "input_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Template name",
            "minLength": 1,
            "maxLength": 255
          },
          "description": {
            "type": "string",
            "description": "Template description"
          },
          "category": {
            "type": "string",
            "description": "Template category"
          },
          "is_public": {
            "type": "boolean",
            "description": "Whether template is publicly available",
            "default": true
          },
          "userId": {
            "type": "integer",
            "description": "User ID creating the template"
          }
        },
        "required": [
          "name",
          "userId"
        ]
      }
    },
    {
      "name": "list_templates",
      "description": "List available gig templates",
      "method": "GET",
      "path": "/templates",
      "input_schema": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string",
            "description": "Filter by category"
          },
          "is_public": {
            "type": "boolean",
            "description": "Filter by public visibility"
          },
          "userId": {
            "type": "integer",
            "description": "Filter by creator user ID"
          },
          "limit": {
            "type": "integer",
            "description": "Number of templates to return",
            "default": 50,
            "minimum": 1,
            "maximum": 100
          },
          "offset": {
            "type": "integer",
            "description": "Pagination offset",
            "default": 0,
            "minimum": 0
          }
        }
      }
    },
    {
      "name": "apply_template_to_gig",
      "description": "Apply a template's instructions to a gig",
      "method": "POST",
      "path": "/gigs/%7B%7Bid%7D%7D/apply-template",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Gig ID"
          },
          "template_id": {
            "type": "integer",
            "description": "Template ID to apply"
          },
          "userId": {
            "type": "integer",
            "description": "User ID performing the action"
          }
        },
        "required": [
          "id",
          "template_id",
          "userId"
        ]
      }
    },
    {
      "name": "add_instruction_to_gig",
      "description": "Add an instruction from the instruction library to a gig. Use 'List Instructions' or 'Search Instructions' to find the library instruction_id.",
      "method": "POST",
      "path": "/gigs/%7B%7Bid%7D%7D/instructions",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Gig ID"
          },
          "instruction_id": {
            "type": "integer",
            "description": "Instruction library ID (from List/Search Instructions), NOT the gig_instructions record ID"
          },
          "custom_content": {
            "type": "string",
            "description": "Optional custom content override for this gig"
          },
          "order_index": {
            "type": "integer",
            "description": "Step number/position in instruction list (auto-assigned if omitted)"
          },
          "userId": {
            "type": "integer",
            "description": "User ID performing the action (must be gig owner)"
          }
        },
        "required": [
          "id",
          "instruction_id",
          "userId"
        ]
      }
    },
    {
      "name": "get_gig_instructions",
      "description": "Get all instructions attached to a gig. Returns gig_instructions records with their 'id' (needed for remove/complete/customize/reset operations), instruction details, completion status, and submitted files.",
      "method": "GET",
      "path": "/gigs/%7B%7Bid%7D%7D/instructions",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Gig ID"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    {
      "name": "mark_instruction_complete",
      "description": "Mark a gig instruction as completed. Use 'Get Gig Instructions' first to find the gig_instructions record ID.",
      "method": "PUT",
      "path": "/gigs/%7B%7Bid%7D%7D/instructions/%7B%7BinstructionId%7D%7D/complete",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Gig ID"
          },
          "instructionId": {
            "type": "integer",
            "description": "The gig_instructions record ID (the 'id' field returned by Get Gig Instructions), NOT the instruction library ID"
          },
          "userId": {
            "type": "integer",
            "description": "User ID performing the action"
          }
        },
        "required": [
          "id",
          "instructionId",
          "userId"
        ]
      }
    },
    {
      "name": "submit_work",
      "description": "Submit work files for a gig",
      "method": "POST",
      "path": "/gigs/%7B%7Bid%7D%7D/submissions",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Gig ID"
          },
          "file_name": {
            "type": "string",
            "description": "Name of the submitted file"
          },
          "file_url": {
            "type": "string",
            "description": "URL to the submitted file"
          },
          "file_type": {
            "type": "string",
            "description": "MIME type of the file"
          },
          "file_size": {
            "type": "integer",
            "description": "File size in bytes"
          },
          "submission_notes": {
            "type": "string",
            "description": "Notes accompanying the submission"
          },
          "userId": {
            "type": "integer",
            "description": "Worker user ID submitting work"
          }
        },
        "required": [
          "id",
          "file_name",
          "file_url",
          "userId"
        ]
      }
    },
    {
      "name": "get_submissions",
      "description": "Get all submissions for a gig",
      "method": "GET",
      "path": "/gigs/%7B%7Bid%7D%7D/submissions",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Gig ID"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    {
      "name": "review_submission",
      "description": "Review and approve/reject a work submission (client only)",
      "method": "POST",
      "path": "/gigs/%7B%7Bid%7D%7D/submissions/%7B%7BsubmissionId%7D%7D/review",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Gig ID"
          },
          "submissionId": {
            "type": "integer",
            "description": "Submission ID to review"
          },
          "status": {
            "type": "string",
            "description": "Review decision",
            "enum": [
              "approved",
              "rejected",
              "revision_requested"
            ]
          },
          "review_notes": {
            "type": "string",
            "description": "Review feedback"
          },
          "userId": {
            "type": "integer",
            "description": "Client user ID reviewing submission"
          }
        },
        "required": [
          "id",
          "submissionId",
          "status",
          "userId"
        ]
      }
    },
    {
      "name": "request_revision",
      "description": "Request changes to a work submission",
      "method": "POST",
      "path": "/gigs/%7B%7Bid%7D%7D/submissions/%7B%7BsubmissionId%7D%7D/revision",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Gig ID"
          },
          "submissionId": {
            "type": "integer",
            "description": "Submission ID to request revision for"
          },
          "revision_notes": {
            "type": "string",
            "description": "Detailed revision requirements"
          },
          "userId": {
            "type": "integer",
            "description": "User ID requesting revision"
          }
        },
        "required": [
          "id",
          "submissionId",
          "revision_notes",
          "userId"
        ]
      }
    },
    {
      "name": "get_gig_activity",
      "description": "Get activity log/history for a gig",
      "method": "GET",
      "path": "/gigs/%7B%7Bid%7D%7D/activity",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Gig ID"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    {
      "name": "list_users",
      "description": "List available workers and clients in the system with optional role and project filtering",
      "method": "GET",
      "path": "/users",
      "input_schema": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "description": "Filter by user role",
            "enum": [
              "all",
              "worker",
              "client"
            ],
            "default": "all"
          },
          "project_id": {
            "type": "integer",
            "description": "Filter by project ID"
          },
          "limit": {
            "type": "integer",
            "description": "Number of users to return",
            "default": 50,
            "minimum": 1,
            "maximum": 100
          },
          "offset": {
            "type": "integer",
            "description": "Pagination offset",
            "default": 0,
            "minimum": 0
          }
        }
      }
    },
    {
      "name": "get_instruction",
      "description": "Get a single instruction from the library by ID",
      "method": "GET",
      "path": "/instructions/%7B%7Bid%7D%7D",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Instruction ID"
          },
          "userId": {
            "type": "integer",
            "description": "User ID requesting the instruction"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    {
      "name": "update_instruction",
      "description": "Update an instruction's content, media, or settings",
      "method": "PUT",
      "path": "/instructions/%7B%7Bid%7D%7D",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Instruction ID to update"
          },
          "name": {
            "type": "string",
            "description": "Updated instruction name"
          },
          "description": {
            "type": "string",
            "description": "Updated description"
          },
          "content": {
            "type": "string",
            "description": "Updated instruction content"
          },
          "category": {
            "type": "string",
            "description": "Updated category"
          },
          "tags": {
            "type": "array",
            "description": "Updated tags",
            "items": {
              "type": "string"
            }
          },
          "media_type": {
            "type": "string",
            "description": "Media type",
            "enum": [
              "text",
              "video",
              "image",
              "audio",
              "document"
            ]
          },
          "media_url": {
            "type": "string",
            "description": "URL to media file"
          },
          "is_public": {
            "type": "boolean",
            "description": "Whether instruction is publicly visible"
          },
          "duration_minutes": {
            "type": "integer",
            "description": "Expected duration in minutes"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    {
      "name": "delete_instruction",
      "description": "Delete an instruction from the library",
      "method": "DELETE",
      "path": "/instructions/%7B%7Bid%7D%7D",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Instruction ID to delete"
          },
          "userId": {
            "type": "integer",
            "description": "User ID (must be owner)"
          }
        },
        "required": [
          "id",
          "userId"
        ]
      }
    },
    {
      "name": "get_template",
      "description": "Get a template with its instructions",
      "method": "GET",
      "path": "/templates/%7B%7Bid%7D%7D",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Template ID"
          },
          "userId": {
            "type": "integer",
            "description": "User ID requesting the template"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    {
      "name": "update_template",
      "description": "Update a gig template's name, description, or settings",
      "method": "PUT",
      "path": "/update-template",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Template ID to update"
          },
          "name": {
            "type": "string",
            "description": "Updated template name"
          },
          "description": {
            "type": "string",
            "description": "Updated description"
          },
          "category": {
            "type": "string",
            "description": "Updated category"
          },
          "is_public": {
            "type": "boolean",
            "description": "Whether template is publicly available"
          },
          "userId": {
            "type": "integer",
            "description": "User ID (must be owner)"
