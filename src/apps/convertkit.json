{
  "slug": "convertkit",
  "name": "Kit",
  "description": "Kit (formerly ConvertKit) API v4 for subscribers, forms, tags, sequences, broadcasts, custom fields, purchases, and webhooks.",
  "logo": "https://www.google.com/s2/favicons?domain=kit.com&sz=128",
  "categories": ["email-marketing", "newsletters", "creators", "automation", "commerce"],
  "base_url": "https://api.kit.com/v4",
  "auth": { "types": ["api_key"], "headers": { "X-Kit-Api-Key": "{{token}}", "Accept": "application/json", "Content-Type": "application/json" }, "credential_fields": [{ "name": "token", "label": "Kit API Key", "description": "Kit API v4 key." }] },
  "health_check": { "tool": "list_subscribers", "input": { "per_page": 1 } },
  "tools": [
    { "name": "list_subscribers", "description": "List subscribers with cursor pagination.", "method": "GET", "path": "/subscribers", "query_params": ["status", "after", "before", "per_page"], "input_schema": { "type": "object", "properties": { "status": { "type": "string" }, "after": { "type": "string" }, "before": { "type": "string" }, "per_page": { "type": "integer" } } } },
    { "name": "get_subscriber", "description": "Get one subscriber.", "method": "GET", "path": "/subscribers/{subscriber_id}", "input_schema": { "type": "object", "properties": { "subscriber_id": { "type": "string" } }, "required": ["subscriber_id"] } },
    { "name": "create_subscriber", "description": "Create a subscriber.", "method": "POST", "path": "/subscribers", "input_schema": { "type": "object", "properties": { "email_address": { "type": "string" }, "first_name": { "type": "string" }, "fields": { "type": "object", "additionalProperties": true } }, "required": ["email_address"] } },
    { "name": "update_subscriber", "description": "Update subscriber fields.", "method": "PUT", "path": "/subscribers/{subscriber_id}", "input_schema": { "type": "object", "properties": { "subscriber_id": { "type": "string" }, "email_address": { "type": "string" }, "first_name": { "type": "string" }, "fields": { "type": "object", "additionalProperties": true } }, "required": ["subscriber_id"] } },
    { "name": "list_forms", "description": "List forms.", "method": "GET", "path": "/forms", "query_params": ["status", "after", "before", "per_page"], "input_schema": { "type": "object", "properties": { "status": { "type": "string" }, "after": { "type": "string" }, "before": { "type": "string" }, "per_page": { "type": "integer" } } } },
    { "name": "get_form", "description": "Get one form.", "method": "GET", "path": "/forms/{form_id}", "input_schema": { "type": "object", "properties": { "form_id": { "type": "string" } }, "required": ["form_id"] } },
    { "name": "add_subscriber_to_form", "description": "Subscribe an existing subscriber to a form.", "method": "POST", "path": "/forms/{form_id}/subscribers/{subscriber_id}", "input_schema": { "type": "object", "properties": { "form_id": { "type": "string" }, "subscriber_id": { "type": "string" } }, "required": ["form_id", "subscriber_id"] } },
    { "name": "list_tags", "description": "List tags.", "method": "GET", "path": "/tags", "query_params": ["after", "before", "per_page"], "input_schema": { "type": "object", "properties": { "after": { "type": "string" }, "before": { "type": "string" }, "per_page": { "type": "integer" } } } },
    { "name": "create_tag", "description": "Create a tag.", "method": "POST", "path": "/tags", "input_schema": { "type": "object", "properties": { "name": { "type": "string" } }, "required": ["name"] } },
    { "name": "tag_subscriber", "description": "Apply a tag to a subscriber.", "method": "POST", "path": "/tags/{tag_id}/subscribers/{subscriber_id}", "input_schema": { "type": "object", "properties": { "tag_id": { "type": "string" }, "subscriber_id": { "type": "string" } }, "required": ["tag_id", "subscriber_id"] } },
    { "name": "remove_tag_from_subscriber", "description": "Remove a tag from a subscriber.", "method": "DELETE", "path": "/tags/{tag_id}/subscribers/{subscriber_id}", "input_schema": { "type": "object", "properties": { "tag_id": { "type": "string" }, "subscriber_id": { "type": "string" } }, "required": ["tag_id", "subscriber_id"] } },
    { "name": "list_sequences", "description": "List sequences.", "method": "GET", "path": "/sequences", "query_params": ["after", "before", "per_page"], "input_schema": { "type": "object", "properties": { "after": { "type": "string" }, "before": { "type": "string" }, "per_page": { "type": "integer" } } } },
    { "name": "add_subscriber_to_sequence", "description": "Subscribe an existing subscriber to a sequence.", "method": "POST", "path": "/sequences/{sequence_id}/subscribers/{subscriber_id}", "input_schema": { "type": "object", "properties": { "sequence_id": { "type": "string" }, "subscriber_id": { "type": "string" } }, "required": ["sequence_id", "subscriber_id"] } },
    { "name": "list_broadcasts", "description": "List broadcasts.", "method": "GET", "path": "/broadcasts", "query_params": ["after", "before", "per_page"], "input_schema": { "type": "object", "properties": { "after": { "type": "string" }, "before": { "type": "string" }, "per_page": { "type": "integer" } } } },
    { "name": "get_broadcast", "description": "Get one broadcast.", "method": "GET", "path": "/broadcasts/{broadcast_id}", "input_schema": { "type": "object", "properties": { "broadcast_id": { "type": "string" } }, "required": ["broadcast_id"] } },
    { "name": "create_broadcast", "description": "Create a broadcast.", "method": "POST", "path": "/broadcasts", "input_schema": { "type": "object", "properties": { "subject": { "type": "string" }, "content": { "type": "string" }, "description": { "type": "string" }, "public": { "type": "boolean" }, "published_at": { "type": "string" }, "send_at": { "type": "string" }, "email_address": { "type": "string" }, "thumbnail_alt": { "type": "string" }, "thumbnail_url": { "type": "string" } }, "required": ["subject", "content"] } },
    { "name": "list_custom_fields", "description": "List custom fields.", "method": "GET", "path": "/custom_fields", "query_params": ["after", "before", "per_page"], "input_schema": { "type": "object", "properties": { "after": { "type": "string" }, "before": { "type": "string" }, "per_page": { "type": "integer" } } } },
    { "name": "create_custom_field", "description": "Create a custom field.", "method": "POST", "path": "/custom_fields", "input_schema": { "type": "object", "properties": { "label": { "type": "string" } }, "required": ["label"] } },
    { "name": "list_purchases", "description": "List purchases.", "method": "GET", "path": "/purchases", "query_params": ["after", "before", "per_page"], "input_schema": { "type": "object", "properties": { "after": { "type": "string" }, "before": { "type": "string" }, "per_page": { "type": "integer" } } } },
    { "name": "create_purchase", "description": "Create a purchase record.", "method": "POST", "path": "/purchases", "input_schema": { "type": "object", "properties": { "email_address": { "type": "string" }, "transaction_id": { "type": "string" }, "amount": { "type": "integer" }, "currency": { "type": "string" }, "transaction_time": { "type": "string" }, "product_name": { "type": "string" }, "status": { "type": "string" } }, "required": ["email_address", "transaction_id", "amount"] } },
    { "name": "list_webhooks", "description": "List webhooks.", "method": "GET", "path": "/webhooks", "query_params": ["after", "before", "per_page"], "input_schema": { "type": "object", "properties": { "after": { "type": "string" }, "before": { "type": "string" }, "per_page": { "type": "integer" } } } },
    { "name": "create_webhook", "description": "Create a webhook subscription.", "method": "POST", "path": "/webhooks", "input_schema": { "type": "object", "properties": { "event": { "type": "string" }, "target_url": { "type": "string" } }, "required": ["event", "target_url"] } },
    { "name": "delete_webhook", "description": "Delete a webhook.", "method": "DELETE", "path": "/webhooks/{webhook_id}", "input_schema": { "type": "object", "properties": { "webhook_id": { "type": "string" } }, "required": ["webhook_id"] } }
  ],
  "webhooks": { "signature_header": "x-convertkit-signature", "events": [{ "name": "subscriber.subscriber_activate", "description": "Subscriber activated" }, { "name": "subscriber.subscriber_unsubscribe", "description": "Subscriber unsubscribed" }, { "name": "subscriber.form_subscribe", "description": "Subscriber joined a form" }, { "name": "subscriber.tag_add", "description": "Tag added" }, { "name": "subscriber.tag_remove", "description": "Tag removed" }, { "name": "purchase.purchase_create", "description": "Purchase created" }] }
}
