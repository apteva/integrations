    {
      "name": "update_live_static_renditions",
      "description": "Replace the static MP4/M4A renditions generated for new assets recorded from a live stream.",
      "method": "PUT",
      "path": "/video/v1/live-streams/{LIVE_STREAM_ID}/new-asset-settings/static-renditions",
      "input_schema": {
        "type": "object",
        "properties": {
          "LIVE_STREAM_ID": { "type": "string" },
          "static_renditions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "resolution": { "type": "string", "enum": ["highest", "audio-only", "2160p", "1440p", "1080p", "720p", "540p", "480p", "360p", "270p"] },
                "passthrough": { "type": "string" }
              },
              "required": ["resolution"]
            }
          }
        },
        "required": ["LIVE_STREAM_ID", "static_renditions"]
      }
    },
    {
      "name": "delete_live_static_renditions",
      "description": "Remove static-rendition settings so future assets recorded from this live stream do not generate MP4/M4A renditions.",
      "method": "DELETE",
      "path": "/video/v1/live-streams/{LIVE_STREAM_ID}/new-asset-settings/static-renditions",
      "input_schema": { "type": "object", "properties": { "LIVE_STREAM_ID": { "type": "string" } }, "required": ["LIVE_STREAM_ID"] }
    },
    {
      "name": "create_playback_restriction",
      "description": "Create domain/referrer and user-agent rules that can be enforced by signed playback JWTs.",
      "method": "POST",
      "path": "/video/v1/playback-restrictions",
      "input_schema": {
        "type": "object",
        "properties": {
          "referrer": {
            "type": "object",
            "properties": {
              "allowed_domains": { "type": "array", "maxItems": 10, "items": { "type": "string" } },
              "allow_no_referrer": { "type": "boolean" }
            },
            "required": ["allowed_domains"]
          },
          "user_agent": {
            "type": "object",
            "properties": {
              "allow_high_risk_user_agent": { "type": "boolean" },
              "allow_no_user_agent": { "type": "boolean" }
            }
          }
        },
        "required": ["referrer", "user_agent"]
      }
    },
    {
      "name": "list_playback_restrictions",
      "description": "List playback restriction policies.",
      "method": "GET",
      "path": "/video/v1/playback-restrictions",
      "input_schema": { "type": "object", "properties": { "limit": { "type": "integer" }, "page": { "type": "integer" } } }
    },
    {
      "name": "get_playback_restriction",
      "description": "Get one playback restriction policy.",
      "method": "GET",
      "path": "/video/v1/playback-restrictions/{PLAYBACK_RESTRICTION_ID}",
      "input_schema": { "type": "object", "properties": { "PLAYBACK_RESTRICTION_ID": { "type": "string" } }, "required": ["PLAYBACK_RESTRICTION_ID"] }
    },
    {
      "name": "update_playback_restriction_referrer",
      "description": "Replace the complete allowed-domain list and no-referrer behavior of a restriction.",
      "method": "PUT",
      "path": "/video/v1/playback-restrictions/{PLAYBACK_RESTRICTION_ID}/referrer",
      "input_schema": {
        "type": "object",
        "properties": {
          "PLAYBACK_RESTRICTION_ID": { "type": "string" },
          "allowed_domains": { "type": "array", "maxItems": 10, "items": { "type": "string" } },
          "allow_no_referrer": { "type": "boolean" }
        },
        "required": ["PLAYBACK_RESTRICTION_ID", "allowed_domains"]
      }
    },
    {
      "name": "update_playback_restriction_user_agent",
      "description": "Replace user-agent validation behavior for a playback restriction.",
      "method": "PUT",
      "path": "/video/v1/playback-restrictions/{PLAYBACK_RESTRICTION_ID}/user_agent",
      "input_schema": {
        "type": "object",
        "properties": {
          "PLAYBACK_RESTRICTION_ID": { "type": "string" },
          "allow_high_risk_user_agent": { "type": "boolean" },
          "allow_no_user_agent": { "type": "boolean" }
        },
        "required": ["PLAYBACK_RESTRICTION_ID", "allow_high_risk_user_agent", "allow_no_user_agent"]
      }
    },
    {
      "name": "delete_playback_restriction",
      "description": "Permanently delete a playback restriction policy.",
      "method": "DELETE",
      "path": "/video/v1/playback-restrictions/{PLAYBACK_RESTRICTION_ID}",
      "input_schema": { "type": "object", "properties": { "PLAYBACK_RESTRICTION_ID": { "type": "string" } }, "required": ["PLAYBACK_RESTRICTION_ID"] }
    },
    {
      "name": "create_transcription_vocabulary",
      "description": "Create a reusable vocabulary that improves recognition of names, jargon, and uncommon phrases in generated live subtitles.",
      "method": "POST",
      "path": "/video/v1/transcription-vocabularies",
      "input_schema": {
        "type": "object",
        "properties": {
          "phrases": { "type": "array", "items": { "type": "string" } },
          "name": { "type": "string" },
          "passthrough": { "type": "string", "maxLength": 255 }
        },
        "required": ["phrases"]
      }
    },
    {
      "name": "list_transcription_vocabularies",
      "description": "List reusable transcription vocabularies.",
      "method": "GET",
      "path": "/video/v1/transcription-vocabularies",
      "input_schema": { "type": "object", "properties": { "limit": { "type": "integer" }, "page": { "type": "integer" } } }
    },
    {
      "name": "get_transcription_vocabulary",
      "description": "Get one transcription vocabulary and its phrases.",
      "method": "GET",
      "path": "/video/v1/transcription-vocabularies/{TRANSCRIPTION_VOCABULARY_ID}",
      "input_schema": { "type": "object", "properties": { "TRANSCRIPTION_VOCABULARY_ID": { "type": "string" } }, "required": ["TRANSCRIPTION_VOCABULARY_ID"] }
    },
    {
      "name": "update_transcription_vocabulary",
      "description": "Replace a transcription vocabulary's phrases and optionally update its name and passthrough metadata.",
      "method": "PUT",
      "path": "/video/v1/transcription-vocabularies/{TRANSCRIPTION_VOCABULARY_ID}",
      "input_schema": {
        "type": "object",
        "properties": {
          "TRANSCRIPTION_VOCABULARY_ID": { "type": "string" },
          "phrases": { "type": "array", "items": { "type": "string" } },
          "name": { "type": "string" },
          "passthrough": { "type": "string", "maxLength": 255 }
        },
        "required": ["TRANSCRIPTION_VOCABULARY_ID", "phrases"]
      }
    },
    {
      "name": "delete_transcription_vocabulary",
      "description": "Delete a transcription vocabulary and disassociate it from future live caption sessions.",
      "method": "DELETE",
      "path": "/video/v1/transcription-vocabularies/{TRANSCRIPTION_VOCABULARY_ID}",
      "input_schema": { "type": "object", "properties": { "TRANSCRIPTION_VOCABULARY_ID": { "type": "string" } }, "required": ["TRANSCRIPTION_VOCABULARY_ID"] }
    },
    {
      "name": "list_drm_configurations",
      "description": "List available Mux DRM configurations for advanced DRM playback policies.",
      "method": "GET",
      "path": "/video/v1/drm-configurations",
      "input_schema": { "type": "object", "properties": { "limit": { "type": "integer" }, "page": { "type": "integer" } } }
    },
    {
      "name": "get_drm_configuration",
      "description": "Get one DRM configuration by ID.",
      "method": "GET",
      "path": "/video/v1/drm-configurations/{DRM_CONFIGURATION_ID}",
      "input_schema": { "type": "object", "properties": { "DRM_CONFIGURATION_ID": { "type": "string" } }, "required": ["DRM_CONFIGURATION_ID"] }
    },
    {
      "name": "list_delivery_usage",
      "description": "Report delivered seconds by resolution tier for an asset, live stream, or Unix-time window. Do not combine asset_id and live_stream_id.",
      "method": "GET",
      "path": "/video/v1/delivery-usage",
      "query_param_aliases": { "timeframe": "timeframe[]" },
      "input_schema": {
        "type": "object",
        "properties": {
          "asset_id": { "type": "string" },
          "live_stream_id": { "type": "string" },
          "timeframe": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "string" }, "description": "Start and end Unix timestamps." },
          "limit": { "type": "integer" },
          "page": { "type": "integer" }
        }
      }
    },
    {
      "name": "create_signing_key",
      "description": "Create an RSA signing key for signed playback JWTs. Save the returned private_key immediately; Mux returns it only once.",
      "method": "POST",
      "path": "/system/v1/signing-keys",
      "input_schema": { "type": "object", "properties": {} }
    },
    {
      "name": "list_signing_keys",
      "description": "List signing-key IDs. Private keys are never returned by this operation.",
      "method": "GET",
      "path": "/system/v1/signing-keys",
      "input_schema": { "type": "object", "properties": { "limit": { "type": "integer" }, "page": { "type": "integer" } } }
    },
    {
      "name": "get_signing_key",
      "description": "Get signing-key metadata. The private key is not returned after creation.",
      "method": "GET",
      "path": "/system/v1/signing-keys/{SIGNING_KEY_ID}",
      "input_schema": { "type": "object", "properties": { "SIGNING_KEY_ID": { "type": "string" } }, "required": ["SIGNING_KEY_ID"] }
    },
    {
      "name": "delete_signing_key",
      "description": "Delete a signing key and immediately invalidate tokens that depend on it. Rotate keys before deleting an active one.",
      "method": "DELETE",
      "path": "/system/v1/signing-keys/{SIGNING_KEY_ID}",
      "input_schema": { "type": "object", "properties": { "SIGNING_KEY_ID": { "type": "string" } }, "required": ["SIGNING_KEY_ID"] }
    }
  ]
}
