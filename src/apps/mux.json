{
  "slug": "mux",
  "name": "Mux Video",
  "description": "Mux Video API for on-demand assets, direct uploads, playback IDs, static renditions, tracks and generated subtitles, live streams and simulcasting, playback restrictions, transcription vocabularies, DRM configuration lookup, delivery usage, and signing keys. Public HLS playback uses https://stream.mux.com/{PLAYBACK_ID}.m3u8; thumbnails use https://image.mux.com/{PLAYBACK_ID}/thumbnail.jpg.",
  "logo": "https://www.google.com/s2/favicons?domain=mux.com&sz=128",
  "categories": ["video", "streaming", "media", "live", "transcoding"],
  "base_url": "https://api.mux.com",
  "auth": {
    "types": ["basic"],
    "headers": {
      "Authorization": "Basic {{basic_auth}}",
      "Content-Type": "application/json"
    },
    "credential_fields": [
      {
        "name": "username",
        "label": "Access Token ID",
        "description": "Mux Access Token ID — issued from the Settings → Access Tokens page. Acts as the username for HTTP Basic auth.",
        "required": true,
        "type": "text"
      },
      {
        "name": "password",
        "label": "Secret Key",
        "description": "Paired secret. Acts as the password for HTTP Basic auth.",
        "required": true,
        "type": "password"
      }
    ]
  },
  "health_check": {
    "tool": "list_assets",
    "input": { "limit": 1 }
  },
  "tools": [
    {
      "name": "create_asset",
      "description": "Create a new asset by ingesting one or more source URLs. Mux fetches the input(s), transcodes them, and exposes HLS via playback_ids. Returns asset id + initial state (`preparing`); poll get_asset until ready/errored. To enable downloadable MP4s, pass `mp4_support: capped-1080p` (or `audio-only`).",
      "method": "POST",
      "path": "/video/v1/assets",
      "input_schema": {
        "type": "object",
        "properties": {
          "inputs": {
            "type": "array",
            "description": "Array of input objects, each at minimum {url}. Single-input is the common case; multi-input is for stitching subtitle + audio + video tracks. Mux's deprecated `input` (singular) alias still works but new code should use `inputs`.",
            "items": {
              "type": "object",
              "properties": {
                "url": { "type": "string", "description": "HTTPS URL Mux can fetch the source from." },
                "overlay_settings": { "type": "object" },
                "generated_subtitles": { "type": "array" },
                "type": { "type": "string", "enum": ["video", "audio", "text"] }
              },
              "required": ["url"]
            }
          },
          "playback_policies": {
            "type": "array",
            "description": "Playback access modes. Use [\"public\"] for unsigned playback, [\"signed\"] when you need per-viewer JWTs, or omit this to create an asset without a playback ID.",
            "items": { "type": "string", "enum": ["public", "signed", "drm"] }
          },
          "advanced_playback_policies": {
            "type": "array",
            "description": "Use instead of playback_policies when creating a DRM playback ID.",
            "items": {
              "type": "object",
              "properties": {
                "policy": { "type": "string", "enum": ["public", "signed", "drm"] },
                "drm_configuration_id": { "type": "string" }
              }
            }
          },
          "video_quality": {
            "type": "string",
            "enum": ["basic", "plus", "premium"],
            "description": "Replaces the deprecated `encoding_tier`. `basic` is cheapest single-rendition; `plus`/`premium` enable adaptive bitrate ladders."
          },
          "mp4_support": {
            "type": "string",
            "enum": ["none", "capped-1080p", "audio-only", "audio-only,capped-1080p"],
            "description": "Generate downloadable MP4 renditions alongside HLS. Useful when you want a single-file output (matches our render contract) instead of streaming."
          },
          "normalize_audio": { "type": "boolean" },
          "passthrough": { "type": "string", "description": "Free-form metadata Mux echoes back in webhooks. Good for round-tripping our render_id." },
          "master_access": { "type": "string", "enum": ["none", "temporary"] },
          "max_resolution_tier": { "type": "string", "enum": ["1080p", "1440p", "2160p"] },
          "meta": {
            "type": "object",
            "description": "Non-sensitive metadata that may be visible through the player.",
            "properties": {
              "title": { "type": "string", "maxLength": 512 },
              "external_id": { "type": "string", "maxLength": 128 },
              "creator_id": { "type": "string", "maxLength": 128 }
            }
          },
          "static_renditions": {
            "type": "array",
            "description": "Static MP4/M4A renditions to generate. Do not combine with deprecated mp4_support.",
            "items": {
              "type": "object",
              "properties": {
                "resolution": { "type": "string", "enum": ["highest", "audio-only", "2160p", "1440p", "1080p", "720p", "540p", "480p", "360p", "270p"] },
                "passthrough": { "type": "string", "maxLength": 255 }
              },
              "required": ["resolution"]
            }
          },
          "test": { "type": "boolean", "description": "Asset is purged after 24h; useful for development without burning storage." }
        },
        "required": ["inputs"]
      }
    },
    {
      "name": "list_assets",
      "description": "Paginate through assets. Useful for sync or housekeeping.",
      "method": "GET",
      "path": "/video/v1/assets",
      "input_schema": {
        "type": "object",
        "properties": {
          "limit": { "type": "integer", "default": 25, "maximum": 100 },
          "page": { "type": "integer", "default": 1 },
          "cursor": { "type": "string", "description": "Pagination cursor returned by Mux." },
          "live_stream_id": { "type": "string" },
          "upload_id": { "type": "string" }
        }
      }
    },
    {
      "name": "get_asset",
      "description": "Fetch one asset's metadata + state. Poll this after create_asset until status=`ready` (or `errored`).",
      "method": "GET",
      "path": "/video/v1/assets/{ASSET_ID}",
      "input_schema": {
        "type": "object",
        "properties": {
          "ASSET_ID": { "type": "string" }
        },
        "required": ["ASSET_ID"]
      }
    },
    {
      "name": "delete_asset",
      "description": "Permanently delete an asset and stop billing for its storage.",
      "method": "DELETE",
      "path": "/video/v1/assets/{ASSET_ID}",
      "input_schema": {
        "type": "object",
        "properties": { "ASSET_ID": { "type": "string" } },
        "required": ["ASSET_ID"]
      }
    },
    {
      "name": "create_playback_id",
      "description": "Mint an additional playback id on an asset — useful for revoking access to one URL while keeping others alive (signed mode).",
      "method": "POST",
      "path": "/video/v1/assets/{ASSET_ID}/playback-ids",
      "input_schema": {
        "type": "object",
        "properties": {
          "ASSET_ID": { "type": "string" },
          "policy": { "type": "string", "enum": ["public", "signed", "drm"] },
          "drm_configuration_id": { "type": "string", "description": "Required only when policy is drm." }
        },
        "required": ["ASSET_ID", "policy"]
      }
    },
    {
      "name": "create_static_rendition",
      "description": "Request an MP4 static rendition of an asset at a specific resolution. Useful as a render-executor primitive: the asset = source, the rendition = output mp4. Poll the asset to see when the rendition is ready (it appears under `static_renditions.files`).",
      "method": "POST",
      "path": "/video/v1/assets/{ASSET_ID}/static-renditions",
      "input_schema": {
        "type": "object",
        "properties": {
          "ASSET_ID": { "type": "string" },
          "resolution": {
            "type": "string",
            "enum": ["highest", "audio-only", "2160p", "1440p", "1080p", "720p", "540p", "480p", "360p", "270p"],
            "description": "Output resolution. `highest` matches the source."
          },
          "passthrough": { "type": "string" }
        },
        "required": ["ASSET_ID", "resolution"]
      }
    },
    {
      "name": "create_direct_upload",
      "description": "Provision a one-time signed PUT URL for direct media upload. PUT the raw file bytes to the returned url without Mux Basic auth, then poll get_direct_upload; after upload succeeds, its asset_id identifies the created asset.",
      "method": "POST",
      "path": "/video/v1/uploads",
      "input_schema": {
        "type": "object",
        "properties": {
          "new_asset_settings": {
            "type": "object",
            "description": "Asset settings applied after upload. Optional.",
            "properties": {
              "playback_policies": { "type": "array", "items": { "type": "string", "enum": ["public", "signed", "drm"] } },
              "advanced_playback_policies": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "policy": { "type": "string", "enum": ["public", "signed", "drm"] },
                    "drm_configuration_id": { "type": "string" }
                  }
                }
              },
              "inputs": {
                "type": "array",
                "description": "Optional input settings; the first item may omit url to configure generated subtitles for the uploaded media.",
                "items": {
                  "type": "object",
                  "properties": {
                    "url": { "type": "string" },
                    "type": { "type": "string", "enum": ["video", "audio", "text"] },
                    "language_code": { "type": "string" },
                    "name": { "type": "string" },
                    "text_type": { "type": "string", "enum": ["subtitles"] },
                    "generated_subtitles": { "type": "array", "items": { "type": "object" } }
                  }
                }
              },
              "video_quality": { "type": "string", "enum": ["basic", "plus", "premium"] },
              "max_resolution_tier": { "type": "string", "enum": ["1080p", "1440p", "2160p"] },
              "master_access": { "type": "string", "enum": ["none", "temporary"] },
              "normalize_audio": { "type": "boolean" },
              "passthrough": { "type": "string", "maxLength": 255 },
              "meta": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "external_id": { "type": "string" },
                  "creator_id": { "type": "string" }
                }
              },
              "static_renditions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "resolution": { "type": "string", "enum": ["highest", "audio-only", "2160p", "1440p", "1080p", "720p", "540p", "480p", "360p", "270p"] },
                    "passthrough": { "type": "string" }
                  },
                  "required": ["resolution"]
                }
              }
            }
          },
          "cors_origin": {
            "type": "string",
            "description": "Origin allowed to PUT. Use \"*\" to allow any browser; pin to your domain in production."
          },
          "timeout": {
            "type": "integer",
            "default": 3600,
            "description": "Seconds the upload URL stays valid."
          },
          "test": { "type": "boolean" }
        },
        "required": ["cors_origin"]
      }
    },
    {
      "name": "create_live_stream",
      "description": "Create a live stream endpoint. Returns a `stream_key` for the broadcaster + `playback_ids` for viewers. Out of scope for media's render executor needs but useful when this integration is bound for live-streaming workflows.",
      "method": "POST",
      "path": "/video/v1/live-streams",
      "input_schema": {
        "type": "object",
        "properties": {
          "playback_policies": { "type": "array", "items": { "type": "string" } },
          "advanced_playback_policies": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "policy": { "type": "string", "enum": ["public", "signed", "drm"] },
                "drm_configuration_id": { "type": "string" }
              }
            }
          },
          "new_asset_settings": {
            "type": "object",
            "description": "Settings for each recorded asset created from the stream.",
            "properties": {
              "playback_policies": { "type": "array", "items": { "type": "string", "enum": ["public", "signed", "drm"] } },
              "video_quality": { "type": "string", "enum": ["basic", "plus", "premium"] },
              "master_access": { "type": "string", "enum": ["none", "temporary"] },
              "passthrough": { "type": "string" },
              "meta": { "type": "object" },
              "static_renditions": { "type": "array", "items": { "type": "object" } }
            }
          },
          "reconnect_window": { "type": "integer", "description": "Seconds Mux waits for the stream to come back before ending it. 0 disables." },
          "latency_mode": { "type": "string", "enum": ["standard", "low", "reduced"] },
          "max_continuous_duration": { "type": "integer", "description": "Maximum continuous live duration in seconds." },
          "passthrough": { "type": "string", "maxLength": 255 },
          "meta": { "type": "object", "properties": { "title": { "type": "string", "maxLength": 512 } } },
          "reconnect_slate_url": { "type": "string" },
          "use_slate_for_standard_latency": { "type": "boolean" },
          "test": { "type": "boolean" }
        }
      }
    },
    {
      "name": "list_live_streams",
      "description": "List live streams, optionally filtered by state or exact stream key.",
      "method": "GET",
      "path": "/video/v1/live-streams",
      "input_schema": {
        "type": "object",
        "properties": {
          "limit": { "type": "integer", "default": 25 },
          "page": { "type": "integer", "default": 1 },
          "status": { "type": "string", "enum": ["active", "idle", "disabled"] },
          "stream_key": { "type": "string" }
        }
      }
    },
    {
      "name": "update_asset",
      "description": "Update an asset's passthrough value or structured metadata. Asset media content itself is immutable.",
      "method": "PATCH",
      "path": "/video/v1/assets/{ASSET_ID}",
      "input_schema": {
        "type": "object",
        "properties": {
          "ASSET_ID": { "type": "string" },
          "passthrough": { "type": "string", "maxLength": 255 },
          "meta": {
            "type": "object",
            "properties": {
              "title": { "type": "string", "maxLength": 512 },
              "external_id": { "type": "string", "maxLength": 128 },
              "creator_id": { "type": "string", "maxLength": 128 }
            }
          }
        },
        "required": ["ASSET_ID"]
      }
    },
    {
      "name": "get_asset_input_info",
      "description": "Get the input sources and ingest settings used to create an asset.",
      "method": "GET",
      "path": "/video/v1/assets/{ASSET_ID}/input-info",
      "input_schema": { "type": "object", "properties": { "ASSET_ID": { "type": "string" } }, "required": ["ASSET_ID"] }
    },
    {
      "name": "get_asset_playback_id",
      "description": "Get one playback ID attached to an asset, including its policy and optional DRM configuration.",
      "method": "GET",
      "path": "/video/v1/assets/{ASSET_ID}/playback-ids/{PLAYBACK_ID}",
      "input_schema": {
        "type": "object",
        "properties": { "ASSET_ID": { "type": "string" }, "PLAYBACK_ID": { "type": "string" } },
        "required": ["ASSET_ID", "PLAYBACK_ID"]
      }
    },
    {
      "name": "delete_asset_playback_id",
      "description": "Revoke a playback ID from an asset. Existing viewers may retain temporary access through cached manifests.",
      "method": "DELETE",
      "path": "/video/v1/assets/{ASSET_ID}/playback-ids/{PLAYBACK_ID}",
      "input_schema": {
        "type": "object",
        "properties": { "ASSET_ID": { "type": "string" }, "PLAYBACK_ID": { "type": "string" } },
        "required": ["ASSET_ID", "PLAYBACK_ID"]
      }
    },
    {
      "name": "create_asset_track",
      "description": "Add a subtitle or alternate-audio track to a ready asset from a public SRT, VTT, M4A, WAV, or MP3 URL.",
      "method": "POST",
      "path": "/video/v1/assets/{ASSET_ID}/tracks",
      "input_schema": {
        "type": "object",
        "properties": {
          "ASSET_ID": { "type": "string" },
          "url": { "type": "string" },
          "type": { "type": "string", "enum": ["text", "audio"] },
          "language_code": { "type": "string", "description": "BCP 47 language code, such as en or en-US." },
          "name": { "type": "string" },
          "text_type": { "type": "string", "enum": ["subtitles"] },
          "closed_captions": { "type": "boolean" },
          "passthrough": { "type": "string" }
        },
        "required": ["ASSET_ID", "url", "type", "language_code"]
      }
    },
    {
      "name": "delete_asset_track",
      "description": "Remove an added text or alternate-audio track. Primary video and primary audio tracks cannot be deleted.",
      "method": "DELETE",
      "path": "/video/v1/assets/{ASSET_ID}/tracks/{TRACK_ID}",
      "input_schema": {
        "type": "object",
        "properties": { "ASSET_ID": { "type": "string" }, "TRACK_ID": { "type": "string" } },
        "required": ["ASSET_ID", "TRACK_ID"]
      }
    },
    {
      "name": "generate_asset_subtitles",
      "description": "Generate one or more subtitle tracks from an asset audio track using Mux automatic speech recognition.",
      "method": "POST",
      "path": "/video/v1/assets/{ASSET_ID}/tracks/{TRACK_ID}/generate-subtitles",
      "input_schema": {
        "type": "object",
        "properties": {
          "ASSET_ID": { "type": "string" },
          "TRACK_ID": { "type": "string" },
          "generated_subtitles": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "language_code": { "type": "string", "description": "Supported language code or auto." },
                "name": { "type": "string" },
                "passthrough": { "type": "string" }
              }
            }
          }
        },
        "required": ["ASSET_ID", "TRACK_ID", "generated_subtitles"]
      }
    },
    {
      "name": "delete_static_rendition",
      "description": "Delete one generated static MP4 or M4A rendition from an asset.",
      "method": "DELETE",
      "path": "/video/v1/assets/{ASSET_ID}/static-renditions/{STATIC_RENDITION_ID}",
      "input_schema": {
        "type": "object",
        "properties": { "ASSET_ID": { "type": "string" }, "STATIC_RENDITION_ID": { "type": "string" } },
        "required": ["ASSET_ID", "STATIC_RENDITION_ID"]
      }
    },
    {
      "name": "update_asset_master_access",
      "description": "Enable temporary 24-hour access to the source-quality master file or disable master access.",
      "method": "PUT",
      "path": "/video/v1/assets/{ASSET_ID}/master-access",
      "input_schema": {
        "type": "object",
        "properties": { "ASSET_ID": { "type": "string" }, "master_access": { "type": "string", "enum": ["temporary", "none"] } },
        "required": ["ASSET_ID", "master_access"]
      }
    },
    {
      "name": "update_asset_mp4_support",
      "description": "Legacy MP4 support switch. Prefer create_static_rendition for new workflows; setting none removes legacy MP4 files.",
      "method": "PUT",
      "path": "/video/v1/assets/{ASSET_ID}/mp4-support",
      "input_schema": {
        "type": "object",
        "properties": {
          "ASSET_ID": { "type": "string" },
          "mp4_support": { "type": "string", "enum": ["none", "standard", "capped-1080p", "audio-only", "audio-only,capped-1080p"] }
        },
        "required": ["ASSET_ID", "mp4_support"]
      }
    },
    {
      "name": "get_direct_upload",
      "description": "Get direct-upload status and the resulting asset ID after upload processing begins.",
      "method": "GET",
      "path": "/video/v1/uploads/{UPLOAD_ID}",
      "input_schema": { "type": "object", "properties": { "UPLOAD_ID": { "type": "string" } }, "required": ["UPLOAD_ID"] }
    },
    {
      "name": "list_direct_uploads",
      "description": "List direct uploads and their waiting, asset_created, errored, cancelled, or timed_out states.",
      "method": "GET",
      "path": "/video/v1/uploads",
      "input_schema": {
        "type": "object",
        "properties": { "limit": { "type": "integer", "maximum": 100 }, "page": { "type": "integer", "minimum": 1 } }
      }
    },
    {
      "name": "cancel_direct_upload",
      "description": "Cancel a direct upload that is still waiting for bytes to be uploaded.",
      "method": "PUT",
      "path": "/video/v1/uploads/{UPLOAD_ID}/cancel",
      "input_schema": { "type": "object", "properties": { "UPLOAD_ID": { "type": "string" } }, "required": ["UPLOAD_ID"] }
    },
    {
      "name": "get_playback_id",
      "description": "Resolve a playback ID globally to its object type and associated asset or live-stream metadata.",
      "method": "GET",
      "path": "/video/v1/playback-ids/{PLAYBACK_ID}",
      "input_schema": { "type": "object", "properties": { "PLAYBACK_ID": { "type": "string" } }, "required": ["PLAYBACK_ID"] }
    },
    {
      "name": "get_live_stream",
      "description": "Get a live stream's state, stream key, playback IDs, recent asset IDs, and configuration.",
      "method": "GET",
      "path": "/video/v1/live-streams/{LIVE_STREAM_ID}",
      "input_schema": { "type": "object", "properties": { "LIVE_STREAM_ID": { "type": "string" } }, "required": ["LIVE_STREAM_ID"] }
    },
    {
      "name": "update_live_stream",
      "description": "Update latency, reconnect behavior, metadata, passthrough, and future recorded-asset settings.",
      "method": "PATCH",
      "path": "/video/v1/live-streams/{LIVE_STREAM_ID}",
      "input_schema": {
        "type": "object",
        "properties": {
          "LIVE_STREAM_ID": { "type": "string" },
          "latency_mode": { "type": "string", "enum": ["standard", "reduced", "low"] },
          "max_continuous_duration": { "type": "integer" },
          "reconnect_window": { "type": "integer" },
          "reconnect_slate_url": { "type": "string" },
          "use_slate_for_standard_latency": { "type": "boolean" },
          "passthrough": { "type": "string", "maxLength": 255 },
          "meta": { "type": "object", "properties": { "title": { "type": "string", "maxLength": 512 } } },
          "new_asset_settings": {
            "type": "object",
            "properties": {
              "master_access": { "type": "string", "enum": ["temporary", "none"] },
              "video_quality": { "type": "string", "enum": ["plus", "premium"] },
              "mp4_support": { "type": "string", "enum": ["none", "standard", "capped-1080p", "audio-only", "audio-only,capped-1080p"] },
              "meta": { "type": "object" }
            }
          }
        },
        "required": ["LIVE_STREAM_ID"]
      }
    },
    {
      "name": "delete_live_stream",
      "description": "Permanently delete an idle live-stream configuration.",
      "method": "DELETE",
      "path": "/video/v1/live-streams/{LIVE_STREAM_ID}",
      "input_schema": { "type": "object", "properties": { "LIVE_STREAM_ID": { "type": "string" } }, "required": ["LIVE_STREAM_ID"] }
    },
    {
      "name": "complete_live_stream",
      "description": "Immediately end an active stream and complete its current recorded asset.",
      "method": "PUT",
      "path": "/video/v1/live-streams/{LIVE_STREAM_ID}/complete",
      "input_schema": { "type": "object", "properties": { "LIVE_STREAM_ID": { "type": "string" } }, "required": ["LIVE_STREAM_ID"] }
    },
    {
      "name": "enable_live_stream",
      "description": "Enable a disabled live stream so its stream key can accept broadcasts again.",
      "method": "PUT",
      "path": "/video/v1/live-streams/{LIVE_STREAM_ID}/enable",
      "input_schema": { "type": "object", "properties": { "LIVE_STREAM_ID": { "type": "string" } }, "required": ["LIVE_STREAM_ID"] }
    },
    {
      "name": "disable_live_stream",
      "description": "Disable a live stream. An active broadcast is disconnected and no new broadcast is accepted until enabled.",
      "method": "PUT",
      "path": "/video/v1/live-streams/{LIVE_STREAM_ID}/disable",
      "input_schema": { "type": "object", "properties": { "LIVE_STREAM_ID": { "type": "string" } }, "required": ["LIVE_STREAM_ID"] }
    },
    {
      "name": "reset_live_stream_key",
      "description": "Rotate a live stream's ingest key. The previous key stops working immediately.",
      "method": "POST",
      "path": "/video/v1/live-streams/{LIVE_STREAM_ID}/reset-stream-key",
      "input_schema": { "type": "object", "properties": { "LIVE_STREAM_ID": { "type": "string" } }, "required": ["LIVE_STREAM_ID"] }
    },
    {
      "name": "create_live_stream_playback_id",
      "description": "Create an additional public, signed, or DRM playback ID for a live stream.",
      "method": "POST",
      "path": "/video/v1/live-streams/{LIVE_STREAM_ID}/playback-ids",
      "input_schema": {
        "type": "object",
        "properties": {
          "LIVE_STREAM_ID": { "type": "string" },
          "policy": { "type": "string", "enum": ["public", "signed", "drm"] },
          "drm_configuration_id": { "type": "string", "description": "Required only when policy is drm." }
        },
        "required": ["LIVE_STREAM_ID", "policy"]
      }
    },
    {
      "name": "get_live_stream_playback_id",
      "description": "Get one playback ID attached to a live stream.",
      "method": "GET",
      "path": "/video/v1/live-streams/{LIVE_STREAM_ID}/playback-ids/{PLAYBACK_ID}",
      "input_schema": {
        "type": "object",
        "properties": { "LIVE_STREAM_ID": { "type": "string" }, "PLAYBACK_ID": { "type": "string" } },
        "required": ["LIVE_STREAM_ID", "PLAYBACK_ID"]
      }
    },
    {
      "name": "delete_live_stream_playback_id",
      "description": "Revoke one playback ID from a live stream.",
      "method": "DELETE",
      "path": "/video/v1/live-streams/{LIVE_STREAM_ID}/playback-ids/{PLAYBACK_ID}",
      "input_schema": {
        "type": "object",
        "properties": { "LIVE_STREAM_ID": { "type": "string" }, "PLAYBACK_ID": { "type": "string" } },
        "required": ["LIVE_STREAM_ID", "PLAYBACK_ID"]
      }
    },
    {
      "name": "create_simulcast_target",
      "description": "Forward a live stream to an RTMP, RTMPS, or SRT destination such as YouTube Live or another CDN.",
      "method": "POST",
      "path": "/video/v1/live-streams/{LIVE_STREAM_ID}/simulcast-targets",
      "input_schema": {
        "type": "object",
        "properties": {
          "LIVE_STREAM_ID": { "type": "string" },
          "url": { "type": "string", "description": "RTMP(S) application URL or complete SRT connection string." },
          "stream_key": { "type": "string", "description": "Destination stream key for RTMP(S)." },
          "passthrough": { "type": "string" }
        },
        "required": ["LIVE_STREAM_ID", "url"]
      }
    },
    {
      "name": "get_simulcast_target",
      "description": "Get one simulcast destination and its current status.",
      "method": "GET",
      "path": "/video/v1/live-streams/{LIVE_STREAM_ID}/simulcast-targets/{SIMULCAST_TARGET_ID}",
      "input_schema": {
        "type": "object",
        "properties": { "LIVE_STREAM_ID": { "type": "string" }, "SIMULCAST_TARGET_ID": { "type": "string" } },
        "required": ["LIVE_STREAM_ID", "SIMULCAST_TARGET_ID"]
      }
    },
    {
      "name": "delete_simulcast_target",
      "description": "Stop forwarding to and remove a simulcast destination.",
      "method": "DELETE",
      "path": "/video/v1/live-streams/{LIVE_STREAM_ID}/simulcast-targets/{SIMULCAST_TARGET_ID}",
      "input_schema": {
        "type": "object",
        "properties": { "LIVE_STREAM_ID": { "type": "string" }, "SIMULCAST_TARGET_ID": { "type": "string" } },
        "required": ["LIVE_STREAM_ID", "SIMULCAST_TARGET_ID"]
      }
    },
    {
      "name": "update_live_embedded_subtitles",
      "description": "Replace the CEA-608 embedded-caption configuration for future assets recorded from a live stream.",
      "method": "PUT",
      "path": "/video/v1/live-streams/{LIVE_STREAM_ID}/embedded-subtitles",
      "input_schema": {
        "type": "object",
        "properties": {
          "LIVE_STREAM_ID": { "type": "string" },
          "embedded_subtitles": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "language_channel": { "type": "string", "enum": ["cc1", "cc2", "cc3", "cc4"] },
                "language_code": { "type": "string" },
                "name": { "type": "string" },
                "passthrough": { "type": "string" }
              }
            }
          }
        },
        "required": ["LIVE_STREAM_ID", "embedded_subtitles"]
      }
    },
    {
      "name": "update_live_generated_subtitles",
      "description": "Replace automatic live-caption settings, optionally using transcription vocabularies.",
      "method": "PUT",
      "path": "/video/v1/live-streams/{LIVE_STREAM_ID}/generated-subtitles",
      "input_schema": {
        "type": "object",
        "properties": {
          "LIVE_STREAM_ID": { "type": "string" },
          "generated_subtitles": {
            "type": "array",
            "maxItems": 1,
            "items": {
              "type": "object",
              "properties": {
                "language_code": { "type": "string", "enum": ["en", "en-US", "es", "fr", "de", "pt", "it"] },
                "name": { "type": "string" },
                "passthrough": { "type": "string" },
                "transcription_vocabulary_ids": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        },
        "required": ["LIVE_STREAM_ID", "generated_subtitles"]
      }
