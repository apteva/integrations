        },
        "required": [
          "adGroups"
        ]
      }
    },
    {
      "name": "sp_list_keywords",
      "description": "Sponsored Products: list keywords. Filter by adGroupId or campaignId, matchType (EXACT|PHRASE|BROAD), state.",
      "method": "POST",
      "path": "/sp/keywords/list",
      "input_schema": {
        "type": "object",
        "properties": {
          "campaignIdFilter": {
            "type": "object"
          },
          "adGroupIdFilter": {
            "type": "object"
          },
          "stateFilter": {
            "type": "object"
          },
          "matchTypeFilter": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "EXACT",
                "PHRASE",
                "BROAD"
              ]
            }
          },
          "maxResults": {
            "type": "integer",
            "default": 50
          },
          "nextToken": {
            "type": "string"
          }
        }
      }
    },
    {
      "name": "sp_create_keywords",
      "description": "Sponsored Products: bid keywords into an ad group. Each requires campaignId, adGroupId, keywordText, matchType, state, bid.",
      "method": "POST",
      "path": "/sp/keywords",
      "input_schema": {
        "type": "object",
        "properties": {
          "keywords": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "keywords"
        ]
      }
    },
    {
      "name": "sb_list_campaigns",
