          "count": {
            "type": "integer",
            "default": 100
          },
          "stateFilter": {
            "type": "string",
            "description": "Comma-separated states: enabled,paused,archived"
          },
          "campaignIdFilter": {
            "type": "string",
            "description": "Comma-separated campaign IDs"
          },
          "name": {
            "type": "string",
            "description": "Filter by name (exact match)"
          }
        }
      }
    },
    {
      "name": "create_report",
      "description": "v3 Reporting: request an async performance report. configuration determines reportTypeId (e.g. spCampaigns, spTargeting, sbCampaigns, sdCampaigns), groupBy, columns, filters, timeUnit (DAILY|SUMMARY), format (GZIP_JSON), and reportTypeId. Polled via get_report.",
      "method": "POST",
      "path": "/reporting/reports",
      "input_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Optional report name"
          },
          "startDate": {
            "type": "string",
            "description": "YYYY-MM-DD"
          },
          "endDate": {
            "type": "string",
            "description": "YYYY-MM-DD"
          },
          "configuration": {
            "type": "object",
            "description": "{\"adProduct\": \"SPONSORED_PRODUCTS\", \"groupBy\": [\"campaign\"], \"columns\": [\"impressions\",\"clicks\",\"cost\",\"sales\",\"purchases\"], \"reportTypeId\": \"spCampaigns\", \"timeUnit\": \"DAILY\", \"format\": \"GZIP_JSON\"}"
          }
        },
        "required": [
          "startDate",
          "endDate",
          "configuration"
        ]
      }
    },
    {
      "name": "get_report",
      "description": "Poll an async report by reportId. When status=COMPLETED, the response contains url (a presigned S3 link, valid 60s) for the gzipped JSON output.",
      "method": "GET",
      "path": "/reporting/reports/{reportId}",
      "input_schema": {
        "type": "object",
        "properties": {
          "reportId": {
            "type": "string"
          }
        },
        "required": [
          "reportId"
        ]
      }
    },
