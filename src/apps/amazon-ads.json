{
  "slug": "amazon-ads",
  "name": "Amazon Ads",
  "description": "Amazon Advertising API v3 — Sponsored Products, Sponsored Brands, and Sponsored Display campaigns plus Amazon DSP. LWA OAuth2; every call requires Amazon-Advertising-API-ClientId and (after profile selection) Amazon-Advertising-API-Scope (the profile_id).",
  "logo": "https://www.google.com/s2/favicons?domain=advertising.amazon.com&sz=128",
  "categories": [
    "advertising",
    "marketing",
    "campaigns",
    "amazon",
    "retail-media",
    "dsp",
    "sponsored-ads"
  ],
  "base_url": "https://advertising-api.amazon.com",
  "auth": {
    "types": [
      "bearer",
      "oauth2"
    ],
    "headers": {
      "Authorization": "Bearer {{token}}",
      "Amazon-Advertising-API-ClientId": "{{client_id}}",
      "Amazon-Advertising-API-Scope": "{{profile_id}}"
    },
    "credential_fields": [
      {
        "name": "token",
        "label": "access_token",
        "type": "password",
        "description": "LWA access token (1-hour TTL — refresh with refresh_token)"
      },
      {
        "name": "refresh_token",
        "label": "refresh_token",
        "type": "password"
      },
      {
        "name": "client_id",
        "label": "LWA Client ID",
        "description": "Client ID from your Login with Amazon security profile"
      },
      {
        "name": "profile_id",
        "label": "Profile ID",
        "description": "Default Amazon-Advertising-API-Scope value. Discover via list_profiles."
      },
      {
        "name": "expires_in",
        "label": "expires_in"
      }
    ],
    "oauth2": {
      "authorize_url": "https://www.amazon.com/ap/oa",
      "token_url": "https://api.amazon.com/auth/o2/token",
      "scopes": [
        "advertising::campaign_management",
        "advertising::account_management"
      ],
      "client_id_required": true,
      "pkce": false
    }
  },
  "tools": [
    {
      "name": "list_profiles",
      "description": "List advertiser profiles the authenticated user has access to. Each profile carries a profileId (used as Amazon-Advertising-API-Scope on all subsequent calls), countryCode, currencyCode, accountInfo (advertiser type and marketplace).",
      "method": "GET",
      "path": "/v2/profiles",
      "input_schema": {
        "type": "object",
        "properties": {
          "apiProgram": {
            "type": "string",
            "enum": [
              "billing",
              "campaign",
              "paymentMethods",
              "store",
              "account",
              "posts"
            ]
          },
          "accessLevel": {
            "type": "string",
            "enum": [
              "edit",
              "view"
            ]
          },
          "profileTypeFilter": {
            "type": "string",
            "description": "Comma-separated, e.g. seller,vendor,agency"
          },
          "validPaymentMethodFilter": {
            "type": "string",
            "enum": [
              "true",
              "false"
            ]
          }
        }
      }
    },
    {
      "name": "sp_list_campaigns",
      "description": "Sponsored Products: list campaigns. Filter by campaignId, name, state (enabled|paused|archived), portfolioId. Returns up to maxResults per page; use nextToken from response for paging.",
      "method": "POST",
      "path": "/sp/campaigns/list",
      "input_schema": {
        "type": "object",
        "properties": {
          "campaignIdFilter": {
            "type": "object",
            "description": "{\"include\": [\"123\", \"456\"]}"
          },
          "stateFilter": {
            "type": "object",
            "description": "{\"include\": [\"ENABLED\"]}"
          },
          "nameFilter": {
            "type": "object",
            "description": "{\"queryTermMatchType\": \"BROAD_MATCH\", \"include\": [\"summer\"]}"
          },
          "portfolioIdFilter": {
            "type": "object"
          },
          "maxResults": {
            "type": "integer",
            "default": 50,
            "description": "Max 5000"
          },
          "nextToken": {
            "type": "string"
          }
        }
      }
    },
    {
      "name": "sp_create_campaign",
      "description": "Sponsored Products: create one or more campaigns. Each campaign requires name, targetingType (MANUAL|AUTO), state (ENABLED|PAUSED), startDate (YYYY-MM-DD), budget {budgetType: DAILY, budget: number}, dynamicBidding {strategy: LEGACY_FOR_SALES|AUTO_FOR_SALES|MANUAL|RULE_BASED}.",
      "method": "POST",
      "path": "/sp/campaigns",
      "input_schema": {
        "type": "object",
        "properties": {
          "campaigns": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "campaigns"
        ]
      }
    },
    {
      "name": "sp_update_campaign",
      "description": "Sponsored Products: update existing campaigns. Each item must include campaignId; only provided fields are mutated.",
      "method": "PUT",
      "path": "/sp/campaigns",
      "input_schema": {
        "type": "object",
        "properties": {
          "campaigns": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "campaigns"
        ]
      }
    },
