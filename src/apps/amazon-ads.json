            "type": "string"
          }
        }
      }
    },
    {
      "name": "sp_create_ad_group",
      "description": "Sponsored Products: create one or more ad groups. Each requires campaignId, name, defaultBid, state.",
      "method": "POST",
      "path": "/sp/adGroups",
      "input_schema": {
        "type": "object",
        "properties": {
          "adGroups": {
            "type": "array",
