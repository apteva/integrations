{
  "slug": "elevenlabs",
  "name": "ElevenLabs",
  "description": "AI voice synthesis and music generation platform with text-to-speech, voice cloning, and AI music composition",
  "logo": "https://www.google.com/s2/favicons?domain=elevenlabs.io&sz=128",
  "categories": [
    "ai",
    "voice",
    "text-to-speech",
    "audio",
    "voice-cloning",
    "music",
    "speech-synthesis"
  ],
  "base_url": "",
  "auth": {
    "types": [
      "api_key"
    ],
    "headers": {
      "xi-api-key": "{{token}}"
    },
    "credential_fields": [
      {
        "name": "token",
        "label": "Api Key",
        "description": "Your ElevenLabs API Key"
      }
    ]
  },
  "tools": [
    {
      "name": "generate_speech",
      "description": "Convert text to speech with AI voices and customizable voice settings",
      "method": "GET",
      "path": "/generate-speech",
      "input_schema": {
        "type": "object",
        "properties": {
          "apiKey": {
            "type": "string",
            "description": "ElevenLabs API key (required)"
          },
          "text": {
            "type": "string",
            "description": "Text to convert to speech (required)"
          },
          "voice_id": {
            "type": "string",
            "description": "Voice ID to use (required)"
          },
          "model": {
            "type": "string",
            "default": "eleven_monolingual_v1",
            "description": "ElevenLabs model to use"
          },
          "stability": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "default": 0.5,
            "description": "Voice stability (0.0-1.0)"
          },
          "similarity_boost": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "default": 0.5,
            "description": "Similarity boost (0.0-1.0)"
          },
          "style": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "default": 0,
            "description": "Style setting (0.0-1.0)"
          }
        },
        "required": [
          "apiKey",
          "text",
          "voice_id"
        ]
      }
    },
    {
      "name": "list_voices",
      "description": "Get available AI voices with pagination, search, and filtering support",
      "method": "GET",
      "path": "/list-voices",
      "input_schema": {
        "type": "object",
        "properties": {
          "apiKey": {
            "type": "string",
            "description": "ElevenLabs API key (required)"
          },
          "next_page_token": {
            "type": "string",
            "description": "Token for pagination from previous response"
          },
          "page_size": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 10,
            "description": "Number of voices to return (max 100, default 10)"
          },
          "search": {
            "type": "string",
            "description": "Search by name, description, labels, and category"
          },
          "sort": {
            "type": "string",
            "enum": [
              "created_at_unix",
              "name"
            ],
            "description": "Sort field"
          },
          "sort_direction": {
            "type": "string",
            "enum": [
              "asc",
              "desc"
            ],
            "description": "Sort order"
          },
          "voice_type": {
            "type": "string",
            "enum": [
              "personal",
              "community",
              "default",
              "workspace",
              "non-default"
            ],
            "description": "Filter by voice type"
          },
          "category": {
            "type": "string",
            "enum": [
              "premade",
              "cloned",
              "generated",
              "professional"
            ],
            "description": "Filter by category"
          },
          "fine_tuning_state": {
            "type": "string",
            "description": "Filter professional voice clones by state"
          },
          "collection_id": {
            "type": "string",
            "description": "Filter voices by collection ID"
          },
          "include_total_count": {
            "type": "boolean",
            "default": false,
            "description": "Include total count of voices in response"
          },
          "voice_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "maxItems": 100,
            "description": "Voice IDs to lookup (max 100)"
          }
        },
        "required": [
          "apiKey"
        ]
      }
    },
    {
      "name": "clone_voice",
      "description": "Create a custom voice clone from audio samples for personalized speech synthesis",
      "method": "GET",
      "path": "/clone-voice",
      "input_schema": {
        "type": "object",
        "properties": {
          "apiKey": {
            "type": "string",
            "description": "ElevenLabs API key (required)"
          },
          "name": {
            "type": "string",
            "description": "Name for the cloned voice (required)"
          },
          "description": {
            "type": "string",
            "description": "Description for the cloned voice"
          },
          "audio_files": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "data": {
                  "type": "string",
                  "description": "Base64 encoded audio data"
                },
                "filename": {
                  "type": "string",
                  "description": "Filename for the audio file"
                },
                "contentType": {
                  "type": "string",
                  "description": "Content type (e.g., audio/wav)"
                }
              }
            },
            "description": "Array of audio file data (base64 encoded, 1-25 files)"
          },
          "labels": {
            "type": "object",
            "description": "Labels for the voice (accent, age, gender, etc.)"
          }
        },
        "required": [
          "apiKey",
          "name",
          "audio_files"
        ]
      }
    },
    {
      "name": "compose_music",
      "description": "Generate AI music composition from text prompts with customizable duration and style",
      "method": "GET",
      "path": "/compose-music",
      "input_schema": {
        "type": "object",
        "properties": {
          "apiKey": {
            "type": "string",
            "description": "ElevenLabs API key (required)"
          },
          "prompt": {
            "type": "string",
            "description": "Text description of desired music (required if composition_plan not provided)"
          },
          "composition_plan": {
            "type": "object",
            "description": "JSON composition plan object (required if prompt not provided)"
          },
          "music_length_ms": {
            "type": "number",
            "minimum": 10000,
            "maximum": 300000,
            "default": 30000,
            "description": "Music length in milliseconds (10000-300000, 10 seconds to 5 minutes)"
          },
          "output_format": {
            "type": "string",
            "default": "mp3",
            "description": "Audio output format (mp3 or wav)"
          }
        },
        "required": [
          "apiKey"
        ]
      }
    },
    {
      "name": "get_music_generation",
      "description": "Get status and download URL for music generation task",
      "method": "GET",
      "path": "/get-music-generation",
      "input_schema": {
        "type": "object",
        "properties": {
          "apiKey": {
            "type": "string",
            "description": "ElevenLabs API key (required)"
          },
          "generation_id": {
            "type": "string",
            "description": "ID of the music generation to retrieve (required)"
          },
          "include_audio": {
            "type": "boolean",
            "default": true,
            "description": "Whether to include audio data in response when completed"
          }
        },
        "required": [
          "apiKey",
          "generation_id"
        ]
      }
    },
    {
      "name": "create_composition_plan",
      "description": "Generate detailed composition plans from prompts for fine-grained music control",
      "method": "POST",
      "path": "/create-composition-plan",
      "input_schema": {
        "type": "object",
        "properties": {
          "apiKey": {
            "type": "string",
            "description": "ElevenLabs API key (required)"
          },
          "prompt": {
            "type": "string",
            "description": "Text description of desired music for plan generation (required)"
          },
          "music_length_ms": {
            "type": "number",
            "minimum": 5000,
            "maximum": 300000,
            "default": 30000,
            "description": "Target music length in milliseconds"
          }
        },
        "required": [
          "apiKey",
          "prompt"
        ]
      }
    }
  ]
}
