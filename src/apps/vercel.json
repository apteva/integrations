{
  "slug": "vercel",
  "name": "Vercel",
  "description": "MCP server for Vercel - deployments, projects, domains, environment variables",
  "logo": "https://www.google.com/s2/favicons?domain=vercel.com&sz=128",
  "categories": ["hosting", "deployment", "devops", "serverless"],
  "base_url": "https://api.vercel.com",
  "auth": {
    "types": ["bearer"],
    "headers": { "Authorization": "Bearer {{token}}" },
    "credential_fields": [
      { "name": "token", "label": "Access Token" },
      { "name": "teamId", "label": "Team ID", "description": "Optional - scope requests to a team" }
    ]
  },
  "tools": [
    {
      "name": "list_projects",
      "description": "List all projects",
      "method": "GET",
      "path": "/v9/projects",
      "input_schema": {
        "type": "object",
        "properties": {
          "teamId": { "type": "string" },
          "limit": { "type": "number" }
        }
      }
    },
    {
      "name": "get_project",
      "description": "Retrieve a project by ID or name",
      "method": "GET",
      "path": "/v9/projects/{id_or_name}",
      "input_schema": {
        "type": "object",
        "properties": { "id_or_name": { "type": "string" } },
        "required": ["id_or_name"]
      }
    },
    {
      "name": "create_project",
      "description": "Create a new project",
      "method": "POST",
      "path": "/v11/projects",
      "input_schema": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "framework": { "type": "string" },
          "gitRepository": { "type": "object" }
        },
        "required": ["name"]
      }
    },
    {
      "name": "list_deployments",
      "description": "List deployments",
      "method": "GET",
      "path": "/v6/deployments",
      "input_schema": {
        "type": "object",
        "properties": {
          "projectId": { "type": "string" },
          "state": { "type": "string" },
          "limit": { "type": "number" }
        }
      }
    },
    {
      "name": "get_deployment",
      "description": "Get a deployment by ID",
      "method": "GET",
      "path": "/v13/deployments/{id}",
      "input_schema": {
        "type": "object",
        "properties": { "id": { "type": "string" } },
        "required": ["id"]
      }
    },
    {
      "name": "create_deployment",
      "description": "Create a new deployment",
      "method": "POST",
      "path": "/v13/deployments",
      "input_schema": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "files": { "type": "array" },
          "projectSettings": { "type": "object" },
          "target": { "type": "string" }
        },
        "required": ["name"]
      }
    },
    {
      "name": "cancel_deployment",
      "description": "Cancel a running deployment",
      "method": "PATCH",
      "path": "/v12/deployments/{id}/cancel",
      "input_schema": {
        "type": "object",
        "properties": { "id": { "type": "string" } },
        "required": ["id"]
      }
    },
    {
      "name": "list_domains",
      "description": "List domains for a project",
      "method": "GET",
      "path": "/v9/projects/{id_or_name}/domains",
      "input_schema": {
        "type": "object",
        "properties": { "id_or_name": { "type": "string" } },
        "required": ["id_or_name"]
      }
    },
    {
      "name": "add_env_var",
      "description": "Add an environment variable to a project",
      "method": "POST",
      "path": "/v10/projects/{id_or_name}/env",
      "input_schema": {
        "type": "object",
        "properties": {
          "id_or_name": { "type": "string" },
          "key": { "type": "string" },
          "value": { "type": "string" },
          "target": { "type": "array", "items": { "type": "string" } },
          "type": { "type": "string" }
        },
        "required": ["id_or_name", "key", "value", "target"]
      }
    }
  ]
}
