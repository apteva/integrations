    {
      "name": "create_price_rule",
      "description": "Create a discount/price rule in Shopify",
      "method": "POST",
      "path": "/create-price-rule",
      "input_schema": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Price rule title"
          },
          "valueType": {
            "type": "string",
            "enum": [
              "PERCENTAGE",
              "FIXED_AMOUNT"
            ],
            "description": "Type of discount value"
          },
          "value": {
            "type": "number",
            "description": "Discount value (percentage or fixed amount)"
          },
          "targetType": {
            "type": "string",
            "enum": [
              "LINE_ITEM",
              "SHIPPING_LINE"
            ],
            "description": "What the discount applies to"
          },
          "targetSelection": {
            "type": "string",
            "enum": [
              "ALL",
              "ENTITLED"
            ],
            "description": "Which items the discount applies to"
          },
          "allocationMethod": {
            "type": "string",
            "enum": [
              "ACROSS",
              "EACH"
            ],
            "description": "How the discount is allocated"
          },
          "customerSelection": {
            "type": "string",
