          "limit": {
            "type": "number",
            "description": "Number of products to return"
          },
          "since_id": {
            "type": "string",
            "description": "Restrict results to after the specified ID"
          },
          "collection_id": {
            "type": "string",
            "description": "Filter by collection"
          }
        }
      }
    },
