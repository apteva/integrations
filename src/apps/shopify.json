{
  "slug": "shopify",
  "name": "Shopify",
  "description": "MCP server for Shopify e-commerce platform - products, orders, customers, inventory, fulfillment, metafields, discounts, and webhooks",
  "logo": "https://www.google.com/s2/favicons?domain=shopify.com&sz=128",
  "categories": [
    "e-commerce",
    "retail",
    "products",
    "orders",
    "inventory",
    "fulfillment",
    "discounts"
  ],
  "base_url": "https://{shop}.myshopify.com/admin/api/2024-01",
  "auth": {
    "types": [
      "bearer",
      "oauth2"
    ],
    "headers": {
      "X-Shopify-Access-Token": "{{token}}"
    },
    "credential_fields": [
      {
        "name": "token",
        "label": "access_token"
      }
    ],
    "oauth2": {
      "authorize_url": "https://{shop}.myshopify.com/admin/oauth/authorize",
      "token_url": "https://{shop}.myshopify.com/admin/oauth/access_token",
      "scopes": [
        "read_products",
        "write_products",
        "read_product_listings",
        "read_customers",
        "write_customers",
        "read_orders",
        "write_orders",
        "read_all_orders",
        "read_draft_orders",
        "write_draft_orders",
        "read_inventory",
        "write_inventory",
        "read_locations",
        "read_script_tags",
        "write_script_tags",
        "read_fulfillments",
        "write_fulfillments",
        "read_assigned_fulfillment_orders",
        "write_assigned_fulfillment_orders",
        "read_merchant_managed_fulfillment_orders",
        "write_merchant_managed_fulfillment_orders",
        "read_shipping",
        "write_shipping",
        "read_analytics",
        "read_checkouts",
        "write_checkouts",
        "read_reports",
        "write_reports",
        "read_price_rules",
        "write_price_rules",
        "read_discounts",
        "write_discounts",
        "read_marketing_events",
        "write_marketing_events",
        "read_resource_feedbacks",
        "write_resource_feedbacks",
        "read_shopify_payments_payouts",
        "read_shopify_payments_disputes",
        "read_translations",
        "write_translations",
        "read_locales",
        "write_locales"
      ],
      "client_id_required": true,
      "pkce": false
    }
  },
  "tools": [
    {
      "name": "get_shop_info",
      "description": "Get information about the Shopify store",
      "method": "GET",
      "path": "/get-shop-info",
      "input_schema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "list_products",
