{
  "slug": "cloudinary",
  "name": "Cloudinary",
  "description": "MCP server for Cloudinary media management - upload, transform, deliver",
  "logo": "https://www.google.com/s2/favicons?domain=cloudinary.com&sz=128",
  "categories": [
    "media",
    "images",
    "videos",
    "cdn"
  ],
  "base_url": "https://api.cloudinary.com/v1_1",
  "auth": {
    "types": [
      "bearer"
    ],
    "headers": {
      "Authorization": "Bearer {{token}}"
    },
    "credential_fields": [
      {
        "name": "token",
        "label": "API Key"
      }
    ]
  },
  "tools": [
    {
      "name": "upload_image",
      "description": "Upload an image to Cloudinary",
      "method": "POST",
      "path": "/upload-image",
      "input_schema": {
        "type": "object",
        "properties": {
          "file": {
            "type": "string",
            "description": "File URL or base64"
          },
          "public_id": {
            "type": "string"
          },
          "folder": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "file"
        ]
      }
    },
    {
      "name": "generate_delivery_url",
      "description": "Generate a delivery URL with transformations",
      "method": "GET",
      "path": "/generate-delivery-url",
      "input_schema": {
        "type": "object",
        "properties": {
          "public_id": {
            "type": "string"
          },
          "transformations": {
            "type": "object"
          },
          "format": {
            "type": "string"
          }
        },
        "required": [
          "public_id"
        ]
      }
    },
    {
      "name": "get_image_analysis",
      "description": "Get AI analysis of an image",
      "method": "GET",
      "path": "/get-image-analysis",
      "input_schema": {
        "type": "object",
        "properties": {
          "public_id": {
            "type": "string"
          }
        },
        "required": [
          "public_id"
        ]
      }
    },
    {
      "name": "ai_background_removal",
      "description": "Remove image background using AI",
      "method": "GET",
      "path": "/ai-background-removal",
      "input_schema": {
        "type": "object",
        "properties": {
          "public_id": {
            "type": "string"
          }
        },
        "required": [
          "public_id"
        ]
      }
    },
    {
      "name": "explicit_transformation",
      "description": "Apply transformations to an image",
      "method": "GET",
      "path": "/explicit-transformation",
      "input_schema": {
        "type": "object",
        "properties": {
          "public_id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "eager": {
            "type": "array"
          }
        },
        "required": [
          "public_id"
        ]
      }
    },
    {
      "name": "destroy_resource",
      "description": "Delete a resource",
      "method": "GET",
      "path": "/destroy-resource",
      "input_schema": {
        "type": "object",
        "properties": {
          "public_id": {
            "type": "string"
          },
          "resource_type": {
            "type": "string",
            "enum": [
              "image",
              "video",
              "raw"
            ]
          }
        },
        "required": [
          "public_id"
        ]
      }
    }
  ]
}
