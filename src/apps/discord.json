{
  "slug": "discord",
  "name": "Discord",
  "description": "MCP server for Discord - messages, channels, webhooks, moderation",
  "logo": "https://www.google.com/s2/favicons?domain=discord.com&sz=128",
  "categories": [
    "messaging",
    "gaming",
    "community",
    "chat"
  ],
  "base_url": "https://discord.com/api/v10",
  "auth": {
    "types": [
      "bearer",
      "oauth2"
    ],
    "headers": {
      "Authorization": "Bearer {{token}}"
    },
    "credential_fields": [
      {
        "name": "token",
        "label": "access_token"
      },
      {
        "name": "refresh_token",
        "label": "refresh_token"
      },
      {
        "name": "expires_in",
        "label": "expires_in"
      },
      {
        "name": "token_type",
        "label": "token_type"
      },
      {
        "name": "scope",
        "label": "scope"
      }
    ],
    "oauth2": {
      "authorize_url": "https://discord.com/api/oauth2/authorize",
      "token_url": "https://discord.com/api/oauth2/token",
      "scopes": [
        "identify",
        "email",
        "connections",
        "guilds",
        "guilds.join",
        "guilds.members.read",
        "gdm.join",
        "rpc",
        "rpc.notifications.read",
        "rpc.voice.read",
        "rpc.voice.write",
        "rpc.activities.write",
        "bot",
        "webhook.incoming",
        "messages.read",
        "applications.builds.upload",
        "applications.builds.read",
        "applications.commands",
        "applications.store.update",
        "applications.entitlements",
        "activities.read",
        "activities.write",
        "relationships.read",
        "voice",
        "dm_channels.read",
        "role_connections.write"
      ],
      "client_id_required": true,
      "pkce": false
    }
  },
