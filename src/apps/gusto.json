{
  "slug": "gusto",
  "name": "Gusto",
  "description": "MCP server for Gusto HR and payroll operations - employees, companies, and payrolls",
  "logo": "https://www.google.com/s2/favicons?domain=gusto.com&sz=128",
  "categories": [
    "hr",
    "payroll",
    "gusto",
    "employees"
  ],
  "base_url": "https://api.gusto.com/v1",
  "auth": {
    "types": [
      "bearer"
    ],
    "headers": {
      "Authorization": "Bearer {{token}}"
    },
    "credential_fields": [
      {
        "name": "token",
        "label": "API Key"
      }
    ]
  },
  "tools": [
    {
      "name": "list_companies",
      "description": "List companies from Gusto",
      "method": "GET",
      "path": "/list-companies",
      "input_schema": {
        "type": "object",
        "properties": {
          "page": {
            "type": "number",
            "description": "Page number",
            "default": 1
          },
          "perPage": {
            "type": "number",
            "description": "Results per page",
            "default": 25
          }
        }
      }
    },
    {
      "name": "get_company",
      "description": "Get a specific company from Gusto",
      "method": "GET",
      "path": "/get-company",
      "input_schema": {
        "type": "object",
        "properties": {
          "companyId": {
            "type": "string",
            "description": "Company ID"
          }
        },
        "required": [
          "companyId"
        ]
      }
    },
    {
      "name": "list_employees",
      "description": "List employees from a Gusto company",
      "method": "GET",
      "path": "/list-employees",
      "input_schema": {
        "type": "object",
        "properties": {
          "companyId": {
            "type": "string",
            "description": "Company ID"
          },
          "page": {
            "type": "number",
            "description": "Page number",
            "default": 1
          },
          "perPage": {
            "type": "number",
            "description": "Results per page",
            "default": 25
          },
          "terminated": {
            "type": "boolean",
            "description": "Include terminated employees"
          }
        },
        "required": [
          "companyId"
        ]
      }
    },
    {
      "name": "get_employee",
      "description": "Get a specific employee from Gusto",
      "method": "GET",
      "path": "/get-employee",
      "input_schema": {
        "type": "object",
        "properties": {
          "employeeId": {
            "type": "string",
            "description": "Employee ID"
          }
        },
        "required": [
          "employeeId"
        ]
      }
    },
    {
      "name": "list_payrolls",
      "description": "List payrolls from a Gusto company",
      "method": "GET",
      "path": "/list-payrolls",
      "input_schema": {
        "type": "object",
        "properties": {
          "companyId": {
            "type": "string",
            "description": "Company ID"
          },
          "processed": {
            "type": "boolean",
            "description": "Filter by processed status"
          },
          "startDate": {
            "type": "string",
            "description": "Start date filter"
          },
          "endDate": {
            "type": "string",
            "description": "End date filter"
          }
        },
        "required": [
          "companyId"
        ]
      }
    },
    {
      "name": "get_payroll",
      "description": "Get a specific payroll from Gusto",
      "method": "GET",
      "path": "/get-payroll",
      "input_schema": {
        "type": "object",
        "properties": {
          "companyId": {
            "type": "string",
            "description": "Company ID"
          },
          "payrollId": {
            "type": "string",
            "description": "Payroll ID"
          }
        },
        "required": [
          "companyId",
          "payrollId"
        ]
      }
    }
  ]
}
