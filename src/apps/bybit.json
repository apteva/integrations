{
  "slug": "bybit",
  "name": "Bybit",
  "description": "Major crypto exchange \u2014 spot and derivatives market data, orderbooks, candles, tickers, and account management.",
  "logo": "https://www.google.com/s2/favicons?domain=bybit.com&sz=128",
  "categories": [
    "crypto",
    "exchange",
    "trading",
    "derivatives",
    "perpetuals"
  ],
  "base_url": "https://api.bybit.com",
  "auth": {
    "types": [
      "bearer"
    ],
    "headers": {
      "Authorization": "Bearer {{token}}"
    },
    "credential_fields": [
      {
        "name": "api_key",
        "label": "Api_key",
        "description": "Bybit API key"
      },
      {
        "name": "api_secret",
        "label": "Api_secret",
        "description": "Bybit API secret"
      },
      {
        "name": "testnet",
        "label": "Testnet",
        "description": "Set to true to use testnet (api-testnet.bybit.com)"
      }
    ]
  },
  "tools": [
    {
      "name": "get_tickers",
      "description": "Get ticker data for all or specific trading pairs. Category: spot, linear (USDT perps), inverse.",
      "method": "GET",
      "path": "/get-tickers",
      "input_schema": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "spot",
              "linear",
              "inverse"
            ],
            "default": "spot"
          },
          "symbol": {
            "type": "string",
            "description": "Trading pair (e.g., BTCUSDT). Omit for all tickers."
          }
        }
      }
    },
    {
      "name": "get_kline",
      "description": "Get OHLCV kline data for a trading pair.",
      "method": "GET",
      "path": "/get-kline",
      "input_schema": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "spot",
              "linear",
              "inverse"
            ],
            "default": "spot"
          },
          "symbol": {
            "type": "string",
            "description": "Trading pair (e.g., BTCUSDT)"
          },
          "interval": {
            "type": "string",
            "enum": [
              "1",
              "3",
              "5",
              "15",
              "30",
              "60",
              "120",
              "240",
              "360",
              "720",
              "D",
              "W",
              "M"
            ],
            "default": "60"
          },
          "limit": {
            "type": "integer",
            "default": 200,
            "description": "Max results (1-1000)"
          }
        },
        "required": [
          "symbol"
        ]
      }
    },
    {
      "name": "get_orderbook",
      "description": "Get order book depth for a trading pair.",
      "method": "GET",
      "path": "/get-orderbook",
      "input_schema": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "spot",
              "linear",
              "inverse"
            ],
            "default": "spot"
          },
          "symbol": {
            "type": "string"
          },
          "limit": {
            "type": "integer",
            "default": 25
          }
        },
        "required": [
          "symbol"
        ]
      }
    },
    {
      "name": "get_instruments",
      "description": "Get trading pair specifications \u2014 lot sizes, price filters, leverage, and trading status.",
      "method": "GET",
      "path": "/get-instruments",
      "input_schema": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "spot",
              "linear",
              "inverse"
            ],
            "default": "spot"
          },
          "symbol": {
            "type": "string",
            "description": "Specific pair (optional)"
          }
        }
      }
    },
    {
      "name": "get_funding_rate",
      "description": "Get funding rate history for perpetual contracts.",
      "method": "GET",
      "path": "/get-funding-rate",
      "input_schema": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string",
            "description": "Perpetual pair (e.g., BTCUSDT)"
          },
          "limit": {
            "type": "integer",
            "default": 50
          }
        },
        "required": [
          "symbol"
        ]
      }
    }
  ]
}