{
  "slug": "bunny-stream",
  "name": "Bunny Stream",
  "description": "MCP server for Bunny Stream video hosting, streaming, and media management platform",
  "logo": "https://www.google.com/s2/favicons?domain=bunny.net&sz=128",
  "categories": [
    "video",
    "streaming",
    "media",
    "video-hosting",
    "transcoding"
  ],
  "base_url": "https://api.bunny.net",
  "auth": {
    "types": [
      "api_key"
    ],
    "headers": {
      "AccessKey": "{{streamApiKey}}"
    },
    "credential_fields": [
      {
        "name": "streamApiKey",
        "label": "Stream API Key",
        "description": "Your Bunny Stream library API key for the configured video library. Used for video, collection, upload, and fetch tools on video.bunnycdn.com."
      },
      {
        "name": "accountApiKey",
        "label": "Account API Key",
        "required": false,
        "description": "Optional Bunny account API key from Account Settings > API Keys. Required only for account-level library tools: list_libraries, get_library, and create_library."
      },
      {
        "name": "libraryId",
        "label": "Library Id",
        "description": "The numeric Bunny Stream video library ID used with the per-library Stream API key."
      }
    ]
  },
  "explorer": {
    "resources": [
      {
        "id": "collections",
        "label": "Collections",
        "description": "Collections in the configured Bunny Stream library.",
        "list_tool": "list_collections",
        "response_path": "items",
        "item_id_path": "guid",
        "item_label_path": "name",
        "item_subtitle_path": "videoCount",
        "actions": [
          {
            "label": "Create collection",
            "tool": "create_collection"
          }
        ]
      },
      {
        "id": "videos",
        "label": "Videos",
        "description": "Videos in the configured Bunny Stream library.",
        "list_tool": "list_videos",
        "response_path": "items",
        "item_id_path": "guid",
        "item_label_path": "title",
        "item_subtitle_path": "status",
        "detail_tool": "get_video",
        "detail_input": {
          "videoId": "{{item.guid}}"
        },
        "actions": [
          {
            "label": "Fetch video",
            "tool": "fetch_video"
          },
          {
            "label": "Update selected video",
            "tool": "update_video",
            "input": {
              "videoId": "{{item.guid}}"
            }
          },
          {
            "label": "Delete selected video",
            "tool": "delete_video",
            "input": {
              "videoId": "{{item.guid}}"
            },
            "destructive": true
          }
        ]
      }
    ]
  },
  "tools": [
    {
      "name": "list_libraries",
      "description": "List all video libraries in your Bunny account. This is a Core API endpoint and requires the accountApiKey credential, not the per-library streamApiKey. Returns Id, Name, VideoCount, StorageUsage, PullZoneId, StorageZoneId, ApiKey, and ReadOnlyApiKey where available.",
      "method": "GET",
      "path": "/videolibrary",
      "headers": {
        "AccessKey": "{{accountApiKey}}"
      },
      "query_param_aliases": {
        "itemsPerPage": "perPage"
      },
      "input_schema": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "description": "Page number for pagination",
            "default": 1
          },
          "itemsPerPage": {
            "type": "integer",
            "description": "Items per page",
            "default": 1000,
            "minimum": 5,
            "maximum": 1000
          },
          "search": {
            "type": "string",
            "description": "Search term used to filter video libraries"
          }
        }
      },
      "mock_response": {
        "Items": [
          {
            "Id": 12345,
            "Name": "My Library",
            "VideoCount": 27,
            "TrafficUsage": 1048576,
            "StorageUsage": 524288000,
            "DateCreated": "2025-01-01T00:00:00",
            "ReplicationRegions": [
              "DE"
            ],
            "EnabledResolutions": "240p,360p,480p,720p,1080p",
            "PullZoneId": 67890,
            "StorageZoneId": 98765
          }
        ],
        "CurrentPage": 1,
        "TotalItems": 1,
        "HasMoreItems": false
      }
    },
    {
      "name": "get_library",
      "description": "Get account-level details for the configured video library. This is a Core API endpoint and requires accountApiKey, not streamApiKey.",
      "method": "GET",
      "path": "/videolibrary/{{credential.libraryId}}",
      "headers": {
        "AccessKey": "{{accountApiKey}}"
      },
      "input_schema": {
        "type": "object",
        "properties": {}
      },
      "mock_response": {
        "Id": 12345,
        "Name": "My Library",
        "VideoCount": 27,
        "TrafficUsage": 1048576,
        "StorageUsage": 524288000,
        "DateCreated": "2025-01-01T00:00:00",
        "ReplicationRegions": [
          "DE"
        ],
        "EnabledResolutions": "240p,360p,480p,720p,1080p",
        "PullZoneId": 67890,
        "StorageZoneId": 98765
      }
    },
    {
      "name": "create_library",
      "description": "Create a new video library for organizing and hosting videos. This is a Core API endpoint and requires accountApiKey, not streamApiKey. The response includes the new library Id and ApiKey; use those as libraryId and streamApiKey for Stream tools.",
      "method": "POST",
      "path": "/videolibrary",
      "headers": {
        "AccessKey": "{{accountApiKey}}"
      },
      "input_schema": {
        "type": "object",
        "properties": {
          "Name": {
            "type": "string",
            "description": "Library name",
            "minLength": 1,
            "maxLength": 100
          },
          "ReplicationRegions": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "DE",
                "UK",
                "NY",
                "LA",
                "SG",
                "SYD",
                "BR",
                "JH"
              ]
            },
            "description": "Regions to replicate videos",
            "default": [
              "DE"
            ]
          },
          "EnableDRM": {
            "type": "boolean",
            "description": "Enable DRM protection",
            "default": false
          },
          "EnableTokenAuthentication": {
            "type": "boolean",
            "description": "Enable token authentication for playback"
          },
          "EnableOriginalQuality": {
            "type": "boolean",
            "description": "Keep original quality version"
          },
          "EnableMP4Fallback": {
            "type": "boolean",
            "description": "Enable MP4 fallback"
          },
          "WatermarkPositionLeft": {
            "type": "integer",
            "description": "Watermark left position"
          },
          "WatermarkPositionTop": {
            "type": "integer",
            "description": "Watermark top position"
          },
          "WatermarkWidth": {
            "type": "integer",
            "description": "Watermark width"
          },
          "WatermarkHeight": {
            "type": "integer",
            "description": "Watermark height"
          },
          "PlayerKeyColor": {
            "type": "string",
            "description": "Player key color (hex)"
          }
        },
        "required": [
          "Name"
        ]
      },
      "mock_response": {
        "Id": 12399,
        "Name": "(library name)",
        "VideoCount": 0,
        "TrafficUsage": 0,
        "StorageUsage": 0,
        "DateCreated": "2026-05-22T12:00:00",
        "ReplicationRegions": [],
        "EnabledResolutions": "240p,360p,480p,720p,1080p",
        "PullZoneId": 67899,
        "StorageZoneId": 98799,
        "ApiKey": "mock-library-api-key-AbCdEf1234567890"
      }
    },
    {
      "name": "list_videos",
      "description": "List videos in the library with pagination and filtering. Each video includes guid, videoLibraryId, title, status, length, views, collectionId, and more. Pass collectionId to filter to one Bunny collection; the integration sends this to Bunny as the required collection query parameter.\n\nURL construction for agents:\n- Use guid as the video ID.\n- Use videoLibraryId from the video response as the library ID. If videoLibraryId is missing, use the configured libraryId or the Id from list_libraries/get_library.\n- Embed/player URL: https://iframe.mediadelivery.net/embed/{videoLibraryId}/{guid}\n- Alternate player host: https://player.mediadelivery.net/embed/{videoLibraryId}/{guid}\n- Thumbnail URL: https://vz-{videoLibraryId}.b-cdn.net/{guid}/thumbnail.jpg\n- Direct MP4/download URLs are only available when MP4 fallback is enabled and require the library pull-zone hostname from Bunny; the video response alone is not enough.",
      "method": "GET",
      "base_url": "https://video.bunnycdn.com",
      "path": "/library/{{credential.libraryId}}/videos",
      "query_param_aliases": {
        "collectionId": "collection"
      },
      "input_schema": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "description": "Page number",
            "default": 1
          },
          "itemsPerPage": {
            "type": "integer",
            "description": "Items per page",
            "default": 20,
            "maximum": 100
          },
          "search": {
            "type": "string",
            "description": "Search query for video titles"
          },
          "collectionId": {
            "type": "string",
            "description": "Filter by collection ID"
          },
          "orderBy": {
            "type": "string",
            "enum": [
              "date",
              "title",
              "views"
            ],
            "description": "Sort order",
            "default": "date"
          }
        }
      },
      "mock_response": {
        "totalItems": 1,
        "currentPage": 1,
        "itemsPerPage": 100,
        "items": [
          {
            "videoLibraryId": 12345,
            "guid": "9e8d7c6b-5a4f-3e2d-1c0b-a9b8c7d6e5f4",
            "title": "Behind the build",
            "dateUploaded": "2026-05-22T12:00:00.000Z",
            "views": 1250,
            "isPublic": true,
            "length": 34,
            "status": 4,
            "framerate": 30,
            "width": 1920,
            "height": 1080,
            "availableResolutions": "240p,360p,480p,720p,1080p",
            "encodeProgress": 100,
            "storageSize": 24576000
          }
        ]
      }
    },
    {
      "name": "get_video",
      "description": "Get video details including status, encoding progress, resolution, duration, collectionId, and metadata.\n\nURL construction for agents:\n- The guid field in the response is the Bunny video ID.\n- The videoLibraryId field in the response is the Bunny Stream library ID. If videoLibraryId is missing, use the configured libraryId or the Id from list_libraries/get_library.\n- Embed/player URL: https://iframe.mediadelivery.net/embed/{videoLibraryId}/{guid}\n- Alternate player host: https://player.mediadelivery.net/embed/{videoLibraryId}/{guid}\n- Thumbnail URL: https://vz-{videoLibraryId}.b-cdn.net/{guid}/thumbnail.jpg\n- Direct MP4/download URLs are not returned by get_video. They only work when MP4 fallback is enabled and require the library pull-zone hostname from Bunny, for example https://{pullZoneHostname}/{guid}/play_720p.mp4. Do not invent this hostname from guid or videoLibraryId alone.",
      "method": "GET",
      "base_url": "https://video.bunnycdn.com",
      "path": "/library/{{credential.libraryId}}/videos/{videoId}",
      "input_schema": {
        "type": "object",
        "properties": {
          "videoId": {
            "type": "string",
            "description": "Video ID"
          }
        },
        "required": [
          "videoId"
        ]
      },
      "mock_response": {
        "videoLibraryId": 12345,
        "guid": "9e8d7c6b-5a4f-3e2d-1c0b-a9b8c7d6e5f4",
        "title": "Behind the build",
        "dateUploaded": "2026-05-22T12:00:00.000Z",
        "views": 1250,
        "isPublic": true,
        "length": 34,
        "status": 4,
        "framerate": 30,
        "width": 1920,
        "height": 1080,
        "availableResolutions": "240p,360p,480p,720p,1080p",
        "thumbnailCount": 5,
        "encodeProgress": 100,
        "storageSize": 24576000,
        "category": "unknown"
      }
    },
    {
      "name": "create_video",
      "description": "Create a new video entry in the library (use fetch-video to add content from a URL)",
      "method": "POST",
      "base_url": "https://video.bunnycdn.com",
      "path": "/library/{{credential.libraryId}}/videos",
      "input_schema": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Video title",
            "minLength": 1,
            "maxLength": 200
          },
          "collectionId": {
            "type": "string",
            "description": "Collection ID to add video to"
          },
          "thumbnailTime": {
            "type": "integer",
            "description": "Thumbnail generation time in milliseconds"
          }
        },
        "required": [
          "title"
        ]
      },
      "mock_response": {
        "videoLibraryId": 12345,
        "guid": "1a2b3c4d-5e6f-7a8b-9c0d-1e2f3a4b5c6d",
        "title": "(video title)",
        "dateUploaded": "2026-05-22T12:00:00.000Z",
        "views": 0,
        "isPublic": false,
        "length": 0,
        "status": 0,
        "framerate": 0,
        "width": 0,
        "height": 0,
        "availableResolutions": "",
        "encodeProgress": 0,
        "storageSize": 0
      }
    },
    {
      "name": "update_video",
      "description": "Update video metadata including title, description, chapters, moments, and meta tags. metaTags must be an array of objects like [{\"property\":\"keywords\",\"value\":\"tag one, tag two\"}], not an array of strings.",
      "method": "POST",
      "base_url": "https://video.bunnycdn.com",
      "path": "/library/{{credential.libraryId}}/videos/{videoId}",
      "input_schema": {
        "type": "object",
        "properties": {
          "videoId": {
            "type": "string",
            "description": "Video ID"
          },
          "title": {
            "type": "string",
            "description": "New video title"
          },
          "description": {
            "type": "string",
            "description": "Video description"
          },
          "collectionId": {
            "type": "string",
            "description": "Move to different collection"
          },
          "chapters": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "title": {
                  "type": "string"
                },
                "start": {
                  "type": "integer"
                },
                "end": {
                  "type": "integer"
                }
              }
            },
            "description": "Video chapters"
          },
          "moments": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "label": {
                  "type": "string"
                },
                "timestamp": {
                  "type": "integer"
                }
              }
            },
            "description": "Video moments/markers"
          },
          "metaTags": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "property": {
                  "type": "string",
                  "description": "Meta tag property/name, for example keywords, title, or description"
                },
                "value": {
                  "type": "string",
                  "description": "Meta tag value"
                }
              }
            },
            "description": "Meta tags for SEO as Bunny MetaTagModel objects. Do not pass plain strings; use objects like {\"property\":\"keywords\",\"value\":\"tag one, tag two\"}."
          }
        },
        "required": [
          "videoId"
        ]
      },
      "mock_response": {
        "success": true,
        "message": "OK",
        "statusCode": 200
      }
    },
    {
      "name": "delete_video",
      "description": "Permanently delete a Bunny Stream video from the configured library. This cannot be undone. Args: videoId.",
      "method": "DELETE",
      "base_url": "https://video.bunnycdn.com",
      "path": "/library/{{credential.libraryId}}/videos/{videoId}",
      "input_schema": {
        "type": "object",
        "properties": {
          "videoId": {
            "type": "string",
            "description": "Video ID (guid) to delete"
          }
        },
        "required": [
          "videoId"
        ]
      },
      "mock_response": {
        "success": true,
        "message": "OK",
        "statusCode": 200
      }
    },
    {
      "name": "list_collections",
      "description": "List all video collections in the library",
      "method": "GET",
      "base_url": "https://video.bunnycdn.com",
      "path": "/library/{{credential.libraryId}}/collections",
      "input_schema": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "description": "Page number",
            "default": 1
          },
          "itemsPerPage": {
            "type": "integer",
            "description": "Items per page",
            "default": 20,
            "maximum": 100
          },
          "orderBy": {
            "type": "string",
            "description": "Sort order"
          }
        }
      },
      "mock_response": {
        "totalItems": 1,
        "currentPage": 1,
        "itemsPerPage": 100,
        "items": [
          {
            "videoLibraryId": 12345,
            "guid": "c0llecti-0n00-0000-0000-000000000001",
            "name": "Tutorials",
            "videoCount": 8,
            "totalSize": 196608000,
            "previewVideoIds": "9e8d7c6b-5a4f-3e2d-1c0b-a9b8c7d6e5f4"
          }
        ]
      }
    },
    {
      "name": "create_collection",
      "description": "Create a new collection for organizing videos in the library",
      "method": "POST",
      "base_url": "https://video.bunnycdn.com",
      "path": "/library/{{credential.libraryId}}/collections",
      "input_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Collection name",
            "minLength": 1,
            "maxLength": 100
          }
        },
        "required": [
          "name"
        ]
      },
      "mock_response": {
        "videoLibraryId": 12345,
        "guid": "c0llecti-0n00-0000-0000-000000000099",
        "name": "(collection name)",
        "videoCount": 0,
        "totalSize": 0,
        "previewVideoIds": ""
      }
    },
    {
      "name": "fetch_video",
      "description": "Fetch and upload a video from an external URL to Bunny Stream for processing. If collectionId is provided, it is sent as Bunny's collectionId query parameter so the fetched video is assigned to that collection. thumbnailTime is in milliseconds.",
      "method": "POST",
      "base_url": "https://video.bunnycdn.com",
      "path": "/library/{{credential.libraryId}}/videos/fetch",
      "query_params": [
        "collectionId",
        "thumbnailTime"
      ],
      "input_schema": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "External URL to fetch the video from"
          },
          "title": {
            "type": "string",
            "description": "Video title (defaults to filename from URL)"
          },
          "collectionId": {
            "type": "string",
            "description": "Collection ID to add video to"
          },
          "thumbnailTime": {
            "type": "integer",
            "description": "Video time in milliseconds to generate the main thumbnail"
          },
          "headers": {
            "type": "object",
            "description": "Optional headers to send when fetching the video URL"
          }
        },
        "required": [
          "url"
        ]
      },
      "mock_response": {
        "success": true,
        "message": "OK",
        "statusCode": 200,
        "id": "2b3c4d5e-6f7a-8b9c-0d1e-2f3a4b5c6d7e"
      }
    }
  ]
}
