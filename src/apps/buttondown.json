{
  "slug": "buttondown",
  "name": "Buttondown",
  "description": "Buttondown REST API for newsletters, subscribers, emails, tags, images, exports, bulk actions, and webhooks.",
  "logo": "https://www.google.com/s2/favicons?domain=buttondown.com&sz=128",
  "categories": ["newsletter", "email", "publishing", "subscribers", "developer-tools"],
  "base_url": "https://api.buttondown.com/v1",
  "auth": { "types": ["api_key"], "headers": { "Authorization": "Token {{api_key}}", "Accept": "application/json", "Content-Type": "application/json" }, "credential_fields": [{ "name": "api_key", "label": "API Key", "description": "Buttondown API key." }] },
  "health_check": { "tool": "ping", "input": {} },
  "tools": [
    { "name": "ping", "description": "Ping Buttondown API.", "method": "GET", "path": "/ping", "input_schema": { "type": "object", "properties": {} } },
    { "name": "list_subscribers", "description": "List subscribers. Supports type, email, tag, negative tag, metadata, and pagination filters.", "method": "GET", "path": "/subscribers", "query_params": ["type", "email", "tag", "-tag", "metadata", "page", "ordering", "expand"], "input_schema": { "type": "object", "properties": { "type": { "type": "string" }, "email": { "type": "string" }, "tag": { "type": "string" }, "-tag": { "type": "string" }, "metadata": { "type": "string" }, "page": { "type": "integer" }, "ordering": { "type": "string" }, "expand": { "type": "string" } } } },
    { "name": "create_subscriber", "description": "Create a subscriber. Buttondown may double opt-in by default unless type is regular.", "method": "POST", "path": "/subscribers", "input_schema": { "type": "object", "properties": { "email_address": { "type": "string" }, "type": { "type": "string" }, "tags": { "type": "array", "items": { "type": "string" } }, "metadata": { "type": "object", "additionalProperties": true }, "notes": { "type": "string" }, "referrer_url": { "type": "string" }, "ip_address": { "type": "string" } }, "required": ["email_address"] } },
    { "name": "get_subscriber", "description": "Get one subscriber by id or email.", "method": "GET", "path": "/subscribers/{id_or_email}", "query_params": ["expand"], "input_schema": { "type": "object", "properties": { "id_or_email": { "type": "string" }, "expand": { "type": "string" } }, "required": ["id_or_email"] } },
    { "name": "update_subscriber", "description": "Update a subscriber.", "method": "PATCH", "path": "/subscribers/{id_or_email}", "input_schema": { "type": "object", "properties": { "id_or_email": { "type": "string" }, "email_address": { "type": "string" }, "type": { "type": "string" }, "tags": { "type": "array", "items": { "type": "string" } }, "metadata": { "type": "object", "additionalProperties": true }, "notes": { "type": "string" } }, "required": ["id_or_email"] } },
    { "name": "delete_subscriber", "description": "Delete a subscriber.", "method": "DELETE", "path": "/subscribers/{id_or_email}", "input_schema": { "type": "object", "properties": { "id_or_email": { "type": "string" } }, "required": ["id_or_email"] } },
    { "name": "list_emails", "description": "List emails/drafts/newsletters.", "method": "GET", "path": "/emails", "query_params": ["status", "included_tags", "excluded_tags", "page", "ordering", "expand"], "input_schema": { "type": "object", "properties": { "status": { "type": "array", "items": { "type": "string" } }, "included_tags": { "type": "array", "items": { "type": "string" } }, "excluded_tags": { "type": "array", "items": { "type": "string" } }, "page": { "type": "integer" }, "ordering": { "type": "string" }, "expand": { "type": "string" } } } },
    { "name": "create_email", "description": "Create an email. Buttondown detects Markdown/plaintext versus rich HTML by body mode.", "method": "POST", "path": "/emails", "input_schema": { "type": "object", "properties": { "subject": { "type": "string" }, "body": { "type": "string" }, "body_mode": { "type": "string", "description": "plaintext for Markdown, fancy for rich HTML." }, "slug": { "type": "string" }, "description": { "type": "string" }, "publish_date": { "type": "string" }, "metadata": { "type": "object", "additionalProperties": true }, "tags": { "type": "array", "items": { "type": "string" } } }, "required": ["subject", "body"] } },
    { "name": "get_email", "description": "Get one email.", "method": "GET", "path": "/emails/{email_id}", "query_params": ["expand"], "input_schema": { "type": "object", "properties": { "email_id": { "type": "string" }, "expand": { "type": "string" } }, "required": ["email_id"] } },
    { "name": "update_email", "description": "Update an email.", "method": "PATCH", "path": "/emails/{email_id}", "input_schema": { "type": "object", "properties": { "email_id": { "type": "string" }, "subject": { "type": "string" }, "body": { "type": "string" }, "body_mode": { "type": "string" }, "slug": { "type": "string" }, "description": { "type": "string" }, "publish_date": { "type": "string" }, "metadata": { "type": "object", "additionalProperties": true }, "tags": { "type": "array", "items": { "type": "string" } } }, "required": ["email_id"] } },
    { "name": "publish_email", "description": "Publish/send an email now or schedule it with publish_date.", "method": "POST", "path": "/emails/{email_id}/publish", "input_schema": { "type": "object", "properties": { "email_id": { "type": "string" }, "publish_date": { "type": "string" } }, "required": ["email_id"] } },
    { "name": "list_newsletters", "description": "List newsletters.", "method": "GET", "path": "/newsletters", "input_schema": { "type": "object", "properties": {} } },
    { "name": "create_newsletter", "description": "Create a Buttondown newsletter.", "method": "POST", "path": "/newsletters", "input_schema": { "type": "object", "properties": { "name": { "type": "string" }, "username": { "type": "string" }, "description": { "type": "string" } }, "required": ["name", "username", "description"] } },
    { "name": "update_newsletter", "description": "Update a newsletter.", "method": "PATCH", "path": "/newsletters/{newsletter_id}", "input_schema": { "type": "object", "properties": { "newsletter_id": { "type": "string" }, "name": { "type": "string" }, "username": { "type": "string" }, "description": { "type": "string" } }, "required": ["newsletter_id"] } },
    { "name": "delete_newsletter", "description": "Delete a newsletter.", "method": "DELETE", "path": "/newsletters/{newsletter_id}", "input_schema": { "type": "object", "properties": { "newsletter_id": { "type": "string" } }, "required": ["newsletter_id"] } },
    { "name": "list_tags", "description": "List tags.", "method": "GET", "path": "/tags", "query_params": ["page"], "input_schema": { "type": "object", "properties": { "page": { "type": "integer" } } } },
    { "name": "create_tag", "description": "Create a tag.", "method": "POST", "path": "/tags", "input_schema": { "type": "object", "properties": { "name": { "type": "string" }, "color": { "type": "string" } }, "required": ["name"] } },
    { "name": "list_exports", "description": "List exports.", "method": "GET", "path": "/exports", "input_schema": { "type": "object", "properties": {} } },
    { "name": "create_export", "description": "Create an export.", "method": "POST", "path": "/exports", "input_schema": { "type": "object", "properties": { "collections": { "type": "array", "items": { "type": "string" } } }, "required": ["collections"] } },
    { "name": "list_webhooks", "description": "List webhooks.", "method": "GET", "path": "/webhooks", "input_schema": { "type": "object", "properties": {} } },
    { "name": "create_webhook", "description": "Create a webhook.", "method": "POST", "path": "/webhooks", "input_schema": { "type": "object", "properties": { "url": { "type": "string" }, "event_types": { "type": "array", "items": { "type": "string" } } }, "required": ["url"] } },
    { "name": "delete_webhook", "description": "Delete a webhook.", "method": "DELETE", "path": "/webhooks/{webhook_id}", "input_schema": { "type": "object", "properties": { "webhook_id": { "type": "string" } }, "required": ["webhook_id"] } }
  ]
}
