{
  "slug": "slant3d",
  "name": "Slant 3D",
  "description": "Slant 3D v2 API for on-demand 3D printing, file management, quoting, print farm orders, components, and platform setup.",
  "logo": "https://www.google.com/s2/favicons?domain=slant3d.com&sz=128",
  "categories": ["3d-printing", "manufacturing", "print-farm", "on-demand", "slant3d"],
  "base_url": "https://slant3dapi.com/v2",
  "auth": {
    "types": ["bearer"],
    "headers": {
      "Authorization": "Bearer {{api_key}}"
    },
    "credential_fields": [
      {
        "name": "api_key",
        "label": "API Key",
        "description": "Slant 3D API key. Sent as a Bearer token to the v2 API."
      }
    ]
  },
  "health_check": { "tool": "list_filaments" },
  "tools": [
    {
      "name": "list_filaments",
      "description": "List available Slant 3D filament/profile options.",
      "method": "GET",
      "path": "/api/filaments",
      "input_schema": { "type": "object", "properties": {} }
    },
    {
      "name": "create_direct_upload",
      "description": "Create a presigned direct-upload slot for an STL file. Upload the bytes to the returned URL, then call confirm_direct_upload.",
      "method": "POST",
      "path": "/api/files/direct-upload",
      "input_schema": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "STL filename." },
          "ownerId": { "type": "string" },
          "platformId": { "type": "string" }
        },
        "required": ["name", "platformId"]
      }
    },
    {
      "name": "upload_presigned_file",
      "description": "PUT the STL bytes to the uploadUrl returned by create_direct_upload. This calls the absolute presigned storage URL without the Slant bearer token. On success, call confirm_direct_upload with the original filePlaceholder.",
      "method": "PUT",
      "path": "{uploadUrl}",
      "omit_auth_headers": ["Authorization"],
      "body_binary_param": "file",
      "input_schema": {
        "type": "object",
        "properties": {
          "uploadUrl": { "type": "string", "format": "uri", "description": "Exact presigned upload URL returned by create_direct_upload." },
          "file": { "type": "string", "description": "STL bytes as a blobref:// handle or runtime binary envelope. Do not inline large base64 manually." }
        },
        "required": ["uploadUrl", "file"]
      }
    },
    {
      "name": "confirm_direct_upload",
      "description": "Confirm a completed presigned upload. Pass the complete filePlaceholder object returned by create_direct_upload after the PUT to its presigned URL succeeds.",
      "method": "POST",
      "path": "/api/files/confirm-upload",
      "input_schema": {
        "type": "object",
        "properties": {
          "filePlaceholder": {
            "type": "object",
            "description": "Unmodified filePlaceholder object from create_direct_upload.",
            "properties": {
              "publicFileServiceId": { "type": "string" },
              "ownerId": { "type": "string" },
              "type": { "type": "string" },
              "platformId": { "type": "string" },
              "name": { "type": "string" },
              "fileURL": { "type": "string" }
            },
            "required": ["publicFileServiceId", "platformId", "name"]
          }
        },
        "required": ["filePlaceholder"]
      }
    },
    {
      "name": "get_file",
      "description": "Get metadata and processing status for an uploaded Slant 3D file.",
      "method": "GET",
      "path": "/api/files/{publicFileServiceId}",
      "input_schema": {
        "type": "object",
        "properties": {
          "publicFileServiceId": { "type": "string" }
        },
        "required": ["publicFileServiceId"]
      }
    },
    {
      "name": "list_files",
      "description": "List uploaded files using Slant 3D's documented platform, owner, public-id, date, pagination, and sorting filters.",
      "method": "GET",
      "path": "/api/files",
      "query_params": ["platformId", "ownerId", "publicId", "startDate", "endDate", "page", "limit"],
      "input_schema": {
        "type": "object",
        "properties": {
          "ownerId": { "type": "string" },
          "platformId": { "type": "string" },
          "publicId": { "type": "string" },
          "startDate": { "type": "string", "format": "date-time" },
          "endDate": { "type": "string", "format": "date-time" },
          "page": { "type": "integer", "minimum": 1, "default": 1 },
          "limit": { "type": "integer", "minimum": 1, "maximum": 100, "default": 50 }
        }
      }
    },
    {
      "name": "get_files_batch",
      "description": "Fetch metadata for several Slant 3D files in one call.",
      "method": "POST",
      "path": "/api/files/batch",
      "input_schema": {
        "type": "object",
        "properties": {
          "publicIds": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["publicIds"]
      }
    },
    {
      "name": "delete_file",
      "description": "Permanently delete an uploaded Slant 3D file. Inspect it with get_file first and do not delete files referenced by active orders.",
      "method": "DELETE",
      "path": "/api/files/{publicFileServiceId}",
      "input_schema": {
        "type": "object",
        "properties": { "publicFileServiceId": { "type": "string" } },
        "required": ["publicFileServiceId"]
      }
    },
    {
      "name": "estimate_file_price",
      "description": "Estimate the printing price for a processed file. Pass a filament id from list_filaments in options; this endpoint does not create or charge an order.",
      "method": "POST",
      "path": "/api/files/{publicFileServiceId}/estimate",
      "input_schema": {
        "type": "object",
        "properties": {
          "publicFileServiceId": { "type": "string" },
          "options": {
            "type": "object",
            "properties": {
              "filamentId": { "type": "string", "description": "Filament id from list_filaments; defaults to Slant's PLA black profile." },
              "quantity": { "type": "integer", "minimum": 1, "default": 1 }
            }
          }
        },
        "required": ["publicFileServiceId", "options"]
      }
    },
    {
      "name": "generate_stl_from_openscad",
      "description": "Generate an STL file from OpenSCAD source and register it with Slant 3D.",
      "method": "POST",
      "path": "/api/files/openScad",
      "input_schema": {
        "type": "object",
        "properties": {
          "scadCode": { "type": "string", "description": "Complete OpenSCAD source code." }
        },
        "required": ["scadCode"]
      }
    },
    {
      "name": "list_components",
      "description": "List reusable Slant 3D components.",
      "method": "GET",
      "path": "/api/components",
      "input_schema": { "type": "object", "properties": {} }
    },
    {
      "name": "list_stationery",
      "description": "List stationery/inserts available for STATIONERY order items.",
      "method": "GET",
      "path": "/api/stationery",
      "input_schema": { "type": "object", "properties": {} }
    },
    {
      "name": "get_usage",
      "description": "Get current Slant 3D API-key usage and request-limit information for operational monitoring.",
      "method": "GET",
      "path": "/api/usage",
      "input_schema": { "type": "object", "properties": {} }
    },
    {
      "name": "create_draft_order",
      "description": "Create and price a draft order without charging it. Use PRINT items for files, COMPONENT for stocked components, and STATIONERY for inserts. Inspect the returned totals before process_order.",
      "method": "POST",
      "path": "/api/orders",
      "input_schema": {
        "type": "object",
        "properties": {
          "platformId": { "type": "string", "description": "Platform created with create_platform." },
          "ownerId": { "type": "string", "description": "Optional application user/customer id." },
          "customer": {
            "type": "object",
            "properties": {
              "publicPaymentServiceId": { "type": "string", "description": "Optional customer payment id; omit to use the account payment method." },
              "details": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "address": {
                    "type": "object",
                    "properties": {
                      "name": { "type": "string" }, "line1": { "type": "string" }, "line2": { "type": "string" },
                      "city": { "type": "string" }, "state": { "type": "string" }, "zip": { "type": "string" },
                      "country": { "type": "string", "description": "ISO 3166 two-letter country code." }
                    },
                    "required": ["name", "line1", "city", "zip", "country"]
                  }
                },
                "required": ["email", "address"]
              }
            },
            "required": ["details"]
          },
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "properties": {
                "type": { "type": "string", "enum": ["PRINT", "COMPONENT", "STATIONERY"] },
                "publicFileServiceId": { "type": "string", "description": "Required for PRINT." },
                "filamentId": { "type": "string", "description": "Required for PRINT." },
                "componentId": { "type": "string", "description": "Required for COMPONENT." },
                "stationeryId": { "type": "string", "description": "Required for STATIONERY." },
                "imageUrl": { "type": "string", "format": "uri", "description": "4x6 inch black-and-white JPEG/PNG URL for STATIONERY." },
                "quantity": { "type": "integer", "minimum": 1 },
                "name": { "type": "string" },
                "SKU": { "type": "string" },
                "options": {
                  "type": "object",
                  "properties": {
                    "slicerOptions": { "type": "object", "properties": { "support_enable": { "type": "boolean" } } }
                  }
                }
              },
              "required": ["type", "quantity"]
            }
          },
          "options": { "type": "object", "description": "Optional account-enabled order options." },
          "metadata": { "type": "object", "description": "At most 10 fields and 3 levels deep; some keys are reserved by Slant 3D." }
        },
        "required": ["platformId", "customer", "items"]
      }
    },
    {
      "name": "process_order",
      "description": "Charge and submit a validated draft order to production. This is billable and cannot be treated as a retry-safe operation; call get_order after an ambiguous response before retrying.",
      "method": "POST",
      "path": "/api/orders/{publicOrderId}",
      "input_schema": {
        "type": "object",
        "properties": {
          "publicOrderId": { "type": "string" }
        },
        "required": ["publicOrderId"]
      }
    },
    {
      "name": "get_order",
      "description": "Get a Slant 3D order by public order id.",
      "method": "GET",
      "path": "/api/orders/{publicOrderId}",
      "input_schema": {
        "type": "object",
        "properties": {
          "publicOrderId": { "type": "string" }
        },
        "required": ["publicOrderId"]
      }
    },
    {
      "name": "list_orders",
      "description": "List Slant 3D orders using documented platform, owner, status, date, and pagination filters.",
      "method": "GET",
      "path": "/api/orders",
      "query_params": ["platformId", "ownerId", "status", "startDate", "endDate", "page", "limit"],
      "input_schema": {
        "type": "object",
        "properties": {
          "platformId": { "type": "string" },
          "ownerId": { "type": "string" },
          "status": { "type": "string" },
          "startDate": { "type": "string", "format": "date-time" },
          "endDate": { "type": "string", "format": "date-time" },
          "page": { "type": "integer", "minimum": 1, "default": 1 },
          "limit": { "type": "integer", "minimum": 1, "default": 50 }
        }
      }
    },
    {
      "name": "search_orders",
      "description": "Search Slant 3D orders using the provider's dedicated free-text search route.",
      "method": "GET",
      "path": "/api/orders/search",
      "query_params": ["query"],
      "input_schema": {
        "type": "object",
        "properties": { "query": { "type": "string" } },
        "required": ["query"]
      }
    },
    {
      "name": "get_orders_batch",
      "description": "Fetch several Slant 3D orders in one call.",
      "method": "POST",
      "path": "/api/orders/batch",
      "input_schema": {
        "type": "object",
        "properties": {
          "public_ids": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["public_ids"]
      }
    },
    {
      "name": "cancel_order",
      "description": "Cancel an order and request its refund when possible. This is destructive; if the order already shipped, Slant documents that only the refund can occur. Inspect get_order first and do not retry a successful cancellation.",
      "method": "DELETE",
      "path": "/api/orders/{publicOrderId}",
      "input_schema": {
        "type": "object",
        "properties": {
          "publicOrderId": { "type": "string" }
        },
        "required": ["publicOrderId"]
      }
    },
    {
      "name": "list_platforms",
      "description": "List Slant 3D platforms available to the authenticated account.",
      "method": "GET",
      "path": "/api/platforms",
      "input_schema": { "type": "object", "properties": {} }
    },
    {
      "name": "get_platform_stripe_public_key",
      "description": "Get Slant 3D's Stripe public key for platform customer-payment setup. This is public configuration, not a secret key.",
      "method": "GET",
      "path": "/api/platforms/stripe/public-key",
      "input_schema": { "type": "object", "properties": {} }
    },
    {
      "name": "create_platform",
      "description": "Create a Slant 3D platform configuration.",
      "method": "POST",
      "path": "/api/platforms",
      "input_schema": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "maxLength": 100 },
          "url": { "type": "string", "format": "uri" },
          "webhookURL": { "type": "string", "format": "uri", "description": "HTTPS endpoint for Slant order and payment events." },
          "description": { "type": "string", "maxLength": 500 }
        },
        "required": ["name", "url"]
      }
    },
    {
      "name": "get_platform",
      "description": "Get a Slant 3D platform by id.",
      "method": "GET",
      "path": "/api/platforms/{platformId}",
      "input_schema": {
        "type": "object",
        "properties": { "platformId": { "type": "string" } },
        "required": ["platformId"]
      }
    },
    {
      "name": "update_platform",
      "description": "Patch a Slant 3D platform configuration.",
      "method": "PATCH",
      "path": "/api/platforms/{platformId}",
      "input_schema": {
        "type": "object",
        "properties": {
          "platformId": { "type": "string" },
          "name": { "type": "string", "maxLength": 100 },
          "url": { "type": "string", "format": "uri" },
          "webhookURL": { "type": "string", "format": "uri", "description": "Set to an empty string to remove webhook delivery." },
          "description": { "type": "string", "maxLength": 500 }
        },
        "required": ["platformId"]
      }
    },
    {
      "name": "delete_platform",
      "description": "Delete a Slant 3D platform configuration.",
      "method": "DELETE",
      "path": "/api/platforms/{platformId}",
      "input_schema": {
        "type": "object",
        "properties": { "platformId": { "type": "string" } },
        "required": ["platformId"]
      }
    }
  ]
}
