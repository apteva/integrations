{
  "slug": "hetzner",
  "name": "Hetzner Cloud",
  "description": "MCP server for Hetzner Cloud - servers, volumes, images, SSH keys",
  "logo": "https://www.google.com/s2/favicons?domain=hetzner.com&sz=128",
  "categories": [
    "cloud",
    "servers",
    "vps",
    "infrastructure"
  ],
  "base_url": "https://api.hetzner.cloud/v1",
  "auth": {
    "types": [
      "bearer"
    ],
    "headers": {
      "Authorization": "Bearer {{token}}"
    },
    "credential_fields": [
      {
        "name": "token",
        "label": "API Key"
      }
    ]
  },
  "tools": [
    {
      "name": "server_list",
      "description": "List all servers",
      "method": "GET",
      "path": "/server-list",
      "input_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "label_selector": {
            "type": "string"
          }
        }
      }
    },
    {
      "name": "server_get",
      "description": "Get server details",
      "method": "GET",
      "path": "/server-get",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    {
      "name": "server_create",
      "description": "Create a new server",
      "method": "GET",
      "path": "/server-create",
      "input_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "server_type": {
            "type": "string"
          },
          "image": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "ssh_keys": {
            "type": "array"
          }
        },
        "required": [
          "name",
          "server_type",
          "image"
        ]
      }
    },
    {
      "name": "server_delete",
      "description": "Delete a server",
      "method": "GET",
      "path": "/server-delete",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    {
      "name": "server_update",
      "description": "Update server details",
      "method": "GET",
      "path": "/server-update",
      "input_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "name": {
            "type": "string"
          },
          "labels": {
            "type": "object"
          }
        },
        "required": [
          "id"
        ]
      }
    },
