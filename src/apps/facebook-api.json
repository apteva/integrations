{
  "slug": "facebook-api",
  "name": "Facebook Pages",
  "description": "MCP server for Facebook Graph API operations including page management, post publishing, and social media analytics",
  "logo": "https://www.google.com/s2/favicons?domain=www.facebook.com&sz=128",
  "categories": [
    "facebook",
    "meta",
    "social-media",
    "pages",
    "posts"
  ],
  "base_url": "https://graph.facebook.com/v25.0",
  "auth": {
    "types": [
      "bearer",
      "oauth2"
    ],
    "headers": {
      "Authorization": "Bearer {{token}}"
    },
    "credential_fields": [
      {
        "name": "accessToken",
        "label": "accessToken"
      },
      {
        "name": "refreshToken",
        "label": "refreshToken"
      },
      {
        "name": "expiresIn",
        "label": "expiresIn"
      }
    ],
    "oauth2": {
      "authorize_url": "https://www.facebook.com/v25.0/dialog/oauth",
      "token_url": "https://graph.facebook.com/v25.0/oauth/access_token",
      "scopes": [
        "email",
        "public_profile",
        "pages_show_list",
        "pages_read_engagement",
        "pages_manage_posts",
        "pages_manage_metadata",
        "instagram_basic",
        "instagram_content_publish",
        "ads_management",
        "business_management"
      ],
      "client_id_required": true,
      "pkce": false
    }
  },
  "tools": [
    {
      "name": "post_to_page",
      "description": "Post text, links, or photos to a Facebook page. For IMAGE/PHOTO posts, use the 'image' parameter with a public URL - do NOT use 'link' for images. The 'link' parameter is only for sharing webpage URLs. For video uploads, use facebook-api-post-video instead. Caller MUST also include access_token=<page-level token from list_pages> — Facebook rejects the user token for /feed writes (error 210).",
      "method": "POST",
      "path": "/{pageId}/feed",
      "input_schema": {
        "type": "object",
        "properties": {
          "pageId": {
            "type": "string",
            "description": "Facebook page ID"
          },
          "message": {
            "type": "string",
            "description": "Post message content (used as caption for photos)"
          },
          "image": {
            "type": "string",
            "description": "Image/photo URL to post (must be publicly accessible). Use this for posting images - NOT the 'link' parameter."
          },
          "link": {
            "type": "string",
            "description": "Webpage URL to share (NOT for images - use 'image' parameter for photos)"
          },
          "photos": {
            "type": "array",
            "description": "Array of photo URLs for multi-image posts (must be publicly accessible)",
            "items": {
              "type": "string"
            }
          },
          "access_token": {
            "type": "string",
            "description": "Page-level access token (from list_pages → data[].access_token). Required: Facebook rejects user-level tokens for /feed writes."
          }
        },
        "required": [
          "pageId"
        ]
      }
    },
    {
      "name": "post_video",
      "description": "Upload and post a video to a Facebook page using a publicly accessible URL. Videos must be under 1GB and 20 minutes. Caller MUST include access_token=<page-level token from list_pages> — Facebook rejects user tokens for /videos writes (error 210).",
      "method": "POST",
      "path": "/{pageId}/videos",
      "input_schema": {
        "type": "object",
        "properties": {
          "pageId": {
            "type": "string",
            "description": "Facebook page ID"
          },
          "file_url": {
            "type": "string",
            "description": "Publicly accessible URL to the video file (MP4, MOV, AVI, WMV, FLV supported)"
          },
          "title": {
            "type": "string",
            "description": "Video title"
          },
          "description": {
            "type": "string",
            "description": "Video description text"
          },
          "thumb": {
            "type": "string",
            "description": "URL to custom thumbnail image"
          },
          "access_token": {
            "type": "string",
            "description": "Page-level access token (from list_pages → data[].access_token). Required: Facebook rejects user-level tokens for /videos writes."
          }
        },
        "required": [
          "pageId",
          "file_url"
        ]
      }
    },
    {
      "name": "get_page_posts",
      "description": "List posts from a Facebook page. Get all posts with message content, images, links, and engagement metrics (reactions, comments, shares). Supports pagination and date filtering.",
      "method": "GET",
      "path": "/get-page-posts",
      "input_schema": {
        "type": "object",
        "properties": {
          "pageId": {
            "type": "string",
            "description": "Facebook page ID"
          },
          "limit": {
            "type": "integer",
            "description": "Number of posts to retrieve",
            "default": 25,
            "maximum": 100
          },
          "fields": {
            "type": "string",
            "description": "Comma-separated list of fields to include",
            "default": "id,message,created_time,full_picture,permalink_url,shares,reactions.summary(true),comments.summary(true)"
          },
          "since": {
            "type": "string",
            "description": "Unix timestamp or date string to filter posts from"
          },
          "until": {
            "type": "string",
            "description": "Unix timestamp or date string to filter posts until"
          },
          "includeHidden": {
            "type": "boolean",
            "description": "Whether to include hidden posts",
            "default": false
          }
        },
        "required": [
          "pageId"
        ]
      }
    },
    {
      "name": "get_page_insights",
      "description": "Get analytics data for a Facebook page",
      "method": "GET",
      "path": "/get-page-insights",
      "input_schema": {
        "type": "object",
        "properties": {
          "pageId": {
            "type": "string",
            "description": "Facebook page ID"
          },
          "metrics": {
            "type": "array",
            "description": "Metrics to retrieve",
            "items": {
              "type": "string"
            },
            "default": [
              "page_fans"
            ]
          },
          "period": {
            "type": "string",
            "description": "Time period",
            "enum": [
              "day",
              "week",
              "days_28"
            ],
            "default": "day"
          },
          "since": {
            "type": "string",
            "description": "Start date (YYYY-MM-DD or Unix timestamp)"
          },
          "until": {
            "type": "string",
            "description": "End date (YYYY-MM-DD or Unix timestamp)"
          },
          "datePreset": {
            "type": "string",
            "description": "Predefined date range",
            "enum": [
              "today",
              "yesterday",
              "this_week",
              "last_week",
              "this_month",
              "last_month"
            ]
          }
        },
        "required": [
          "pageId"
        ]
      }
    },
    {
      "name": "list_pages",
      "description": "List all Facebook pages managed by the authenticated user with details like name, category, fan count, and verification status",
      "method": "GET",
      "path": "/me/accounts",
      "input_schema": {
        "type": "object",
        "properties": {
          "fields": {
            "type": "string",
            "description": "Comma-separated list of fields to include",
            "default": "id,name,category,access_token,tasks,fan_count,verification_status,website"
          }
        }
      }
    },
    {
      "name": "facebook_get_post",
      "description": "Get details of a specific Facebook post including message, creation time, and engagement metrics",
      "method": "GET",
      "path": "/facebook-get-post",
      "input_schema": {
        "type": "object",
        "properties": {
          "postId": {
            "type": "string",
            "description": "Facebook post ID (format: pageId_postId)"
          },
          "fields": {
            "type": "string",
            "description": "Comma-separated list of fields to include",
            "default": "id,message,created_time,updated_time"
          }
        },
        "required": [
          "postId"
        ]
      }
    },
    {
      "name": "facebook_update_post",
      "description": "Update/edit the message content of a Facebook post",
      "method": "GET",
      "path": "/facebook-update-post",
      "input_schema": {
        "type": "object",
        "properties": {
          "postId": {
            "type": "string",
            "description": "Facebook post ID (format: pageId_postId)"
          },
          "message": {
            "type": "string",
            "description": "New message content for the post"
          }
        },
        "required": [
          "postId",
          "message"
        ]
      }
    },
    {
      "name": "facebook_delete_post",
      "description": "Permanently delete a Facebook post from a page",
      "method": "GET",
      "path": "/facebook-delete-post",
      "input_schema": {
        "type": "object",
        "properties": {
          "postId": {
            "type": "string",
            "description": "Facebook post ID (format: pageId_postId)"
          }
        },
        "required": [
          "postId"
        ]
      }
    }
  ]
}