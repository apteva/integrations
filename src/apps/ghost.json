{
  "slug": "ghost",
  "name": "Ghost",
  "description": "Ghost Admin API for publication sites, posts, pages, tags, members, newsletters, tiers, offers, users, site metadata, and webhooks. Uses a Ghost Admin API key and signs each request as a short-lived Ghost JWT.",
  "logo": "https://www.google.com/s2/favicons?domain=ghost.org&sz=128",
  "categories": ["cms", "newsletter", "publishing", "memberships", "content"],
  "base_url": "{{credential.site_url}}/ghost/api/admin",
  "auth": {
    "types": ["api_key"],
    "headers": { "Accept-Version": "{{api_version}}", "Accept": "application/json", "Content-Type": "application/json" },
    "signers": [{ "name": "ghost_admin", "params": { "key_field": "admin_api_key" } }],
    "credential_fields": [
      { "name": "site_url", "label": "Admin Site URL", "description": "Ghost admin/site origin, e.g. https://example.com or https://example.ghost.io.", "type": "text" },
      { "name": "admin_api_key", "label": "Admin API Key", "description": "Ghost Admin API key in id:secret format from a Custom Integration." },
      { "name": "api_version", "label": "Accept Version", "description": "Ghost Admin API version header, e.g. v5.0.", "required": false, "type": "text" }
    ]
  },
  "health_check": { "tool": "get_site", "input": {} },
  "tools": [
    { "name": "get_site", "description": "Read Ghost site metadata.", "method": "GET", "path": "/site/", "input_schema": { "type": "object", "properties": {} } },
    { "name": "list_posts", "description": "Browse posts. Supports include, fields, filter, limit, page, order, and formats query parameters.", "method": "GET", "path": "/posts/", "query_params": ["include", "fields", "filter", "limit", "page", "order", "formats"], "input_schema": { "type": "object", "properties": { "include": { "type": "string" }, "fields": { "type": "string" }, "filter": { "type": "string" }, "limit": { "type": "string" }, "page": { "type": "integer" }, "order": { "type": "string" }, "formats": { "type": "string", "description": "html,lexical,mobiledoc,plaintext" } } } },
    { "name": "get_post", "description": "Read one post by ID.", "method": "GET", "path": "/posts/{post_id}/", "query_params": ["include", "fields", "formats"], "input_schema": { "type": "object", "properties": { "post_id": { "type": "string" }, "include": { "type": "string" }, "fields": { "type": "string" }, "formats": { "type": "string" } }, "required": ["post_id"] } },
    { "name": "create_post", "description": "Create a Ghost post. To email it as a newsletter, publish/schedule with newsletter and email_segment query parameters where supported by your Ghost version.", "method": "POST", "path": "/posts/", "query_params": ["source", "newsletter", "email_segment"], "request_transform": { "type": "json_wrap", "target": "posts", "fields": ["title", "slug", "html", "lexical", "mobiledoc", "status", "published_at", "feature_image", "custom_excerpt", "tags", "authors", "visibility", "meta_title", "meta_description", "email_subject", "email_only", "newsletter_id"], "as_array": true }, "input_schema": { "type": "object", "properties": { "title": { "type": "string" }, "html": { "type": "string" }, "lexical": { "type": "string" }, "mobiledoc": { "type": "string" }, "status": { "type": "string", "enum": ["draft", "published", "scheduled"] }, "published_at": { "type": "string" }, "slug": { "type": "string" }, "feature_image": { "type": "string" }, "custom_excerpt": { "type": "string" }, "tags": { "type": "array", "items": { "type": "object" } }, "authors": { "type": "array", "items": { "type": "object" } }, "visibility": { "type": "string" }, "email_subject": { "type": "string" }, "email_only": { "type": "boolean" }, "source": { "type": "string", "description": "Use html to convert html into Ghost editor format." }, "newsletter": { "type": "string", "description": "Newsletter slug/id query parameter for email publish flows when supported." }, "email_segment": { "type": "string" } }, "required": ["title"] } },
    { "name": "update_post", "description": "Update a Ghost post. Include updated_at from the current post for optimistic locking.", "method": "PUT", "path": "/posts/{post_id}/", "query_params": ["source", "newsletter", "email_segment"], "request_transform": { "type": "json_wrap", "target": "posts", "fields": ["title", "slug", "html", "lexical", "mobiledoc", "status", "updated_at", "published_at", "feature_image", "custom_excerpt", "tags", "authors", "visibility", "meta_title", "meta_description", "email_subject", "email_only", "newsletter_id"], "as_array": true }, "input_schema": { "type": "object", "properties": { "post_id": { "type": "string" }, "updated_at": { "type": "string" }, "title": { "type": "string" }, "html": { "type": "string" }, "status": { "type": "string" }, "source": { "type": "string" }, "newsletter": { "type": "string" }, "email_segment": { "type": "string" } }, "required": ["post_id", "updated_at"] } },
    { "name": "delete_post", "description": "Delete one Ghost post.", "method": "DELETE", "path": "/posts/{post_id}/", "input_schema": { "type": "object", "properties": { "post_id": { "type": "string" } }, "required": ["post_id"] } },
    { "name": "list_pages", "description": "Browse pages.", "method": "GET", "path": "/pages/", "query_params": ["include", "fields", "filter", "limit", "page", "order", "formats"], "input_schema": { "type": "object", "properties": { "include": { "type": "string" }, "fields": { "type": "string" }, "filter": { "type": "string" }, "limit": { "type": "string" }, "page": { "type": "integer" }, "order": { "type": "string" }, "formats": { "type": "string" } } } },
    { "name": "create_page", "description": "Create a Ghost page.", "method": "POST", "path": "/pages/", "query_params": ["source"], "request_transform": { "type": "json_wrap", "target": "pages", "fields": ["title", "slug", "html", "lexical", "mobiledoc", "status", "published_at", "feature_image", "custom_excerpt", "tags", "authors", "visibility", "meta_title", "meta_description"], "as_array": true }, "input_schema": { "type": "object", "properties": { "title": { "type": "string" }, "html": { "type": "string" }, "status": { "type": "string" }, "source": { "type": "string" } }, "required": ["title"] } },
    { "name": "list_tags", "description": "Browse tags.", "method": "GET", "path": "/tags/", "query_params": ["include", "fields", "filter", "limit", "page", "order"], "input_schema": { "type": "object", "properties": { "include": { "type": "string" }, "fields": { "type": "string" }, "filter": { "type": "string" }, "limit": { "type": "string" }, "page": { "type": "integer" }, "order": { "type": "string" } } } },
    { "name": "create_tag", "description": "Create a Ghost tag.", "method": "POST", "path": "/tags/", "request_transform": { "type": "json_wrap", "target": "tags", "fields": ["name", "slug", "description", "feature_image", "visibility", "meta_title", "meta_description", "accent_color"], "as_array": true }, "input_schema": { "type": "object", "properties": { "name": { "type": "string" }, "slug": { "type": "string" }, "description": { "type": "string" }, "visibility": { "type": "string" }, "accent_color": { "type": "string" } }, "required": ["name"] } },
    { "name": "list_members", "description": "Browse members and paid subscribers.", "method": "GET", "path": "/members/", "query_params": ["include", "fields", "filter", "limit", "page", "order"], "input_schema": { "type": "object", "properties": { "include": { "type": "string" }, "fields": { "type": "string" }, "filter": { "type": "string" }, "limit": { "type": "string" }, "page": { "type": "integer" }, "order": { "type": "string" } } } },
    { "name": "get_member", "description": "Read one Ghost member.", "method": "GET", "path": "/members/{member_id}/", "query_params": ["include", "fields"], "input_schema": { "type": "object", "properties": { "member_id": { "type": "string" }, "include": { "type": "string" }, "fields": { "type": "string" } }, "required": ["member_id"] } },
    { "name": "create_member", "description": "Create a Ghost member.", "method": "POST", "path": "/members/", "request_transform": { "type": "json_wrap", "target": "members", "fields": ["email", "name", "note", "labels", "subscribed", "newsletters"], "as_array": true }, "input_schema": { "type": "object", "properties": { "email": { "type": "string" }, "name": { "type": "string" }, "note": { "type": "string" }, "labels": { "type": "array", "items": { "type": "object" } }, "subscribed": { "type": "boolean" }, "newsletters": { "type": "array", "items": { "type": "object" } } }, "required": ["email"] } },
    { "name": "update_member", "description": "Update a Ghost member.", "method": "PUT", "path": "/members/{member_id}/", "request_transform": { "type": "json_wrap", "target": "members", "fields": ["email", "name", "note", "labels", "subscribed", "newsletters"], "as_array": true }, "input_schema": { "type": "object", "properties": { "member_id": { "type": "string" }, "email": { "type": "string" }, "name": { "type": "string" }, "note": { "type": "string" }, "subscribed": { "type": "boolean" } }, "required": ["member_id"] } },
    { "name": "list_newsletters", "description": "Browse Ghost newsletters.", "method": "GET", "path": "/newsletters/", "query_params": ["include", "fields", "filter", "limit", "page", "order"], "input_schema": { "type": "object", "properties": { "include": { "type": "string" }, "fields": { "type": "string" }, "filter": { "type": "string" }, "limit": { "type": "string" }, "page": { "type": "integer" }, "order": { "type": "string" } } } },
    { "name": "create_newsletter", "description": "Create a Ghost newsletter.", "method": "POST", "path": "/newsletters/", "request_transform": { "type": "json_wrap", "target": "newsletters", "fields": ["name", "slug", "description", "sender_name", "sender_email", "status", "subscribe_on_signup", "visibility"], "as_array": true }, "input_schema": { "type": "object", "properties": { "name": { "type": "string" }, "slug": { "type": "string" }, "description": { "type": "string" }, "sender_name": { "type": "string" }, "sender_email": { "type": "string" }, "status": { "type": "string" }, "subscribe_on_signup": { "type": "boolean" }, "visibility": { "type": "string" } }, "required": ["name"] } },
    { "name": "list_tiers", "description": "Browse membership tiers.", "method": "GET", "path": "/tiers/", "query_params": ["include", "fields", "filter", "limit", "page", "order"], "input_schema": { "type": "object", "properties": { "include": { "type": "string" }, "filter": { "type": "string" }, "limit": { "type": "string" }, "page": { "type": "integer" } } } },
    { "name": "list_offers", "description": "Browse paid membership offers.", "method": "GET", "path": "/offers/", "query_params": ["include", "fields", "filter", "limit", "page", "order"], "input_schema": { "type": "object", "properties": { "include": { "type": "string" }, "filter": { "type": "string" }, "limit": { "type": "string" }, "page": { "type": "integer" } } } },
    { "name": "list_users", "description": "Browse Ghost staff users/authors.", "method": "GET", "path": "/users/", "query_params": ["include", "fields", "filter", "limit", "page", "order"], "input_schema": { "type": "object", "properties": { "include": { "type": "string" }, "fields": { "type": "string" }, "filter": { "type": "string" }, "limit": { "type": "string" }, "page": { "type": "integer" } } } },
    { "name": "add_webhook", "description": "Create a Ghost integration webhook.", "method": "POST", "path": "/webhooks/", "request_transform": { "type": "json_wrap", "target": "webhooks", "fields": ["event", "target_url", "name", "secret", "api_version"], "as_array": true }, "input_schema": { "type": "object", "properties": { "event": { "type": "string" }, "target_url": { "type": "string" }, "name": { "type": "string" }, "secret": { "type": "string" }, "api_version": { "type": "string" } }, "required": ["event", "target_url"] } },
    { "name": "delete_webhook", "description": "Delete a Ghost webhook.", "method": "DELETE", "path": "/webhooks/{webhook_id}/", "input_schema": { "type": "object", "properties": { "webhook_id": { "type": "string" } }, "required": ["webhook_id"] } }
  ]
}
