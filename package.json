{
  "name": "@apteva/integrations",
  "version": "0.9.0",
  "description": "Local integrations, connections, and webhooks for Apteva. Self-contained app templates, OAuth engine, and trigger provider.",
  "author": "Apteva <hello@apteva.com>",
  "license": "Elastic-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/apteva/integrations.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./apps": {
      "types": "./dist/apps/index.d.ts",
      "import": "./dist/apps/index.js"
    }
  },
  "files": [
    "dist",
    "src/apps/*.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "explorer": "bun run scripts/dev-explorer.ts",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "lucide-react": "^1.14.0"
  }
}
